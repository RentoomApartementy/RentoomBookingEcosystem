<!DOCTYPE html>
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Environment
@using RentoomBookingWeb.Helpers
<html lang="@SeoCultureHelper.GetHtmlLang()">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @if (!Environment.IsProduction())
    {
        <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    }
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="/app.css" as="style" />
    <link rel="preload" href="/RentoomBookingWeb.styles.css" as="style" />
    <link rel="stylesheet" href="/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="/app.css" />
    <link rel="stylesheet" href="/RentoomBookingWeb.styles.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@@24,300,0..1,-25&display=block" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=block" />
    <link rel="icon" type="image/svg" href="/assets/svgs/logo-sygnet.svg" />

    <meta property="og:locale" content="@SeoCultureHelper.GetOgLocale()" />
    
    <SeoHreflangs />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />

    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.Default.css" />
    <script src="https://unpkg.com/leaflet.markercluster/dist/leaflet.markercluster.js"></script>
    
    <script src="/js/mapInterop.js"></script>
    <script src="/js/cookieConsentInterop.js"></script>
    
    <script src="/_framework/blazor.web.js"></script>
    
    <script>
    window.clickListeners = {};

    window.registerClickOutside = (elementId, dotnetHelper) => {
        const listener = (e) => {
            const el = document.getElementById(elementId);
            if (el && !el.contains(e.target)) {
                try {
                    dotnetHelper.invokeMethodAsync("CloseModal")
                        .catch(() => {});
                } catch (e) {}
            }
        };
        window.clickListeners[elementId] = listener;
        window.addEventListener("click", listener);
    };

    window.unregisterClickOutside = (elementId) => {
        const listener = window.clickListeners[elementId];
        if (listener) {
            window.removeEventListener("click", listener);
            delete window.clickListeners[elementId];
        }
    };
    
    </script>
    
    </body>

</html>
