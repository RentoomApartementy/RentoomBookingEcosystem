@using RentoomBooking.SharedClasses.Models
@using RentoomBooking.SharedClasses.Services.ReservationWorkflow
@using RentoomBookingWeb.Components.Features.Statute.Components
@using System.Globalization
@using Microsoft.Extensions.Localization
@inject CustomerTermsService TermsService
@inject NavigationManager NavManager
@inject IStringLocalizer<Statute> Localizer
@inject RentoomBookingWeb.Services.Localization.IRouteLocalizationService RouteService

<PageTitle>@Localizer["PageTitle"]</PageTitle>

<HeadContent>
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="@CanonicalUrl" />
    <meta name="description" content="@SeoDescription" />

    <meta property="og:title" content="@CurrentBreadcrumbName" />
    <meta property="og:description" content="@SeoDescription" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@CanonicalUrl" />

    <BreadcrumbJsonLd CurrentPageName="@CurrentBreadcrumbName" CurrentPagePath="@CurrentBreadcrumbPath" />
</HeadContent>

<main class="statute-container">
    <HeaderSection ImagePath="/assets/images/header-bg-statute.jpg" Title="@Localizer["StatuteHeader"]" Height="230px" />
    
    <div class="main-wrapper">
        @if (_isLoading)
        {
            <div class="loading-container">@Localizer["LoadingStatutes"]</div>
        }
        else if (_currentTerm != null)
        {
            <div class="statute-content">
                <h2>@(_currentTerm.Title ?? _currentTerm.Description)</h2>
                <RegulationViewer Content="@_currentTerm.HtmlContent" />
            </div>

            <hr />

            <RegulationsList Regulations="@_allTerms" />
        }
        else
        {
            <div class="error-container">@Localizer["StatuteNotFound"]</div>
        }
    </div>
</main>

@implements IDisposable

@code {
    [Parameter] public int? Id { get; set; }
    [Parameter] public string? Slug { get; set; }

    private List<CustomerTermDisplayDto> _allTerms = new();
    private CustomerTermDisplayDto? _currentTerm;
    private bool _isLoading = true;
    private CancellationTokenSource _cts = new();

    private string CurrentBreadcrumbName => _currentTerm?.Title ?? _currentTerm?.Description ?? Localizer["StatuteHeader"];
    private string CurrentBreadcrumbPath => Id.HasValue
        ? $"{RouteService.GetLocalizedUrl("Statute")}/{Id}{(string.IsNullOrWhiteSpace(Slug) ? string.Empty : $"/{Slug}")}"
        : RouteService.GetLocalizedUrl("Statute");

    private string CanonicalUrl => $"{NavManager.BaseUri.TrimEnd('/')}{CurrentBreadcrumbPath}";
    private string SeoDescription => !string.IsNullOrWhiteSpace(_currentTerm?.Description) 
        ? _currentTerm.Description 
        : (!string.IsNullOrWhiteSpace(_currentTerm?.Title) ? _currentTerm.Title : Localizer["StatuteHeader"].Value);


    protected override async Task OnParametersSetAsync()
    {
        // Cancel any pending operation before starting a new one
        await _cts.CancelAsync();
        _cts.Dispose();
        _cts = new CancellationTokenSource();

        try
        {
            await LoadDataAsync(_cts.Token);
        }
        catch (OperationCanceledException)
        {
            // Expected when parameters change quickly
        }
    }

    private async Task LoadDataAsync(CancellationToken ct)
    {
        _isLoading = true;
        try
        {
            var culture = CultureInfo.CurrentUICulture.Name;
            _allTerms = await TermsService.GetTermsForDisplayAsync(culture, ct: ct);

            if (Id.HasValue)
            {
                _currentTerm = await TermsService.GetTermByIdAsync(Id.Value, culture, ct: ct);
            }
            else
            {
                // Domyślnie ładujemy pierwszy regulamin typu "Main"
                _currentTerm = _allTerms.FirstOrDefault(t => t.TermsType == "Main") 
                              ?? _allTerms.FirstOrDefault();
            }
        }
        finally
        {
            if (!ct.IsCancellationRequested)
            {
                _isLoading = false;
            }
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
