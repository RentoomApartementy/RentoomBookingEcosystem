@page "/kontakt"
@using Microsoft.AspNetCore.Components.Web;
@inject IJSRuntime JSRuntime;
@inject NavigationManager NavManager;
@using Microsoft.Extensions.Localization;
@using RentoomBookingWeb.Services;
@using System.Net.Mail;
@inject IStringLocalizer<RentoomBookingWeb.Contact> Localizer;
@inject BitrixLeadCaptureService LeadCaptureService

<PageTitle>@Localizer["Contact_PageTitle"]</PageTitle>

<HeadContent>
    <meta name="robots" content="index, follow" />
    <meta name="description" content="@Localizer["Contact_MetaDescription"]" />
    <meta name="keywords" content="@Localizer["Contact_MetaKeywords"]" />
    <link rel="canonical" href="@NavManager.Uri" />

    <meta property="og:title" content="@Localizer["Contact_OgTitle"]" />
    <meta property="og:description" content="@Localizer["Contact_OgDescription"]" />
    <meta property="og:image" content="@($"{NavManager.BaseUri}assets/images/header-bg-contact.jpeg")" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@NavManager.Uri" />
    <meta property="og:locale" content="pl_PL" />
    <BreadcrumbJsonLd CurrentPageName="@Localizer["ContactText"]" CurrentPagePath="/kontakt" />
</HeadContent>

<main class="contact-container">
    <HeaderSection ImagePath="/assets/images/header-bg-contact.jpeg" Title="@Localizer["ContactText"]" Height="230px" />
    
    <div class="main-wrapper">
        <div class="contact-grid">
            
            <section class="contact-card info-card" aria-labelledby="contact-details-heading">
                <h2 id="contact-details-heading" class="card-title">@Localizer["ContactDetails"]</h2>
                
                <div class="company-details" itemscope itemtype="https://schema.org/Organization">
                    <h3 itemprop="name">Rentoom Apartamenty sp. z o.o.</h3>
                    
                    <address itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
                        <i class="icon-location" aria-hidden="true"></i>
                        <span itemprop="streetAddress">ul. Stanisława Szymańskiego 1B</span><br />
                        <span itemprop="postalCode">87-100</span> <span itemprop="addressLocality">Toruń</span>
                    </address>
                </div>

                <div class="tax-info">
                    <div class="tax-row"><span>NIP:</span> <strong>8792727407</strong></div>
                    <div class="tax-row"><span>KRS:</span> <strong>0000871532</strong></div>
                    <div class="tax-row"><span>REGON:</span> <strong>387605281</strong></div>
                </div>

                <h3 class="bank-title">@Localizer["BankAccountNumber"]</h3>
                
                <div class="bank-account">
                    <div class="currency-badge pln">PLN</div>
                    <span class="iban">25 1050 1979 1000 0090 8110 5711</span>
                    <button class="copy-btn" @onclick='() => CopyToClipboard("25105019791000009081105711")' aria-label="@Localizer["Contact_CopyPlnAriaLabel"]" title="@Localizer["Contact_CopyPlnTitle"]">
                        📋
                    </button>
                </div>
                
                <div class="bank-account">
                    <div class="currency-badge eur">EUR</div>
                    <span class="iban">24 1050 1979 1000 0090 8110 5729</span>
                    <button class="copy-btn" @onclick='() => CopyToClipboard("24105019791000009081105729")' aria-label="@Localizer["Contact_CopyEurAriaLabel"]" title="@Localizer["Contact_CopyEurTitle"]">
                        📋
                    </button>
                </div>
                
                <p class="swift">SWIFT: <strong>INGBPLPW</strong></p>
            </section>

            <section class="contact-card form-card" aria-labelledby="contact-form-heading">
                <h2 id="contact-form-heading" class="card-title">@Localizer["ContactForm"]</h2>
                <p class="form-subtitle">@Localizer["FillOutText"]</p>
                
                <div class="custom-form-layout">
                    
                    <Input Placeholder="@Localizer["FirstAndLastName"]" Type="text" @bind-Value="_name" IsFull="true" />
                    
                    <Input Placeholder="@Localizer["EmailAddress"]" Type="email" @bind-Value="_email" IsFull="true" />
                    
                    <Input Placeholder="@Localizer["PhoneNumber"]" Type="tel" @bind-Value="_phone" IsFull="true" />

                    <textarea class="custom-textarea" placeholder="@Localizer["MessageContent"]" @bind="_message"></textarea>

                    <div class="checkbox-wrapper">
                        <input type="checkbox" id="rodo" @bind="_consent" />
                        <label for="rodo">
                            @Localizer["ConsentText"] (<a href="/polityka-prywatnosci" target="_blank">@Localizer["Privacypolicy"]</a>).
                        </label>
                    </div>

                    <div class="btn-wrapper">
                        <Button style="width: 100%;" Disabled="@_isSubmitting" OnClick="HandleSubmitClick">
                            @(_isSubmitting ? Localizer["Sending"] : Localizer["Send"])
                        </Button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_submitMessage))
                    {
                        <p class="form-feedback success">@_submitMessage</p>
                    }

                    @if (!string.IsNullOrWhiteSpace(_submitError))
                    {
                        <p class="form-feedback error">@_submitError</p>
                    }
                </div>
            </section>

        </div>
    </div>
</main>

@code {
    private string _name = "";
    private string _email = "";
    private string _phone = "";
    private string _message = "";
    private bool _consent = false;
    private bool _isSubmitting = false;
    private string _submitMessage = "";
    private string _submitError = "";

    private async Task CopyToClipboard(string text)
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private Task HandleSubmitClick(MouseEventArgs _)
    {
        return SubmitAsync();
    }

    private async Task SubmitAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        _submitMessage = string.Empty;
        _submitError = string.Empty;

        if (!ValidateForm())
        {
            return;
        }

        _isSubmitting = true;

        try
        {
            var (firstName, lastName) = SplitName(_name);

            await LeadCaptureService.SubmitAsync(new BitrixLeadCaptureRequest(
                FirstName: firstName,
                LastName: lastName,
                Email: _email.Trim(),
                Phone: _phone.Trim(),
                Message: _message.Trim(),
                DealTitle: BuildDealTitle(),
                CommentFields: new[]
                {
                    new KeyValuePair<string, string?>("Zrodlo", "formularz kontaktowy RentoomBookingWeb"),
                    new KeyValuePair<string, string?>("Imie i nazwisko", _name.Trim())
                }
            ));

            ResetForm();
            _submitMessage = Localizer["SubmitSuccess"];
        }
        catch (BitrixLeadCaptureException ex)
        {
            _submitError = ex.ContactCreated
                ? Localizer["SubmitPartialError"]
                : Localizer["SubmitError"];
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private bool ValidateForm()
    {
        if (string.IsNullOrWhiteSpace(_name) ||
            string.IsNullOrWhiteSpace(_email) ||
            string.IsNullOrWhiteSpace(_phone) ||
            string.IsNullOrWhiteSpace(_message))
        {
            _submitError = Localizer["RequiredFieldsError"];
            return false;
        }

        if (!MailAddress.TryCreate(_email.Trim(), out _))
        {
            _submitError = Localizer["InvalidEmailError"];
            return false;
        }

        if (!_consent)
        {
            _submitError = Localizer["ConsentRequiredError"];
            return false;
        }

        return true;
    }

    private string BuildDealTitle()
    {
        return $"{Localizer["Contact_DealTitlePrefix"]} - {_name.Trim()}";
    }

    private void ResetForm()
    {
        _name = string.Empty;
        _email = string.Empty;
        _phone = string.Empty;
        _message = string.Empty;
        _consent = false;
    }

    private static (string FirstName, string LastName) SplitName(string fullName)
    {
        var parts = fullName.Trim().Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 0)
        {
            return (string.Empty, string.Empty);
        }

        if (parts.Length == 1)
        {
            return (parts[0], string.Empty);
        }

        return (parts[0], parts[1]);
    }
}
