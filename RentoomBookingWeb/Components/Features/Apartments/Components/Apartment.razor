@using RentoomBooking.SharedClasses.Models.IdoBooking;
@using RentoomBooking.SharedClasses.Models.IdoBooking.Public;
@using RentoomBooking.SharedClasses.Services.IdoBooking;
@inject IIdoApartmentService IdoApartmentService;
@inject NavigationManager Navigation;

<article @ref="_elementRef" @onclick="GoToApartment" class="apartment-card" itemscope itemtype="https://schema.org/Apartment">
    <header>
        @if (_currentObjectMedium == null)
        {
            <div class="loading-image">
                <div class="skeleton"></div>
            </div>
        }
        else
        {   
            <div class="image-container">
                <div class="image-wrapper">
                    <img 
                        src="@_currentObjectMedium.Url"
                        alt="@Item?.Name"
                        title="@Item?.Name"
                        itemprop="photo"
                        class="apartment-image" 
                    />
                </div>
                
                <div @onclick="() => ChangeCurrentObjectMedium(1)" @onclick:stopPropagation  class="right-button">
                    &gt;
                </div>
                
                <div @onclick="() => ChangeCurrentObjectMedium(-1)" @onclick:stopPropagation  class="left-button">
                    &lt;
                </div>
                
                @if (_objectMediums != null)
                {
                    <div class="image-counter">
                        <small>@(_currentMediumIndex + 1)/@(_objectMediums.Count)</small>
                    </div>
                }
            </div>
        }
    </header>

    <div class="apartment-info">
        <div class="">
            <div class="">
                @if (Item == null)
                {
                    <div class="skeleton skeleton-text title"></div>
                }
                else
                {
                    <h2 itemprop="name">@Item.Name</h2>
                }

                <p class="apartment-address" itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
                    @if (Item == null)
                    {
                        <span class="skeleton skeleton-text address"></span>
                    }
                    else
                    {
                        <span itemprop="streetAddress">@Item.ObjectLocation?.LocalizationItem?.Street</span><span>, </span> 
                        <span itemprop="postalCode">@Item.ObjectLocation?.LocalizationItem?.ZipCode</span> 
                        <span itemprop="addressLocality">@Item.ObjectLocation?.LocalizationItem?.City</span>
                    }
                </p>
            </div>
        </div>

        <ul class="apartment-details">
            <li>
                <img src="assets/svgs/users.svg" alt="Liczba osób" class="icon" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini"></span>
                }
                else
                {
                    <span itemprop="occupancy">@Item.MinCapacity - @Item.Capacity</span>
                }
            </li>
            
            <li>
                <img src="assets/svgs/bed.svg" alt="Liczba łóżek" class="icon" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini"></span>
                }
                else
                {
                    <span>@_bedsCount</span>
                }
            </li>
            
            <li>
                <img src="assets/svgs/bath.svg" alt="Liczba łazienek" class="icon" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini" style="width: 20px;"></span>
                }
                else
                {
                    <span>1</span>
                }
            </li>
            
            <li>
                <img src="assets/svgs/m2.svg" alt="Powierzchnia apartamentu" class="icon" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini"></span>
                }
                else
                {
                    <span itemprop="floorSize">@Item.Area m²</span>
                }
            </li>
        </ul>
        
        <div @onclick:stopPropagation="true" class="apartment-button-wrapper">
            @if (ShowPrice)
            {
                <div class="apartment-price-info">
                    @if (Offer != null)
                    {
                        <div class="price-wrapper">
                            <span class="price">@FormatHelper.FormatCurrency(Offer?.MinimalPrice)</span>
                            <small>Cena za pobyt</small>
                        </div>
                    }
                    else if (Item == null) 
                    {
                        /* Skeleton dla ceny, jeśli element się ładuje */
                        <div class="price-wrapper">
                            <span class="skeleton skeleton-text mini" style="width: 80px; height: 24px;"></span>
                            <small class="skeleton skeleton-text mini" style="width: 60px; height: 12px; margin-top: 4px;"></small>
                        </div>
                    }
                    else
                    {
                        <small class="non-offer">Brak oferty w wybranym terminie</small>
                    } 
                </div>
            }
            <Button @onclick="GoToReservation" Disabled="@(Item == null || (ShowPrice && Offer == null))">
                Rezerwacja
            </Button>
        </div>
    </div>
</article>

@code {
    [Parameter] public string ImageUrl { get; set; } = "assets/images/rent.jpeg";
    [Parameter] public ApartmentObject? Item { get; set; } = null;
    [Parameter] public PricingOffer? Offer { get; set; } = null;
    [Parameter] public bool ShowPrice { get; set; } = false;
    private List<ObjectMedium>? _objectMediums = null;
    private int _currentMediumIndex = 0;
    private ObjectMedium? _currentObjectMedium = null;
    private int? _bedsCount = null;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<Apartment>? _objRef;
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Item != null)
        {
            _objRef = DotNetObjectReference.Create(this);
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/lazyLoad.js");
            await _jsModule.InvokeVoidAsync("observeElement", _objRef, _elementRef);
        }
    }
    
    [JSInvokable]
    public async Task LoadMedia()
    {
        await GetObjectMedia();
        StateHasChanged();
    }

    private ElementReference _elementRef;
    
    protected override async Task OnInitializedAsync()
    {
        _bedsCount = Item?.BedsConfiguration?.Sum(item => item.Count);
        //await GetObjectMedia();
    }
    
    private async Task GetObjectMedia()
    {
        var id = Item?.Id;
        if (id!=null)
        {
            _objectMediums = await IdoApartmentService.GetObjectMediaFromIdoSellAsync(id.Value) ?? new List<ObjectMedium>();
            _currentMediumIndex = 0;
            _currentObjectMedium = _objectMediums.FirstOrDefault();
        }
    }
    
    private void GoToApartment()
    {
        if (Item != null)
        {
            Navigation.NavigateTo($"/apartamenty/{Item.Id}");
        }
    }

    private void ChangeCurrentObjectMedium(int step)
    {
        if (_objectMediums == null || !_objectMediums.Any())
            return;

        _currentMediumIndex += step;

        if (_currentMediumIndex < 0)
            _currentMediumIndex = _objectMediums.Count - 1;
        else if (_currentMediumIndex >= _objectMediums.Count)
            _currentMediumIndex = 0;

        _currentObjectMedium = _objectMediums[_currentMediumIndex];
    }

    private void GoToReservation()
    {
        if (Item != null)
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            var queryParams = Microsoft.AspNetCore.WebUtilities
                .QueryHelpers.ParseQuery(uri.Query);

            string? startDate = queryParams.ContainsKey("startDate") ? queryParams["startDate"].ToString() : null;
            string? endDate   = queryParams.ContainsKey("endDate")   ? queryParams["endDate"].ToString()   : null;
            string? adults    = queryParams.ContainsKey("adults")    ? queryParams["adults"].ToString()    : null;
            string? children  = queryParams.ContainsKey("children")  ? queryParams["children"].ToString()  : null;

            string url = $"/rezerwacja/{Item.Id}";

            if (startDate != null || endDate != null || adults != null || children != null)
            {
                url = $"/rezerwacja/{Item.Id}/{startDate ?? ""}/{endDate ?? ""}/{adults ?? ""}/{children ?? ""}";
            }

            Navigation.NavigateTo(url);
        }
    }
}