@using RentoomBooking.SharedClasses.Models.AvailableTerms
@using RentoomBooking.SharedClasses.Models.IdoBooking;
@using RentoomBooking.SharedClasses.Models.IdoBooking.Public;
@using RentoomBooking.SharedClasses.Services.IdoBooking;
@inject IIdoApartmentService IdoApartmentService;
@inject NavigationManager Navigation;
@using RentoomBookingWeb.Services
@inject IJSRuntime JS
@using RentoomBookingWeb.Helpers
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<RentoomBookingWeb.Apartments> Localizer;
@inject IStringLocalizer<RentoomBookingWeb.Currency> CurrencyLocalizer;
@inject MediaCacheService MediaCache 
@implements IAsyncDisposable

<article class="apartment-card" 
         @ref="_elementRef"
         style="@($"{ (DisableForGoToReservation ? "cursor: default; " : "") }{ (!string.IsNullOrEmpty(Width) ? $"width: {Width}; min-width: {Width}; max-width: {Width};" : "") }")"
         itemscope itemtype="https://schema.org/Apartment">
    <header>
        @if (_currentObjectMedium == null)
        {
            <div class="loading-image">
                <div class="skeleton"></div>
            </div>
        }
        else
        {   
            <div class="image-container">
                <div class="image-slider" @ref="_sliderRef">
                    @if (_objectMediums != null)
                    {
                        @foreach (var medium in _objectMediums)
                        {
                            <div class="image-wrapper" title="@Item?.Name">
                                <img 
                                    src="@medium.Url"
                                    alt="@Item?.Name"
                                    itemprop="photo"
                                    class="apartment-image" 
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                        }
                    }
                    else if (_currentObjectMedium != null)
                    {
                        <div class="image-wrapper" title="@Item?.Name">
                            <img 
                                src="@_currentObjectMedium.Url"
                                alt="@Item?.Name"
                                itemprop="photo"
                                class="apartment-image" 
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                    }
                </div>
                
                <div @onclick="() => ChangeCurrentObjectMedium(1)" @onclick:stopPropagation @onclick:preventDefault class="right-button">
                    &gt;
                </div>
                
                <div @onclick="() => ChangeCurrentObjectMedium(-1)" @onclick:stopPropagation @onclick:preventDefault class="left-button">
                    &lt;
                </div>
                
                @if (_objectMediums != null)
                {
                    <div class="image-counter">
                        <small>@(_currentMediumIndex + 1)/@(_objectMediums.Count)</small>
                    </div>
                }
            </div>
        }
    </header>

    <div class="apartment-info">
        <div class="">
            <div class="">
                @if (Item == null)
                {
                    <div class="skeleton skeleton-text title"></div>
                }
                else
                {
                    <h2 itemprop="name">
                        @if (!string.IsNullOrEmpty(_detailsUrl))
                        {
                            <a href="@_detailsUrl" style="text-decoration: none; color: inherit;" title="@Item.Name">@Item.Name</a>
                        }
                        else
                        {
                            @Item.Name
                        }
                    </h2>
                }

                <p class="apartment-address" itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
                    @if (Item == null)
                    {
                        <span class="skeleton skeleton-text address"></span>
                    }
                    else
                    {
                        <span itemprop="streetAddress">@Item.ObjectLocation?.LocalizationItem?.Street</span><span>, </span> 
                        <span itemprop="postalCode">@Item.ObjectLocation?.LocalizationItem?.ZipCode</span> 
                        <span itemprop="addressLocality">@Item.ObjectLocation?.LocalizationItem?.City</span>
                    }
                </p>
            </div>
        </div>

        <ul class="apartment-details">
            <li>
                <img src="assets/svgs/users.svg" alt="Liczba osób" class="icon" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini"></span>
                }
                else
                {
                    <span itemprop="occupancy" itemscope itemtype="https://schema.org/QuantitativeValue">
                        <meta itemprop="minValue" content="@(Item.MinCapacity ?? 1)" />
                        <meta itemprop="maxValue" content="@(Item.Capacity ?? 1)" />
                        <meta itemprop="value" content="@(Item.Capacity ?? 1)" />
                        @Item.MinCapacity - @Item.Capacity
                    </span>
                }
            </li>
            
            <li>
                <img src="assets/svgs/bed.svg" alt="Liczba łóżek" class="icon" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini"></span>
                }
                else
                {
                    <span>@_bedsCount</span>
                }
            </li>
            
            <li>
                <img src="assets/svgs/bath.svg" alt="Liczba łazienek" class="icon" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini" style="width: 20px;"></span>
                }
                else
                {
                    <span>1</span>
                }
            </li>
            
            <li>
                <img src="assets/svgs/m2.svg" alt="Powierzchnia apartamentu" class="icon" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini"></span>
                }
                else
                {
                    <span itemprop="floorSize" itemscope itemtype="https://schema.org/QuantitativeValue">
                        <meta itemprop="value" content="@(string.IsNullOrEmpty(Item.Area) ? "0" : Item.Area)" />
                        <meta itemprop="unitCode" content="MTK" />
                        @Item.Area m²
                    </span>
                }
            </li>
        </ul>
        
        @if (!Readonly)
        {
            <div class="apartment-button-wrapper">
            @if (ShowPrice)
            {
                <div class="apartment-price-info">
                    @if (Offer != null)
                    {
                        <div class="price-wrapper">
                            <span class="price">@Offer?.MinimalPrice.ToString("N2") @CurrencyLocalizer["PLN"]</span>
                            <small>@Localizer["TotalPrice"]</small>
                        </div>
                    }
                    else if (Item == null) 
                    {
                        <div class="price-wrapper">
                            <span class="skeleton skeleton-text mini" style="width: 80px; height: 24px;"></span>
                            <small class="skeleton skeleton-text mini" style="width: 60px; height: 12px; margin-top: 4px;"></small>
                        </div>
                    }
                    else
                    {
                        <div class="price-wrapper">
                            @if (IsSuggestionsLoading && !(SuggestionDates?.Any() == true))
                            {
                                <span class="availability-status loading">
                                    <span class="mini-spinner"></span>
                                        <span>@Localizer["SuggestedDateLoading"]</span>
                                </span>
                            }
                            else
                            {
                                    <span class="availability-status">@(SuggestionDates?.Any() == true ? Localizer["SuggestedDateFoundText"] : Localizer["SuggestedDateNotFoundText"])</span>
                            }
                        </div>
                    } 
                </div>
            }
            
            @if (Item == null || (ShowPrice && Offer == null))
            {
                <Button Href="@_detailsUrl"
                        Disabled="@(Item == null || (ShowPrice && Offer == null))">
                    @Localizer["Details"]
                </Button>
            }
            else
            {
                <Button Href="@_detailsUrl">
                    @Localizer["BookNow"]
                </Button>
            }
            </div>

            @if (ShowPrice && Offer == null && Item != null)
            {
                <div class="non-offer-wrapper">
                    @if (SuggestionDates?.Any() == true)
                    {
                        <div class="suggestion-labels-row">
                            @foreach (var term in SuggestionDates.Take(3))
                            {
                                <span class="suggestion-label">@FormatSuggestionLabel(term)</span>
                            }
                        </div>
                    }
                    else
                    {
                        @if (IsSuggestionsLoading)
                        {
                            <small class="non-offer">
                                <span class="mini-spinner"></span>
                                <span>@Localizer["SuggestedDateLoading"]</span>
                            </small>
                        }
                        else
                        {
                            <small class="non-offer">@Localizer["NoOfferText2"]</small>
                        }
                    }
                </div>
            }
        }
    </div>
</article>

@code {
    [Parameter] public string ImageUrl { get; set; } = "assets/images/rent.jpeg";
    [Parameter] public ApartmentObject? Item { get; set; } = null;
    [Parameter] public PricingOffer? Offer { get; set; } = null;
    [Parameter] public bool ShowPrice { get; set; } = false;
    
    [Parameter] public string? StartDate { get; set; }
    [Parameter] public string? EndDate { get; set; }
    [Parameter] public string? Adults { get; set; }
    [Parameter] public string? Children { get; set; }
    [Parameter] public bool Readonly { get; set; } = false;
    
    [Parameter] public bool DisableForGoToReservation { get; set; } = false;
    [Parameter] public bool IsSuggestionsLoading { get; set; } = false;
    
    [Parameter] public IReadOnlyList<AvailableTerm>? SuggestionDates { get; set; } = null;

    [Parameter] public string? Width { get; set; } = null;

    private List<ObjectMedium>? _objectMediums = null;
    private int _currentMediumIndex = 0;
    private ObjectMedium? _currentObjectMedium = null;
    private int? _bedsCount = null;
    private string? _detailsUrl;
    
    private IJSObjectReference? _jsModule;
    private IJSObjectReference? _sliderModule;
    private DotNetObjectReference<Apartment>? _objRef;
    private ElementReference _elementRef;
    private ElementReference _sliderRef;
    private bool _isMediaLoaded = false;
    private bool _isSliderInitialized = false;

    protected override void OnInitialized()
    {
        _bedsCount = Item?.BedsConfiguration?.Sum(item => item.Count);
        CalculateDetailsUrl();
        
        if (Item?.Id != null)
        {
            if (MediaCache.TryGetCachedMedia(Item.Id, out var cachedMedia))
            {
                _objectMediums = cachedMedia;
                _currentMediumIndex = 0;
                _currentObjectMedium = _objectMediums?.FirstOrDefault();
                _isMediaLoaded = true; 
            }
        }
    }

    protected override void OnParametersSet()
    {
        CalculateDetailsUrl();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Item != null && _objRef == null)
        {
            _objRef = DotNetObjectReference.Create(this);
        }

        if (firstRender && Item != null && !_isMediaLoaded)
        {
            try 
            {
                _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/lazyLoad.js");
                await _jsModule.InvokeVoidAsync("observeElement", _objRef, _elementRef);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Lazy load init failed: {ex.Message}");
                _ = LoadMedia();
            }
        }

        if (_isMediaLoaded && !_isSliderInitialized && _objectMediums?.Count > 1)
        {
            _isSliderInitialized = true;
            try
            {
                _sliderModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/apartmentSlider.js");
                await _sliderModule.InvokeVoidAsync("initSlider", _objRef, _sliderRef);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Slider init failed: {ex.Message}");
            }
        }
    }
    
    [JSInvokable("LoadMedia")]
    public async Task LoadMedia()
    {
        if (_isMediaLoaded) return;
        _isMediaLoaded = true;

        try
        {
            await GetObjectMedia();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading media: {ex.Message}");
        }
    }

    [JSInvokable("OnImageSwiped")]
    public void OnImageSwiped(int index)
    {
        if (_objectMediums == null || index < 0 || index >= _objectMediums.Count) return;
        
        _currentMediumIndex = index;
        _currentObjectMedium = _objectMediums[index];
        StateHasChanged();
    }

    private async Task GetObjectMedia()
    {
        var id = Item?.Id;
        if (id != null)
        {
            _objectMediums = await MediaCache.GetOrFetchMediaAsync(
                id.Value, 
                async () => await IdoApartmentService.GetObjectMediaFromIdoSellAsync(id.Value) ?? new List<ObjectMedium>()
            );

            _currentMediumIndex = 0;
            _currentObjectMedium = _objectMediums.FirstOrDefault();
        }
    }

    private async Task ChangeCurrentObjectMedium(int step)
    {
        if (_objectMediums == null || !_objectMediums.Any()) return;

        _currentMediumIndex += step;
        if (_currentMediumIndex < 0) _currentMediumIndex = _objectMediums.Count - 1;
        else if (_currentMediumIndex >= _objectMediums.Count) _currentMediumIndex = 0;

        _currentObjectMedium = _objectMediums[_currentMediumIndex];

        if (_sliderModule != null)
        {
            await _sliderModule.InvokeVoidAsync("scrollToImage", _sliderRef, _currentMediumIndex);
        }
    }

    private void CalculateDetailsUrl()
    {
        if (DisableForGoToReservation || Item == null) { _detailsUrl = null; return; }

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        string? GetQ(string k) => queryParams.TryGetValue(k, out var v) ? v.ToString() : null;

        string? finalStart = !string.IsNullOrEmpty(StartDate) ? StartDate : GetQ("startDate");
        string? finalEnd = !string.IsNullOrEmpty(EndDate) ? EndDate : GetQ("endDate");
        string? finalAdults = !string.IsNullOrEmpty(Adults) ? Adults : GetQ("adults");
        string? finalChildren = !string.IsNullOrEmpty(Children) ? Children : GetQ("children");

        string baseUrl = $"/apartamenty/{Item.Id}/{Item.Name?.ToSlug()}";

        if (!string.IsNullOrEmpty(finalStart) || !string.IsNullOrEmpty(finalEnd))
        {
            var segments = new List<string> {
                finalStart ?? "null", finalEnd ?? "null", finalAdults ?? "1", finalChildren ?? "0"
            };
            _detailsUrl = $"{baseUrl}/{string.Join("/", segments)}";
        }
        else
        {
            _detailsUrl = baseUrl;
        }
        _detailsUrl = _detailsUrl.Replace("//", "/");
    }

    private static string FormatSuggestionLabel(AvailableTerm term)
    {
        if (!DateTime.TryParse(term.StartDate, out var startDate) || !DateTime.TryParse(term.EndDate, out var endDate))
        {
            return $"{term.StartDate}-{term.EndDate}";
        }

        var nights = Math.Max(0, (endDate.Date - startDate.Date).Days);
        return $"{startDate:dd.MM}-{endDate:dd.MM} ({nights} night/s)";
    }

    public async ValueTask DisposeAsync()
    {
        try 
        {
            if (_jsModule != null) 
            {
                try {
                    await _jsModule.InvokeVoidAsync("unobserveElement", _elementRef);
                } catch {  }
                
                await _jsModule.DisposeAsync();
            }

            if (_sliderModule != null)
            {
                await _sliderModule.DisposeAsync();
            }
            
            _objRef?.Dispose();
        } 
        catch (Exception ex)
        {
            Console.WriteLine($"Dispose error: {ex.Message}");
        }
    }
}
