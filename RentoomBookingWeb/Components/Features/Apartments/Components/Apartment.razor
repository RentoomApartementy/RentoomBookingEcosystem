@using RentoomBooking.SharedClasses.Models.AvailableTerms
@using RentoomBooking.SharedClasses.Models.IdoBooking;
@using RentoomBooking.SharedClasses.Models.IdoBooking.Public;
@using RentoomBooking.SharedClasses.Services.ApartmentMedia;
@using RentoomBookingWeb.Components.Features.Apartments.ViewModels
@inject NavigationManager Navigation;
@using RentoomBookingWeb.Services
@inject IJSRuntime JS
@using RentoomBookingWeb.Helpers
@using Microsoft.Extensions.Logging
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<RentoomBookingWeb.Apartments> Localizer;
@inject IStringLocalizer<RentoomBookingWeb.Apartment> ApartmentLocalizer;
@inject IStringLocalizer<RentoomBookingWeb.Currency> CurrencyLocalizer;
@inject MediaCacheService MediaCache 
@inject IApartmentMediaCatalogService ApartmentMediaCatalogService
@inject RentoomBookingWeb.Services.Localization.IRouteLocalizationService RouteService
@inject ReservationWorkflowTelemetry WorkflowTelemetry
@inject GoogleAnalyticsService GoogleAnalytics
@inject ILogger<Apartment> Logger
@implements IAsyncDisposable

<article id="@($"{Item?.Name}-{Item?.Id}")" class="apartment-card" 
         @ref="_elementRef"
         style="@($"{ (DisableForGoToReservation ? "cursor: default; " : "") }{ (!string.IsNullOrEmpty(Width) ? $"width: {Width}; min-width: {Width}; max-width: {Width};" : "") }")"
         itemscope itemtype="https://schema.org/Apartment">
    <header>
        @if (_currentObjectMedium == null)
        {
            <div class="loading-image">
                <div class="skeleton"></div>
            </div>
        }
        else
        {   
            <div class="image-container">
                <div class="image-slider" @ref="_sliderRef">
                    @if (_objectMediums != null)
                    {
                        @for (var index = 0; index < _objectMediums.Count; index++)
                        {
                            var medium = _objectMediums[index];

                            <div class="image-wrapper" title="@Item?.Name">
                                @if (ShouldRenderImageSource(index))
                                {
                                    <img 
                                        src="@GetListingImageUrl(medium)"
                                        alt="@Item?.Name"
                                        itemprop="photo"
                                        class="apartment-image"
                                        loading="@GetImageLoading(index)"
                                        fetchpriority="@GetImageFetchPriority(index)"
                                        decoding="async"
                                    />
                                }
                                else
                                {
                                    <div class="apartment-image apartment-image-placeholder" aria-hidden="true"></div>
                                }
                            </div>
                        }
                    }
                    else if (_currentObjectMedium != null)
                    {
                        <div class="image-wrapper" title="@Item?.Name">
                            <img 
                                src="@GetListingImageUrl(_currentObjectMedium)"
                                alt="@Item?.Name"
                                itemprop="photo"
                                class="apartment-image" 
                                loading="eager"
                                fetchpriority="high"
                                decoding="async"
                            />
                        </div>
                    }
                </div>
                
                <div @onclick="() => ChangeCurrentObjectMedium(1)" @onclick:stopPropagation @onclick:preventDefault class="right-button">
                    &gt;
                </div>
                
                <div @onclick="() => ChangeCurrentObjectMedium(-1)" @onclick:stopPropagation @onclick:preventDefault class="left-button">
                    &lt;
                </div>
                
                @if (_objectMediums != null)
                {
                    <div class="image-counter">
                        <small>@(_currentMediumIndex + 1)/@(_objectMediums.Count)</small>
                    </div>
                }
            </div>
        }
    </header>

    <div class="apartment-info">
        <div class="">
            <div class="">
                @if (Item == null)
                {
                    <div class="skeleton skeleton-text title"></div>
                }
                else
                {
                    <h2 itemprop="name">
                        @if (!string.IsNullOrEmpty(_detailsUrl))
                        {
                            <a href="@_detailsUrl" @onclick='(() => TrackApartmentClickAsync("title"))' style="text-decoration: none; color: inherit;" title="@Item.Name">@Item.Name</a>
                        }
                        else
                        {
                            @Item.Name
                        }
                    </h2>
                }

                <p class="apartment-address" itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
                    @if (Item == null)
                    {
                        <span class="skeleton skeleton-text address"></span>
                    }
                    else
                    {
                        <span itemprop="streetAddress">@Item.ObjectLocation?.LocalizationItem?.Street</span><span>, </span> 
                        <span itemprop="postalCode">@Item.ObjectLocation?.LocalizationItem?.ZipCode</span> 
                        <span itemprop="addressLocality">@Item.ObjectLocation?.LocalizationItem?.City</span>
                    }
                </p>
            </div>
        </div>

        <ul class="apartment-details">
            <li>
                <GoogleIcon Name="groups" Class="icon" AriaLabel="@ApartmentLocalizer["Reservation_AltOccupancy"]" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini"></span>
                }
                else
                {
                    <span itemprop="occupancy" itemscope itemtype="https://schema.org/QuantitativeValue">
                        <meta itemprop="minValue" content="@(Item.MinCapacity ?? 1)" />
                        <meta itemprop="maxValue" content="@(Item.Capacity ?? 1)" />
                        <meta itemprop="value" content="@(Item.Capacity ?? 1)" />
                        @Item.MinCapacity - @Item.Capacity
                    </span>
                }
            </li>
            
            <li>
                <GoogleIcon Name="bed" Class="icon" AriaLabel="@ApartmentLocalizer["Reservation_AltBeds"]" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini"></span>
                }
                else
                {
                    <span>@_bedsCount</span>
                }
            </li>
            
            <li>
                <GoogleIcon Name="bathtub" Class="icon" AriaLabel="@ApartmentLocalizer["Reservation_AltBathrooms"]" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini" style="width: 20px;"></span>
                }
                else
                {
                    <span>1</span>
                }
            </li>
            
            <li>
                <GoogleIcon Name="square_foot" Class="icon" AriaLabel="Powierzchnia apartamentu" />
                @if (Item == null)
                {
                    <span class="skeleton skeleton-text mini"></span>
                }
                else
                {
                    <span itemprop="floorSize" itemscope itemtype="https://schema.org/QuantitativeValue">
                        <meta itemprop="value" content="@(string.IsNullOrEmpty(Item.Area) ? "0" : Item.Area)" />
                        <meta itemprop="unitCode" content="MTK" />
                        @Item.Area m²
                    </span>
                }
            </li>
        </ul>
        
        @if (!Readonly)
        {
            <div class="apartment-button-wrapper">
            @if (ShowPrice)
            {
                <div class="apartment-price-info">
                    @if (Offer != null)
                    {
                        <div class="price-wrapper">
                            <span class="price">@Offer?.MinimalPrice.ToString("N2") @CurrencyLocalizer["PLN"]</span>
                            @if (_resolvedOfferLength.HasValue && _resolvedOfferLength.Value > 0)
                            {
                                <small>@Localizer["TotalPrice"] @_resolvedOfferLength.Value @GetNightLabel(_resolvedOfferLength.Value)</small>
                            }
                        </div>
                    }
                    else if (PublicOffer != null)
                    {
                        <div class="price-wrapper">
                            <span class="price">@ApartmentLocalizer["From"] @PublicOffer.MinimalPrice.ToString("N2") @(string.IsNullOrWhiteSpace(PublicOffer.Currency) ? CurrencyLocalizer["PLN"].Value : PublicOffer.Currency)</span>
                        </div>
                    }
                    else if (Item == null)
                    {
                        <div class="price-wrapper">
                            <span class="skeleton skeleton-text mini" style="width: 80px; height: 24px;"></span>
                            <small class="skeleton skeleton-text mini" style="width: 60px; height: 12px; margin-top: 4px;"></small>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(NoOfferPriceHint))
                    {
                        <div class="price-wrapper">
                            <span class="price-hint">@NoOfferPriceHint</span>
                        </div>
                    }
                    else
                    {
                        <div class="price-wrapper">
                            @if (IsSuggestionLoading() && !(SuggestionDates?.Any() == true))
                            {
                                <span class="availability-status loading">
                                    <span class="mini-spinner"></span>
                                        <span>@Localizer["SuggestedDateLoading"]</span>
                                </span>
                            }
                            else
                            {
                                    <span class="availability-status">@(SuggestionDates?.Any() == true ? Localizer["SuggestedDateFoundText"] : Localizer["SuggestedDateNotFoundText"])</span>
                            }
                        </div>
                    } 
                </div>
            }
            
            @if (Item == null || (ShowPrice && Offer == null))
            {
                <Button Href="@_detailsUrl"
                        OnClick='(() => TrackApartmentClickAsync("button"))'
                        Disabled="@(Item == null || (ShowPrice && Offer == null && PublicOffer == null && string.IsNullOrWhiteSpace(NoOfferPriceHint)))">
                    @Localizer["Details"]
                </Button>
            }
            else
            {
                <Button Href="@_detailsUrl"
                        OnClick='(() => TrackApartmentClickAsync("button"))'>
                    @Localizer["BookNow"]
                </Button>
            }
            </div>

            @if (ShowPrice && Offer == null && Item != null && string.IsNullOrWhiteSpace(NoOfferPriceHint))
            {
                <div class="non-offer-wrapper">
                    @if (SuggestionDates?.Any() == true)
                    {
                        <div class="suggestion-labels-row">
                            @foreach (var term in SuggestionDates.Take(3))
                            {
                                <a href="@GetSuggestionUrl(term)"
                                   class="suggestion-label"
                                   @onclick='(() => TrackApartmentClickAsync("suggestion"))'>
                                    @FormatSuggestionLabel(term)
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        @if (IsSuggestionLoading())
                        {
                            <small class="non-offer">
                                <span class="mini-spinner"></span>
                                <span>@Localizer["SuggestedDateLoading"]</span>
                            </small>
                        }
                        else
                        {
                            <small class="non-offer">@Localizer["NoOfferText2"]</small>
                        }
                    }
                </div>
            }
        }
    </div>
</article>

@code {
    [Parameter] public string ImageUrl { get; set; } = "assets/images/rent.jpeg";
    [Parameter] public ApartmentObject? Item { get; set; } = null;
    [Parameter] public PricingOffer? Offer { get; set; } = null;
    // Fallback offer from the IdoBooking public/offer endpoint. Used only when there is no dated Offer.
    [Parameter] public PublicApartmentOffer? PublicOffer { get; set; } = null;
    // When set and there is neither a dated nor a public offer, shows this hint in place of the price/availability
    // (e.g. "Cena po wybraniu terminu") and keeps the Details button active. Used by the blog listing.
    [Parameter] public string? NoOfferPriceHint { get; set; } = null;
    [Parameter] public int? OfferLength { get; set; } = null;
    [Parameter] public bool ShowPrice { get; set; } = false;
    
    [Parameter] public string? StartDate { get; set; }
    [Parameter] public string? EndDate { get; set; }
    [Parameter] public string? Adults { get; set; }
    [Parameter] public string? Children { get; set; }
    [Parameter] public bool Readonly { get; set; } = false;
    
    [Parameter] public bool DisableForGoToReservation { get; set; } = false;
    [Parameter] public SuggestionStatus SuggestionState { get; set; } = SuggestionStatus.NotStarted;
    
    [Parameter] public IReadOnlyList<AvailableTerm>? SuggestionDates { get; set; } = null;

    [Parameter] public string? Width { get; set; } = null;
    [Parameter] public string ListingSource { get; set; } = "apartments-list";
    [Parameter] public bool DeferGalleryImages { get; set; } = false;

    private List<ObjectMedium>? _objectMediums = null;
    private int _currentMediumIndex = 0;
    private ObjectMedium? _currentObjectMedium = null;
    private int? _bedsCount = null;
    private string? _detailsUrl;
    private int? _resolvedOfferLength;
    
    private IJSObjectReference? _jsModule;
    private IJSObjectReference? _sliderModule;
    private DotNetObjectReference<Apartment>? _objRef;
    private ElementReference _elementRef;
    private ElementReference _sliderRef;
    private bool _isMediaLoaded = false;
    private bool _isSliderInitialized = false;
    private bool _isDisposed = false;
    private readonly HashSet<int> _activatedImageIndexes = new();

    protected override void OnInitialized()
    {
        _bedsCount = Item?.BedsConfiguration?.Sum(item => item.Count);
        CalculateDetailsUrl();
        ResolveOfferLength();
        TryLoadMediaFromCache();
    }

    protected override void OnParametersSet()
    {
        _bedsCount = Item?.BedsConfiguration?.Sum(item => item.Count);
        CalculateDetailsUrl();
        ResolveOfferLength();

        if (!_isMediaLoaded)
        {
            TryLoadMediaFromCache();
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Item != null && _objRef == null)
        {
            _objRef = DotNetObjectReference.Create(this);
        }

        if (firstRender && Item != null && !_isMediaLoaded)
        {
            try 
            {
                _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/lazyLoad.js");
                await _jsModule.InvokeVoidAsync("observeElement", _objRef, _elementRef);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Apartment lazy load initialization failed for apartment {ApartmentId}. Falling back to immediate media load.", Item?.Id);
                _ = LoadMedia();
            }
        }

        if (_isMediaLoaded && !_isSliderInitialized && _objectMediums?.Count > 1)
        {
            _isSliderInitialized = true;
            try
            {
                _sliderModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/apartmentSlider.js");
                await _sliderModule.InvokeVoidAsync("initSlider", _objRef, _sliderRef);
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Apartment slider initialization failed for apartment {ApartmentId}.", Item?.Id);
            }
        }
    }
    
    [JSInvokable("LoadMedia")]
    public async Task LoadMedia()
    {
        if (_isMediaLoaded || _isDisposed) return;

        if (TryLoadMediaFromCache())
        {
            if (!_isDisposed)
            {
                await InvokeAsync(StateHasChanged);
            }

            return;
        }

        _isMediaLoaded = true;

        try
        {
            await GetObjectMedia();
            if (!_isDisposed)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Apartment media loading failed for apartment {ApartmentId}.", Item?.Id);
        }
    }

    [JSInvokable("OnImageSwiped")]
    public async Task OnImageSwiped(int index)
    {
        if (_objectMediums == null || index < 0 || index >= _objectMediums.Count || _isDisposed) return;
        
        _currentMediumIndex = index;
        _currentObjectMedium = _objectMediums[index];
        ActivateImageIndex(index);
        PrefetchNextImage(index);
        await InvokeAsync(StateHasChanged);
    }

    private async Task GetObjectMedia()
    {
        var id = Item?.Id;
        if (id != null)
        {
            var media = await MediaCache.GetOrFetchMediaAsync(
                id.Value, 
                async () => await ApartmentMediaCatalogService.GetApartmentMediaAsync(id.Value)
            );

            ApplyLoadedMedia(media);
        }
    }

    private bool TryLoadMediaFromCache()
    {
        var id = Item?.Id;
        if (id == null)
        {
            return false;
        }

        if (!MediaCache.TryGetCachedMedia(id.Value, out var cachedMedia) || cachedMedia == null || !cachedMedia.Any())
        {
            return false;
        }

        _isMediaLoaded = true;
        ApplyLoadedMedia(cachedMedia);
        return true;
    }

    private void ApplyLoadedMedia(List<ObjectMedium> media)
    {
        _objectMediums = media;
        _currentMediumIndex = 0;
        _currentObjectMedium = _objectMediums.FirstOrDefault();
        ResetActivatedImages();
    }

    private async Task ChangeCurrentObjectMedium(int step)
    {
        if (_objectMediums == null || !_objectMediums.Any()) return;

        _currentMediumIndex += step;
        if (_currentMediumIndex < 0) _currentMediumIndex = _objectMediums.Count - 1;
        else if (_currentMediumIndex >= _objectMediums.Count) _currentMediumIndex = 0;

        _currentObjectMedium = _objectMediums[_currentMediumIndex];
        ActivateImageIndex(_currentMediumIndex);
        PrefetchNextImage(_currentMediumIndex);

        await InvokeAsync(StateHasChanged);

        if (_sliderModule != null)
        {
            await _sliderModule.InvokeVoidAsync("scrollToImage", _sliderRef, _currentMediumIndex);
        }
    }

    private void CalculateDetailsUrl()
    {
        if (DisableForGoToReservation || Item == null) { _detailsUrl = null; return; }

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        string? GetQ(string k) => queryParams.TryGetValue(k, out var v) ? v.ToString() : null;

        string? finalStart = !string.IsNullOrEmpty(StartDate) ? StartDate : GetQ("startDate");
        string? finalEnd = !string.IsNullOrEmpty(EndDate) ? EndDate : GetQ("endDate");
        string? finalAdults = !string.IsNullOrEmpty(Adults) ? Adults : GetQ("adults");
        string? finalChildren = !string.IsNullOrEmpty(Children) ? Children : GetQ("children");

        string localizedBase = RouteService.GetLocalizedUrl("ApartmentDetail");
        string baseUrl = $"{localizedBase}/{Item.Id}/{Item.Name?.ToSlug()}";

        if (!string.IsNullOrEmpty(finalStart) || !string.IsNullOrEmpty(finalEnd))
        {
            var segments = new List<string> {
                finalStart ?? "null", finalEnd ?? "null", finalAdults ?? "1", finalChildren ?? "0"
            };
            _detailsUrl = $"{baseUrl}/{string.Join("/", segments)}";
        }
        else
        {
            _detailsUrl = baseUrl;
        }
        _detailsUrl = _detailsUrl.Replace("//", "/");
    }

    private bool ShouldRenderImageSource(int index)
    {
        return !DeferGalleryImages || _activatedImageIndexes.Contains(index);
    }

    private static string? GetListingImageUrl(ObjectMedium? medium)
    {
        return medium?.CardUrl ?? medium?.Url;
    }

    private bool IsSuggestionLoading()
    {
        return SuggestionState == SuggestionStatus.Loading;
    }

    private string GetImageLoading(int index)
    {
        return index == 0 ? "eager" : "lazy";
    }

    private string GetImageFetchPriority(int index)
    {
        return index == 0 ? "high" : "low";
    }

    private void ResetActivatedImages()
    {
        _activatedImageIndexes.Clear();

        if (_objectMediums?.Count > 0)
        {
            _activatedImageIndexes.Add(0);
        }
    }

    private void ActivateImageIndex(int index)
    {
        if (_objectMediums == null || index < 0 || index >= _objectMediums.Count)
        {
            return;
        }

        _activatedImageIndexes.Add(index);
    }

    private void PrefetchNextImage(int index)
    {
        if (!DeferGalleryImages || _objectMediums == null || _objectMediums.Count <= 1)
        {
            return;
        }

        var nextIndex = index + 1;
        if (nextIndex >= _objectMediums.Count)
        {
            nextIndex = 0;
        }

        _activatedImageIndexes.Add(nextIndex);
    }

    private void ResolveOfferLength()
    {
        if (DateTime.TryParse(StartDate, out var startDate) && DateTime.TryParse(EndDate, out var endDate))
        {
            var nights = Math.Max(0, (endDate.Date - startDate.Date).Days);
            if (nights > 0)
            {
                _resolvedOfferLength = nights;
                return;
            }
        }

        if (OfferLength.HasValue && OfferLength.Value > 0)
        {
            _resolvedOfferLength = OfferLength.Value;
            return;
        }

        _resolvedOfferLength = null;
    }

    private string FormatSuggestionLabel(AvailableTerm term)
    {
        if (!DateTime.TryParse(term.StartDate, out var startDate) || !DateTime.TryParse(term.EndDate, out var endDate))
        {
            return $"{term.StartDate}-{term.EndDate}";
        }

        var nights = Math.Max(0, (endDate.Date - startDate.Date).Days);
        return $"{startDate:dd.MM}-{endDate:dd.MM} ({nights} {GetNightLabel(nights)})";
    }

    private string GetStayLengthSuffix()
    {
        if (!DateTime.TryParse(StartDate, out var startDate) || !DateTime.TryParse(EndDate, out var endDate))
        {
            return string.Empty;
        }

        var nights = Math.Max(0, (endDate.Date - startDate.Date).Days);
        if (nights <= 0)
        {
            return string.Empty;
        }

        return $" ({nights} {GetNightLabel(nights)})";
    }

    private string GetNightLabel(int nights)
    {
        if (nights == 1)
        {
            return ApartmentLocalizer["StayNight_1"];
        }

        if (nights % 10 == 1)
        {
            return ApartmentLocalizer["StayNight_Many"];
        }


        if (nights % 10 is >= 2 and <= 4 && nights % 100 is < 12 or > 14)
        {
            return ApartmentLocalizer["StayNight_234"];
        }

        return ApartmentLocalizer["StayNight_Many"];
    }

    private string GetSuggestionUrl(AvailableTerm term)
    {
        if (Item == null)
        {
            return "#";
        }

        var localizedBase = RouteService.GetLocalizedUrl("ApartmentDetail");
        var slug = Item.Name?.ToSlug() ?? "szczegoly";
        var adults = !string.IsNullOrWhiteSpace(Adults) ? Adults : "2";
        var children = !string.IsNullOrWhiteSpace(Children) ? Children : "0";

        return $"{localizedBase}/{Item.Id}/{slug}/{term.StartDate}/{term.EndDate}/{adults}/{children}".Replace("//", "/");
    }

    private async Task TrackApartmentClickAsync(string target)
    {
        if (Item is null || string.IsNullOrWhiteSpace(_detailsUrl))
        {
            return;
        }

        // Distinguish a dated offer from the public/offer fallback price, without touching the existing fields.
        var priceSource = Offer is not null ? "dated" : (PublicOffer is not null ? "public-fallback" : "none");

        WorkflowTelemetry.TrackEvent(
            "ApartmentListingClicked",
            new Dictionary<string, string?>
            {
                ["ApartmentId"] = Item.Id.ToString(),
                ["ApartmentName"] = Item.Name,
                ["ListingSource"] = ListingSource,
                ["ClickTarget"] = target,
                ["DetailsUrl"] = _detailsUrl,
                ["StartDate"] = StartDate,
                ["EndDate"] = EndDate,
                ["Adults"] = Adults,
                ["Children"] = Children,
                ["PriceSource"] = priceSource
            },
            new Dictionary<string, double>
            {
                ["HasOffer"] = Offer is null ? 0 : 1,
                ["MinimalPrice"] = (double?)Offer?.MinimalPrice ?? 0,
                ["HasPublicOffer"] = PublicOffer is null ? 0 : 1,
                ["PublicMinimalPrice"] = (double?)PublicOffer?.MinimalPrice ?? 0
            });

        await GoogleAnalytics.TrackEventAsync("apartment_listing_click", new Dictionary<string, object?>
        {
            ["apartment_id"] = Item.Id,
            ["apartment_name"] = Item.Name,
            ["listing_source"] = ListingSource,
            ["click_target"] = target,
            ["start_date"] = StartDate,
            ["end_date"] = EndDate,
            ["adults"] = Adults,
            ["children"] = Children,
            ["has_offer"] = Offer is null ? 0 : 1,
            ["minimal_price"] = Offer?.MinimalPrice,
            ["price_source"] = priceSource,
            ["public_minimal_price"] = PublicOffer?.MinimalPrice
        });
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        try 
        {
            if (_jsModule != null) 
            {
                try {
                    await _jsModule.InvokeVoidAsync("unobserveElement", _elementRef);
                } catch {  }
                
                await _jsModule.DisposeAsync();
            }

            if (_sliderModule != null)
            {
                await _sliderModule.DisposeAsync();
            }
            
            _objRef?.Dispose();
        } 
        catch (Exception ex)
        {
            if (ex is JSDisconnectedException)
            {
                return;
            }

            Logger.LogDebug(ex, "Apartment component dispose failed for apartment {ApartmentId}.", Item?.Id);
        }
    }
}
