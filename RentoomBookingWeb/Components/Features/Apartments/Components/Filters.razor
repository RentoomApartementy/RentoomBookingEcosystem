@using System.Text
@using RentoomBooking.SharedClasses.Models.RentoomBooking
@using RentoomBooking.SharedClasses.Services.Upsell
@using RentoomBooking.SharedClasses.Models.Upsell
@inject IApartmentSearchFiltersService ApartmentSearchFiltersService
@inject NavigationManager Navigation
@using RentoomBookingWeb.Components.Enums
@using Microsoft.Extensions.Localization
@using System.Web
@using System.Globalization
@inject IStringLocalizer<RentoomBookingWeb.Apartments> Localizer
@inject IStringLocalizer<RentoomBookingWeb.Currency> CurrencyLocalizer;

<div class="mobile-filter-wrapper">
    <button class="mobile-filter-trigger" @onclick="ToggleMobileFilters">
        <div class="trigger-content">
            <GoogleIcon Name="tune" Class="trigger-icon" AriaLabel="Filters" />
            <span class="trigger-text">@Localizer["Filters"]</span>
            @if (GetSelectedCount() > 0)
            {
                <span class="filter-badge">@GetSelectedCount()</span>
            }
        </div>
        <div class="trigger-arrow">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </div>
    </button>

    @if (HasSelectedFilters)
    {
        <div class="active-filters-pills">
            @foreach (var loc in _locations.Where(l => l.IsSelected))
            {
                <div class="filter-pill" @onclick="() => OnLocationChanged(loc)">
                    @Localizer[loc.Name]
                    <span class="pill-remove">&times;</span>
                </div>
            }
            @foreach (var filter in _filterOptions.Where(f => f.IsSelected))
            {
                <div class="filter-pill" @onclick="() => OnFilterChanged(filter)">
                    @Localizer[filter.Name]
                    <span class="pill-remove">&times;</span>
                </div>
            }
            @if (_selectedUpsell != null)
            {
                <div class="filter-pill" @onclick="ResetUpsellOnly">
                    @Localizer["Package"]: @_selectedUpsell.Title
                    <span class="pill-remove">&times;</span>
                </div>
            }
            @if (_minPrice > MinPriceOffer || _maxPrice < MaxPriceOffer)
            {
                <div class="filter-pill" @onclick="ResetPriceOnly">
                    @_minPrice - @_maxPrice @CurrencyLocalizer["PLN"]
                    <span class="pill-remove">&times;</span>
                </div>
            }
        </div>
    }
</div>

<div class="filters-container @(_isMobileFiltersOpen ? "active" : "")">
    
    @if (_isMobileFiltersOpen)
    {
        <button class="close-filters-btn" @onclick="ToggleMobileFilters">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
    }

    @if (_isLoading)
    {
        @for (int i = 0; i < 9; i++)
        {
            <div class="text-skeleton"></div>
        }
    }
    else
    {
        @if (_selectedUpsell != null)
        {
            <div class="selected-upsell-sidebar">
                <p class="filters-title">@Localizer["SelectedPackage"]</p>
                <div class="filter-option selected" @onclick="ResetUpsellOnly" style="cursor: pointer;">
                    <GoogleIcon Name="kid_star" Class="filter-icon small-icon" AriaLabel="Selected package" />
                    <span>@_selectedUpsell.Title</span>
                </div>
                <hr/>
            </div>
        }

        @if (!IsMapActive)
        {
            <div @onclick="HandleClickOnMapFilter" class="map-filter">
                <span class="map-filter-title">@Localizer["MapView"]</span>
            </div>
        }
        
        <p class="filters-title">@Localizer["WhereCheckIn"]</p>
        
        <div class="filters">
            @foreach (var option in _locations.Where(loc => loc.Name == "Stare Miasto" || loc.Name == "Centrum"))
            {
                <label class="@(option.IsSelected ? "filter-option selected" : "filter-option")" for="@option.Id">
                    <GoogleIcon Name="@option.Icon" Class="filter-icon" AriaLabel="@option.Name" />
                    <input type="checkbox"
                           id="@option.Id"
                           checked="@option.IsSelected"
                           @onchange="(e) => OnLocationChanged(option)"
                           style="position:absolute; opacity:0; width:0; height:0;"/>
                    <span>@Localizer[option.Name]</span>
                </label>
            }
        </div>
        
        @if (MaxPriceOffer > 0 && MaxPriceOffer > MinPriceOffer)
        {
            <hr/>
            <div class="price-filter" style="padding: 0 10px;">
                <PricesPickerRange
                    Min="@MinPriceOffer" 
                    Max="@MaxPriceOffer"
                    MinSelected="_minPrice"
                    MaxSelected="_maxPrice"
                    MinSelectedChanged="@(val => _minPrice = val)"
                    MaxSelectedChanged="@(val => _maxPrice = val)"
                    OnRangeChanged="HandlePriceCommit" />
            </div>
        }

        <hr/>
        <p class="filters-title">@Localizer["Filters"]</p>

        <div class="filters">
            @foreach (var filter in _filterOptions)
            {
                <label class="@(filter.IsSelected ? "filter-option selected" : "filter-option")" for="@filter.Id">
                    <GoogleIcon Name="@filter.Icon" Class="filter-icon" AriaLabel="@filter.Name" />
                    <input type="checkbox"
                           id="@filter.Id"
                           checked="@filter.IsSelected"
                           @onchange="(e) => OnFilterChanged(filter)"
                           style="position:absolute; opacity:0; width:0; height:0;"/>
                    <span>@Localizer[filter.Name]</span>
                </label>
            }
        </div>
        
        @if (_isMobileFiltersOpen)
        {
            <div>
                <Button OnClick="ToggleMobileFilters" style="width: 100%; margin-top: 1rem;" Type="ButtonType.Secondary">@Localizer["ApplyFilters"]</Button>  
            </div> 
        }
        
        @if (HasSelectedFilters)
        {
            <div class="reset-button-wrapper">
                <Button OnClick="async () => await ResetFilters()" style="width: 100%">@Localizer["Reset"]</Button>  
            </div> 
        }
    }
</div>

@code {
    [Parameter] public bool IsMapActive { get; set; } = false;
    [Parameter] public int MinPriceOffer { get; set; } = 0;
    [Parameter] public int MaxPriceOffer { get; set; } = 0;
    [Parameter] public int? InitialMinPrice { get; set; } 
    [Parameter] public int? InitialMaxPrice { get; set; } 
    [Parameter] public Guid SliderResetKey { get; set; }
    [Parameter] public EventCallback<(ApartmentFilters Filters, int MinPrice, int MaxPrice)> OnFiltersChanged { get; set; }
    [Parameter] public EventCallback OnClickOnMap { get; set; }

    [Inject] IUpsellCatalogService UpsellCatalogService { get; set; } = default!;

    private List<FilterOption> _locations = new();
    private List<FilterOption> _filterOptions = new();
    private UpsellTileDto? _selectedUpsell;
    private bool _isLoading = false;
    private int _minPrice;
    private int _maxPrice;
    private bool _isMobileFiltersOpen = false;

    private int _lastMinOffer;
    private int _lastMaxOffer;

    protected override void OnParametersSet()
    {
        if (MinPriceOffer != _lastMinOffer || MaxPriceOffer != _lastMaxOffer)
        {
            _lastMinOffer = MinPriceOffer;
            _lastMaxOffer = MaxPriceOffer;

            _minPrice = InitialMinPrice ?? MinPriceOffer;
            _maxPrice = InitialMaxPrice ?? MaxPriceOffer;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await GetFilters();
    }

    private async Task GetFilters()
    {
        _isLoading = true;
        try {
            await LoadUrlUpsell();
            var filters = await ApartmentSearchFiltersService.GetFiltersAsync();
            var locationFilters = filters.FirstOrDefault(f => f.id == "city-regions-filter")?.filtersDictionary.GetValueOrDefault("pl");
            var amenitiesFilters = filters.FirstOrDefault(f => f.id == "amenities-filter")?.filtersDictionary.GetValueOrDefault("pl");
            
            if (locationFilters != null) 
                _locations = locationFilters.Select(f => new FilterOption(f.id.ToString(), f.name, f.icon_materialui_name)).ToList();
            
            if (amenitiesFilters != null) 
                _filterOptions = amenitiesFilters.Select(f => new FilterOption(f.id.ToString(), f.name, f.icon_materialui_name)).ToList();
            
            ApplyUrlFilters();
            _isLoading = false;
        } 
        catch (Exception ex) 
        { 
            Console.WriteLine($"Error fetching filters definition: {ex.Message}");
            _isLoading = false;
        }
    }

    private async Task LoadUrlUpsell()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = HttpUtility.ParseQueryString(uri.Query);
        if (int.TryParse(query["upsellId"], out int uId))
        {
            var upsells = await UpsellCatalogService.GetAvailableUpsellTilesAsync(CultureInfo.CurrentUICulture.Name, "rentoombooking");
            _selectedUpsell = upsells.FirstOrDefault(u => u.PartnerServiceId == uId);
        }
    }

    private async Task OnLocationChanged(FilterOption option)
    {
        option.IsSelected = !option.IsSelected;
        UpdateUrl();
        await ApplyFilters();
    }

    private async Task OnFilterChanged(FilterOption filter)
    {
        filter.IsSelected = !filter.IsSelected;
        UpdateUrl();
        await ApplyFilters();
    }

    private async Task HandlePriceCommit()
    {
        UpdateUrl();
        await ApplyFilters();
    }

    private void UpdateUrl()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = HttpUtility.ParseQueryString(uri.Query);

        var selectedLocationIds = _locations.Where(l => l.IsSelected).Select(l => l.Id).ToList();
        if (selectedLocationIds.Any()) query["locations"] = string.Join(",", selectedLocationIds);
        else query.Remove("locations");

        var selectedFilterIds = _filterOptions.Where(f => f.IsSelected).Select(f => f.Id).ToList();
        if (selectedFilterIds.Any()) query["filters"] = string.Join(",", selectedFilterIds);
        else query.Remove("filters");

        if (_selectedUpsell != null) query["upsellId"] = _selectedUpsell.PartnerServiceId.ToString();
        else query.Remove("upsellId");

        if (_minPrice > MinPriceOffer || _maxPrice < MaxPriceOffer)
        {
            query["minPrice"] = _minPrice.ToString();
            query["maxPrice"] = _maxPrice.ToString();
        }
        else
        {
            query.Remove("minPrice");
            query.Remove("maxPrice");
        }

        var path = uri.GetLeftPart(UriPartial.Path);
        var queryString = query.ToString();
        var newUri = string.IsNullOrEmpty(queryString) ? path : $"{path}?{queryString}";
        
        Navigation.NavigateTo(newUri, forceLoad: false);
    }

    private void ApplyUrlFilters()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = HttpUtility.ParseQueryString(uri.Query);
        
        var selectedLocIds = (query["locations"] ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries).ToHashSet();
        var selectedAmeIds = (query["filters"] ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries).ToHashSet();
        
        foreach (var location in _locations) location.IsSelected = selectedLocIds.Contains(location.Id);
        foreach (var filter in _filterOptions) filter.IsSelected = selectedAmeIds.Contains(filter.Id);
    }

    private async Task ApplyFilters()
    {
        var filters = new ApartmentFilters
        {
            ApartmentAmenitiesFilter = _filterOptions.Where(f => f.IsSelected).Select(f => int.Parse(f.Id)).ToList(),
            ApartmentLocationsFilter = _locations.Where(l => l.IsSelected).Select(l => l.Name).ToList()
        };

        if (_selectedUpsell != null)
        {
            filters.ApartmentAddonFilter = new List<int> { _selectedUpsell.PartnerServiceId };
        }

        var priceFilters = new OfferPriceFilter
        {
            PriceFrom = _minPrice,
            PriceTo = _maxPrice,
        };
        
        await OnFiltersChanged.InvokeAsync((filters, _minPrice, _maxPrice));
    }

    private async Task ResetFilters()
    {
        foreach (var location in _locations) location.IsSelected = false;
        foreach (var filter in _filterOptions) filter.IsSelected = false;
        _selectedUpsell = null;
        
        _minPrice = MinPriceOffer;
        _maxPrice = MaxPriceOffer;
        
        UpdateUrl();
        await ApplyFilters();
    }

    private async Task ResetPriceOnly()
    {
        _minPrice = MinPriceOffer;
        _maxPrice = MaxPriceOffer;
        UpdateUrl();
        await ApplyFilters();
    }

    private async Task ResetUpsellOnly()
    {
        _selectedUpsell = null;
        UpdateUrl();
        await ApplyFilters();
    }

    private int GetSelectedCount()
    {
        int count = _locations.Count(l => l.IsSelected) + _filterOptions.Count(f => f.IsSelected);
        if (_minPrice > MinPriceOffer || _maxPrice < MaxPriceOffer) count++;
        if (_selectedUpsell != null) count++;
        return count;
    }

    private void ToggleMobileFilters() => _isMobileFiltersOpen = !_isMobileFiltersOpen;
    private async Task HandleClickOnMapFilter() => await OnClickOnMap.InvokeAsync();

    private bool HasSelectedFilters => 
        _locations.Any(l => l.IsSelected) || 
        _filterOptions.Any(f => f.IsSelected) || 
        _selectedUpsell != null ||
        (_minPrice > MinPriceOffer && MinPriceOffer > 0) || 
        (_maxPrice < MaxPriceOffer && MaxPriceOffer > 0);

    public class FilterOption
    {
        public string Id { get; }
        public string Name { get; }
        public string Icon { get; set; }
        public bool IsSelected { get; set; }
        public FilterOption(string id, string name, string icon)
        {
            Id = id; Name = name; Icon = icon;
        }
    }
}
