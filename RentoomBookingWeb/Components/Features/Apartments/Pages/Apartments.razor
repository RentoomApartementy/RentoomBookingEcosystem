@page "/apartamenty"
@using RentoomBookingWeb.Components.Features.Apartments.Components
@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.SharedClasses.Models.IdoBooking.Public
@using RentoomBooking.SharedClasses.Models.RentoomBooking
@inject IApartmentsService ApartmentsService
@inject IRentoomOfferService RentoomOfferService
@inject IJSRuntime JS
@using System.Text.Json
@using Microsoft.AspNetCore.WebUtilities
@inject IApartmentsService ApartmentsApiService
@inject NavigationManager NavManager

<PageTitle>Apartamenty</PageTitle>

<div class="apartments-container">
    <HeaderSection ImagePath="/assets/images/header-bg-apartments.jpeg" Title="Apartamenty" Height="230px" />

    <div class="apartments-search-wrapper">
        <SearchBar
            StartDate="@_startDate"
            EndDate="@_endDate"
            Adults="@_adults"
            Children="@_children"
            Rooms="@_rooms"
            OnSearch="@(async query => await HandleSearch(query))" 
        />
    </div>

    <div class="apartments-items">
        <Filters />

        
            <div class="apartments-items-wrapper">
                <div class="text-button-wrapper">
                    <h4>@ApartmentsCount apartamenty/ów</h4>
                    <div class="view-buttons-wrapper">
                        <div @onclick="() => ToggleView(false)" class="view-button @(IsMapView ? "" : "view-button-active")">Siatka</div>
                        <div @onclick="() => ToggleView(true)" class="view-button @(IsMapView ? "view-button-active" : "")">Mapa</div>
                    </div>
                </div>

                @if (!IsMapView)
                {
                    <div class="apartments-items-container">
                        @if (!string.IsNullOrEmpty(Error))
                        {
                            <p class="text-red-600">@Error</p>
                        }

                        @if (Items.Count > 0)
                        {
                            @foreach (var item in Items)
                            {
                                <Apartment Item="@item" Offer="@GetPricingOfferByObjectId(int.Parse(item.Id))" ShowPrice="_isSearch"/>
                            }
                        }

                        @if (ApartmentsIsloading)
                        {
                            <div class="loading-text">
                                Ładowanie apartamentów...
                            </div>
                        }
                    </div>   
                }
                
                
                <div class="apartments-items-map" style="display: @(IsMapView ? "block" : "none")">
                    <ApartmentsMap Offers="@Offers" IsSearch="@_isSearch"></ApartmentsMap>
                </div>   
                
            </div>
        
        
        @* <div class="apartments-items-map" style="display:@(IsMapView ? "block" : "none")"> *@
        @*     <div class="text-button-wrapper"> *@
        @*         <h4>@ApartmentsCount apartamenty/ów</h4> *@
        @*         <div class="view-buttons-wrapper"> *@
        @*             <div @onclick="OnListView" class="view-button">Siatka</div> *@
        @*             <div class="view-button-active">Mapa</div> *@
        @*         </div> *@
        @*     </div> *@
        @*     <ApartmentsMap Offers="@Offers"></ApartmentsMap> *@
        @* </div> *@
    </div>
</div>

@code {
    private long? ApartmentsCount;
    private bool IsLoading = true;
    private const int PageSize = 6;
    private readonly List<ApartmentObject> Items = new();
    private readonly List<PricingOffer> Offers = new();
    private string? Token;
    private bool ApartmentsIsloading = false;
    private bool HasMore = true;
    private string? Error;
    private DotNetObjectReference<Apartments>? ObjRef;
    private IJSObjectReference? JsModule;
    private bool IsMapView = false;

    private string? _startDate = "";
    private string? _endDate = "";
    private string? _adults = "";
    private string? _children = "";
    private string? _rooms = "";
    private bool _isSearch = false;

    protected override async Task OnInitializedAsync()
    {
        GetFiltersFromUrl();

        _isSearch = !string.IsNullOrEmpty(_startDate) || !string.IsNullOrEmpty(_endDate)
                    || !string.IsNullOrEmpty(_adults) || !string.IsNullOrEmpty(_children)
                    || !string.IsNullOrEmpty(_rooms);

        await GetApartmentsCount();

        if (_isSearch)
        {
            var query = new Dictionary<string, string>
            {
                { "startDate", _startDate },
                { "endDate", _endDate },
                { "adults", _adults },
                { "children", _children },
                { "rooms", _rooms }
            };
            await HandleSearch(query, updateUrl: false);
        }
        else
        {
            await LoadMore();
            await GetFilteredOffers();
        }
    }

    private async Task GetApartmentsCount()
    {
        IsLoading = true;
        try
        {
            ApartmentsCount = await ApartmentsService.GetApartmentsCountAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Wystąpił błąd: {ex.Message}");
            ApartmentsCount = null;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadMore()
    {
        if (ApartmentsIsloading || !HasMore) return;

        ApartmentsIsloading = true;
        Error = null;
        StateHasChanged();

        try
        {
            var page = await ApartmentsService.GetApartmentsByPageAsync(Token, top: PageSize);
            if (page?.Items is { Count: > 0 })
            {
                Items.AddRange(page.Items);
                Token = page.ContinuationToken;
                HasMore = !string.IsNullOrEmpty(Token);
            }
            else
            {
                HasMore = false;
            }
        }
        catch (Exception ex)
        {
            Error = ex.Message;
            HasMore = false;
        }
        finally
        {
            ApartmentsIsloading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ObjRef = DotNetObjectReference.Create(this);
            JsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/infiniteScroll.js");
            await JsModule.InvokeVoidAsync("init", ObjRef);
        }
    }

    [JSInvokable]
    public async Task LoadMoreOnScroll()
    {
        if (!ApartmentsIsloading && HasMore)
        {
            await LoadMore();
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (JsModule is not null && ObjRef is not null)
        {
            await JsModule.InvokeVoidAsync("unregister", ObjRef);
        }

        ObjRef?.Dispose();
        JsModule?.DisposeAsync();
    }

    private void OnListView() => IsMapView = false;
    private void OnMapView() => IsMapView = true;
    private void ToggleView(bool map)
    {
        IsMapView = map;
        StateHasChanged(); // wymusza ponowne renderowanie, żeby div #map istniał
    }

    private async Task<List<ApartmentObject>?> GetAllApartments()
    {
        try
        {
            var page = await ApartmentsApiService.GetAllApartmentsList();
            var items = new List<ApartmentObject>();
            if (page?.Items is { Count: > 0 })
            {
                items?.AddRange(page.Items);
            }
            return items;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            return null;
        }
    }

    private async Task GetFilteredOffers()
    {
        try
        {
            var items = await GetAllApartments() ?? new List<ApartmentObject>();

            List<int> ids = items
                .Select(a => int.TryParse(a.Id, out var id) ? id : (int?)null)
                .Where(id => id.HasValue)
                .Select(id => id!.Value)
                .ToList();

            var idoParams = new PricingOffersRequest
            {
                ObjectIds = ids,
                DateFrom = _startDate,
                DateTo = _endDate,
                NumberOfAdults = int.TryParse(_adults, out var adults) ? adults : 0,
                NumberOfBigChildren = int.TryParse(_children, out var children) ? children : 0,
            };

            var filters = new RentoomQueryOffer
            {
                IdoOfferParams = idoParams,
                ApartmentFilterParams = new ApartmentFilters()
            };

            var filteredOffers = await RentoomOfferService.getOfferWitFilter(filters);
            Offers.AddRange(filteredOffers.PricingOffers);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Wystąpił błąd: {ex.Message}");
        }
    }

    private void GetFiltersFromUrl()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        _startDate = query.TryGetValue("startDate", out var s) ? s : "";
        _endDate = query.TryGetValue("endDate", out var e) ? e : "";
        _adults = query.TryGetValue("adults", out var a) ? a : "";
        _children = query.TryGetValue("children", out var c) ? c : "";
        _rooms = query.TryGetValue("rooms", out var r) ? r : "";
    }

    private PricingOffer? GetPricingOfferByObjectId(int objectId)
        => Offers.Find(o => o.ObjectId == objectId);

    private async Task HandleSearch(Dictionary<string, string> query, bool updateUrl = true)
    {
        _startDate = query.GetValueOrDefault("startDate", "");
        _endDate = query.GetValueOrDefault("endDate", "");
        _adults = query.GetValueOrDefault("adults", "");
        _children = query.GetValueOrDefault("children", "");
        _rooms = query.GetValueOrDefault("rooms", "");

        if (updateUrl)
        {
            var urlQuery = new Dictionary<string, string>
            {
                { "startDate", _startDate },
                { "endDate", _endDate },
                { "adults", _adults },
                { "children", _children },
                { "rooms", _rooms }
            };
            var url = QueryHelpers.AddQueryString("/apartamenty", urlQuery);
            NavManager.NavigateTo(url, forceLoad: false);
        }

        Items.Clear();
        Offers.Clear();
        Token = null;
        HasMore = false;

        await GetApartmentsCount();
        ApartmentsIsloading = true;
        StateHasChanged();

        Items.AddRange(await GetAllApartments() ?? new List<ApartmentObject>());

        await GetFilteredOffers();

        Items.Sort((a, b) =>
        {
            var offerA = GetPricingOfferByObjectId(int.Parse(a.Id));
            var offerB = GetPricingOfferByObjectId(int.Parse(b.Id));
            if (offerA != null && offerB == null) return -1;
            if (offerA == null && offerB != null) return 1;
            return 0;
        });

        ApartmentsIsloading = false;
        _isSearch = true;

        StateHasChanged();
    }
}
