    <meta name="keywords" content="apartamenty toruń, noclegi toruń, wynajem krótkoterminowy, apartamenty starówka, rentoom" />

    <link rel="canonical" href="@Navigation.BaseUri" />

    <meta property="og:title" content="Apartamenty Toruń - Twój komfortowy nocleg" />
    <meta property="og:description" content="Sprawdź nasze apartamenty w sercu Torunia. Idealne na weekend i dłuższy pobyt." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@Navigation.BaseUri" />
    <meta property="og:image" content="@($"{Navigation.BaseUri}assets/images/hero-bg.jpeg")" />
</HeadContent>

<div class="home-container">
    <HeroSection/>
    <ApartmentsSection/>
    <PackagesSection/>
    <CitySection/>
    <StatsSection/>
    <WhyRentoomSection/>
