@using Microsoft.Extensions.Localization
@inject IStringLocalizer<HomePage> Localizer

<section class="rentoom-container">
    <header class="rentoom-header">
        <h1 class="rentoom-title">@Localizer["whyRentoom"]</h1>
        <p class="rentoom-subtitle">@Localizer["whyRentoomSubtitle"]</p>
    </header>

    <div class="rentoom-content">
        <article class="rentoom-text-column">
            <div class="rentoom-text-block">
                <p>@Localizer["whyRentoomTitle"]</p>
                <p>@Localizer["whyRentoomText1"]</p>
                <p>@Localizer["whyRentoomText2"]</p>
            </div>
        </article>

        <div class="rentoom-image-wrapper">
            <img src="assets/images/apartment.png" alt="Apartamenty w Toruniu – wnętrze" class="rentoom-image" loading="lazy" />
        </div>
    </div>
</section>