@using Microsoft.Extensions.Localization;
@inject IStringLocalizer<HomePage> Localizer;

<div class="contact-container">
    <h1 class="contact-title">@Localizer["formtext"]</h1>
    <h2 class="contact-subtitle">@Localizer["formContactText"]</h2>
    
    <div class="contact-content">
        <div 
            class="contact-img"
            style="background-image: url('/assets/images/contact.jpeg'); background-size: cover; background-position: center;"
        ></div>
        
        <div class="contact-form">
            <input type="text" placeholder="@Localizer["name"]" @bind="Name" />
            <input type="text" placeholder="@Localizer["lastName"]" @bind="Surname" />
            <input type="text" placeholder="@Localizer["phone"]" @bind="Phone" />
            <input type="email" placeholder="Email" @bind="Email" />
            
            <div class="contact-form-buttons">
                <label class="contact-checkbox-wrapper">
                    <input type="checkbox" @bind="IsAccepted" />
                    <small class="contact-check-text">
                        @Localizer["formConfirm"]
                    </small>
                </label>
                
                <Button>@Localizer["send"]</Button>
            </div>
        </div>
    </div>
</div>

@code {
    private string Name = "";
    private string Surname = "";
    private string Phone = "";
    private string Email = "";
    private bool IsAccepted = false;
}