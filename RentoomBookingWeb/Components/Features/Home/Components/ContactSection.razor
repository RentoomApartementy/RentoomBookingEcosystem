<div class="contact-container">
    <h1 class="contact-title">Zostaw swoje informacje kontaktowe, a my się z tobą skontaktujemy!</h1>
    <h2 class="contact-subtitle">Formularz kontaktowy</h2>
    
    <div class="contact-content">
        <div 
            class="contact-img"
            style="background-image: url('assets/images/contact.jpeg'); background-size: cover; background-position: center;"
        ></div>
        
        <div class="contact-form">
            <input type="text" placeholder="Imię" @bind="Name" />
            <input type="text" placeholder="Nazwisko" @bind="Surname" />
            <input type="text" placeholder="Telefon" @bind="Phone" />
            <input type="email" placeholder="Email" @bind="Email" />
            
            <div class="contact-form-buttons">
                <label class="contact-checkbox-wrapper">
                    <input type="checkbox" @bind="IsAccepted" />
                    <small class="contact-check-text">
                        Wyrażam zgodę na przetwarzanie moich danych osobowych podanych w powyższym formularzu
                    </small>
                </label>
                
                <Button>Wyślij</Button>
            </div>
        </div>
    </div>
</div>

@code {
    private string Name = "";
    private string Surname = "";
    private string Phone = "";
    private string Email = "";
    private bool IsAccepted = false;
}