@using Microsoft.Extensions.Localization
@inject IStringLocalizer<HomePage> Localizer

<section class="city-container">
    <header class="city-header">
        <h1 class="city-title">@Localizer["title2"]</h1>
        <p class="city-subtitle">@Localizer["title3subtitle"]</p>
    </header>

    <div class="city-content">
        <div class="city-image-wrapper">
            <img src="assets/images/torun.jpeg" alt="Apartamenty w Toruniu – panorama miasta" class="city-image" loading="lazy" />
        </div>

        <article class="city-text-column">
            <div class="city-text-block">
                <h3>@Localizer["text1title"]</h3>
                <p>@Localizer["text1description"]</p>
            </div>

            <div class="city-text-block">
                <h3>@Localizer["text1title2"]</h3>
                <p>@Localizer["text1description2"]</p>
            </div>
        </article>
    </div>
</section>