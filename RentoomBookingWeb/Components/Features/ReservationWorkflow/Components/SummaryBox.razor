@using Microsoft.Extensions.Localization;
@using RentoomBooking.SharedClasses.Models.IdoBooking;
@using RentoomBooking.SharedClasses.Models.RentoomBooking
@using RentoomBooking.SharedClasses.Models.ReservationWorkflow
@using RentoomBookingWeb.Components.Features.Apartments.Components;
@inject IStringLocalizer<RentoomBookingWeb.Payment> Localizer;
@inject IStringLocalizer<RentoomBookingWeb.Currency> CurrencyLocalizer;
@inject IStringLocalizer<RentoomBookingWeb.Apartment> ApartmentLocalizer;

<div class="order-wrapper">
    @if (Apartment != null)
    {
        <div style="width: 100%;">
            <div style="margin: 0 auto; max-width: 500px;">
                <Apartment
                    Item="@Apartment"
                    Readonly="true"
                    DisableForGoToReservation="true"/>
            </div>
        </div>
    }
    else
    {
        <div style="width: 100%;">
            <div style="margin: 0 auto; max-width: 500px;">
                <Apartment 
                    Readonly="true"
                    DisableForGoToReservation="true"
                /> 
            </div>
        </div>
    }
            
    <div class="summary-box">
        <div class="form-wrapper-title">
            <div class="form-wrapper-title-icon-wrapper">
                <GoogleIcon Name="calendar_month" Class="form-wrapper-title-icon" AriaLabel="ikona uzytkownika" />
            </div> 
            <div class="form-wrapper-title-text">
                <h3 class="summary-box-title">@Localizer["YourStay"]</h3>
                <p class="summary-box-dates">
                    @Localizer["From"] @(Summary?.StartRequest?.StartDate.ToString("dd.MM.yyyy") + " " + Summary?.StartRequest?.CheckInTime.ToString("HH:mm") ?? "---")
                    <br>
                    @Localizer["To"] @(Summary?.StartRequest?.EndDate.ToString("dd.MM.yyyy") + " " + Summary?.StartRequest?.CheckOutTime.ToString("HH:mm") ?? "---")
                </p>
            </div>
        </div>
        <hr style="margin: 0;">
                
        <div class="summary-box-prices">
            <div class="summary-box-prices-text">
                @* <span>@_pricePerNight.ToString("N2") @Summary?.StartRequest?.Currency x @_totalDays @Localizer["NightsText"]</span> *@
                @* <b>@_basePrice.ToString("N2") @Summary?.StartRequest?.Currency</b> *@
                <span>@GetStaySummaryText()</span>
                <b>@_basePrice.ToString("N2") @CurrencyLocalizer["PLN"]</b>
            </div>
            @if (Summary?.StartRequest?.SelectedAddons?.Count > 0)
            {
                @foreach (AddonSummaryLineDto addon in Summary.Addons)
                {
                    <div class="summary-box-prices-text">
                        <span>@(!string.IsNullOrWhiteSpace(addon.DisplayText) ? addon.DisplayText : GetAddonName(addon.AddonId)) @(addon.PaymentType == AddonPaymentType.PayPerAmount? "x " + @addon.Quantity:"")</span>
                        <b>@addon.LineTotalGross.ToString("N2") @CurrencyLocalizer["PLN"]</b>
                    </div>
                }
            }

            @if (Summary?.StartRequest?.MandatoryAddons?.Count > 0)
            {
                @foreach (AddonSummaryLineDto addon in Summary.Addons)
                {
                    <div class="summary-box-prices-text">
                        <span>@(!string.IsNullOrWhiteSpace(addon.DisplayText) ? addon.DisplayText : GetAddonName(addon.AddonId)) @(addon.PaymentType == AddonPaymentType.PayPerAmount ? "x " + @addon.Quantity : "")</span>
                        <b>@addon.LineTotalGross.ToString("N2") @CurrencyLocalizer["PLN"]</b>
                    </div>
                }
            }


            @if (Summary?.StartRequest?.SelectedUpsells?.Count > 0)
            {
                @foreach (var upsell in Summary.Upsells)
                {
                    <div class="summary-box-prices-text">
                        <span>@upsell.Title</span>
                        @* <b>@upsell.LineTotalGross.ToString("N2") @Summary.Currency</b> *@
                        <b>@upsell.LineTotalGross.ToString("N2") @CurrencyLocalizer["PLN"]</b>
                    </div>
                }
            }

            @if (Summary?.Invoice !=null)
            {
               
                    <div class="summary-box-prices-text">
                    <span>@Localizer["InvoiceSummaryBoxLabel"]</span>
                    <b>@(Summary?.Invoice !=null? Localizer["InvoiceYes"]:Localizer["InvoiceNo"])</b>
                    </div>
               
            }

            @if ((Summary?.DiscountAmountPln ?? 0m) > 0m)
            {
                <div class="summary-box-prices-text">
                    <span style="color: #0f766e; font-weight: 700;">@Localizer["BonusDiscountLabel"]</span>
                    <b style="color: #0f766e;">-@Summary!.DiscountAmountPln.ToString("N2") @CurrencyLocalizer["PLN"]</b>
                </div>
            }


        </div>
        <hr style="margin: 0;">
                
        <div class="summary-box-prices-text">
            <b style="font-size: 1.2rem;">@Localizer["SummaryText"]</b>
            <span style="display: flex; flex-direction: column; align-items: flex-end; gap: 2px;">
                @if ((Summary?.DiscountAmountPln ?? 0m) > 0m)
                {
                    <small style="color: #94a3b8; text-decoration: line-through;">
                        @Summary!.GrandTotalBeforeDiscount.ToString("N2") @CurrencyLocalizer["PLN"]
                    </small>
                }
                <b style="font-size: 1.2rem; color: #0f766e;">@Summary?.GrandTotal.ToString("N2") @CurrencyLocalizer["PLN"]</b>
            </span>
        </div>
    </div>
</div>

@code
{
    [Parameter] public ReservationSummaryDto? Summary { get; set; }
    [Parameter] public ApartmentObject? Apartment { get; set; }

    private int _totalDays;
    private decimal _pricePerNight;
    private decimal _basePrice;

    private string GetNightsSummaryText()
    {
        if (Summary?.StartRequest == null) return string.Empty;
        var nights = _totalDays;
        string nightsKey = nights switch
        {
            1 => "StayNight_1",
            var n when n % 10 >= 2 && n % 10 <= 4 && (n % 100 < 10 || n % 100 >= 20) => "StayNight_234",
            _ => "StayNight_Many"
        };
        return $"{nights} {ApartmentLocalizer[nightsKey]}";
    }

    private string GetPersonsSummaryText()
    {
        if (Summary?.StartRequest == null) return string.Empty;
        var guests = (Summary.StartRequest.Adults) + (Summary.StartRequest.Children);
        string personsKey = guests switch
        {
            1 => "StayPerson_1",
            var g when g % 10 >= 2 && g % 10 <= 4 && (g % 100 < 10 || g % 100 >= 20) => "StayPerson_234",
            _ => "StayPerson_Many"
        };
        return $"{guests} {ApartmentLocalizer[personsKey]}";
    }

    private string GetStaySummaryText()
    {
        if (Summary?.StartRequest == null) return string.Empty;
        return $"{GetNightsSummaryText()} / {GetPersonsSummaryText()}";
    }

    protected override void OnParametersSet()
    {
        var start = Summary?.StartRequest?.StartDate;
        var end = Summary?.StartRequest?.EndDate;

        if (start != null && end != null)
        {
            _totalDays = end.Value.DayNumber - start.Value.DayNumber;
            if (_totalDays <= 0) _totalDays = 1;

            if (Summary?.StartRequest?.OfferPrice != null)
            {
                //var addonsTotal = (decimal)(Summary.StartRequest.SelectedAddons?.Sum(a => a.Price * a.Quantity) ?? 0);
                var addonsTotal = Summary.AddonsTotal;
                _basePrice = Summary.StartRequest.OfferPrice.Value;//(Summary.StartRequest.OfferPrice ?? 0) - addonsTotal;
                _pricePerNight = Math.Round(_basePrice / _totalDays, 2);
            }
        }
    }

    private string GetAddonName(int idoId)
    {
        if (Apartment?.Addons != null)
        {
            return Apartment.Addons.FirstOrDefault(item => item.Id == idoId)?.Name ?? "Dodatek";
        }
        return "Dodatek";
    }
}
