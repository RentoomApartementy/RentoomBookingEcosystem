@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.SharedClasses.Models.AvailableTerms
@using Microsoft.Extensions.Localization

@if (StartDate == null || EndDate == null)
{
    <div class="placeholder-offer" @onclick="OnSearchModalOpen">
        <div class="placeholder-icon">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M19 19H5V8h14m-3-7v2H8V1H6v2H5c-1.11 0-2 .89-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2h-1V1m-1 11h-5v5h5v-5z"/></svg>
        </div>
        <b class="placeholder-title">@Localizer["PriceAvailableAfterSelectingDates"]</b>
        <p class="placeholder-desc">@Localizer["Apartment_PriceSelectDatesDescription"]</p>
        <div class="summary-offer-price-button">
            <Button Type="ButtonType.Primary" Class="btn-select-dates">
                <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24"><path fill="currentColor" d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 002 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z"/></svg>
                @Localizer["SelectDatesButtonLabel"]
            </Button>
        </div>
    </div>
}
else if (IsOfferLoading)
{
    <div class="summary-offer-price-wrapper" style="justify-content: center; padding: 2rem;">
        <b>@Localizer["Loading"]...</b>
    </div>
}
else if (OffersResponse?.Result?.PricingOffers?.Count > 0)
{
    <div id="offers-section" class="summary-offer-price-wrapper"> 
        @{
               var pricingData = OffersResponse?.Result?.PricingOffers?.FirstOrDefault();
               var refundableOffer = pricingData?.Offers?.FirstOrDefault(o => string.Equals(o.OfferType, "refundable", StringComparison.OrdinalIgnoreCase));
               var nonRefundableOffer = pricingData?.Offers?.FirstOrDefault(o => string.Equals(o.OfferType, "nonrefundable", StringComparison.OrdinalIgnoreCase));
         }
        
        @if (nonRefundableOffer != null)
        {
            <div class="summary-offer-price @(IsSelectedOffer("nonrefundable") ? "selected-offer" : "")">
                <b>@Localizer["Non-refundableOffer"]</b>
                <small>@Localizer["NonRefundableText"]</small>
                <div class="summary-offer-price-button" style="display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;">
                    <span class="summary-offer-price-button-price">
                        <b>@((nonRefundableOffer.Price + TotalAdditionalPrice).ToString("N2")) @CurrencySymbol</b>
                        <span class="stay-summary-text">@StaySummaryText</span>
                    </span>
                    <div class="offer-action-buttons" style="display: flex; gap: 8px; flex-wrap: wrap; flex: 1; justify-content: flex-end;">
                        <div @onclick="OnSearchModalOpen" @onclick:stopPropagation="true" style="flex: 1; max-width: 200px;">
                            <Button Type="ButtonType.Secondary" Class="btn-offer-mobile" style="width: 100%; white-space: nowrap;">@Localizer["ChangeDatesButtonLabel"]</Button>
                        </div>
                        <div @onclick="@(() => OnBookNow.InvokeAsync("nonrefundable"))" @onclick:stopPropagation="true" style="flex: 1; max-width: 200px;">
                            <Button Type="ButtonType.Tertiary" Class="btn-offer-mobile" style="width: 100%; white-space: nowrap;">@GetOfferButtonLabel("nonrefundable")</Button>
                        </div>
                    </div>
                </div>
            </div>  
        }
        
        @if (refundableOffer != null)
        {
            <div class="summary-offer-price refundable @(IsSelectedOffer("refundable") ? "selected-offer" : "")">
                <b>@Localizer["RefundableOffer"]</b>
                <small>@RefundableOfferText</small>
                <div class="summary-offer-price-button" style="display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;">
                    <span class="summary-offer-price-button-price">
                        <b>@((refundableOffer.Price + TotalAdditionalPrice).ToString("N2")) @CurrencySymbol</b>
                        <span class="stay-summary-text">@StaySummaryText</span>
                    </span>
                    <div class="offer-action-buttons" style="display: flex; gap: 8px; flex-wrap: wrap; flex: 1; justify-content: flex-end;">
                        <div @onclick="OnSearchModalOpen" @onclick:stopPropagation="true" style="flex: 1; max-width: 200px;">
                            <Button Type="ButtonType.Secondary" Class="btn-offer-mobile" style="width: 100%; white-space: nowrap;">@Localizer["ChangeDatesButtonLabel"]</Button>
                        </div>
                        <div @onclick="@(() => OnBookNow.InvokeAsync("refundable"))" @onclick:stopPropagation="true" style="flex: 1; max-width: 200px;">
                            <Button Type="@(nonRefundableOffer != null ? ButtonType.Primary : ButtonType.Tertiary)" Class="btn-offer-mobile" style="width: 100%; white-space: nowrap;">@GetOfferButtonLabel("refundable")</Button>
                        </div>
                    </div>
                </div>
            </div>   
        }
    </div>
    
    <small style="margin-top: .5rem">@Localizer["CleaningIncluded"]</small>
}
else
{
    <div class="summary-offer-price-wrapper">
        @if (SuggestionDates.Count > 0)
        {
            <div class="summary-offer-price">
                <b>@Localizer["NoOffersAvailable"]</b>
                <span>@Localizer["SuggestedDate"]:</span>
                <div class="summary-suggestion-list">
                    @foreach (var term in SuggestionDates)
                    {
                        var isSelected = SelectedSuggestionDate?.StartDate == term.StartDate &&
                                         SelectedSuggestionDate?.EndDate == term.EndDate;
                        <button type="button"
                                class="summary-suggestion-chip @(isSelected ? "selected" : "")"
                                @onclick="@(() => OnSuggestionSelected.InvokeAsync(term))">
                            @($"{term.StartDate} - {term.EndDate}")
                        </button>
                    }
                </div>
                <div @onclick="@(() => OnGoToSuggestion.InvokeAsync(SelectedSuggestionDate))" @onclick:stopPropagation="true">
                    <Button>@Localizer["BookNow"]</Button>
                </div>
            </div>  
        }
        @if (IsSuggestionLoading)
        {
            <div class="summary-offer-price">
                <b>@Localizer["NoOffersAvailable"]</b>
                <div class="summary-suggestion-loading">
                    <span class="mini-spinner"></span>
                        <span>@Localizer["SuggestedDateLoading"]</span>
                </div>
                <Button Disabled="true">@Localizer["BookNow"]</Button>
            </div>  
        }
    </div>
}

@code {
    [Parameter] public string? StartDate { get; set; }
    [Parameter] public string? EndDate { get; set; }
    [Parameter] public bool IsOfferLoading { get; set; }
    [Parameter] public PricingOffersResponse? OffersResponse { get; set; }
    [Parameter] public decimal TotalAdditionalPrice { get; set; }
    [Parameter] public string CurrencySymbol { get; set; } = "PLN";
    [Parameter] public string StaySummaryText { get; set; } = "";
    [Parameter] public string RefundableOfferText { get; set; } = "";
    [Parameter] public string? SelectedOfferType { get; set; }
    [Parameter] public bool HasActiveReservation { get; set; }
    [Parameter] public List<AvailableTerm> SuggestionDates { get; set; } = new();
    [Parameter] public AvailableTerm? SelectedSuggestionDate { get; set; }
    [Parameter] public bool IsSuggestionLoading { get; set; }
    [Parameter] public IStringLocalizer Localizer { get; set; } = default!;

    [Parameter] public EventCallback OnSearchModalOpen { get; set; }
    [Parameter] public EventCallback<string> OnBookNow { get; set; }
    [Parameter] public EventCallback<AvailableTerm> OnSuggestionSelected { get; set; }
    [Parameter] public EventCallback<AvailableTerm> OnGoToSuggestion { get; set; }

    private bool IsSelectedOffer(string offerType) => 
        string.Equals(SelectedOfferType, offerType, StringComparison.OrdinalIgnoreCase);

    private string GetOfferButtonLabel(string offerType) => 
        HasActiveReservation && IsSelectedOffer(offerType) ? Localizer["ContinueReservation"] : Localizer["BookNow"];
}
