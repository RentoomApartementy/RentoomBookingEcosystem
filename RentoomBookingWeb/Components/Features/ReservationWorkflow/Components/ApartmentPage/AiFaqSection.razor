@using RentoomBooking.SharedClasses.Services.Descriptions
@using Microsoft.Extensions.Localization

@if (Faqs != null && Faqs.Any())
{
    <div class="ai-faq-container">
        <h3 class="faq-title">@Localizer["FAQ_Title"]</h3>
        <div class="faq-list">
            @foreach (var faq in Faqs)
            {
                <details class="faq-item">
                    <summary class="faq-question">
                        <span>@faq.Question</span>
                        <div class="faq-chevron">
                            <svg viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                        </div>
                    </summary>
                    <div class="faq-answer">
                        <div class="faq-answer-content">
                            @((MarkupString)faq.Answer)
                        </div>
                    </div>
                </details>
            }
        </div>
    </div>
}

@code {
    [Parameter] public List<AiFaqItemDto>? Faqs { get; set; }
    [Parameter] public IStringLocalizer Localizer { get; set; } = default!;
}
