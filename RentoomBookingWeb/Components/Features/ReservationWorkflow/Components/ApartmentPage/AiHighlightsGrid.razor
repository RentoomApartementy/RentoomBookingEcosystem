@using Microsoft.Extensions.Localization

@if (Highlights != null && Highlights.Any())
{
    <div class="ai-highlights-container">
        <ul class="highlights-grid">
            @foreach (var highlight in Highlights)
            {
                <li class="highlight-item">
                    <span class="highlight-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    </span>
                    <span class="highlight-text">@((MarkupString)highlight)</span>
                </li>
            }
        </ul>
    </div>
}

@code {
    [Parameter] public List<string>? Highlights { get; set; }
}
