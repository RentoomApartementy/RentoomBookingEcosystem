@using RentoomBooking.SharedClasses.Services.Descriptions
@using Microsoft.Extensions.Localization
@using RentoomBooking.SharedClasses.Models.RentoomBooking
@using RentoomBooking.SharedClasses.Integrations.RentoomApp.NearbyAttractions.Models

<div class="ai-description-container">
    @* TOP: Always visible intro (Hook) *@
    <article class="ai-intro-content">
        @if (!string.IsNullOrEmpty(Data?.H1))
        {
            <h3 class="ai-h1">@Data.H1</h3>
        }

        @if (!string.IsNullOrEmpty(Data?.ShortDescription))
        {
            <div class="ai-short-description">
                @((MarkupString)Data.ShortDescription)
            </div>
        }
    </article>

    @* MIDDLE: Highlights (Always visible) *@
    <div class="ai-highlights-section">
        <AiHighlightsGrid Highlights="Data?.Highlights" />
    </div>

    @* BOTTOM: Collapsible details *@
    <div class="ai-details-wrapper @(IsExpanded ? "expanded" : "collapsed")">

        
        <div class="ai-main-description">
            @if (!string.IsNullOrEmpty(Data?.MainDescription))
            {
                @((MarkupString)Data.MainDescription)
            }
        </div>

        <ApartmentAmenities Amenities="Amenities" Localizer="Localizer" />

        <ApartmentNearbyAttractions
            Title="@Localizer["NearbyAttractions_Title"]"
            Subtitle="@Localizer["NearbyAttractions_Subtitle"]"
            Data="NearbyAttractions"
            Localizer="Localizer" />

        <div class="faq-section">
            <AiFaqSection Faqs="Data?.Faqs" Localizer="Localizer" />
        </div>
    </div>

    <div class="ai-expand-btn-wrapper">
        <button class="read-more-btn" @onclick="OnToggleExpand">
            <span class="btn-text">@(IsExpanded ? Localizer["HideDetails"] : Localizer["ShowAllDetails"])</span>
            <i class="chevron @(IsExpanded ? "up" : "down")"></i>
        </button>
    </div>
</div>

@code {
    [Parameter] public ApartmentAiDescriptionDto? Data { get; set; }
    [Parameter] public List<ObjectAmenity>? Amenities { get; set; }
    [Parameter] public NearbyAttractionsResultDTO? NearbyAttractions { get; set; }
    [Parameter] public bool IsExpanded { get; set; }
    [Parameter] public EventCallback OnToggleExpand { get; set; }
    [Parameter] public IStringLocalizer Localizer { get; set; } = default!;
}
