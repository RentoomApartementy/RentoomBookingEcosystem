@using Microsoft.Extensions.Localization
@using RentoomBooking.SharedClasses.Models.IdoBooking
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IStringLocalizer<RentoomBookingWeb.Apartment> Localizer;

@if (IsModalOpen)
{
    <div class="modal-backdrop">
        <div id="@Id" class="modal-card animate-pop-in">
            <div class="modal-header">
                <div class="modal-title">
                    <span>@Localizer["ApartmentsMap"]</span>
                </div>
                
                <button class="close-btn" @onclick="CloseModal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
            
            @if (Apartment != null)
            {
                <div class="map-wrapper">
                    <ApartmentsMapPopup
                        Latitude="@Apartment?.ObjectLocation?.LocalizationItem?.GeoLocationLat"
                        Longitude="@Apartment?.ObjectLocation?.LocalizationItem?.GeoLocationLng"
                        ApartmentAddress="@Apartment?.ObjectLocation?.Address"
                        Id="map-popup"
                        ClassName="leafletPopupMap"
                        Apartment="Apartment"
                        StartDate="@StartDate"
                        EndDate="@EndDate"
                        Adults="@Adults"
                        Children="@Children"
                    />
                </div>   
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool IsModalOpen { get; set; }
    [Parameter] public EventCallback<bool> IsModalOpenChanged { get; set; }
    
    [Parameter] public ApartmentObject? Apartment { get; set; }
    [Parameter] public String? StartDate { get; set; } = null;
    [Parameter] public String? EndDate { get; set; } = null;
    [Parameter] public String? Adults { get; set; } = null;
    [Parameter] public String? Children { get; set; } = null;

    private DotNetObjectReference<MapPopup>? objRef;
    private string Id { get; } = $"mappopup-{Guid.NewGuid()}";
    
    [JSInvokable]
    public async Task CloseModal()
    {
        if (IsModalOpen)
        {
            await IsModalOpenChanged.InvokeAsync(false); 
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerClickOutside", Id, objRef);
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("unregisterClickOutside", Id);
        }
        catch (Exception)
        {
        }
        finally
        {
            objRef?.Dispose();
        }
    }
}