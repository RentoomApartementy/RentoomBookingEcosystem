@page "/rezerwuj/{ReservationTokenGuid:guid}/oplac/error"
@page "/rezerwuj/{ReservationTokenGuid:guid}/oplac/fail"

@using Microsoft.Extensions.Localization
@using RentoomBooking.SharedClasses.Models.ReservationWorkflow
@using RentoomBooking.SharedClasses.Services.ReservationWorkflow
@using RentoomBookingWeb.Services
@inject IReservationWorkflowService ReservationWorkflowService
@inject NavigationManager Navigation
@inject IStringLocalizer<RentoomBookingWeb.Payment> Localizer
@inject ReservationWorkflowTelemetry WorkflowTelemetry

<PageTitle>@Localizer["FailPageTitle"]</PageTitle>

<div class="summary-container">
    <div class="status-card">
        <div class="state-content">
            @if (string.IsNullOrWhiteSpace(_error))
            {
                <div class="info-icon-wrapper alert-icon-wrapper">
                    <GoogleIcon Name="error" Class="status-icon" AriaLabel="@Localizer["FailIconAlt"]" Filled="true" />
                </div>
                <div class="spinner-container">
                    <div class="loading-spinner"></div>
                </div>
                <h2>@GetTitle()</h2>
                <p class="message">@GetMessage()</p>
                <p class="sub-message">@Localizer["NotRefreshPage"]</p>
            }
            else
            {
                <div class="error-box">
                    <div class="info-icon-wrapper alert-icon-wrapper">
                        <GoogleIcon Name="error" Class="status-icon" AriaLabel="@Localizer["FailIconAlt"]" Filled="true" />
                    </div>

                    <AppError Message="@_error"
                              Title="@Localizer["SomethingWrong"]"
                              Dismissible="false" />
                </div>
                <Button OnClick="GoToSummary">@Localizer["BackToSummary"]</Button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid ReservationTokenGuid { get; set; }

    private string? _error;
    private string _status = "checking";
    private bool _verificationStarted;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _verificationStarted)
        {
            return;
        }

        _verificationStarted = true;
        WorkflowTelemetry.TrackEvent(
            "ReservationPaymentReturnVerificationStarted",
            new Dictionary<string, string?>
            {
                ["ReservationTokenGuid"] = ReservationTokenGuid.ToString()
            });

        try
        {
            for (var attempt = 1; attempt <= 3; attempt++)
            {
                var paymentState = await ReservationWorkflowService.GetPaymentStateAsync(ReservationTokenGuid);
                if (string.Equals(paymentState.PaymentStatus, PaymentStatuses.Paid, StringComparison.OrdinalIgnoreCase))
                {
                    WorkflowTelemetry.TrackEvent(
                        "ReservationPaymentReturnVerifiedPaid",
                        new Dictionary<string, string?>
                        {
                            ["ReservationTokenGuid"] = ReservationTokenGuid.ToString()
                        });
                    Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie", true);
                    return;
                }

                if (string.Equals(paymentState.PaymentStatus, PaymentStatuses.Failed, StringComparison.OrdinalIgnoreCase))
                {
                    WorkflowTelemetry.TrackEvent(
                        "ReservationPaymentReturnVerifiedFailed",
                        new Dictionary<string, string?>
                        {
                            ["ReservationTokenGuid"] = ReservationTokenGuid.ToString()
                        });
                    Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie?paymentReturn=failed", true);
                    return;
                }

                _status = attempt == 1 ? "waiting" : "pending";
                await InvokeAsync(StateHasChanged);

                if (attempt < 3)
                {
                    await Task.Delay(TimeSpan.FromSeconds(3));
                }
            }

            WorkflowTelemetry.TrackEvent(
                "ReservationPaymentReturnPending",
                new Dictionary<string, string?>
                {
                    ["ReservationTokenGuid"] = ReservationTokenGuid.ToString()
                });
            Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie?paymentReturn=pending", true);
        }
        catch
        {
            _error = GetErrorText();
            WorkflowTelemetry.TrackEvent(
                "ReservationPaymentReturnVerificationFailed",
                new Dictionary<string, string?>
                {
                    ["ReservationTokenGuid"] = ReservationTokenGuid.ToString()
                });
            await InvokeAsync(StateHasChanged);
        }
    }

    private void GoToSummary()
    {
        Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie");
    }

    private string GetTitle()
    {
        return _status switch
        {
            "waiting" => Localizer["PaymentReturnWaitingTitle"],
            "pending" => Localizer["PaymentReturnPendingTitle"],
            _ => Localizer["PaymentReturnCheckingTitle"]
        };
    }

    private string GetMessage()
    {
        return _status switch
        {
            "waiting" => Localizer["PaymentReturnWaitingMessage"],
            "pending" => Localizer["PaymentReturnPendingMessage"],
            _ => Localizer["PaymentReturnCheckingMessage"]
        };
    }

    private string GetErrorText()
    {
        return Localizer["PaymentReturnVerificationError"];
    }
}
