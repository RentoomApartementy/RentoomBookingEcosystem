@page "/apartamenty/{id:int}/{slug}"
@page "/apartamenty/{id:int}/{slug}/{startDate?}/{endDate?}/{adults?}/{children?}"
@using System.Globalization
@using RentoomBooking.SharedClasses.Models.Database.EFEntitites
@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.SharedClasses.Models.IdoBooking.Public
@using RentoomBooking.SharedClasses.Models.ReservationWorkflow
@using RentoomBooking.SharedClasses.Models.Upsell
@using RentoomBooking.SharedClasses.Services.IdoBooking
@using RentoomBooking.SharedClasses.Services.ReservationWorkflow
@using RentoomBooking.SharedClasses.Services.Upsell
@using RentoomBookingWeb.Components.Features.Apartments.Components
@inject IApartmentsService ApartmentsService
@inject IIdoApartmentService IdoApartmentService
@inject NavigationManager Navigation
@inject IIdoOfferService OfferService
@inject IJSRuntime JSRuntime
@using RentoomBookingWeb.Models
@using RentoomBookingWeb.Services
@inject IAvailabilityFinderService AvailabilityFinder
@using RentoomBookingWeb.Helpers
@using System.Text.RegularExpressions
@inject NavigationManager NavManager
@using Microsoft.Extensions.Localization
@using RentoomBookingWeb.Components.Enums
@using RentoomBookingWeb.Components.Features.ReservationWorkflow.Components
@inject IStringLocalizer<RentoomBookingWeb.Apartment> Localizer;
@inject IStringLocalizer<RentoomBookingWeb.Upsell> UpsellLocalizer;
@inject IReservationWorkflowService ReservationWorkflowService
@inject IUpsellCatalogService UpsellCatalogService
@inject MediaCacheService MediaCache
@implements IDisposable
@using RentoomBookingWeb.Components.Enums;

<PageTitle>@GetSeoTitle()</PageTitle>

<HeadContent>
    <meta name="description" content="@GetSeoDescription()" />
    <meta name="keywords" content="apartament toruń, nocleg toruń, rentoom, wynajem krótkoterminowy, @_apartment?.Name" />
    <link rel="canonical" href="@GetCanonicalUrl()" />

    <meta property="og:title" content="@GetSeoTitle()" />
    <meta property="og:description" content="@GetSeoDescription()" />
    <meta property="og:image" content="@GetSeoImage()" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@GetCanonicalUrl()" />
    <meta property="og:locale" content="pl_PL" />
</HeadContent>

<div class="apartment-container">
    <HeaderSection
        ImagePath="@_objectMediums?.FirstOrDefault()?.Url"
        Title="@_apartment?.Name"
        Height="230px"
        IsShadow="true"
    />   
    
    <div class="main-wrapper">
        
        <div class="left-container">
            <div class="apartment-wrapper @(_isExpanded ? "expanded" : "collapsed")">
                <div class="apartment-text-wrapper">
                    <div class="">
                        <h2>@_apartment?.Name</h2>
                        <span itemprop="streetAddress">@_apartment?.ObjectLocation?.LocalizationItem?.Street</span>,
                        <span itemprop="postalCode">@_apartment?.ObjectLocation?.LocalizationItem?.ZipCode</span>
                        <span itemprop="addressLocality">@_apartment?.ObjectLocation?.LocalizationItem?.City</span>
                    </div>
                
                    <ul class="apartment-details">
                        <li>
                            <img src="assets/svgs/users.svg" alt="Liczba osób" class="icon"/>
                            <span itemprop="occupancy">@_apartment?.MinCapacity - @_apartment?.Capacity</span>
                        </li>
                        <li>
                            <img src="assets/svgs/bed.svg" alt="Liczba łóżek" class="icon"/>
                            @_bedsCount
                        </li>
                        <li>
                            <img src="assets/svgs/bath.svg" alt="Liczba łazienek" class="icon"/>
                            1
                        </li>
                        <li>
                            <img src="assets/svgs/m2.svg" alt="Powierzchnia apartamentu" class="icon"/>
                            <span itemprop="floorSize">@_apartment?.Area m²</span>
                        </li>
                    </ul>
                </div>

                <div style="margin-top: 1rem;"></div>
                
                <Images ImagesList="_objectMediums"></Images>

                <article class="description-wrapper">
                    @if (!string.IsNullOrEmpty(_objectDescription?.ShortDescription))
                    {
                        <h4>@_objectDescription.ShortDescription</h4>
                    }

                    @if (!string.IsNullOrEmpty(_objectDescription?.LongDescription))
                    {
                        <div class="long-description" itemprop="description">
                            @((MarkupString)_objectDescription.LongDescription)
                        </div>
                    }
                </article>

                <div class="amenities-wrapper">
                    @if (_amenities != null)
                    {
                        @foreach (var amenity in _amenities)
                        {
                            <div class="amenity">
                                @amenity.Name
                            </div>
                        }
                    }
                </div>

                @if (!_isExpanded)
                {
                    <div class="wrapper-shadow"></div>
                }
            </div>

            <span class="read-more-btn" @onclick="ToggleExpand" @onclick:stopPropagation="true">
                @(_isExpanded ? @Localizer["HideDetails"] : @Localizer["ShowAll"])
            </span>
            
             @if (localHasOffers)
            {
                <hr style="width: 100%;"/>
                
                 <h3 id="confirm-reservation" class="header-text text-lg">@Localizer["Summary"]</h3>

            @if (_apartment?.Addons != null && _apartment.Addons.Any(x => x.Optional != false))
            {
                <div class="addon-list-container">
                    <div class="addon-list-wrapper">
                        <div class="upsell-title-group">
                            <div class="upsell-icon">
                                <img src="assets/svgs/kid_star.svg" alt="icon" style="width: 20px; height: 20px;" />
                            </div>
                            <div class="upsell-text">
                                <h2 class="upsell-main-title">@Localizer["AdditionalOptions"]</h2>
                            </div>
                        </div>
                        
                        <div class="addons-wrapper">
                               @foreach (var addon in _apartment.Addons.Where(x => x.Optional != false))
                        {
                            
                            if (_definedAddons != null)
                            {
                                var fa = _definedAddons.FirstOrDefault(a => a.IdoBookingId == addon.Id);
                                var fadesc = fa?.AddonDefinition.Details.FirstOrDefault(a => a.Lang == CurrentAddonLanguage);
                                var paymentType = fadesc?.PaymentTypeShortDescription;

                                @if (fa != null)
                                {
                                    <div class="addon-item">
                                        <div class="addon-label" @onclick="@(() => ToggleAddonWrapper(addon.Id, addon.Optional))" @onclick:stopPropagation="true">
                                            <div class="addon-info-col">
                                                <span class="addon-name">@fadesc?.Name</span>
                                                @* <small class="addon-subtext">(@fadesc?.PaymentTypeShortDescription)</small> *@
                                            </div>

                                            <div class="price-box">
                                                <b class="addon-price">+@String.Format("{0:#.00}", AddonPricingCalculator.CalculateTotal(fa.PaymentType, fa.PriceGross, _reservationPricingContext.Nights, _reservationPricingContext.TotalGuests, quantity: 1)) zł</b>
                                                <input type="checkbox"
                                                       class="addon-checkbox"
                                                       checked="@(IsAddonSelected(addon.Id))"
                                                       disabled="@(IsAddonMandatory(addon.Optional))"
                                                       readonly/>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="addon-item">
                                        <div class="addon-label">
                                            <span class="addon-name-empty">Brak opisu dodatku</span>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="skeleton-row">
                                    <div style="flex: 1;">
                                        <span class="skeleton-box" style="width: 50%; height: 16px; margin-bottom: 6px;"></span>
                                        <span class="skeleton-box" style="width: 30%; height: 12px;"></span>
                                    </div>
                                    <div style="display: flex; gap: 10px; align-items: center;">
                                        <span class="skeleton-box" style="width: 60px; height: 16px;"></span>
                                        <span class="skeleton-box" style="width: 20px; height: 20px; border-radius: 4px;"></span>
                                    </div>
                                </div>
                            }
                        }
                        </div>
                    </div>
                </div>
            }
            
            
             @if (_reservationPricingContext is not null)
            {
                <UpsellList AvailableUpsellsList="_availableUpsells"
                            ReservationContext="_reservationPricingContext"
                            OnSelectionChanged="HandleUpsellSelectionChanged"
                            Texts="UpsellTexts"/>
            }

            
            @if (TotalAddonsPrice + TotalUpsellsPrice > 0)
            {
                <div class="additional-price">
                    +@((TotalAddonsPrice + TotalUpsellsPrice).ToString("N2")) zł
                </div>
            }
            
            @if (_isOfferLoading)
            {
                <div class="summary-offer-price-wrapper" style="justify-content: center; padding: 2rem;">
                    <b>@Localizer["Loading"]...</b>
                </div>
            }
            else if (_offersResponse?.Result?.PricingOffers?.Count != null && _offersResponse?.Result?.PricingOffers?.Count > 0)
            {
                <div id="offers-section" class="summary-offer-price-wrapper"> @{
                                                                                  var pricingData = _offersResponse?.Result?.PricingOffers?.FirstOrDefault();
                                                                                  var refundableOffer = pricingData?.Offers?.FirstOrDefault(o => o.OfferType == "refundable");
                                                                                  var nonRefundableOffer = pricingData?.Offers?.FirstOrDefault(o => o.OfferType == "nonrefundable");
                                                                              }
                    
                    @if (nonRefundableOffer != null)
                    {
                        <div class="summary-offer-price">
                            <b>@Localizer["Non-refundableOffer"]</b>
                            <small>@Localizer["NonRefundableText"]</small>
                            <div class="summary-offer-price-button">
                                <span class="summary-offer-price-button-price"><b>@(nonRefundableOffer.Price + (decimal)TotalAddonsPrice + TotalUpsellsPrice) @_reservationPricingContext?.Currency</b></span>
                                <div @onclick="@(() => GoToPayment(OfferTypeNonrefundable))" @onclick:stopPropagation="true">
                                    <Button>@Localizer["BookNow"]</Button>
                                </div>
                            </div>
                        </div>  
                    }
                    
                    @if (refundableOffer != null)
                    {
                        <div class="summary-offer-price refundable">
                            <b>@Localizer["RefundableOffer"]</b>
                            <small>@Localizer["RefundableOfferText"]</small>
                            <div class="summary-offer-price-button">
                                <span class="summary-offer-price-button-price"><b>@(refundableOffer.Price + (decimal)TotalAddonsPrice + TotalUpsellsPrice) @_reservationPricingContext?.Currency</b></span>
                                <div @onclick="@(() => GoToPayment(OfferTypeRefundable))" @onclick:stopPropagation="true">
                                    <Button Type="ButtonType.Tertiary">@Localizer["BookNow"]</Button>
                                </div>
                            </div>
                        </div>   
                    }
                </div>
                
                <small style="margin-top: .5rem">@Localizer["CleaningIncluded"]</small>
            }
            else
            {
                <div class="summary-offer-price-wrapper">
                    @if (_suggestionDates?.StartDate != null && _suggestionDates?.EndDate != null)
                    {
                        <div class="summary-offer-price">
                            <b>@Localizer["NoOffersAvailable"]</b>
                            <span>@Localizer["SuggestedDate"]: <b>@_suggestionDates?.StartDate - @_suggestionDates?.EndDate</b></span>
                            <div @onclick="GoToSuggestionDates" @onclick:stopPropagation="true">
                                <Button>@Localizer["BookNow"]</Button>
                            </div>
                        </div>  
                    }
                    @if (_suggestionLoading)
                    {
                        <div class="summary-offer-price">
                            <span>@Localizer["SuggestedDate"]: <b>@Localizer["SuggestedDateLoading"]</b></span>
                            <Button Disabled="true">@Localizer["BookNow"]</Button>
                        </div>  
                    }
                </div>
            }
            }
        </div>

     <div class="info-box @(_isMobileExpanded ? "mobile-expanded" : "")">
            
            <div class="mobile-sticky-header" @onclick="ToggleMobileExpand" style="@(!localHasOffers ? "width: 100%; justify-content: center;" : "")">
                <div class="mobile-price-group">
                    @if (localHasOffers)
                    {
                        <span class="label">@Localizer["From"]</span>
                        <span class="price">@localMinPrice zł</span>
                    }
                </div>

                <div class="mobile-action-btn">
                    @if (StartDate == null && EndDate == null)
                    {
                        <div @onclick="OpenSearchModal" @onclick:stopPropagation="true"> 
                            <Button Type="ButtonType.Tertiary" style="width: 100%;">
                                @Localizer["SelectDatesAndGuests"]
                            </Button>
                        </div>
                        
                        <div @onclick="ToggleMobileExpand" @onclick:stopPropagation="true" class="chevron @(_isMobileExpanded ? "rotated" : "")">
                            <svg viewBox="0 0 24 24"><path d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z"/></svg>
                        </div>
                    }
                    
                    @if (localHasOffers)
                    {
                        <Button Type="ButtonType.Tertiary"
                                style="width: 100%; padding: 0.5rem 1rem; font-size: 0.9rem;"
                                @onclick="SmartScrollAction">
                            @(_isAtSummary ? Localizer["SelectOffer"] : Localizer["Summary"])
                        </Button>
                    }

                    @if (localHasOffers)
                    {
                        <div @onclick="ToggleMobileExpand" @onclick:stopPropagation="true" class="chevron @(_isMobileExpanded ? "rotated" : "")">
                            <svg viewBox="0 0 24 24"><path d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z"/></svg>
                        </div>
                    }
                    
                    @if (!localHasOffers && StartDate != null && EndDate != null)
                    {
                        <span @onclick="ToggleMobileExpand" @onclick:stopPropagation="true">@Localizer["ClickToCheckDetails"]</span>
                    }

                </div>
            </div>

            <div class="info-box-content">
                <div class="reservation-info">
                    @if (localHasOffers && !_isOfferLoading)
                    {
                        <div class="reservation-header desktop-only">
                            <div class="header-price">
                                <span class="price-value">@Localizer["From"] @localMinPrice zł</span>
                            </div>
                        </div>
                    }

                    <div class="reservation-body">
                         <div class="info-row">
                            <div class="info-icon">
                                <svg viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 002 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z"/></svg>
                            </div>
                            <div class="info-content">
                                <span class="info-title">@Localizer["SelectedDates"]</span>
                                @if (StartDate != null && EndDate != null)
                                {
                                    <span class="info-text">@StartDate – @EndDate</span>
                                }
                                else
                                {
                                    <span class="info-text">@Localizer["NoDatesSelected"]</span>
                                }
                            </div>
                        </div>

                        <div class="info-row">
                            <div class="info-icon">
                                <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
                            </div>
                            <div class="info-content">
                                <span class="info-title">@Localizer["NumberOfGuests"]</span>
                                @if (StartDate != null && EndDate != null)
                                {
                                    <span class="info-text">@Adults @Localizer["Adults"], @(Children != null ? Children : 0) @Localizer["Children"]</span>
                                }
                                else
                                {
                                    <span class="info-text">@Localizer["NoGuestsSelected"]</span>
                                }
                            </div>
                        </div>
                        
                        <div class="info-row">
                            <div class="info-icon">
                                <svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
                            </div>
                            <div class="info-content">
                                <small style="font-weight: bold">@Localizer["CheckInTimeFormat"]</small>
                                <small style="font-weight: bold">@Localizer["CheckOutTimeFormat"]</small>
                            </div>
                        </div>
                        
                        @if (_isOfferLoading)
                        {
                            <div style="width: 100%; text-align: center; padding: 1rem; color: #666;">
                                <b>@Localizer["Loading"]...</b>
                            </div>
                        }
                        else if (localHasOffers)
                        {
                            <div class="desktop-only" style="margin-top: 1rem; width: 100%;" @onclick="SmartScrollAction"> 
                                <Button style="width: 100%;">
                                    @(_isAtSummary ? Localizer["SelectOffer"] : Localizer["Summary"]) 
                                </Button>
                            </div>
                        }
                        else if (StartDate != null && EndDate != null)
                        {
                           <div class="no-offers-wrapper">
                                <div class="alert-box warning">
                                    <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                                    <span>@Localizer["NoOffersAvailable"]</span>
                                </div>
                                
                                @if (_suggestionDates?.StartDate != null && _suggestionDates?.EndDate != null)
                                {
                                    <div @onclick="GoToSuggestionDates" class="suggest-offer-card">
                                        <div class="suggest-icon">
                                            <svg viewBox="0 0 24 24"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19a2 2 0 002 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/></svg>
                                        </div>
                                        <div class="suggest-content">
                                            <span class="suggest-title">@Localizer["SuggestedDate"]</span>
                                            <span class="suggest-dates">@Localizer["From"] @_suggestionDates?.StartDate @Localizer["To"] @_suggestionDates?.EndDate</span>
                                        </div>
                                        <div class="suggest-action">
                                            <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                                        </div>
                                    </div>  
                                }
                            </div>
                        }
                        else if (StartDate == null && EndDate == null)
                        {
                            <div class="desktop-only" style="margin-top: 1rem; width: 100%;" @onclick="OpenSearchModal"> 
                                <Button style="width: 100%;">
                                    Wybierz datę i liczbę gości
                                </Button>
                            </div>
                        }
                    </div>
                </div>

                @* DODANA MAPA DLA WIDOKU MOBILNEGO - Klasa mobile-only-map *@
                <div class="map-card-wrapper mobile-only-map" style="margin-top: 1rem;">
                    @* <div class="map-top-section"> *@
                    @* <ApartmentMap *@
                    @* Id="apartmentMap-mobile" *@
                    @* Latitude="@_apartment?.ObjectLocation?.LocalizationItem?.GeoLocationLat" *@
                    @* Longitude="@_apartment?.ObjectLocation?.LocalizationItem?.GeoLocationLng" *@
                    @* ApartmentAddress="@_apartment?.ObjectLocation?.Address" *@
                    @* />    *@
                    @* </div> *@
    
                    <div class="map-bottom-section">
                        <div class="map-address-row">
                            <div class="map-pin-icon">
                                <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                            </div>
                            <div class="map-address-details">
                                <span class="map-street-name">@_apartment?.ObjectLocation?.LocalizationItem?.Street</span>
                                <span class="map-city-name">@_apartment?.ObjectLocation?.LocalizationItem?.ZipCode @_apartment?.ObjectLocation?.LocalizationItem?.City, Polska</span>
                            </div>
                        </div>
    
                        <div class="map-action-row">
                             <button class="map-secondary-btn" 
                                    @onclick="OpenModal"
                                    @onclick:stopPropagation="true">
                                <svg viewBox="0 0 24 24"><path d="M20.5 3l-.16.03L15 5.1 9 3 3.36 4.9c-.21.07-.36.25-.36.48V20.5c0 .28.22.5.5.5l.16-.03L9 18.9l6 2.1 5.64-1.9c.21-.07.36-.25.36-.48V3.5c0-.28-.22-.5-.5-.5zM15 19l-6-2.11V5l6 2.11V19z"/></svg>
                                @Localizer["SeeMore"]
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            @* MAPA DLA WIDOKU DESKTOPOWEGO (bez zmian) - Klasa desktop-only-map *@
            <div class="map-card-wrapper desktop-only-map">
                <div class="map-top-section">
                    <ApartmentMap
                        Id="apartmentMap-desktop"
                        Latitude="@_apartment?.ObjectLocation?.LocalizationItem?.GeoLocationLat"
                        Longitude="@_apartment?.ObjectLocation?.LocalizationItem?.GeoLocationLng"
                        ApartmentAddress="@_apartment?.ObjectLocation?.Address"
                    />   
                </div>
                <div class="map-bottom-section">
                     <div class="map-address-row">
                        <div class="map-pin-icon">
                            <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                        </div>
                        <div class="map-address-details">
                            <span class="map-street-name">@_apartment?.ObjectLocation?.LocalizationItem?.Street</span>
                            <span class="map-city-name">@_apartment?.ObjectLocation?.LocalizationItem?.ZipCode @_apartment?.ObjectLocation?.LocalizationItem?.City, Polska</span>
                        </div>
                    </div>

                    <div class="map-action-row">
                        <button class="map-secondary-btn" 
                                @onclick="OpenModal"
                                @onclick:stopPropagation="true">
                            <svg viewBox="0 0 24 24"><path d="M20.5 3l-.16.03L15 5.1 9 3 3.36 4.9c-.21.07-.36.25-.36.48V20.5c0 .28.22.5.5.5l.16-.03L9 18.9l6 2.1 5.64-1.9c.21-.07.36-.25.36-.48V3.5c0-.28-.22-.5-.5-.5zM15 19l-6-2.11V5l6 2.11V19z"/></svg>
                            @Localizer["SeeMore"]
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
    
    <div style="margin-top: 2rem;"></div>
    
    <MapPopup
        @bind-IsModalOpen="_isModalOpen"
        Apartment="_apartment"
        StartDate="@StartDate"
        EndDate="@EndDate"
        Adults="@Adults"
        Children="@Children"
        />

    @* MODAL WYSZUKIWANIA *@
    @if (_isSearchModalOpen)
    {
        <div class="search-modal-overlay" @onclick="CloseSearchModal">
            <div class="search-modal-content" @onclick:stopPropagation="true">
                <div class="search-modal-header">
                    <h3>@Localizer["SelectDatesAndGuests"]</h3>
                    <button class="close-modal-btn" @onclick="CloseSearchModal">&times;</button>
                </div>
                <div class="search-modal-body">
                    <SearchBar 
                        OnSearch="async (query) => { await HandleSearch(query); CloseSearchModal(); }" />
                </div>
            </div>
        </div>
    }
</div>

<style>
    .search-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
