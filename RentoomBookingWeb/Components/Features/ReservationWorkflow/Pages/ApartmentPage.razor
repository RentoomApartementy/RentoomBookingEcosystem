@page "/apartamenty/{id:int}/{slug}"
@page "/apartamenty/{id:int}/{slug}/{startDate?}/{endDate?}/{adults?}/{children?}"
@using System.Globalization
@using RentoomBooking.SharedClasses.Models.Database.EFEntitites
@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.SharedClasses.Models.IdoBooking.Public
@using RentoomBooking.SharedClasses.Models.ReservationWorkflow
@using RentoomBooking.SharedClasses.Models.Upsell
@using RentoomBooking.SharedClasses.Services.IdoBooking
@using RentoomBooking.SharedClasses.Services.ReservationWorkflow
@using RentoomBooking.SharedClasses.Services.Upsell
@using RentoomBookingWeb.Components.Features.Apartments.Components
@inject IApartmentsService ApartmentsService
@inject IIdoApartmentService IdoApartmentService
@inject NavigationManager Navigation
@inject IIdoOfferService OfferService
@inject IJSRuntime JSRuntime
@using RentoomBookingWeb.Models
@using RentoomBookingWeb.Services
@inject IAvailabilityFinderService AvailabilityFinder
@using RentoomBookingWeb.Helpers
@using System.Text.RegularExpressions
@inject NavigationManager NavManager
@using Microsoft.Extensions.Localization
@using RentoomBookingWeb.Components.Enums
@using RentoomBookingWeb.Components.Features.ReservationWorkflow.Components
@inject IStringLocalizer<RentoomBookingWeb.Apartment> Localizer;
@inject IStringLocalizer<PurchasedUpsellPage> UpsellLocalizer;
@inject IReservationWorkflowService ReservationWorkflowService
@inject IUpsellCatalogService UpsellCatalogService
@inject MediaCacheService MediaCache

<PageTitle>@GetSeoTitle()</PageTitle>

<HeadContent>
    <meta name="description" content="@GetSeoDescription()" />
    <meta name="keywords" content="apartament toruń, nocleg toruń, rentoom, wynajem krótkoterminowy, @_apartment?.Name" />
    <link rel="canonical" href="@GetCanonicalUrl()" />

    <meta property="og:title" content="@GetSeoTitle()" />
    <meta property="og:description" content="@GetSeoDescription()" />
    <meta property="og:image" content="@GetSeoImage()" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@GetCanonicalUrl()" />
    <meta property="og:locale" content="pl_PL" />
</HeadContent>

<div class="apartment-container">
    <HeaderSection
        ImagePath="@_objectMediums?.FirstOrDefault()?.Url"
        Title="@_apartment?.Name"
        Height="230px"
        IsShadow="true"
    />   
    
    <div class="main-wrapper">
        
        <div class="left-container">
            <div class="apartment-wrapper @(_isExpanded ? "expanded" : "collapsed")">
                <div class="apartment-text-wrapper">
                    <div class="">
                        <h2>@_apartment?.Name</h2>
                        <span itemprop="streetAddress">@_apartment?.ObjectLocation?.LocalizationItem?.Street</span>,
                        <span itemprop="postalCode">@_apartment?.ObjectLocation?.LocalizationItem?.ZipCode</span>
                        <span itemprop="addressLocality">@_apartment?.ObjectLocation?.LocalizationItem?.City</span>
                    </div>
                
                    <ul class="apartment-details">
                        <li>
                            <img src="assets/svgs/users.svg" alt="Liczba osób" class="icon"/>
                            <span itemprop="occupancy">@_apartment?.MinCapacity - @_apartment?.Capacity</span>
                        </li>
                        <li>
                            <img src="assets/svgs/bed.svg" alt="Liczba łóżek" class="icon"/>
                            @_bedsCount
                        </li>
                        <li>
                            <img src="assets/svgs/bath.svg" alt="Liczba łazienek" class="icon"/>
                            1
                        </li>
                        <li>
                            <img src="assets/svgs/m2.svg" alt="Powierzchnia apartamentu" class="icon"/>
                            <span itemprop="floorSize">@_apartment?.Area m²</span>
                        </li>
                    </ul>
                </div>

                <div style="margin-top: 1rem;"></div>
                
                <Images ImagesList="_objectMediums"></Images>

                <article class="description-wrapper">
                    @if (!string.IsNullOrEmpty(_objectDescription?.ShortDescription))
                    {
                        <h4>@_objectDescription.ShortDescription</h4>
                    }

                    @if (!string.IsNullOrEmpty(_objectDescription?.LongDescription))
                    {
                        <div class="long-description" itemprop="description">
                            @((MarkupString)_objectDescription.LongDescription)
                        </div>
                    }
                </article>

                <div class="amenities-wrapper">
                    @if (_amenities != null)
                    {
                        @foreach (var amenity in _amenities)
                        {
                            <div class="amenity">
                                @amenity.Name
                            </div>
                        }
                    }
                </div>

                @if (!_isExpanded)
                {
                    <div class="wrapper-shadow"></div>
                }
            </div>

            <span class="read-more-btn" @onclick="ToggleExpand">
                @(_isExpanded ? @Localizer["HideDetails"] : @Localizer["ShowAll"])
            </span>
        </div>

        <div class="info-box">
            <div class="reservation-info">
                <div>
                    <h5>@Localizer["SelectedDates"]</h5>
                    @if (StartDate != null && EndDate != null)
                    {
                        <p>@Localizer["From"] @StartDate @Localizer["To"] @EndDate</p>
                    }
                    else
                    {
                        <p>@Localizer["NoDatesSelected"]</p>
                    }
                        
                    <h5>@Localizer["NumberOfGuests"]</h5>
                    @if (StartDate != null && EndDate != null)
                    {
                        <p>@Localizer["Adults"]: @Adults, @Localizer["Children"]: @(Children != null ? Children :  0)</p>
                    }
                    else
                    {
                        <p>@Localizer["NoGuestsSelected"]</p>
                    }
                        
                    @if (_isOfferLoading)
                    {
                        <div class="offer-price-wrapper">
                            <div style="width: 100%; text-align: center; padding: 1rem; color: #666;">
                                <b>@Localizer["Loading"]...</b>
                            </div>
                        </div>
                    }
                    else if (_offersResponse?.Result?.PricingOffers?.Count != null && _offersResponse?.Result?.PricingOffers?.Count > 0)
                    {
                        <div class="offer-price-wrapper">
                            @{
                                var pricingData = _offersResponse?.Result?.PricingOffers?.FirstOrDefault();

                                var refundableOffer = pricingData?.Offers?.FirstOrDefault(o => o.OfferType == "refundable");
                                var nonRefundableOffer = pricingData?.Offers?.FirstOrDefault(o => o.OfferType == "nonrefundable");
                            }

                            @if (refundableOffer != null)
                            {
                                <div class="offer-price">
                                    <span>@Localizer["RefundableOffer"]: <b>@refundableOffer.Price zł</b></span>
                                </div>   
                            }

                            @if (nonRefundableOffer != null)
                            {
                                <div class="offer-price">
                                    <span>@Localizer["Non-refundableOffer"]: <b>@nonRefundableOffer.Price zł</b></span>
                                </div>
                            }

                            <div style="margin-top: .2rem"></div>
                            <div style="width: 100%;" @onclick="ScrollToReservation">
                                <Button style="width: 100%;">@Localizer["BookNow"]</Button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div >
                            @Localizer["NoOffersAvailable"]
                            @if (_suggestionDates?.StartDate != null && _suggestionDates?.EndDate != null)
                            {
                                <div @onclick="GoToSuggestionDates" class="suggest-offer">
                                    <span>@Localizer["SuggestedDate"]</span>
                                    @* Michal-->: ponizej dodac czas checkintime checkouttime \/ *@
                                    <b>@Localizer["From"] @_suggestionDates?.StartDate @Localizer["To"] @_suggestionDates?.EndDate</b> 
                                </div>  
                            }
                            @if (_suggestionLoading)
                            {
                                <div class="suggest-offer">
                                    <span>@Localizer["SuggestedDate"]</span>
                                    <b>@Localizer["SuggestedDateLoading"]</b>
                                </div>  
                            }
                        </div>
                    }
                </div>
            </div>
            
            <div class="map" @onclick="OpenModal">
                <ApartmentMap
                    Latitude="@_apartment?.ObjectLocation?.LocalizationItem?.GeoLocationLat"
                    Longitude="@_apartment?.ObjectLocation?.LocalizationItem?.GeoLocationLng"
                    ApartmentAddress="@_apartment?.ObjectLocation?.Address"
                    />   
            </div>
        </div>

    </div>
    
    <div style="margin-top: 2rem;"></div>
    
    <hr style="width: 90%;"/>
    
    <h3 class="header-text text-lg">@Localizer["Summary"]</h3>
    
    <SearchBar
        StartDate="@StartDate"
        EndDate="@EndDate"
        Adults="@Adults"
        Children="@Children"
        IsRoom="false"
        OnSearch="@(async query => await HandleSearch(query))"
    ></SearchBar>
    
    @if (_apartment?.Addons != null && _apartment.Addons.Any(x => x.Optional == false))
    {
        <h3 id="confirm-reservation" class="header-text" style="margin-bottom: -1rem;">@Localizer["MandatoryOptions"]</h3>
        
        <div class="addon-list-container">
            @foreach (var addon in _apartment.Addons.Where(x => x.Optional == false))
            {
                if (_definedAddons != null)
                {
                    var fa = _definedAddons.FirstOrDefault(a => a.IdoBookingId == addon.Id);
                    var fadesc = fa?.AddonDefinition.Details.FirstOrDefault(a => a.Lang == "PL");
                    var paymentType = fadesc?.PaymentTypeShortDescription;

                    @if (fa != null)
                    {
                        <div class="addon-item">
                            <div class="addon-label" @onclick="@(() => ToggleAddonWrapper(addon.Id, addon.Optional))">
                                <div class="addon-info-col">
                                    <span class="addon-name">@fadesc?.Name</span>
                                    <small class="addon-subtext">(@fadesc?.PaymentTypeShortDescription)</small>
                                </div>

                                <div class="addon-quantity-col empty" @onclick:stopPropagation="true" @onclick:preventDefault="true">
                                </div>

                                <div class="price-box">
                                    <b class="addon-price">+@String.Format("{0:#.00}", fa.PriceGross) zł</b>
                                    @* <input type="checkbox"  *@
                                    @*        class="addon-checkbox"  *@
                                    @*        checked="@(IsAddonSelected(addon.Id))" *@
                                    @*        disabled="true" *@
                                    @*        readonly /> *@
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="addon-item">
                            <div class="addon-label">
                                <span class="addon-name-empty">Brak opisu dodatku</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="skeleton-row">
                        <div style="flex: 1;">
                            <span class="skeleton-box" style="width: 50%; height: 16px; margin-bottom: 6px;"></span>
                            <span class="skeleton-box" style="width: 30%; height: 12px;"></span>
                        </div>
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <span class="skeleton-box" style="width: 60px; height: 16px;"></span>
                            <span class="skeleton-box" style="width: 20px; height: 20px; border-radius: 4px;"></span>
                        </div>
                    </div>
                }
            }
        </div>
    }

    @if (_apartment?.Addons != null && _apartment.Addons.Any(x => x.Optional != false))
    {
        <h3 class="header-text" style="margin-bottom: -1rem;">@Localizer["AdditionalOptions"]</h3>
        
        <div class="addon-list-container">
            @foreach (var addon in _apartment.Addons.Where(x => x.Optional != false))
            {
                if (_definedAddons != null)
                {
                    var fa = _definedAddons.FirstOrDefault(a => a.IdoBookingId == addon.Id);
                    var fadesc = fa?.AddonDefinition.Details.FirstOrDefault(a => a.Lang == "PL");
                    var paymentType = fadesc?.PaymentTypeShortDescription;

                    @if (fa != null)
                    {
                        <div class="addon-item">
                            <div class="addon-label" @onclick="@(() => ToggleAddonWrapper(addon.Id, addon.Optional))">
                                <div class="addon-info-col">
                                    <span class="addon-name">@fadesc?.Name</span>
                                    <small class="addon-subtext">(@fadesc?.PaymentTypeShortDescription)</small>
                                </div>

                                @* <div class="addon-quantity-col @((IsAddonSelected(addon.Id) && paymentType != null && paymentType.Contains("Za ilość", StringComparison.OrdinalIgnoreCase)) ? "" : "empty")"  *@
                                @*      @onclick:stopPropagation="true"  *@
                                @*      @onclick:preventDefault="true"> *@
                                @*      *@
                                @*     @if (IsAddonSelected(addon.Id) && paymentType != null && paymentType.Contains("Za ilość", StringComparison.OrdinalIgnoreCase)) *@
                                @*     { *@
                                @*         var currentQty = GetSelectedAddonQuantity(addon.Id); *@
                                @*         <div class="quantity-selector"> *@
                                @*             <button class="quantity-btn" @onclick="@(() => UpdateAddonQuantity(addon.Id, currentQty - 1))"> *@
                                @*                 <span>−</span> *@
                                @*             </button> *@
                                @*             <span class="quantity-value">@currentQty</span> *@
                                @*             <button class="quantity-btn" @onclick="@(() => UpdateAddonQuantity(addon.Id, currentQty + 1))"> *@
                                @*                 <span>+</span> *@
                                @*             </button> *@
                                @*         </div> *@
                                @*     } *@
                                @* </div> *@

                                <div class="price-box">
                                    <b class="addon-price">+@String.Format("{0:#.00}", fa.PriceGross) zł</b>
                                    <input type="checkbox" 
                                           class="addon-checkbox" 
                                           checked="@(IsAddonSelected(addon.Id))"
                                           disabled="@(IsAddonMandatory(addon.Optional))"
                                           readonly />
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="addon-item">
                            <div class="addon-label">
                                <span class="addon-name-empty">Brak opisu dodatku</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="skeleton-row">
                        <div style="flex: 1;">
                            <span class="skeleton-box" style="width: 50%; height: 16px; margin-bottom: 6px;"></span>
                            <span class="skeleton-box" style="width: 30%; height: 12px;"></span>
                        </div>
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <span class="skeleton-box" style="width: 60px; height: 16px;"></span>
                            <span class="skeleton-box" style="width: 20px; height: 20px; border-radius: 4px;"></span>
                        </div>
                    </div>
                }
            }
        </div>
    }
    
    
     @if (_reservationPricingContext is not null)
    {
        <UpsellList AvailableUpsellsList="_availableUpsells"
                    ReservationContext="_reservationPricingContext"
                    OnSelectionChanged="HandleUpsellSelectionChanged"
                    Texts="UpsellTexts"/>
    }

    
    @if (TotalAddonsPrice > 0)
    {
        <div class="additional-price">
            +@((TotalAddonsPrice + TotalUpsellsPrice).ToString("N2")) zł
        </div>
    }
    
    @if (_isOfferLoading)
    {
        <div class="summary-offer-price-wrapper" style="justify-content: center; padding: 2rem;">
            <b>@Localizer["Loading"]...</b>
        </div>
    }
    else if (_offersResponse?.Result?.PricingOffers?.Count != null && _offersResponse?.Result?.PricingOffers?.Count > 0)
    {
        <div class="summary-offer-price-wrapper">
            @{
                var pricingData = _offersResponse?.Result?.PricingOffers?.FirstOrDefault();
                var refundableOffer = pricingData?.Offers?.FirstOrDefault(o => o.OfferType == "refundable");
                var nonRefundableOffer = pricingData?.Offers?.FirstOrDefault(o => o.OfferType == "nonrefundable");
            }
            
            @if (nonRefundableOffer != null)
            {
                <div class="summary-offer-price">
                    <b>@Localizer["Non-refundableOffer"]</b>
                    <small>@Localizer["NonRefundableText"]</small>
                    <div class="summary-offer-price-button">
                        <span class="summary-offer-price-button-price"><b>@(nonRefundableOffer.Price + (decimal)TotalAddonsPrice + TotalUpsellsPrice) @_reservationPricingContext?.Currency</b></span>
                        <Button @onclick="@(() => GoToPayment(OfferTypeNonrefundable))">@Localizer["BookNow"]</Button>
                    </div>
                </div>  
            }
            
            @if (refundableOffer != null)
            {
                <div class="summary-offer-price refundable">
                    <b>@Localizer["RefundableOffer"]</b>
                    <small>@Localizer["RefundableOfferText"]</small>
                    <div class="summary-offer-price-button">
                        <span class="summary-offer-price-button-price"><b>@(refundableOffer.Price + (decimal)TotalAddonsPrice + TotalUpsellsPrice) @_reservationPricingContext?.Currency</b></span>
                        <Button Type="ButtonType.Tertiary" @onclick="@(() => GoToPayment(OfferTypeRefundable))">@Localizer["BookNow"]</Button>
                    </div>
                </div>   
            }
        </div>
    }
    else
    {
        <div class="summary-offer-price-wrapper">
            @if (_suggestionDates?.StartDate != null && _suggestionDates?.EndDate != null)
            {
                <div class="summary-offer-price">
                    <b>@Localizer["NoOffersAvailable"]</b>
                    <span>@Localizer["SuggestedDate"]: <b>@_suggestionDates?.StartDate - @_suggestionDates?.EndDate</b></span>
                    <Button @onclick="GoToSuggestionDates">@Localizer["BookNow"]</Button>
                </div>  
            }
            @if (_suggestionLoading)
            {
                <div class="summary-offer-price">
                    <span>@Localizer["SuggestedDate"]: <b>@Localizer["SuggestedDateLoading"]</b></span>
                    <Button Disabled="true">@Localizer["BookNow"]</Button>
                </div>  
            }
        </div>
    }
    
    <MapPopup
        @bind-IsModalOpen="_isModalOpen"
        Apartment="_apartment"
        StartDate="@StartDate"
        EndDate="@EndDate"
        Adults="@Adults"
        Children="@Children"
        />
</div>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public string? Slug { get; set; }
    [Parameter] public string? StartDate { get; set; }
    [Parameter] public string? EndDate { get; set; }
    [Parameter] public string? Adults { get; set; }
    [Parameter] public string? Children { get; set; }

    private ApartmentObject? _apartment;
    private List<ObjectMedium>? _objectMediums = null;
    private List<ObjectAmenity>? _amenities = null;
    private int? _bedsCount = null;
    private bool _isExpanded = false;
    private PricingOffersResponse? _offersResponse;

    private bool _isOfferLoading = true;

    private AvailableTerm? _suggestionDates = null;
    private bool _suggestionLoading = false;

    private List<DefinedAddonEntity>? _definedAddons = null;
    private List<SelectedAddonDto> _selectedAddons = new();

    private IReadOnlyList<UpsellTileDto> _availableUpsells = Array.Empty<UpsellTileDto>();
    private ReservationPricingContext? _reservationPricingContext; // uztywany do prawidlowego liczenia upselli w UpsellList 
    private List<SelectedUpsellDto> _selectedUpsells = new();
    private StartReservationRequest? _draftStartReservationRequest;

    public UpsellTextConfig UpsellTexts { get; set; } = new();

    private bool _isModalOpen = false;
    
    private decimal TotalAddonsPrice 
    {
        get
        {
            decimal total = 0;
            if (_reservationPricingContext is null || _selectedAddons == null || _definedAddons == null) return 0m;


            foreach (var selected in _selectedAddons)
            {
                var def = _definedAddons.FirstOrDefault(d => d.IdoBookingId == selected.AddonId);
                var details = def?.AddonDefinition?.Details?.FirstOrDefault(d => d.Lang == "PL");

                if (details == null) continue;

                total += AddonPricingCalculator.CalculateTotal(
                                                                def?.PaymentType, 
                                                                (decimal)selected.Price, 
                                                                _reservationPricingContext.Nights,
                                                                _reservationPricingContext.TotalGuests,
                                                                quantity: 1);
            }
            return total;
        }

        /*get
        {
            float total = 0;
            if (_selectedAddons == null || _definedAddons == null) return 0;

            foreach (var selected in _selectedAddons)
            {
                var def = _definedAddons.FirstOrDefault(d => d.IdoBookingId == selected.AddonId);
                var details = def?.AddonDefinition?.Details?.FirstOrDefault(d => d.Lang == "PL");

                if (details == null) continue;

                var type = details.PaymentTypeShortDescription?.ToLower().Trim() ?? "";

                if (type.Contains("za cały pobyt")) total += selected.Price;
                else if (type.Contains("za osobę za każdą dobę") || type.Contains("za osobę za dobę")) total += selected.Price * selected.Persons * selected.Nights;
                else if (type.Contains("za dobę")) total += selected.Price * selected.Nights;
                else total += selected.Price * selected.Quantity;
            }
            return total;
        }*/
    }

    private decimal TotalUpsellsPrice
    {
        get
        {
            if (_reservationPricingContext is null || _selectedUpsells.Count == 0 || _availableUpsells.Count == 0)
            {
                return 0m;
            }

            decimal total = 0m;
            foreach (var selected in _selectedUpsells)
            {
                var tile = _availableUpsells.FirstOrDefault(item => item.PartnerServiceId == selected.PartnerServiceId);
                if (tile is null)
                {
                    continue;
                }

                var quantity = Math.Max(1, selected.Quantity);
                total += UpsellPricingCalculator.CalculateTotal( 
                                                                tile.PricingModel,
                                                                tile.Price,
                                                                _reservationPricingContext.Nights,
                                                                _reservationPricingContext.TotalGuests,
                                                                quantity);
            }

            return total;
        }
    }

    private const string OfferTypeRefundable = "refundable";
    private const string OfferTypeNonrefundable = "nonrefundable";

    private static Dictionary<string, string> _languageMap = new Dictionary<string, string>
    {
        { "pl-PL", "pol" },
        { "en-US", "eng" }
    };

    private string CurrentLanguage => _languageMap?.GetValueOrDefault(
        CultureInfo.CurrentUICulture.Name, 
        CultureInfo.CurrentUICulture.Name
    ) ?? CultureInfo.CurrentUICulture.Name;

    private string GetSeoTitle()
    {
        if (_apartment == null) return "Szczegóły apartamentu - Rentoom";
        return $"{_apartment.Name} - Rentoom";
    }

    private string GetSeoDescription()
    {
        if (_objectDescription != null && !string.IsNullOrEmpty(_objectDescription.ShortDescription))
        {
            return Regex.Replace(_objectDescription.ShortDescription, "<.*?>", String.Empty).Trim();
        }
        
        if (_apartment != null)
        {
            return $"Zarezerwuj {_apartment.Name} w Rentoom. Świetna lokalizacja, {_bedsCount} pokoje, wysoki standard.";
        }
        
        return "Sprawdź szczegóły apartamentu i zarezerwuj pobyt w Rentoom.";
    }

    private string GetSeoImage()
    {
        var img = _objectMediums?.FirstOrDefault()?.Url;
        if (!string.IsNullOrEmpty(img))
        {
            return img;
        }
        return $"{NavManager.BaseUri}assets/images/header-bg-contact.jpeg";
    }

    private string GetCanonicalUrl()
    {
        return $"{NavManager.BaseUri}apartamenty/{Id}/{Slug}";
    }

    protected override async Task OnInitializedAsync()
    {
        _apartment = await ApartmentsService.GetApartmentByIdAsync(Id);
        await GetObjectMedia();
        
        if (_apartment != null)
        {
            await GetObjectDescription(_apartment.Id, CurrentLanguage);
            _amenities = await GetAmenities(_apartment.Id);
            _bedsCount = _apartment?.BedsConfiguration?.Sum(item => item.Count);
            
            _definedAddons = await ApartmentsService.GetDefinedAddonsAsync();
            InitializeMandatoryAddons();

            UpdateReservationPricingContext();
            await LoadUpsellsAsync();

        }
        
        await GetOffer();
        
        UpsellTexts = new UpsellTextConfig()
        {
            Title = UpsellLocalizer["ListTitle"],
            SubTitle = UpsellLocalizer["ListSubtitle"],
            BadgeInfo = UpsellLocalizer["BadgeInfo"],
            NightsText = UpsellLocalizer["Nights"],
            GuestsText = UpsellLocalizer["Guests"],
            DeleteText = UpsellLocalizer["Delete"],
            AddText = UpsellLocalizer["Add"],
            DescriptionText = UpsellLocalizer["Description"],
            TermsTitleText = UpsellLocalizer["TermsTitle"],
            TermsDescriptionText = UpsellLocalizer["TermsDescription"],
            PricingPerApartmentPerDayText = UpsellLocalizer["PricingPerApartmentPerDay"],
            PricingOneTimeText = UpsellLocalizer["PricingOneTime"],
            PricingPerPersonPerDayText = UpsellLocalizer["PricingPerPersonPerDay"],
            PriceLabel = UpsellLocalizer["Price"],
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
    }

    private async Task GetOffer()
    {
        _isOfferLoading = true;
        _suggestionDates = null;
        _suggestionLoading = false;
        
        StateHasChanged(); 

        try 
        {
            _offersResponse = await OfferService.GetPricingOffersAsync(CurrentRequest);
        }
        finally
        {
            _isOfferLoading = false;
        }
        
        bool hasOffers = _offersResponse?.Result?.PricingOffers != null && 
                         _offersResponse.Result.PricingOffers.Any();

        if (!hasOffers && _isOfferLoading)
        {
            _ = Task.Run(async () => await LoadSuggestionInBackground());
        }
    }

    private async Task LoadSuggestionInBackground()
    {
        _suggestionLoading = true;
        await InvokeAsync(StateHasChanged);

        try 
        {
            var aptId = _apartment?.Id ?? 0;
            var sDate = StartDate;
            var eDate = EndDate;
            var aCount = int.TryParse(Adults, out var a) ? a : 2;
            var cCount = int.TryParse(Children, out var c) ? c : 1;

            if (aptId == 0) return;

            var result = await AvailabilityFinder.FindNextAvailableTermAsync(
                aptId, 
                sDate, 
                eDate, 
                aCount, 
                cCount
            );

            _suggestionDates = result;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading suggestions: {ex.Message}");
        }
        finally
        {
            _suggestionLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }
    
    private void InitializeMandatoryAddons()
    {
        if (_apartment?.Addons == null || _definedAddons == null) return;

        foreach (var addon in _apartment.Addons)
        {
            if (addon.Id.HasValue && (addon.Optional == false))
            {
                if (!_selectedAddons.Any(x => x.AddonId == addon.Id.Value))
                {
                    AddAddonToList(addon.Id.Value);
                }
            }
        }
    }

    private void AddAddonToList(int addonId)
    {
        var definition = _definedAddons?.FirstOrDefault(d => d.IdoBookingId == addonId);
        
        int nights = 1;
        if (TryParseDate(StartDate, out var s) && TryParseDate(EndDate, out var e))
        {
            var diff = (e.ToDateTime(TimeOnly.MinValue) - s.ToDateTime(TimeOnly.MinValue)).Days;
            if (diff > 0) nights = diff;
        }
        
        int persons = (int.TryParse(Adults, out var a) ? a : 1) + (int.TryParse(Children, out var c) ? c : 0);

        var newDto = new SelectedAddonDto
        {
            AddonId = addonId,
            Quantity = 1, 
            Price = definition != null ? (float)definition.PriceGross : 0f, 
            Vat = 8f,
            Persons = persons, 
            Nights = nights,
            PaymentType = definition?.PaymentType
        };

        _selectedAddons.Add(newDto);
    }

    private bool IsAddonSelected(int? addonId)
    {
        if (!addonId.HasValue) return false;
        return _selectedAddons.Any(a => a.AddonId == addonId.Value);
    }
    
    private int GetSelectedAddonQuantity(int? addonId)
    {
        if (!addonId.HasValue) return 1;
        var item = _selectedAddons.FirstOrDefault(x => x.AddonId == addonId.Value);
        return item?.Quantity ?? 1;
    }

    private void UpdateAddonQuantity(int? addonId, object? value)
    {
        if (!addonId.HasValue || value == null) return;
        
        if (int.TryParse(value.ToString(), out int quantity))
        {
            var item = _selectedAddons.FirstOrDefault(x => x.AddonId == addonId.Value);

            if (quantity > 0)
            {
                if (item != null)
                {
                    item.Quantity = quantity;
                }
            }
            else
            {
                if (item != null)
                {
                    _selectedAddons.Remove(item);
                }
            }
            StateHasChanged();
        }
    }

    private bool IsAddonMandatory(bool? isOptional)
    {
        return isOptional == false;
    }

    private void ToggleAddonWrapper(int? addonId, bool? optional)
    {
        if (IsAddonMandatory(optional)) return;
        ToggleAddon(addonId, !IsAddonSelected(addonId));
    }

    private void ToggleAddon(int? addonId, bool isChecked)
    {
        if (!addonId.HasValue) return;

        if (isChecked)
        {
            if (!_selectedAddons.Any(x => x.AddonId == addonId.Value))
            {
                AddAddonToList(addonId.Value);
            }
        }
        else
        {
            var item = _selectedAddons.FirstOrDefault(x => x.AddonId == addonId.Value);
            if (item != null)
            {
                _selectedAddons.Remove(item);
            }
        }
    }
    
    private void ToggleExpand()
    {
        _isExpanded = !_isExpanded;
    }

