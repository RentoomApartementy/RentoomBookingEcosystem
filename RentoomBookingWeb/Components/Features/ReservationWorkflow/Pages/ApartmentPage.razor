@page "/apartamenty/{id:int}"
@page "/apartamenty/{id:int}/{startDate?}/{endDate?}/{adults?}/{children?}"
@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.SharedClasses.Services.IdoBooking
@using System.Globalization
@using RentoomBooking.SharedClasses.Models.IdoBooking.Public
@using RentoomBookingWeb.Components.Features.Apartments.Components
@inject IApartmentsService ApartmentsService
@inject IIdoApartmentService IdoApartmentService
@inject NavigationManager Navigation
@inject IIdoOfferService OfferService
@inject IJSRuntime JSRuntime
@using RentoomBookingWeb.Models
@using RentoomBookingWeb.Services
@inject IAvailabilityFinderService AvailabilityFinder
@using RentoomBookingWeb.Helpers
@using System.Text.RegularExpressions
@inject NavigationManager NavManager

<PageTitle>@GetSeoTitle()</PageTitle>
@inject IReservationWorkflowService ReservationWorkflowService

<HeadContent>
    <meta name="description" content="@GetSeoDescription()" />
    <meta name="keywords" content="apartament toruń, nocleg toruń, rentoom, wynajem krótkoterminowy, @_apartment?.Name" />
    <link rel="canonical" href="@GetCanonicalUrl()" />

    <meta property="og:title" content="@GetSeoTitle()" />
    <meta property="og:description" content="@GetSeoDescription()" />
    <meta property="og:image" content="@GetSeoImage()" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@GetCanonicalUrl()" />
    <meta property="og:locale" content="pl_PL" />
</HeadContent>

<div class="apartment-container">
    <HeaderSection
        ImagePath="@_objectMediums?.FirstOrDefault()?.Url"
        Title="@_apartment?.Name"
        Height="230px"
        IsShadow="true"
    />   
    
    <div class="main-wrapper">
        
        <div class="left-container">
            <div class="apartment-wrapper @(_isExpanded ? "expanded" : "collapsed")">
                <div class="apartment-text-wrapper">
                    <div class="">
                        <h2>@_apartment?.Name</h2>
                        <span itemprop="streetAddress">@_apartment?.ObjectLocation?.LocalizationItem?.Street</span>,
                        <span itemprop="postalCode">@_apartment?.ObjectLocation?.LocalizationItem?.ZipCode</span>
                        <span itemprop="addressLocality">@_apartment?.ObjectLocation?.LocalizationItem?.City</span>
                    </div>
                
                    <ul class="apartment-details">
                        <li>
                            <img src="assets/svgs/users.svg" alt="Liczba osób" class="icon"/>
                            <span itemprop="occupancy">@_apartment?.MinCapacity - @_apartment?.Capacity</span>
                        </li>
                        <li>
                            <img src="assets/svgs/bed.svg" alt="Liczba łóżek" class="icon"/>
                            @_bedsCount
                        </li>
                        <li>
                            <img src="assets/svgs/bath.svg" alt="Liczba łazienek" class="icon"/>
                            1
                        </li>
                        <li>
                            <img src="assets/svgs/m2.svg" alt="Powierzchnia apartamentu" class="icon"/>
                            <span itemprop="floorSize">@_apartment?.Area m²</span>
                        </li>
                    </ul>
                </div>

                <div style="margin-top: 1rem;"></div>
                
                <Images ImagesList="_objectMediums"></Images>

                <article class="description-wrapper">
                    @if (!string.IsNullOrEmpty(_objectDescription?.ShortDescription))
                    {
                        <h4>@_objectDescription.ShortDescription</h4>
                    }

                    @if (!string.IsNullOrEmpty(_objectDescription?.LongDescription))
                    {
                        <div class="long-description" itemprop="description">
                            @((MarkupString)_objectDescription.LongDescription)
                        </div>
                    }
                </article>

                <div class="amenities-wrapper">
                    @if (_amenities != null)
                    {
                        @foreach (var amenity in _amenities)
                        {
                            <div class="amenity">
                                @amenity.Name
                            </div>
                        }
                    }
                </div>

                @if (!_isExpanded)
                {
                    <div class="wrapper-shadow"></div>
                }
            </div>

            <span class="read-more-btn" @onclick="ToggleExpand">
                @(_isExpanded ? "Zwiń szczegóły" : "Pokaż całość")
            </span>
        </div>

        <div class="info-box">
            <div class="reservation-info">
                <div>
                    <h5>Wybrany termin</h5>
                    @if (StartDate != null && EndDate != null)
                    {
                        <p>Od @StartDate do @EndDate</p>
                    }
                    else
                    {
                        <p>brak wybranego terminu</p>
                    }
                        
                    <h5>Liczba osób</h5>
                    @if (StartDate != null && EndDate != null)
                    {
                        <p>Dorośli: @Adults, Dzieci: @(Children != null ? Children :  0)</p>
                    }
                    else
                    {
                        <p>brak wybranej liczby osób</p>
                    }
                        
                    @if (_offersResponse?.Result?.PricingOffers?.Count != null && _offersResponse?.Result?.PricingOffers?.Count > 0)
                    {
                        <div class="offer-price-wrapper">
                            <div class="offer-price">
                                <span>Oferta zwrotna: <b>@_offersResponse?.Result?.PricingOffers?[0].Offers?.Where(offer => offer.OfferType == "refundable")?.FirstOrDefault()?.Price zł</b></span>
                            </div>   
                            
                            <div class="offer-price">
                                <span>Oferta bezzwrotna: <b>@_offersResponse?.Result?.PricingOffers?[0].Offers?.Where(offer => offer.OfferType == "nonrefundable")?.FirstOrDefault()?.Price zł</b></span>
                            </div> 
                                
                            <div style="margin-top: .2rem"></div>
                            <div style="width: 100%;" @onclick="ScrollToReservation">
                                <Button style="width: 100%;">Zarezerwuj</Button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div >
                            brak oferty w wybranym terminie
                            @if (_suggestionDates?.StartDate != null && _suggestionDates?.EndDate != null)
                            {
                                <div @onclick="GoToSuggestionDates" class="suggest-offer">
                                    <span>Sugerowany termin</span>
                                    <b>Od @_suggestionDates?.StartDate do @_suggestionDates?.EndDate</b>
                                </div>  
                            }
                            @if (_suggestionLoading)
                            {
                                <div class="suggest-offer">
                                    <span>Sugerowany termin</span>
                                    <b>Sprawdzanie dostępności...</b>
                                </div>  
                            }
                        </div>
                    }
                </div>
            </div>
            
            <div class="map">
                <ApartmentMap
                    Latitude="@_apartment?.ObjectLocation?.LocalizationItem?.GeoLocationLat"
                    Longitude="@_apartment?.ObjectLocation?.LocalizationItem?.GeoLocationLng"
                    ApartmentAddress="@_apartment?.ObjectLocation?.Address"
                />
            </div>
        </div>

    </div>
    
    <div style="margin-top: 2rem;"></div>
    
    <hr style="width: 90%;"/>
    
    <h3 class="header-text">Podsumowanie</h3>
    
    <SearchBar
        StartDate="@StartDate"
        EndDate="@EndDate"
        Adults="@Adults"
        Children="@Children"
        IsRoom="false"
        OnSearch="@(async query => await HandleSearch(query))"
    ></SearchBar>
    
    <h3 id="confirm-reservation" class="header-text">Dodatkowe opcje</h3>
    <div class="addon-list-container">
        @if (_apartment?.Addons != null)
        {
            @foreach (var addon in _apartment.Addons)
            {
                <div class="addon-item">
                    <label class="addon-label">
                        <input type="checkbox" class="addon-checkbox" />
                        <span class="addon-name">@addon.Name</span>
                    </label>
                </div>
            }
        }
    </div>
    
    @if (_offersResponse?.Result?.PricingOffers?.Count != null && _offersResponse?.Result?.PricingOffers?.Count > 0)
    {
        <div class="summary-offer-price-wrapper">
            <div class="summary-offer-price">
                <span>Oferta zwrotna: <b>@_offersResponse?.Result?.PricingOffers?[0].Offers?.Where(offer => offer.OfferType == "refundable")?.FirstOrDefault()?.Price zł</b></span>
                <Button @onclick="GoToPayment">Zarezerwuj</Button>
            </div>   
                            
            <div class="summary-offer-price">
                <span>Oferta bezzwrotna: <b>@_offersResponse?.Result?.PricingOffers?[0].Offers?.Where(offer => offer.OfferType == "nonrefundable")?.FirstOrDefault()?.Price zł</b></span>
                <Button @onclick="GoToPayment">Zarezerwuj</Button>
            </div> 
        </div>
    }
    else
    {
        <div class="summary-offer-price-wrapper">
            Brak oferty w wybranym terminie
            @if (_suggestionDates?.StartDate != null && _suggestionDates?.EndDate != null)
            {
                <div class="summary-offer-price">
                    <span>Sugerowany termin: <b>@_suggestionDates?.StartDate - @_suggestionDates?.EndDate</b></span>
                    <Button @onclick="GoToSuggestionDates">Wybierz</Button>
                </div>  
            }
            @if (_suggestionLoading)
            {
                <div class="summary-offer-price">
                    <span>Sugerowany termin: <b>Sprawdzanie dostępności...</b></span>
                    <Button Disabled="true">Wybierz</Button>
                </div>  
            }
        </div>
    }
    
</div>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public string? StartDate { get; set; }
    [Parameter] public string? EndDate { get; set; }
    [Parameter] public string? Adults { get; set; }
    [Parameter] public string? Children { get; set; }
    
    private ApartmentObject? _apartment;
    private List<ObjectMedium>? _objectMediums = null;
    private List<ObjectAmenity>? _amenities = null;
    private int? _bedsCount = null;
    private bool _isExpanded = false;
    private PricingOffersResponse? _offersResponse;

    private AvailableTerm? _suggestionDates = null;
    private bool _suggestionLoading = true;
    
    private const string OfferTypeRefundable = "refundable";
    private const string OfferTypeNonrefundable = "nonrefundable";

    private static Dictionary<string, string> _languageMap = new Dictionary<string, string>
    {
        { "pl-PL", "pol" },
        { "en-US", "eng" }
    };

    private string CurrentLanguage => _languageMap?.GetValueOrDefault(
        CultureInfo.CurrentUICulture.Name, 
        CultureInfo.CurrentUICulture.Name
    ) ?? CultureInfo.CurrentUICulture.Name;

    private string GetSeoTitle()
    {
        if (_apartment == null) return "Szczegóły apartamentu - Rentoom";
        return $"{_apartment.Name} - Rentoom";
    }

    private string GetSeoDescription()
    {
        if (_objectDescription != null && !string.IsNullOrEmpty(_objectDescription.ShortDescription))
        {
            return Regex.Replace(_objectDescription.ShortDescription, "<.*?>", String.Empty).Trim();
        }
        
        if (_apartment != null)
        {
            return $"Zarezerwuj {_apartment.Name} w Rentoom. Świetna lokalizacja, {_bedsCount} pokoje, wysoki standard.";
        }
        
        return "Sprawdź szczegóły apartamentu i zarezerwuj pobyt w Rentoom.";
    }

    private string GetSeoImage()
    {
        var img = _objectMediums?.FirstOrDefault()?.Url;
        if (!string.IsNullOrEmpty(img))
        {
            return img;
        }
        return $"{NavManager.BaseUri}assets/images/header-bg-contact.jpeg";
    }

    private string GetCanonicalUrl()
    {
        return $"{NavManager.BaseUri}apartamenty/{Id}/{Slug}";
    }

    protected override async Task OnInitializedAsync()
    {
        _apartment = await ApartmentsService.GetApartmentByIdAsync(Id);
        await GetObjectMedia();
        
        if (_apartment != null)
        {
            await GetObjectDescription(_apartment.Id, CurrentLanguage);
            _amenities = await GetAmenities(_apartment.Id);
            _bedsCount = _apartment?.BedsConfiguration?.Sum(item => item.Count);
        }
        
        await GetOffer();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _offersResponse?.Result?.PricingOffers?.Count == null)
        {
            bool shouldSearch = _offersResponse?.Result?.PricingOffers == null 
                                || !_offersResponse.Result.PricingOffers.Any();

            if (shouldSearch && _apartment != null)
            {
                _ = Task.Run(async () => 
                {
                    await Task.Delay(160);

                    await LoadSuggestionInBackground();
                    
                    await InvokeAsync(StateHasChanged);
                });
            }
        }
    }

    private async Task LoadSuggestionInBackground()
    {
        try 
        {
            var aptId = _apartment?.Id ?? 0;
            var sDate = StartDate;
            var eDate = EndDate;
            var aCount = int.TryParse(Adults, out var a) ? a : 2;
            var cCount = int.TryParse(Children, out var c) ? c : 1;

            if (aptId == 0) return;

            var result = await AvailabilityFinder.FindNextAvailableTermAsync(
                aptId, 
                sDate, 
                eDate, 
                aCount, 
                cCount
            );

            _suggestionDates = result;
            _suggestionLoading = false;

            if (_suggestionDates != null)
            {
                _suggestionLoading = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Błąd w tle: {ex.Message}");
        }
    }
    
    private void ToggleExpand()
    {
        _isExpanded = !_isExpanded;
    }

    private async Task GetObjectMedia()
    {
        if (_apartment != null)
        {
            _objectMediums = await IdoApartmentService.GetObjectMediaFromIdoSellAsync(_apartment.Id) ?? new List<ObjectMedium>();
        }
    }

    private ObjectDescription? _objectDescription = null;
    private async Task GetObjectDescription(int objectId, string? language)
    {
        var descriptions = await IdoApartmentService.GetObjectDescriptionsAsync(objectId, language);
        _objectDescription = descriptions?.FirstOrDefault();
    }

    private async Task<List<ObjectAmenity>?> GetAmenities(int objectId)
    {
        return await IdoApartmentService.GetObjectAmenitiesAsync(objectId);
    }
    
    private PricingOffersRequest CurrentRequest => new PricingOffersRequest
    {
        ObjectIds = _apartment != null ? new List<int> { _apartment.Id } : null,
        DateFrom = StartDate,
        DateTo = EndDate,
        NumberOfAdults = int.TryParse(Adults, out var a) ? a : null,
        NumberOfBigChildren = int.TryParse(Children, out var c) ? c : null
    };
    
    private async Task GetOffer()
    {
        _offersResponse = await OfferService.GetPricingOffersAsync(CurrentRequest);
    }
    
    private async Task HandleSearch(Dictionary<string, string> query, bool updateUrl = true)
    {
        query.TryGetValue("startDate", out var startDate);
        query.TryGetValue("endDate", out var endDate);
        query.TryGetValue("adults", out var adults);
        query.TryGetValue("children", out var children);

        StartDate = startDate;
        EndDate = endDate;
        Adults = adults;
        Children = children;

        if (_apartment != null)
        {
            var url = $"/apartamenty/{_apartment.Id}/{_apartment.Name?.ToSlug()}/{StartDate}/{EndDate}/{Adults}/{Children}";
            Navigation.NavigateTo(url, forceLoad: false);
            await GetOffer();
        }
    }
    
    private async Task GoToSuggestionDates()
    {
        if (_apartment != null && _suggestionDates?.StartDate != null && _suggestionDates?.EndDate != null)
        {
            var url = $"/apartamenty/{_apartment.Id}/{_apartment.Name?.ToSlug()}/{_suggestionDates.StartDate}/{_suggestionDates.EndDate}/{Adults}/{Children}";
            Navigation.NavigateTo(url, forceLoad: true);
            await GetOffer();
            StateHasChanged();
        }
    }
    
    // GotReservationSummary() -> "Tworz rezerwacje w idobokooking jako unconfirmed"> przekaz ID do ReservationSummary.razor->"Oplac rezerwacje -> zmien status rezerwacji na waitingForPayment-> przekierujuj->Payment.razor/{idrezerwacji}-> automatycznie Przekierowanie do TPAy->{klient opplaca}->payment.razor(wyswietl blad, lub success i info o linku staywell)
    private async Task GoToPayment(string? offerType)
    {
        if (_apartment is null || string.IsNullOrWhiteSpace(StartDate) || string.IsNullOrWhiteSpace(EndDate))
        {
            return;
        }
        
        
        if(!TryParseDate(StartDate, out var start) || !TryParseDate(EndDate, out var end))
        {
            return;
        }

        var selectedOffer = GetOfferByType(offerType);
        var adults = int.TryParse(Adults, out var a) ? a : 1;
        var children = int.TryParse(Children, out var c) ? c : 0;

        var request = new StartReservationRequest
        {
            ObjectId = _apartment.Id, //ID całego apartamentu
            ObjectItemId = _apartment.Items[0].Id.Value, // ID itemu apartamentu - na jego podstawie jest robiona rezerwacja, a nie na podstawie ObjectId
            StartDate = start,
            EndDate = end,
            Adults = adults,
            Children = children,
            SelectedOfferType = selectedOffer?.OfferType ?? offerType,
            OfferPrice = selectedOffer?.Price ?? _offersResponse?.Result?.PricingOffers?.FirstOrDefault()?.MinimalPrice,
            Currency = "PLN",
            SelectedAddons = new List<SelectedAddonDto>()
        };

        var reservationGuid = await ReservationWorkflowService.StartAsync(request);
        Navigation.NavigateTo($"/rezerwuj/{reservationGuid}/dane-klienta", true);
    }
    
    private async Task ScrollToReservation()
    {
        await Task.Yield(); 
        await JSRuntime.InvokeVoidAsync("scrollToElement", "confirm-reservation");
    }

    private static bool TryParseDate(string? value, out DateOnly date)
    {
        if (!string.IsNullOrWhiteSpace(value) && DateOnly.TryParse(value, out date))
        {
            return true;
        }

        if (!string.IsNullOrWhiteSpace(value) && DateTime.TryParse(value, out var parsed))
        {
            date = DateOnly.FromDateTime(parsed);
            return true;
        }

        date = default;
        return false;
    }

    private OfferItem? GetOfferByType(string? offerType)
    {
        var offers = _offersResponse?.Result?.PricingOffers?.FirstOrDefault()?.Offers;
        if (offers is null) return null;

        if (!string.IsNullOrWhiteSpace(offerType))
        {
            var match = offers.FirstOrDefault(o => string.Equals(o.OfferType, offerType, StringComparison.OrdinalIgnoreCase));
            if (match is not null)
            {
                return match;
            }
        }

        return offers.FirstOrDefault();
    }

    
}