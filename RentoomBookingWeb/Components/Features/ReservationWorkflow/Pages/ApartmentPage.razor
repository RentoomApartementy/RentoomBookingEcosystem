@using RentoomBookingWeb.Components.Features.ReservationWorkflow.Components.ApartmentPage
@using RentoomBookingWeb.Components.Features.ReservationWorkflow.Components

<PageTitle>@GetSeoTitle()</PageTitle>

<HeadContent>
    <meta name="robots" content="@(HasRouteDates ? "noindex, nofollow" : "index, follow")" />
    <meta name="description" content="@GetSeoDescription()" />
    <meta name="keywords" content="@GetSeoKeywords()" />
    <link rel="canonical" href="@GetCanonicalUrl()" />

    <meta property="og:title" content="@GetSeoTitle()" />
    <meta property="og:description" content="@GetSeoDescription()" />
    <meta property="og:image" content="@GetSeoImage()" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@GetCanonicalUrl()" />

    @if (_apartment != null)
    {
        <BreadcrumbJsonLd
            CurrentPageName="@(_apartment.Name ?? ApartmentBreadcrumbFallbackName)"
            CurrentPagePath="@GetCanonicalUrl()"
            ParentPageName="@Localizer["Apartment_BreadcrumbParentName"]"
            ParentPagePath="@RouteService.GetLocalizedUrl("Apartments")" />
    }

    @(_apartment != null ? (MarkupString)$@"<script type=""application/ld+json"">{GetJsonLd().Value}</script>" : (MarkupString)"")
</HeadContent>

<div class="apartment-container">
    @if (_apartment == null && !_isOfferLoading)
    {
        <div class="not-found-wrapper">
            <div class="not-found-card">
                <div class="not-found-icon">
                    <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                </div>
                <h2>@Localizer["ApartmentNotFoundTitle"]</h2>
                <p>@Localizer["ApartmentNotFoundDescription"]</p>
                <div style="margin-top: 2rem;">
                    <Button Type="ButtonType.Primary" OnClick='(() => Navigation.NavigateTo(RouteService.GetLocalizedUrl("Apartments")))'>
                        @Localizer["BackToApartments"]
                    </Button>
                </div>
            </div>
        </div>
    }
    else
    {
        <HeaderSection
            ImagePath="@_objectMediums?.FirstOrDefault()?.Url"
            Title="@_apartment?.Name"
            Height="230px"
            IsShadow="true"
            HeadingLevel="1"
        />   
        
        <div class="main-wrapper">
            <div class="left-container">
                
                <ApartmentHero
                    Apartment="_apartment"
                    Mediums="_objectMediums"
                    BedsCount="_bedsCount" />

                @if (_aiDescription != null)
                {
                    <ApartmentAiDescription 
                        Data="_aiDescription" 
                        Amenities="_amenities"
                        IsExpanded="_isExpanded"
                        OnToggleExpand="ToggleExpand"
                        Localizer="Localizer" />
                }
                else
                {
                    <ApartmentDescription
                        Description="_objectDescription"
                        Amenities="_amenities"
                        IsExpanded="_isExpanded"
                        OnToggleExpand="ToggleExpand"
                        Localizer="Localizer" />
                }
                @if (localHasOffers || StartDate == null || EndDate == null)
                {
                    @if (StartDate != null && EndDate != null)
                    {
                        <hr style="width: 100%;" />
                        <h3 class="header-text text-lg">@Localizer["Summary"]</h3>

                        <ApartmentAddonSelector 
                            Addons="_apartment?.Addons" 
                            DefinedAddons="_definedAddons" 
                            SelectedAddons="_selectedAddons" 
                            ReservationContext="_reservationPricingContext" 
                            CurrentAddonLanguage="@CurrentAddonLanguage" 
                            CurrencySymbol="@CurrencyLocalizer["PLN"]" 
                            Localizer="Localizer" 
                            OnToggleAddon="((id) => ToggleAddonWrapper(id, _apartment?.Addons?.FirstOrDefault(x => x.Id == id)?.Optional))" 
                            OnQuantityUpdate="((args) => UpdateAddonQuantity(args.AddonId, args.Quantity))" />

                        @if (Environment.IsDevelopment() && _reservationPricingContext is not null)
                        {
                            <UpsellList AvailableUpsellsList="_availableUpsells"
                                        ReservationContext="_reservationPricingContext"
                                        OnSelectionChanged="HandleUpsellSelectionChanged"
                                        Texts="UpsellTexts" />
                        }

                        @if (TotalAddonsPrice + TotalUpsellsPrice > 0)
                        {
                            <div class="additional-price">
                                +@((TotalAddonsPrice + TotalUpsellsPrice).ToString("N2")) @CurrencyLocalizer["PLN"]
                            </div>
                        }
                    }

                    <BonusCodeBox
                        BonusCode="@_bonusInputName"
                        BonusCodeChanged="OnBonusCodeChanged"
                        OnApply="ApplyBonusOnApartmentPageAsync"
                        IsApplying="@_isApplyingBonus"
                        StatusMessage="@_bonusStatusMessage"
                        IsError="@_bonusStatusIsError"
                        AppliedBonusName="@_bonusAppliedName"
                        DiscountAmount="@_bonusDiscountAmount"
                        Localizer="Localizer" />

                    <ApartmentOfferSelector 
                        StartDate="@StartDate" 
                        EndDate="@EndDate" 
                        IsOfferLoading="_isOfferLoading" 
                        OffersResponse="_offersResponse" 
                        TotalAdditionalPriceBeforeDiscount="@(TotalAddonsPrice + TotalUpsellsPrice)" 
                        BonusDiscountAmount="@_bonusDiscountAmount" 
                        CurrencySymbol="@CurrencyLocalizer["PLN"]" 
                        StaySummaryText="@GetStaySummaryText()" 
                        RefundableOfferText="@GetRefundableOfferText()" 
                        SelectedOfferType="@_selectedOfferType" 
                        HasActiveReservation="HasActiveReservation" 
                        SuggestionDates="_suggestionDates" 
                        SelectedSuggestionDate="_selectedSuggestionDate" 
                        IsSuggestionLoading="_suggestionLoading" 
                        Localizer="Localizer" 
                        OnSearchModalOpen="OpenSearchModal" 
                        OnBookNow="GoToPayment" 
                        OnSuggestionSelected="SelectSuggestionDate" 
                        OnGoToSuggestion="GoToSuggestionDates" />
                }
            </div>

            <div class="right-container">
                <ApartmentStickySummary 
                    IsMobileExpanded="_isMobileExpanded" 
                    HasOffers="localHasOffers" 
                    TotalMinPrice="@(localMinPrice + TotalPriceAdjustment ?? 0m)" 
                    CurrencySymbol="@CurrencyLocalizer["PLN"]" 
                    StartDate="@StartDate" 
                    EndDate="@EndDate" 
                    NightsSummaryText="@GetNightsSummaryText()" 
                    PersonsSummaryText="@GetPersonsSummaryText()" 
                    IsOfferLoading="_isOfferLoading" 
                    IsAtOffers="_isAtOffers" 
                    IsAtSummary="_isAtSummary" 
                    SuggestionDates="_suggestionDates" 
                    IsSuggestionLoading="_suggestionLoading" 
                    Localizer="Localizer" 
                    OnToggleMobileExpand="ToggleMobileExpand" 
                    OnSearchModalOpen="OpenSearchModal" 
                    OnSmartAction="SmartScrollAction" 
                    OnGoToSuggestion="GoToSuggestionDates">
                    
                    <ApartmentLocationMap 
                        Location="_apartment?.ObjectLocation" 
                        IsMobile="true" 
                        MapId="apartmentMap-mobile" 
                        OnSeeMore="OpenModal" 
                        Localizer="Localizer" />
                </ApartmentStickySummary>

                <ApartmentLocationMap 
                    Location="_apartment?.ObjectLocation" 
                    IsMobile="false" 
                    MapId="apartmentMap-desktop" 
                    OnSeeMore="OpenModal" 
                    Localizer="Localizer" />
            </div>
        </div>

        <MapPopup
            @bind-IsModalOpen="_isModalOpen"
            Apartment="_apartment"
            StartDate="@StartDate"
            EndDate="@EndDate"
            Adults="@Adults"
            Children="@Children" />

        @if (_isSearchModalOpen)
        {
            <div class="search-modal-overlay" @onclick="CloseSearchModal">
                <div class="search-modal-content" @onclick:stopPropagation="true">
                    <div class="search-modal-header">
                        <h3>@Localizer["SelectDatesAndGuests"]</h3>
                        <button class="close-modal-btn" @onclick="CloseSearchModal">&times;</button>
                    </div>
                    <div class="search-modal-body">
                       <SearchBar 
                           StartDate="@StartDate"
                           EndDate="@EndDate"
                           Adults="@Adults"
                           Children="@Children"
                           OnSearch="async (query) => { await HandleSearch(query); CloseSearchModal(); }" />
                    </div>
                </div>
            </div>
        }
    }
</div>
