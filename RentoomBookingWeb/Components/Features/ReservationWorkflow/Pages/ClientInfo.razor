@page "/rezerwuj/{ReservationTokenGuid:guid}/dane-klienta/"
@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.SharedClasses.Models.ReservationWorkflow
@using RentoomBooking.SharedClasses.Services.ReservationWorkflow
@using RentoomBookingWeb.Components.Shared
@using RentoomBookingWeb.Services
@using RentoomBooking.SharedClasses.Services.Gus
@using PhoneNumbers
@inject IApartmentsService ApartmentsService
@inject IReservationWorkflowService ReservationWorkflowService
@inject IGusService GusService
@inject NavigationManager Navigation
@using RentoomBookingWeb.Components.Features.ReservationWorkflow.Components
@using Microsoft.Extensions.Localization
@using System.Linq
@using System.ComponentModel.DataAnnotations
@using System.Net.Mail
@using System.Text.RegularExpressions
@using System.Globalization
@inject IStringLocalizer<RentoomBookingWeb.Payment> Localizer

<PageTitle>Płatność</PageTitle>

<div class="payment-container">
    <div class="payment-wrapper">
        <EditForm EditContext="_editContext" OnValidSubmit="SaveAsync" class="editform-width">
            <DataAnnotationsValidator />

            <div class="form-wrapper">
                <div class="form-wrapper-title">
                    <div class="form-wrapper-title-icon-wrapper">
                        <img src="assets/svgs/user.svg" alt="ikona uzytkownika">
                    </div> 
                    <div class="form-wrapper-title-text">
                        <h3>@Localizer["ClientInfoTitle"]</h3>
                        <p>@Localizer["ClientInfoSubtitle"]</p>
                    </div>
                </div>
                
                <div class="form">
                    <div class="form-item">
                        <div class="form-two-items">
                            <div class="input-wrapper">
                                <small>@Localizer["Name"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                                <Input Placeholder="@Localizer["Name"]" IsFull="true" @bind-Value="_form.Client.FirstName"/>
                            </div>
                            <div class="input-wrapper">
                                <small>@Localizer["LastName"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                                <Input Placeholder="@Localizer["LastName"]" IsFull="true" @bind-Value="_form.Client.LastName"/>
                            </div>
                        </div>
                        <div class="input-wrapper">
                            <small>@Localizer["City"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                            <Input Placeholder="@Localizer["City"]" IsFull="true" @bind-Value="_form.Client.City"/>
                        </div>
                        <div class="input-wrapper">
                            <small>@Localizer["Address"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                            <Input Placeholder="@Localizer["Address"]" IsFull="true" @bind-Value="_form.Client.Street"/>
                        </div>
                        <div class="input-wrapper">
                            <small>@Localizer["PostalCode"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                            <Input Placeholder="@Localizer["PostalCode"]" IsFull="true" @bind-Value="_form.Client.ZipCode"/>
                        </div>
                        <div class="form-two-items">
                            <div class="input-wrapper">
                                <small>@Localizer["Email"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                                <Input Placeholder="@Localizer["Email"]" IsFull="true" @bind-Value="_form.Client.Email"/>
                            </div>
                        </div>
                        
                        <div class="input-wrapper">
                            <small>@Localizer["Phone"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                            <div class="phone-grid-container">
                                <div class="input-wrapper phone-prefix-container">
                                    <div class="custom-input">
                                        <select class="prefix-select" @bind="PhoneCountryCode">
                                            @foreach (var prefix in _countryPrefixes)
                                            {
                                                <option value="@prefix.Code">@prefix.Display</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="input-wrapper phone-number-container">
                                    <div class="custom-input">
                                        <input type="text"
                                               maxlength="20"
                                               @bind="PhoneNumber" 
                                               @bind:event="oninput" 
                                               placeholder="@DynamicPlaceholder" />
                                    </div>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(_phoneError))
                            {
                                <small class="text-danger" style="display: block; margin-top: 4px;">@_phoneError</small>
                            }
                        </div>
                    </div>

                    <hr>

                    <label class="addon-label">
                        <input type="checkbox" class="addon-checkbox" @bind="UseInvoice"/>
                        <span class="addon-name">@Localizer["IsInvoiceText"]</span>
                    </label>
                    
                    <div class="form-item mt-1 mb-2">
                        @if (UseInvoice)
                        {
                            <div class="input-wrapper">
                                <small>NIP <span style="color: #999;">(@Localizer["Required"])</span></small>
                                <div class="">
                                    <Input Placeholder="NIP" IsFull="true" @bind-Value="_form.Invoice.TaxNumber"/>
                                    <small class="download-nip-button" @onclick="DownloadGusDataAsync" style="cursor: pointer; color: var(--primary);">
                                        @(_isFetchingGus ? Localizer["Loading"] : Localizer["ClickToDownloadInfo"])
                                    </small>
                                </div>
                            </div>
                            <div class="input-wrapper">
                                <small>@Localizer["CompanyName"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                                <Input Placeholder="@Localizer["CompanyName"]" IsFull="true" @bind-Value="_form.Invoice.CompanyName"/>
                            </div>
                            <div class="form-two-items">
                                <div class="input-wrapper">
                                    <small>@Localizer["City"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                                    <Input Placeholder="@Localizer["City"]" IsFull="true" @bind-Value="_form.Invoice.City"/>
                                </div>
                                <div class="input-wrapper">
                                    <small>@Localizer["Address"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                                    <Input Placeholder="@Localizer["Address"]" IsFull="true" @bind-Value="_form.Invoice.Street"/>
                                </div>
                                <div class="input-wrapper">
                                    <small>@Localizer["PostalCode"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                                    <Input Placeholder="@Localizer["PostalCode"]" IsFull="true" @bind-Value="_form.Invoice.ZipCode"/>
                                </div>
                            </div>
                            <div class="input-wrapper">
                                <small>@Localizer["Email"] <span style="color: #999;">(@Localizer["Required"])</span></small>
                                <Input Placeholder="@Localizer["Email"]" IsFull="true" @bind-Value="_form.Invoice.Email"/>
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <p class="text-danger">@_error</p>
                }

                <button type="submit" disabled="@IsSubmitDisabled" class="button"
                        style="@(!IsFormComplete() ? "opacity: 0.6; filter: brightness(0.8); cursor: not-allowed;" : "")">
                    @(_isSaving ? Localizer["ClientInfoButtonLoading"] : Localizer["ClientInfoButton"])
                </button>
            </div>
        </EditForm>
        
        <SummaryBox 
            Summary="_summary"
            Apartment="_apartment"
            />
    </div>
</div>

@code {
    [Parameter] public Guid ReservationTokenGuid { get; set; }

    private ApartmentObject? _apartment;
    private PaymentFormModel _form = new();
    private EditContext _editContext = default!;
    private bool _isSaving;
    private bool _isFetchingGus;
    private string? _error;
    private string _phoneCountryCode = "48";
    private string _phoneNumberDisplay = string.Empty; 
    private string _phoneNumberRaw = string.Empty;     
    private ReservationSummaryDto? _summary;
    private string _phoneError = string.Empty;

    private static readonly PhoneNumberUtil _phoneUtil = PhoneNumberUtil.GetInstance();

    private class CountryPrefix
    {
        public string Code { get; set; } = "";
        public string Region { get; set; } = "";
        public string Flag { get; set; } = "";
        public string Display => $"{Flag} +{Code}";
    }

    private List<CountryPrefix> _countryPrefixes = new()
    {
        new CountryPrefix { Code = "48", Region = "PL", Flag = "🇵🇱" },
        new CountryPrefix { Code = "44", Region = "GB", Flag = "🇬🇧" },
        new CountryPrefix { Code = "49", Region = "DE", Flag = "🇩🇪" },
        new CountryPrefix { Code = "1",  Region = "US", Flag = "🇺🇸" },
        new CountryPrefix { Code = "420", Region = "CZ", Flag = "🇨🇿" },
        new CountryPrefix { Code = "421", Region = "SK", Flag = "🇸🇰" },
        new CountryPrefix { Code = "380", Region = "UA", Flag = "🇺🇦" },
        new CountryPrefix { Code = "33", Region = "FR", Flag = "🇫🇷" },
        new CountryPrefix { Code = "34", Region = "ES", Flag = "🇪🇸" },
        new CountryPrefix { Code = "39", Region = "IT", Flag = "🇮🇹" },
        new CountryPrefix { Code = "31", Region = "NL", Flag = "🇳🇱" },
        new CountryPrefix { Code = "47", Region = "NO", Flag = "🇳🇴" },
        new CountryPrefix { Code = "46", Region = "SE", Flag = "🇸🇪" }
    };

    private bool IsSubmitDisabled => _isSaving || !IsFormComplete();
    
    private bool UseInvoice
    {
        get => _form.UseInvoice;
        set
        {
            _form.UseInvoice = value;
            if (value && string.IsNullOrWhiteSpace(_form.Invoice.Email) && !string.IsNullOrWhiteSpace(_form.Client.Email))
            {
                _form.Invoice.Email = _form.Client.Email;
            }
        }
    }

    private string PhoneCountryCode
    {
        get => _phoneCountryCode;
        set
        {
            _phoneCountryCode = value;
            PhoneNumber = _phoneNumberRaw; 
        }
    }

    private string PhoneNumber
    {
        get => _phoneNumberDisplay;
        set
        {
            _phoneNumberRaw = DigitsOnly(value);
            _phoneNumberDisplay = FormatAsYouType(_phoneNumberRaw);
            ValidateAndBuildPhone();
        }
    }

    private string DynamicPlaceholder
    {
        get
        {
            var selectedPrefix = _countryPrefixes.FirstOrDefault(c => c.Code == _phoneCountryCode);
            if (selectedPrefix != null && !string.IsNullOrEmpty(selectedPrefix.Region))
            {
                var exampleNumber = _phoneUtil.GetExampleNumberForType(selectedPrefix.Region, PhoneNumberType.MOBILE);
                
                if (exampleNumber != null)
                {
                    return _phoneUtil.Format(exampleNumber, PhoneNumberFormat.NATIONAL);
                }
            }
            return "123 456 789"; 
        }
    }

    private string FormatAsYouType(string digits)
    {
        var selectedPrefix = _countryPrefixes.FirstOrDefault(c => c.Code == _phoneCountryCode);
        if (selectedPrefix == null || string.IsNullOrEmpty(selectedPrefix.Region)) 
        {
            return digits;
        }

        var formatter = _phoneUtil.GetAsYouTypeFormatter(selectedPrefix.Region);
        formatter.Clear();
        string formatted = "";
        
        foreach (char c in digits)
        {
            formatted = formatter.InputDigit(c);
        }
        
        return formatted;
    }

    protected override async Task OnInitializedAsync()
    {
        ParsePhoneNumber(_form.Client.Phone);
        _editContext = new EditContext(_form);

        _summary = await ReservationWorkflowService.BuildDraftSummaryAsync(ReservationTokenGuid);

        if (_summary != null && _summary.StartRequest?.ObjectId != null)
        {
            _apartment = await ApartmentsService.GetApartmentByIdAsync(_summary.StartRequest.ObjectId);   
        }
    }

    private async Task DownloadGusDataAsync()
    {
        if (_isFetchingGus) return;
        var nip = _form.Invoice.TaxNumber;
        if (string.IsNullOrWhiteSpace(nip)) { _error = Localizer["NoNipError"]; return; }
        _isFetchingGus = true; _error = null;
        try
        {
            var data = await GusService.GetCompanyInfoByNipAsync(nip);
            if (data != null)
            {
                _form.Invoice.CompanyName = data.Nazwa;
                _form.Invoice.City = data.Miejscowosc;
                _form.Invoice.ZipCode = data.KodPocztowy;
                _form.Invoice.Street = $"{data.Ulica} {data.NrNieruchomosci}".Trim();
                if (!string.IsNullOrEmpty(data.NrLokalu)) _form.Invoice.Street += $"/{data.NrLokalu}";
                _form.Invoice.Street = _form.Invoice.Street.Trim();
                _error = null;
            }
            else { _error = Localizer["NoGusInfo"]; }
        }
        catch (Exception) { _error = Localizer["GusError"]; }
        finally { _isFetchingGus = false; }
    }

    private async Task SaveAsync()
    {
        if (_isSaving) return;
        ValidateAndBuildPhone();
        if (!IsFormComplete()) return;
        _isSaving = true; _error = null;
        try
        {
            await ReservationWorkflowService.SaveClientInfoAsync(ReservationTokenGuid, _form.Client, _form.UseInvoice ? _form.Invoice : null);
            Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie");
        }
        catch (Exception ex) { _error = "Nie udało się zapisać danych klienta. " + ex.Message ; }
        finally { _isSaving = false; }
    }

    private void ValidateAndBuildPhone()
    {
        _phoneError = string.Empty;
        var cleanPrefix = DigitsOnly(_phoneCountryCode);
        
        if (string.IsNullOrWhiteSpace(cleanPrefix) || string.IsNullOrWhiteSpace(_phoneNumberRaw)) 
        {
            _form.Client.Phone = string.Empty;
            return;
        }

        try
        {
            var fullNumberToParse = $"+{cleanPrefix}{_phoneNumberRaw}";
            PhoneNumber numberProto = _phoneUtil.Parse(fullNumberToParse, null);

            if (_phoneUtil.IsValidNumber(numberProto))
            {
                _form.Client.Phone = $"+{numberProto.CountryCode}.{numberProto.NationalNumber}";
                _phoneError = string.Empty;
            }
            else
            {
                _form.Client.Phone = string.Empty;
            }
        }
        catch (NumberParseException)
        {
            _form.Client.Phone = string.Empty;
        }
    }

    private void ParsePhoneNumber(string? phone)
    {
        var normalizedPhone = (phone ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(normalizedPhone))
        {
            _phoneCountryCode = "48";
            PhoneNumber = string.Empty; 
            return;
        }

        if (normalizedPhone.Contains('.'))
        {
            var splitPhone = normalizedPhone.TrimStart('+').Split('.', 2, StringSplitOptions.TrimEntries);
            _phoneCountryCode = DigitsOnly(splitPhone.ElementAtOrDefault(0));
            PhoneNumber = splitPhone.ElementAtOrDefault(1) ?? string.Empty;
        }
        else
        {
            try
            {
                var fullNumber = normalizedPhone.StartsWith("+") ? normalizedPhone : "+" + normalizedPhone;
                PhoneNumber numberProto = _phoneUtil.Parse(fullNumber, null);
                _phoneCountryCode = numberProto.CountryCode.ToString();
                PhoneNumber = numberProto.NationalNumber.ToString();
            }
            catch
            {
                _phoneCountryCode = string.Empty;
                PhoneNumber = DigitsOnly(normalizedPhone);
            }
        }
        
        if (!string.IsNullOrEmpty(_phoneCountryCode) && !_countryPrefixes.Any(x => x.Code == _phoneCountryCode))
        {
            _countryPrefixes.Add(new CountryPrefix { Code = _phoneCountryCode, Region = "ZZ", Flag = "🌐" });
        }
    }

    private bool IsFormComplete()
    {
        if (!HasValue(_form.Client.FirstName) ||
            !HasValue(_form.Client.LastName) ||
            !HasValue(_form.Client.City) ||
            !HasValue(_form.Client.Street) ||
            !HasValue(_form.Client.ZipCode) ||
            !HasValue(_form.Client.Email) ||
            !IsValidEmail(_form.Client.Email) ||
            !HasValue(_form.Client.Phone)) 
        {
            return false;
        }

        if (!_form.UseInvoice) return true;

        return HasValue(_form.Invoice.TaxNumber) &&
               HasValue(_form.Invoice.CompanyName) &&
               HasValue(_form.Invoice.City) &&
               HasValue(_form.Invoice.Street) &&
               HasValue(_form.Invoice.ZipCode) &&
               HasValue(_form.Invoice.Email) &&
               IsValidEmail(_form.Invoice.Email);
    }

    public bool IsValidEmail(string? email)
    {
        if (string.IsNullOrWhiteSpace(email)) return false;
        try
        {
            email = Regex.Replace(email, @"(@)(.+)$", DomainMapper, RegexOptions.None, TimeSpan.FromMilliseconds(200));
            string DomainMapper(Match match)
            {
                var idn = new IdnMapping();
                string domainName = idn.GetAscii(match.Groups[2].Value);
                return match.Groups[1].Value + domainName;
            }
        }
        catch (Exception) { return false; }

        try
        {
            return Regex.IsMatch(email, @"^[^@\s]+@[^@\s]+\.[^@\s]+$", RegexOptions.IgnoreCase, TimeSpan.FromMilliseconds(250));
        }
        catch (RegexMatchTimeoutException) { return false; }
    }

    private static bool HasValue(string? value) => !string.IsNullOrWhiteSpace(value);
    private static string DigitsOnly(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;
        return new string(value.Where(char.IsDigit).ToArray());
    }

    private sealed class PaymentFormModel
    {
        public ClientInfoDto Client { get; set; } = new();
        public InvoiceInfoDto Invoice { get; set; } = new();
        public bool UseInvoice { get; set; }
    }
}