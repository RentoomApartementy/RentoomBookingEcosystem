@page "/rezerwuj/{ReservationTokenGuid:guid}/oplac/success"

@using RentoomBooking.SharedClasses.Services.ReservationWorkflow
@using Microsoft.Extensions.Localization
@inject IReservationWorkflowService ReservationWorkflowService;
@inject NavigationManager Navigation
@inject IStringLocalizer<RentoomBookingWeb.Payment> Localizer

<PageTitle>@Localizer["SuccessPageTitle"]</PageTitle>

<div class="summary-container">
    <div class="status-card">
        <div class="state-content">
            <AppError Message=@_error
                      Title="@Localizer["SomethingWrong"]"
                      Dismissible="false" />

            @if (string.IsNullOrWhiteSpace(_error))
            {
                <div class="spinner-container">
                    <div class="loading-spinner"></div>
                </div>
                <h2>@Localizer["PaymentConfirmationInProgressTitle"]</h2>
                <p class="sub-message">@Localizer["PaymentConfirmationInProgressMessage"]</p>
            }
            else
            {
                <Button OnClick="GoToSummary">@Localizer["BackToSummary"]</Button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid ReservationTokenGuid { get; set; }
    [Parameter] public Guid tpayTransactionId { get; set; }
    private string? _error;
    private bool _confirmationStarted;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_confirmationStarted)
        {
            _confirmationStarted = true;
            try
            {
                Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie?paymentReturn=confirming", true);
            }
            catch (Exception)
            {
                _error = Localizer["PaymentVerificationError"];
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void GoToSummary()
    {
        Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie?paymentReturn=confirming");
    }
}
