@page "/rezerwuj/{ReservationTokenGuid:guid}/oplac/success"

@using RentoomBooking.SharedClasses.Services.ReservationWorkflow
@using Microsoft.Extensions.Localization
@inject IReservationWorkflowService ReservationWorkflowService;
@inject NavigationManager Navigation
@inject IStringLocalizer<RentoomBookingWeb.Payment> Localizer

<PageTitle>Rentoom - Opłacono</PageTitle>

<div class="summary-container">
    <div class="status-card">
        <div class="state-content">
            <AppError Message=@_error
                      Title="@Localizer["SomethingWrong"]"
                      Dismissible="false" />

            @if (string.IsNullOrWhiteSpace(_error))
            {
                <div class="spinner-container">
                    <div class="loading-spinner"></div>
                </div>
                <h2>Sukces</h2>
                <p class="sub-message">@Localizer["NotRefreshPage"]</p>
            }
            else
            {
                <button class="btn-primary" @onclick="GoToSummary">@Localizer["BackToSummary"]</button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid ReservationTokenGuid { get; set; }
    [Parameter] public Guid tpayTransactionId { get; set; }
    private string? _error;
    private bool _confirmationStarted;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_confirmationStarted)
        {
            _confirmationStarted = true;
            try
            {
                await ReservationWorkflowService.MarkPaymentAsPaidAsync(ReservationTokenGuid);//<< for  testing : flag _idoApi.UseDummyIdoBooking
                Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie/", true);
            }
            catch (Exception)
            {
                _error = "Nie udało się potwierdzić płatności.";
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void GoToSummary()
    {
        Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie/");
    }
}
