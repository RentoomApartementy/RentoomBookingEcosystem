@page "/rezerwuj/{ReservationTokenGuid:guid}/oplac"
@using RentoomBooking.SharedClasses.Services.ReservationWorkflow
@inject IReservationWorkflowService ReservationWorkflowService;
@inject NavigationManager Navigation
@using Microsoft.Extensions.Localization;
@inject IStringLocalizer<RentoomBookingWeb.Payment> Localizer;

<PageTitle>Opłać</PageTitle>

<div class="payment-view-container">
    <div class="status-card">
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="state-content">
                <div class="icon-circle error">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </div>
                <h2>@Localizer["SomethingWrong"]</h2>
                <p class="message">@_error</p>
                <button class="btn-primary" @onclick="GoToSummary">@Localizer["BackToSummary"]</button>
            </div>
        }
        else
        {
            <div class="state-content">
                <div class="spinner-container">
                    <div class="loading-spinner"></div>
                </div>
                <h2>@Localizer["RedirectingToPayment"]</h2>
                <p class="message">@Localizer["RedirectToPaymentText"]</p>
                <p class="sub-message">@Localizer["NotRefreshPage"]</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public Guid ReservationTokenGuid { get; set; }
    
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var payment = await ReservationWorkflowService.InitiatePaymentAsync(ReservationTokenGuid);
            if (!string.IsNullOrWhiteSpace(payment.RedirectUrl))
            {
                Navigation.NavigateTo(payment.RedirectUrl, true);
            }
            else
            {
                Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie-transakcji", true);
            }
        }
        catch (Exception)
        {
            _error = "Nie udało się zainicjować płatności.";
        }
    }

    private void GoToSummary()
    {
        Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie-transakcji");
    }
}