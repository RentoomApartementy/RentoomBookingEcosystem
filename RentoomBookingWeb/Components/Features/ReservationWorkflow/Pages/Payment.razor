@page "/rezerwuj/{ReservationTokenGuid:guid}/oplac"
@using RentoomBooking.SharedClasses.Models.Payments
@using RentoomBooking.SharedClasses.Services.Payments
@inject IPaymentOrchestrator PaymentOrchestrator;
@inject NavigationManager Navigation
@using Microsoft.Extensions.Localization;
@inject IStringLocalizer<RentoomBookingWeb.Payment> Localizer;

<PageTitle>Rentoom - Opłać rezerwację</PageTitle>

<div class="payment-view-container">
    <div class="status-card">
        <div class="state-content">
        @if (!string.IsNullOrEmpty(_error))
        {
            <AppError Message=@_error
                      Title="@Localizer["SomethingWrong"]"
                      Dismissible="false" />
            <button class="btn-primary" @onclick="GoToSummary">@Localizer["BackToSummary"]</button>
        }
        else
        {
            <div class="spinner-container">
                <div class="loading-spinner"></div>
            </div>
            <h2>@Localizer["RedirectingToPayment"]</h2>
            <p class="message">@Localizer["RedirectToPaymentText"]</p>
            <p class="sub-message">@Localizer["NotRefreshPage"]</p>
        }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid ReservationTokenGuid { get; set; }
    
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var payment = await PaymentOrchestrator.CreatePaymentAsync(new PaymentIntentRequest
            {
                FlowType = PaymentFlowType.Reservation,
                OrderId = ReservationTokenGuid
            });
            if (!string.IsNullOrWhiteSpace(payment.RedirectUrl))
            {
                Navigation.NavigateTo(payment.RedirectUrl, true);
            }
            else
            {
                Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie", true);
            }
        }
        catch (Exception)
        {
            _error = "Nie udało się zainicjować płatności.";
        }
    }

    private void GoToSummary()
    {
        Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/podsumowanie");
    }
}
