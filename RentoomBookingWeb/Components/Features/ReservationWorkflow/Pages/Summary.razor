@page "/rezerwuj/{ReservationTokenGuid:guid}/podsumowanie"

@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.SharedClasses.Models.ReservationWorkflow;
@using RentoomBooking.SharedClasses.Services.ReservationWorkflow;
@using RentoomBookingWeb.Components.Features.ReservationWorkflow.Components;
@using QRCoder
@using Microsoft.AspNetCore.WebUtilities
@inject IReservationWorkflowService ReservationWorkflowService;
@inject NavigationManager Navigation;
@inject IApartmentsService ApartmentsService;
@using Microsoft.Extensions.Localization;
@using System.Globalization;
@using RentoomBooking.SharedClasses.Models
@using Microsoft.Extensions.Configuration
@using RentoomBookingWeb.Services
@inject IStringLocalizer<RentoomBookingWeb.Payment> Localizer;
@inject CustomerTermsService TermsService
@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@inject ReservationWorkflowTelemetry WorkflowTelemetry
@implements IDisposable

<PageTitle>Rentoom - Podsumowanie rezerwacji</PageTitle>
<div class="summary-container">
    <AppError Message=@_error
              Title="@Localizer["SomethingWrong"]"
              Dismissible="false" />

    @if (_loading)
    {
        @* <div class="payment-success-card"> *@
        @*     <div class="info-icon-wrapper"> *@
        @*         <div class="spinner" role="status" aria-label="Ładowanie"></div> *@
        @*     </div> *@
        @* *@
        @*     <h2 class="success-title">@Localizer["SummaryLoadingText"]</h2> *@
        @* </div> *@
        <div class="status-card">
            <div class="state-content">
                <div class="spinner-container">
                    <div class="loading-spinner"></div>
                </div>
                <h2>@Localizer["SummaryLoadingText"]</h2>
                <p class="sub-message">@Localizer["NotRefreshPage"]</p>
            </div>
        </div>
    }
    else if (_summary is not null)
    {
        <div class="summary-wrapper">
            <div class="main-section">
                <div class="status-section">
                    <div class="form-wrapper-title">
                        <div class="form-wrapper-title-icon-wrapper">
                            <img src="assets/svgs/file.svg" alt="ikona uzytkownika">
                        </div> 
                        <div class="form-wrapper-title-text">
                            <h3 class="summary-box-title">@Localizer["ReservationSummary"] (@_summary?.IdoReservationId)</h3>
                            <p class="summary-box-dates">
                                @Localizer["SummaryDetailsText"]
                            </p>
                        </div>
                    </div>

                    @if (ShouldShowPaymentReturnBanner)
                    {
                        <div class="status-box @(IsPaymentReturnFailed ? "danger-bg" : "info-bg")">
                            <div class="form-wrapper-title-icon-wrapper @(IsPaymentReturnFailed ? "danger-icon-color" : "info-icon-color") rounded-full">
                                <img src="assets/svgs/@(IsPaymentReturnFailed ? "danger.svg" : "time.svg")" alt="ikona statusu płatności">
                            </div>

                            <div class="status-box-text">
                                <h4 class="@(IsPaymentReturnFailed ? "danger-text-color" : "info-text-color")">@PaymentReturnBannerTitle</h4>
                                <span>@PaymentReturnBannerMessage</span>
                            </div>
                        </div>
                    }
                    
                    @if (IsPaid)
                    {
                        <div class="status-box success-bg paid-status-box">
                            <div class="form-wrapper-title-icon-wrapper success-icon-color rounded-full">
                                <img src="assets/svgs/success.svg" alt="ikona uzytkownika">
                            </div> 
                        
                            <div class="status-box-text">
                                <h4 class="success-text-color">@Localizer["ReservationPaid"]</h4>
                                <span>@Localizer["ReservationPaidInfo"]</span>
                            </div>
                        </div>
                        <div class="status-box info-bg email-status-box">
                            <div class="form-wrapper-title-icon-wrapper info-icon-color rounded-full">
                                <img src="assets/svgs/mail.svg" alt="ikona maila">
                            </div>

                            <div class="status-box-text">
                                @if (!string.IsNullOrEmpty(_emailError))
                                {
                                    <h4 class="danger-text-color">@Localizer["ReservationDanger"]</h4>
                                    <span>@_emailError</span>
                                }
                                else if (_isCheckingEmail || _emailSent != true)
                                {
                                    <h4 class="info-text-color">@EmailDeliveryPendingTitle</h4>
                                    <span>@EmailDeliveryPendingMessage</span>
                                }
                                else
                                {
                                    <h4 class="success-text-color">@MessageSentTitle</h4>
                                    <span>@MessageSentDescription</span>
                                }
                            </div>
                        </div>
                        <div class="staywell-popup-wrapper">
                            <button type="button" class="button staywell-trigger-button" @onclick="ToggleStaywellPopup">
                                <img src="assets/svgs/qrcode.svg" alt="" class="staywell-trigger-icon" />
                                <span>@StaywellButtonText</span>
                            </button>
                            <a href="@staywellLink"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="staywell-mobile-direct-link">
                                @Localizer["GoToStayWellQRCodePopupMobileText"]
                            </a>

                            @if (_isStaywellPopupOpen)
                            {
                                <div class="staywell-popup" role="dialog" aria-label="Informacje StayWell">
                                    <button type="button"
                                            class="staywell-popup-close"
                                            @onclick="CloseStaywellPopup"
                                            aria-label="Zamknij popup StayWell">×</button>

                                    <div class="staywell-popup-content">
                                        <div class="staywell-popup-col staywell-qr-col">
                                            @if (!string.IsNullOrWhiteSpace(_staywellQrDataUri))
                                            {
                                                <img src="@_staywellQrDataUri" alt="Kod QR StayWell" class="staywell-qr" />
                                            }
                                        </div>

                                        <div class="staywell-popup-col staywell-description-col">
                                            <strong class="staywell-popup-title">@Localizer["StaywellPopupTitle"]</strong>
                                            <p class="staywell-popup-description">
                                                <span class="staywell-popup-description-desktop">@Localizer["StaywellPopupDescription"]</span>
                                                <span class="staywell-popup-description-mobile">@Localizer["StaywellPopupDescriptionMobile"]</span>
                                            </p>

                                            <a href="@staywellLink" target="_blank" rel="noopener noreferrer" class="staywell-popup-link">
                                                <span class="staywell-popup-link-desktop">@Localizer["GoToStayWellQRCodePopupText"]</span>
                                                <span class="staywell-popup-link-mobile">@Localizer["GoToStayWellQRCodePopupMobileText"]</span>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                       
                    }
                    else if (IsPaymentInitiated && !ShouldShowTermsAndPayment)
                    {
                        <div class="status-box info-bg">
                            <div class="form-wrapper-title-icon-wrapper info-icon-color rounded-full">
                                <img src="assets/svgs/time.svg" alt="ikona oczekiwania">
                            </div>

                            <div class="status-box-text">
                                <h4 class="info-text-color">@Localizer["WaitingPayment"]</h4>
                                <span>@Localizer["NotRefreshPage"]</span>
                            </div>
                        </div>

                        <button @onclick="RetryPayment" class="button-pending" disabled="@IsRetryPaymentDisabled">
                            @RetryPaymentButtonText
                        </button>
                    }
                    else if (IsPaymentFailed)
                    {
                        <div class="status-box danger-bg">
                            <div class="form-wrapper-title-icon-wrapper danger-icon-color rounded-full">
                                <img src="assets/svgs/danger.svg" alt="ikona bledu">
                            </div>

                            <div class="status-box-text">
                                <h4 class="danger-text-color">@Localizer["PaymentFailed"]</h4>
                                <span>@Localizer["PaymentFailedText"]</span>
                            </div>
                        </div>

                        <button @onclick="RetryPayment" class="button-pending" disabled="@IsRetryPaymentDisabled">
                            @RetryPaymentButtonText
                        </button>
                    }
                    else if (ShouldShowTermsAndPayment)
                    {
                        <div class="status-box pending-bg">
                            <div class="form-wrapper-title-icon-wrapper pending-icon-color rounded-full">
                                <img src="assets/svgs/time.svg" alt="ikona uzytkownika">
                            </div> 
                        
                            <div class="status-box-text">
                                <h4 class="pending-text-color">@Localizer["ReservationPending"]</h4>
                                <span>@Localizer["ReservationPendingInfo"]</span>
                            </div>
                        </div>
                        
                        <div class="customer-terms-section">
                            @if (_isTermsLoading)
                            {
                                <span>@Localizer["Loading"]</span>
                            }
                            else if (_termsSources != null)
                            {
                                <div class="customer-term-row customer-term-row-select-all mb-3 @(AreAllTermsSelected ? "success-bg" : string.Empty)">
                                    <div class="term-checkbox-wrapper">
                                        <input type="checkbox"
                                               class="custom-checkbox"
                                               id="term-select-all"
                                               checked="@AreAllTermsSelected"
                                               @onchange="OnSelectAllTermsChanged" />

                                        <label class="term-label" for="term-select-all">
                                            @Localizer["SelectAllConsents"]
                                        </label>
                                    </div>
                                </div>

                                <div class="customer-terms-group">
                                    @foreach (var term in _termsSources)
                                    {
                                        <div class="customer-term-row mb-3">
                                            <div class="term-checkbox-wrapper">
                                                <input type="checkbox" 
                                                       class="custom-checkbox" 
                                                       id="term-@term.Id" 
                                                       checked="@_userSelections[term.Id]" 
                                                       @onchange="@(e => OnTermChanged(term.Id, e))" />
                
                                                <label class="term-label" for="term-@term.Id">
                                                    @term.Description
                                                    @if (term.IsRequired)
                                                    {
                                                        <span class="required-star" title="@Localizer["FieldRequired"]">*</span>
                                                    }
                                                </label>
                                            </div>

                                            @if (!string.IsNullOrEmpty(term.HtmlContent))
                                            {
                                                <a href="/regulaminy/@term.Id/@GenerateSlug(term.Title ?? term.Description)" target="_blank" class="term-link-icon" title="@Localizer["ViewDocument"]">
                                                    <img src="assets/svgs/external-link.svg" alt="link" style="width: 18px; height: 18px;" />
                                                </a>
                                            }
                                            else if (!string.IsNullOrEmpty(term.Link))
                                            {
                                                <a href="@term.Link" target="_blank" class="term-link-icon" title="@Localizer["ViewDocument"]">
                                                    <img src="assets/svgs/external-link.svg" alt="link" style="width: 18px; height: 18px;" />
                                                </a>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        
                        <button @onclick="GoToPayment" 
                                class="button-pending" 
                                disabled="@(!CanProceedToPayment())"
                                style="@(!CanProceedToPayment() ? "opacity: 0.6; filter: brightness(0.8); cursor: not-allowed;" : "")">
                            <img src="assets/svgs/tpay.svg" alt="Tpay icon"/>
                            @Localizer["ClickToPay"]
                        </button>
                    }
                    else if (@_summary.IdoStatus != "accepted")
                    {
                        <div class="status-box danger-bg">
                            <div class="form-wrapper-title-icon-wrapper danger-icon-color rounded-full">
                                <img src="assets/svgs/danger.svg" alt="ikona uzytkownika">
                            </div> 
                        
                            <div class="status-box-text">
                                <h4 class="danger-text-color">@Localizer["ReservationDanger"]</h4>
                                <span>@Localizer["ReservationDangerInfo"]</span>
                            </div>
                        </div>
                    }
                </div>
                
                <div class="guest-info">
                    <div class="box-text">
                        <img src="assets/svgs/user.svg" alt="ikona uzytkownika" class="box-text-icon">
                        <b class="box-text-title">@Localizer["ClientInfoTitle"]</b>
                    </div>

                    <div class="guest-details-grid">
                        <div class="guest-detail-item">
                            <span class="detail-label">@Localizer["NameLastName"]</span>
                            <span class="detail-value">@_summary?.Client?.FirstName @_summary?.Client?.LastName</span>
                        </div>
                        <div class="guest-detail-item">
                            <span class="detail-label">@Localizer["Email"]</span>
                            <span class="detail-value">@_summary?.Client?.Email</span>
                        </div>
                        <div class="guest-detail-item">
                            <span class="detail-label">@Localizer["Phone"]</span>
                            <span class="detail-value">@_summary?.Client?.Phone</span>
                        </div>
                        <div class="guest-detail-item">
                            <span class="detail-label">@Localizer["Address"]</span>
                            <span class="detail-value">@_summary?.Client?.Street @_summary?.Client?.City @_summary?.Client?.ZipCode</span>
                        </div>
                    </div>
                    
                    @if (ShouldShowTermsAndPayment)
                    {
                        <button class="button" @onclick="GoToClientInfo">@Localizer["Edit"]</button>   
                    }
                </div>
                
                <div class="guest-info">
                    <div class="box-text">
                        <img src="assets/svgs/calendar-2.svg" alt="ikona uzytkownika" class="box-text-icon">
                        <b class="box-text-title">@Localizer["ReservationDetails"]</b>
                    </div>

                    <div class="guest-details-grid">
                        <div class="guest-detail-item">
                            <span class="detail-label">@Localizer["CheckIn"]</span>
                            <span class="detail-value">@_summary?.StartRequest?.StartDate.ToString("yyyy-MM-dd")</span>
                        </div>
                        <div class="guest-detail-item">
                            <span class="detail-label">@Localizer["CheckOut"]</span>
                            <span class="detail-value">@_summary?.StartRequest?.EndDate.ToString("yyyy-MM-dd")</span>
                        </div>
                        <div class="guest-detail-item">
                            <span class="detail-label">@Localizer["Guests"]</span>
                            <span class="detail-value">@(_summary?.StartRequest?.Adults + _summary?.StartRequest?.Children)</span>
                        </div>
                        <div class="guest-detail-item">
                            <span class="detail-label">@Localizer["ConfirmationNumber"]</span>
                            <span class="detail-value">@_summary?.IdoReservationId</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <SummaryBox Summary="_summary" Apartment="_apartment" />
        </div>
    }
</div>

@code {
    [Parameter] public Guid ReservationTokenGuid { get; set; }
    
    private ReservationSummaryDto? _summary;
    private bool _loading = true;
    private string? _error;
    private ApartmentObject? _apartment;
    private bool _isStaywellPopupOpen;
    private string? _staywellQrDataUri;
    private CancellationTokenSource? _paymentPollCts;
    private CancellationTokenSource? _emailPollCts;

    private bool? _emailSent;
    private bool _isCheckingEmail;
    private bool _emailPollStarted;
    private string? _emailError;
    private bool _scrollToTopPending = true;
    private string? _paymentReturn;
    private Guid? _resumePaymentSessionGuid;
    private CancellationTokenSource? _retryCountdownCts;
    private int _retryCountdownSeconds = RetryPaymentDelaySeconds;

    private const int RetryPaymentDelaySeconds = 30;
    private bool _summaryViewedTracked;

    private bool IsPaid => string.Equals(_summary?.PaymentStatus, PaymentStatuses.Paid, StringComparison.OrdinalIgnoreCase);
    private bool IsPaymentInitiated => string.Equals(_summary?.PaymentStatus, PaymentStatuses.Initiated, StringComparison.OrdinalIgnoreCase);
    private bool IsPaymentFailed => string.Equals(_summary?.PaymentStatus, PaymentStatuses.Failed, StringComparison.OrdinalIgnoreCase);
    private bool IsPaymentReturnFailed => string.Equals(_paymentReturn, "failed", StringComparison.OrdinalIgnoreCase);
    private bool ShouldResumeInitiatedPayment => IsPaymentInitiated && _resumePaymentSessionGuid.HasValue;
    private bool ShouldShowPaymentReturnBanner => !IsPaid && !string.IsNullOrWhiteSpace(_paymentReturn);
    private bool ShouldShowRetryPaymentButton => IsPaymentInitiated || IsPaymentFailed;
    private bool IsRetryPaymentDisabled => _retryCountdownSeconds > 0;
    private bool ShouldShowTermsAndPayment => (string.Equals(_summary?.IdoStatus, "waitingForPayment", StringComparison.OrdinalIgnoreCase)
                                              || string.Equals(_summary?.PaymentStatus, "None", StringComparison.OrdinalIgnoreCase)
                                              || ShouldResumeInitiatedPayment)
                                              && !IsPaid
                                              && !IsPaymentFailed;
    
    private string? staywellLink => BuildStaywellLink();

    protected override async Task OnInitializedAsync()
    {
        _staywellQrDataUri = GenerateStaywellQrDataUri();
        ReadPaymentReturnFromQuery();
        ReadResumePaymentSessionFromQuery();

        try
        {
            await RefreshSummaryAsync();
            await EnsureWorkflowChecksAsync();
            StartRetryCountdownIfNeeded();
        }
        catch (Exception ex)
        {
            _error = $"Nie udało się zbudować podsumowania. {ex.Source} {ex.Message} ";
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_scrollToTopPending || _loading)
        {
            return;
        }

        _scrollToTopPending = false;
        await JSRuntime.InvokeVoidAsync("scrollToTop");
    }
    
    private async Task GoToPayment()
    {
        try
        {
            await ReservationWorkflowService.SaveCustomerTermsAsync(ReservationTokenGuid, _userSelections);
            WorkflowTelemetry.TrackEvent(
                "ReservationStepCompleted_Summary",
                new Dictionary<string, string?>
                {
                    ["ReservationTokenGuid"] = ReservationTokenGuid.ToString(),
                    ["ApartmentId"] = _summary?.StartRequest?.ObjectId.ToString(),
                    ["PaymentStatus"] = _summary?.PaymentStatus
                },
                new Dictionary<string, double>
                {
                    ["AcceptedTermsCount"] = _userSelections.Count(x => x.Value)
                });
            Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/oplac");
        }
        catch (Exception)
        {
            _error = "Wystąpił błąd podczas zapisywania zgód. Spróbuj ponownie.";
            WorkflowTelemetry.TrackEvent(
                "ReservationSummarySaveTermsFailed",
                new Dictionary<string, string?>
                {
                    ["ReservationTokenGuid"] = ReservationTokenGuid.ToString()
                });
        }
    }
    
    private void GoToClientInfo()
    {
        Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/dane-klienta");
    }

    private void RetryPayment()
    {
        if (IsRetryPaymentDisabled)
        {
            return;
        }

        WorkflowTelemetry.TrackEvent(
            "ReservationPaymentRetryRequested",
            new Dictionary<string, string?>
            {
                ["ReservationTokenGuid"] = ReservationTokenGuid.ToString(),
                ["PaymentStatus"] = _summary?.PaymentStatus
            });
        Navigation.NavigateTo($"/rezerwuj/{ReservationTokenGuid}/oplac");
    }

    private async Task EnsureWorkflowChecksAsync()
    {
        if (ShouldShowTermsAndPayment)
        {
            await LoadTermsAsync();
        }

        StartPaymentPollingIfNeeded();
        StartEmailPollingIfNeeded();
    }

    private async Task RefreshSummaryAsync()
    {
        _summary = await ReservationWorkflowService.BuildSummaryAsync(ReservationTokenGuid);
        _error = null;
        if (_summary?.StartRequest?.ObjectId != null)
        {
            _apartment = await ApartmentsService.GetApartmentByIdAsync(_summary.StartRequest.ObjectId);
        }

        if (!_summaryViewedTracked)
        {
            _summaryViewedTracked = true;
            WorkflowTelemetry.TrackEvent(
                "ReservationStepViewed_Summary",
                new Dictionary<string, string?>
                {
                    ["ReservationTokenGuid"] = ReservationTokenGuid.ToString(),
                    ["ApartmentId"] = _summary?.StartRequest?.ObjectId.ToString(),
                    ["PaymentStatus"] = _summary?.PaymentStatus,
                    ["IdoStatus"] = _summary?.IdoStatus
                });
        }

        //aut pokazywanie QR kodu StayWell po płatności - na razie wyłączone
      /*  if (IsPaid && !string.IsNullOrWhiteSpace(staywellLink))
        {
            _isStaywellPopupOpen = true;
        }
        */
        StartRetryCountdownIfNeeded();
    }

    private void StartRetryCountdownIfNeeded()
    {
        if (!ShouldShowRetryPaymentButton)
        {
            StopRetryCountdown();
            _retryCountdownSeconds = RetryPaymentDelaySeconds;
            return;
        }

        if (_retryCountdownCts is not null)
        {
            return;
        }

        _retryCountdownSeconds = RetryPaymentDelaySeconds;
        _retryCountdownCts = new CancellationTokenSource();
        _ = RunRetryCountdownAsync(_retryCountdownCts.Token);
    }

    private async Task RunRetryCountdownAsync(CancellationToken token)
    {
        try
        {
            while (_retryCountdownSeconds > 0 && !token.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(1), token);
                _retryCountdownSeconds--;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _retryCountdownCts?.Dispose();
                _retryCountdownCts = null;
            }
        }
    }

    private void StopRetryCountdown()
    {
        _retryCountdownCts?.Cancel();
        _retryCountdownCts?.Dispose();
        _retryCountdownCts = null;
    }

    private void StartPaymentPollingIfNeeded()
    {
        if (!IsPaymentInitiated || _paymentPollCts is not null)
        {
            return;
        }

        _paymentPollCts = new CancellationTokenSource();
        _ = PollPaymentStatusAsync(_paymentPollCts.Token);
    }

    private async Task PollPaymentStatusAsync(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            try
            {
                var state = await ReservationWorkflowService.GetPaymentStateAsync(ReservationTokenGuid);
                if (_summary is not null)
                {
                    _summary.PaymentStatus = state.PaymentStatus;
                    _summary.IdoStatus = state.IdoStatus ?? _summary.IdoStatus;
                }

                if (string.Equals(state.PaymentStatus, PaymentStatuses.Paid, StringComparison.OrdinalIgnoreCase)
                    || string.Equals(state.PaymentStatus, PaymentStatuses.Failed, StringComparison.OrdinalIgnoreCase))
                {
                    WorkflowTelemetry.TrackEvent(
                        string.Equals(state.PaymentStatus, PaymentStatuses.Paid, StringComparison.OrdinalIgnoreCase)
                            ? "ReservationPaymentVerifiedPaid"
                            : "ReservationPaymentVerifiedFailed",
                        new Dictionary<string, string?>
                        {
                            ["ReservationTokenGuid"] = ReservationTokenGuid.ToString(),
                            ["PaymentStatus"] = state.PaymentStatus,
                            ["IdoStatus"] = state.IdoStatus
                        });
                    await RefreshSummaryAsync();
                    await EnsureWorkflowChecksAsync();
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                await InvokeAsync(StateHasChanged);
                await Task.Delay(TimeSpan.FromSeconds(20), token);
            }
            catch (OperationCanceledException) when (token.IsCancellationRequested)
            {
                return;
            }
            catch (Exception ex)
            {
                _error = "Nie udało się pobrać statusu płatności. " + ex.Message;
                await InvokeAsync(StateHasChanged);
                return;
            }
        }
    }

    private void StartEmailPollingIfNeeded()
    {
        if (!IsPaid || _emailPollStarted)
        {
            return;
        }

        _emailPollStarted = true;
        _emailPollCts = new CancellationTokenSource();
        _ = PollEmailStatusAsync(ReservationTokenGuid, _emailPollCts.Token);
    }

    private async Task PollEmailStatusAsync(Guid reservationGuid, CancellationToken token)
    {
        _isCheckingEmail = true;
        _emailError = null;
        _emailSent = null;
        await InvokeAsync(StateHasChanged);

        while (!token.IsCancellationRequested)
        {
            try
            {
                var emailStatus = await ReservationWorkflowService.GetDealEmailStatusAsync(reservationGuid);
                _emailSent = emailStatus.EmailSent;

                if (_emailSent == true)
                {
                    _isCheckingEmail = false;
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                await InvokeAsync(StateHasChanged);
                await Task.Delay(TimeSpan.FromSeconds(2), token);
            }
            catch (OperationCanceledException) when (token.IsCancellationRequested)
            {
                return;
            }
            catch (Exception)
            {
                _emailError = "Nie udało się sprawdzić statusu e-maila.";
                _isCheckingEmail = false;
                await InvokeAsync(StateHasChanged);
                return;
            }
        }
    }

    private void ToggleStaywellPopup()
    {
        if (string.IsNullOrWhiteSpace(_staywellQrDataUri))
        {
            _staywellQrDataUri = GenerateStaywellQrDataUri();
        }

        _isStaywellPopupOpen = !_isStaywellPopupOpen;
    }

    private void CloseStaywellPopup()
    {
        _isStaywellPopupOpen = false;
    }

    private string? GenerateStaywellQrDataUri()
    {
        if (string.IsNullOrWhiteSpace(staywellLink))
        {
            return null;
        }

        using var generator = new QRCodeGenerator();
        using var data = generator.CreateQrCode(staywellLink, QRCodeGenerator.ECCLevel.Q);
        var qr = new PngByteQRCode(data);
        var bytes = qr.GetGraphic(10);

        return $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
    }

    private string? BuildStaywellLink()
    {
        var baseUrl =
            Environment.GetEnvironmentVariable("StayWell__ReservationUrlBase") ??
            Environment.GetEnvironmentVariable("StayWellReservationUrlBase") ??
            Configuration["StayWell:ReservationUrlBase"] ??
            Configuration["StayWellReservationUrlBase"];

        if (string.IsNullOrWhiteSpace(baseUrl))
        {
            return null;
        }

        return baseUrl.Replace("{resToken}", ReservationTokenGuid.ToString(), StringComparison.OrdinalIgnoreCase).TrimEnd('/');
    }

    private void ReadPaymentReturnFromQuery()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("paymentReturn", out var paymentReturn))
        {
            _paymentReturn = paymentReturn.ToString();
        }
    }

    private void ReadResumePaymentSessionFromQuery()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (TryParsePaymentSessionQueryValue(query, "payment_session", out var paymentSessionGuid)
            || TryParsePaymentSessionQueryValue(query, "payment_sessions", out paymentSessionGuid))
        {
            _resumePaymentSessionGuid = paymentSessionGuid;
        }
    }

    private static bool TryParsePaymentSessionQueryValue(
        Dictionary<string, Microsoft.Extensions.Primitives.StringValues> query,
        string key,
        out Guid paymentSessionGuid)
    {
        paymentSessionGuid = Guid.Empty;

        if (!query.TryGetValue(key, out var rawValue))
        {
            return false;
        }

        return Guid.TryParse(rawValue.ToString(), out paymentSessionGuid);
    }

