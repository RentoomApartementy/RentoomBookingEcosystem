@page "/apartamenty-torun"
@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.SharedClasses.Models.RentoomBooking
@using RentoomBooking.SharedClasses.Services
@using RentoomBookingWeb.Components.Shared
@using RentoomBookingWeb.Services.Localization

@using RentoomBookingWeb.Components.Features.AllApartments.Components
@inject IApartmentsService ApartmentsService
@inject NavigationManager Navigation
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<RentoomBookingWeb.Apartments> Localizer
@inject IRouteLocalizationService RouteService

<PageTitle>@Localizer["AllApartments_PageTitle"]</PageTitle>

<HeadContent>
    <meta name="robots" content="index, follow" />
    <meta name="description" content="@Localizer["AllApartments_MetaDescription"]" />
    <HreflangTags CustomUrl="/apartamenty-torun" />
    <BreadcrumbJsonLd CurrentPageName="@Localizer["AllApartments_BreadcrumbName"]" CurrentPagePath="@RouteService.GetUrlWithCulture("/apartamenty-torun", System.Globalization.CultureInfo.CurrentUICulture.Name)" />
</HeadContent>

<HeaderSection Title="@Localizer["AllApartments_HeaderTitle"]" 
               ImagePath="assets/images/rent.jpeg" 
               IsShadow="true" />

<div class="container my-5" style="min-height: 80vh">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="intro-text text-center mb-5">
                <p class="lead">@Localizer["AllApartments_IntroText"]</p>
                <div class="divider"></div>
            </div>

            <div class="mb-4">
                <ApartmentsNameSearchBar @bind-SearchText="_searchText"
                                         Placeholder="@Localizer["AllApartments_SearchPlaceholder"]"
                                         AriaLabel="@Localizer["AllApartments_SearchAriaLabel"]"
                                         ClearAriaLabel="@Localizer["AllApartments_SearchClearAriaLabel"]" />
            </div>

            @if (_isLoading)
            {
                <div class="d-flex justify-content-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">@Localizer["AllApartments_Loading"]</span>
                    </div>
                </div>
            }
            else if (_apartments == null || !_apartments.Any())
            {
                <div class="alert alert-info text-center">
                    @Localizer["AllApartments_NoApartments"]
                </div>
            }
            else
            {
                @if (!FilteredApartments.Any())
                {
                    <div class="alert alert-info text-center">
                        @Localizer["AllApartments_NoApartmentsFound"]
                    </div>
                }
                else
                {
                    <div class="apartments-grid">
                        @foreach (var apartment in FilteredApartments)
                        {
                            <ApartmentListCard Id="@apartment.Id" 
                                               Name="@apartment.Name" 
                                               Url="@GetApartmentUrl(apartment)"
                                               Location="@($"{apartment?.ObjectLocation?.LocalizationItem?.Street} {apartment?.ObjectLocation?.LocalizationItem?.ZipCode} {apartment?.ObjectLocation?.LocalizationItem?.City}")" />
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<ApartmentObject> _apartments = new();
    private bool _isLoading = true;
    private string _searchText = string.Empty;
    private IEnumerable<ApartmentObject> FilteredApartments =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _apartments
            : _apartments.Where(apartment =>
                !string.IsNullOrWhiteSpace(apartment?.Name) &&
                apartment.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await ApartmentsService.GetAllApartmentsList();
            
            if (result?.Items != null)
            {
                _apartments = (List<ApartmentObject>)result.Items;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Błąd pobierania sitemapy: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetApartmentUrl(ApartmentObject item)
    {
        if (item == null) return "#";

        string slug = item.Name?.ToSlug() ?? "szczegoly";
        var path = $"/apartamenty/{item.Id}/{slug}";
        
        return RouteService.GetUrlWithCulture(path, System.Globalization.CultureInfo.CurrentUICulture.Name);
    }
}
