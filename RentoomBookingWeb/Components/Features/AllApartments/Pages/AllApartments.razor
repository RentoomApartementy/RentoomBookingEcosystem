@page "/apartamenty-torun"
@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.SharedClasses.Models.RentoomBooking
@using RentoomBooking.SharedClasses.Services
@using System.Globalization

@using RentoomBookingWeb.Components.Features.AllApartments.Components
@inject IApartmentsService ApartmentsService
@inject NavigationManager Navigation
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<RentoomBookingWeb.Apartments> Localizer

<PageTitle>Apartamenty Toruń - Pełna Lista Noclegów</PageTitle>

<HeadContent>
    <meta name="robots" content="index, follow" />
    <meta name="description" content="Zobacz listę wszystkich naszych apartamentów w Toruniu. Komfortowe noclegi, świetna lokalizacja blisko Starówki. Sprawdź szczegóły każdego apartamentu." />
    <BreadcrumbJsonLd CurrentPageName="@(IsPolish ? "Apartamenty Toruń" : "Apartments in Torun")" CurrentPagePath="/apartamenty-torun" />
</HeadContent>

<HeaderSection Title="@(IsPolish ? "Apartamenty Toruń" : "Apartments Toruń")" 
               ImagePath="assets/images/rent.jpeg" 
               IsShadow="true" />

<div class="container my-5" style="min-height: 80vh">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="intro-text text-center mb-5">
                <p class="lead">@(IsPolish ? "Odkryj naszą pełną ofertę komfortowych apartamentów w samym sercu Torunia." : "Discover our full range of comfortable apartments in the heart of Torun.")</p>
                <div class="divider"></div>
            </div>

            <div class="mb-4">
                <ApartmentsNameSearchBar @bind-SearchText="_searchText"
                                         Placeholder="@(IsPolish ? "Wyszukaj apartament po nazwie..." : "Search apartments by name...")"
                                         AriaLabel="@(IsPolish ? "Wyszukaj apartament po nazwie" : "Search apartment by name")"
                                         ClearAriaLabel="@(IsPolish ? "Wyczyść wyszukiwanie" : "Clear search")" />
            </div>

            @if (_isLoading)
            {
                <div class="d-flex justify-content-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (_apartments == null || !_apartments.Any())
            {
                <div class="alert alert-info text-center">
                    @(IsPolish ? "Obecnie brak dostępnych apartamentów." : "No apartments available at the moment.")
                </div>
            }
            else
            {
                @if (!FilteredApartments.Any())
                {
                    <div class="alert alert-info text-center">
                        @(IsPolish ? "Nie znaleziono apartamentów dla podanej nazwy." : "No apartments found for the entered name.")
                    </div>
                }
                else
                {
                    <div class="apartments-grid">
                        @foreach (var apartment in FilteredApartments)
                        {
                            <ApartmentListCard Id="@apartment.Id" 
                                               Name="@apartment.Name" 
                                               Url="@GetApartmentUrl(apartment)"
                                               Location="@($"{apartment?.ObjectLocation?.LocalizationItem?.Street} {apartment?.ObjectLocation?.LocalizationItem?.ZipCode} {apartment?.ObjectLocation?.LocalizationItem?.City}")" />
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<ApartmentObject> _apartments = new();
    private bool _isLoading = true;
    private string _searchText = string.Empty;
    private bool IsPolish => CultureInfo.CurrentUICulture.Name.StartsWith("pl", StringComparison.OrdinalIgnoreCase);
    private IEnumerable<ApartmentObject> FilteredApartments =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _apartments
            : _apartments.Where(apartment =>
                !string.IsNullOrWhiteSpace(apartment?.Name) &&
                apartment.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await ApartmentsService.GetAllApartmentsList();
            
            if (result?.Items != null)
            {
                _apartments = (List<ApartmentObject>)result.Items;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Błąd pobierania sitemapy: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetApartmentUrl(ApartmentObject item)
    {
        if (item == null) return "#";

        string slug = item.Name?.ToSlug() ?? "szczegoly";
        
        return $"/apartamenty/{item.Id}/{slug}";
    }
}
