@using System.Globalization
@using RentoomBookingWeb.Components.Features.Home.Components
@using RentoomBookingWeb.Components.Features.TorunLocation.Components
@using Microsoft.Extensions.Localization
@inject NavigationManager Navigation
@inject IStringLocalizer<RentoomBookingWeb.SharedResources> Localizer
@inject RentoomBookingWeb.Services.Localization.IRouteLocalizationService RouteService

<PageTitle>@PageTitleText</PageTitle>

<HeadContent>
    <meta name="robots" content="index, follow" />
    <meta name="description" content="@DescriptionText" />
    <meta name="keywords" content="@KeywordsText" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@DescriptionText" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href="@CanonicalUrl" />
    <BreadcrumbJsonLd CurrentPageName="@BreadcrumbName" CurrentPagePath="@RouteService.GetLocalizedUrl("AboutCity")" />
</HeadContent>

 <HeroSection/>

@if (IsPolish)
{
    <TorunLocationPl />
}
else
{
    <TorunLocationEn />
}

@code {
    private bool IsPolish => CultureInfo.CurrentUICulture.Name.StartsWith("pl", StringComparison.OrdinalIgnoreCase);

    private string CanonicalUrl => $"{Navigation.BaseUri.TrimEnd('/')}{RouteService.GetLocalizedUrl("AboutCity")}";

    private string PageTitleText => Localizer["TorunLocation_PageTitle"];

    private string DescriptionText => Localizer["TorunLocation_Description"];

    private string KeywordsText => Localizer["TorunLocation_Keywords"];

    private string BreadcrumbName => Localizer["TorunLocation_Breadcrumb"];
}
