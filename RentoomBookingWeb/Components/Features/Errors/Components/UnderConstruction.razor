
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer

<div class="under-construction-container" style="
    height: 80vh; 
    width: 100%;
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    align-items: center; 
    background-color: #f4f4f4; 
    font-family: sans-serif; 
    text-align: center;
    padding: 20px;
    box-sizing: border-box;">

    <div style="font-size: 5rem; margin-bottom: 1rem;">
        🚧
    </div>

    <h1 style="color: #333; margin: 0; font-size: 2.5rem;">@Localizer["UnderConstruction_Title"]</h1>

    <p style="color: #666; font-size: 1.2rem; margin-top: 1rem; max-width: 600px;">
        @Localizer["UnderConstruction_DescriptionLine1"] <br/>
        @Localizer["UnderConstruction_DescriptionLine2"]
    </p>

    <a href="/" style="
        margin-top: 2rem; 
    ">
        <Button>@Localizer["UnderConstruction_BackHome"]</Button>
    </a>

</div>

