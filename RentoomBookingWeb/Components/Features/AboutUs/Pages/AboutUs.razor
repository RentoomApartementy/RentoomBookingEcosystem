@page "/o-nas";
@using Microsoft.Extensions.Localization;
@inject IStringLocalizer<RentoomBookingWeb.AboutUs> Localizer;
@inject NavigationManager Navigation

<PageTitle>O nas - Rentoom | Profesjonalne Zarządzanie Najmem</PageTitle>

<HeadContent>
    <meta name="description" content="Poznaj zespół Rentoom. Od 6 lat zajmujemy się profesjonalnym zarządzaniem najmem krótkoterminowym, obsługą apartamentów i turystyką. Sprawdź naszą misję." />
    <meta name="keywords" content="zarządzanie najmem, obsługa apartamentów, Rentoom, wynajem krótkoterminowy, zespół Rentoom, inwestycje w nieruchomości" />
    <meta property="og:title" content="O nas - Rentoom | Profesjonalne Zarządzanie Najmem" />
    <meta property="og:description" content="Jesteśmy grupą pasjonatów podróży i ekspertów od nieruchomości. Zobacz, jak możemy pomóc w zarządzaniu Twoim apartamentem." />
    <meta property="og:image" content="assets/images/header-bg-about-us.jpeg" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@Navigation.BaseUri/o-nas" />
    <link rel="canonical" href="@Navigation.BaseUri/o-nas" />
</HeadContent>

<main class="about-container">
    <HeaderSection ImagePath="/assets/images/header-bg-about-us.jpeg" Title="@Localizer["AboutUsText"]" Height="230px" />
    
    <div class="main-wrapper">
        <section class="stats" aria-label="Statystyki firmy">
    <div class="stat-item">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </div>
        <h3>9,7 <span class="accent">/10</span></h3>
        <small>@Localizer["AverageRating"]</small>
    </div>

    <div class="stat-item">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><line x1="9" y1="22" x2="9" y2="22.01"></line><line x1="15" y1="22" x2="15" y2="22.01"></line><line x1="9" y1="18" x2="9" y2="18.01"></line><line x1="15" y1="18" x2="15" y2="18.01"></line><line x1="9" y1="14" x2="9" y2="14.01"></line><line x1="15" y1="14" x2="15" y2="14.01"></line><line x1="9" y1="10" x2="9" y2="10.01"></line><line x1="15" y1="10" x2="15" y2="10.01"></line><line x1="9" y1="6" x2="9" y2="6.01"></line><line x1="15" y1="6" x2="15" y2="6.01"></line></svg>
        </div>
        <h3>50 <span class="accent">+</span></h3>
        <small>@Localizer["ApartmentsManagement"]</small>
    </div>

    <div class="stat-item">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        </div>
        <h3>35</h3>
        <small>@Localizer["CompletedBookings"]</small>
    </div>

    <div class="stat-item">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        </div>
        <h3>300 <span class="accent">K</span></h3>
        <small>@Localizer["QuestsServed"]</small>
    </div>
</section>
        
        <div class="history-mission">
    <section class="hm-card hm-card-dark">
        <div class="hm-header">
            <div class="hm-title-group">
                <div class="hm-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
                </div>
                <h2>@Localizer["HistoryText1"]</h2>
            </div>
            <div class="hm-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
            </div>
        </div>
        <div class="hm-content">
            <p>@Localizer["HistoryText2"]</p>
        </div>
    </section>
    
    <section class="hm-card hm-card-light">
        <div class="hm-header">
            <div class="hm-title-group">
                <div class="hm-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                </div>
                <h2>@Localizer["MissionText1"]</h2>
            </div>
            <div class="hm-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
            </div>
        </div>
        <div class="hm-content">
            <p>@Localizer["MissionText2"]</p>
        </div>
    </section>
</div>

        <hr>
        
        <h2 class="team-title">@Localizer["OurTeamText"]</h2>
        
        <div class="team">
    <article class="team-card">
        <div class="card-image-container">
            <img src="assets/images/test-user-opinion.jpeg" alt="Tomasz" class="card-img">
            <div class="card-overlay">
                <h3>Tomasz</h3>
                <span class="role-badge">CEO & Founder</span>
            </div>
        </div>
        
        <div class="card-content">
            <p>@Localizer["TomaszText1"]</p>
            <div class="team-button-wrapper">
                <button class="btn-call">
                    @Localizer["CallText"] 
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 6px;"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </button>
            </div>
        </div>
    </article>
    
    <article class="team-card">
        <div class="card-image-container">
            <img src="assets/images/test-user-opinion.jpeg" alt="Kamil" class="card-img">
            <div class="card-overlay">
                <h3>Kamil</h3>
                <span class="role-badge">Tech Lead</span>
            </div>
        </div>
        
        <div class="card-content">
            <p>@Localizer["KamilText"]</p>
            <div class="team-button-wrapper">
                <button class="btn-call">
                    @Localizer["CallText"]
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 6px;"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </button>
            </div>
        </div>
    </article>
    
    <article class="team-card">
        <div class="card-image-container">
            <img src="assets/images/test-user-opinion.jpeg" alt="Marta" class="card-img">
            <div class="card-overlay">
                <h3>Marta</h3>
                <span class="role-badge">Head of Operations</span>
            </div>
        </div>
        
        <div class="card-content">
            <p>@Localizer["MartaText1"]</p>
            <div class="team-button-wrapper">
                <button class="btn-call">
                    @Localizer["CallText"]
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 6px;"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </button>
            </div>
        </div>
    </article>
</div>
    </div>
</main>

