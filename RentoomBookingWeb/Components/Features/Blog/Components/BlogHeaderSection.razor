<section class="blog_section_header" @onmouseenter="HandleMouseEnter" @onmouseleave="HandleMouseLeave">
    @for (var index = 0; index < _slides.Count; index++)
    {
        var item = _slides[index];
        var isActive = index == _currentIndex;

        <div @key="item.PublicId" class="blog_header_slide @(isActive ? "is-active" : string.Empty)" aria-hidden="@(!isActive)" inert="@(!isActive)">
            @if (!string.IsNullOrWhiteSpace(item.HeroImageUrl))
            {
                <img src="@item.HeroImageUrl" alt="@item.Title" class="blog_header_bg" fetchpriority="@(isActive ? "high" : "auto")" />
            }

            <div class="blog_header_container">
                <article class="blog_header_card">
                    @{
                        var filteredTags = item.Tags?.Where(tag => !string.Equals(tag, item.Category, System.StringComparison.OrdinalIgnoreCase)).ToList()
                            ?? new System.Collections.Generic.List<string>();
                    }

                    <header class="blog_card_header">
                        <span class="blog_card_read_time">
                            @if (!string.IsNullOrWhiteSpace(item.AuthorDisplayName))
                            {
                                <span>@item.AuthorDisplayName • </span>
                            }
                            @GetReadTimeText(item)
                        </span>
                        <span class="blog_card_date">@item.PublishedAtUtc.ToString("dd.MM.yyyy")</span>
                    </header>

                    @if (UseH1ForTitle && isActive)
                    {
                        <h1 class="blog_card_title">@item.Title</h1>
                    }
                    else
                    {
                        <p class="blog_card_title">@item.Title</p>
                    }

                    <p class="blog_card_excerpt">@item.Excerpt</p>

                    @if (!string.IsNullOrWhiteSpace(item.Category) || filteredTags.Any())
                    {
                        <div class="blog_card_tags">
                            @if (!string.IsNullOrWhiteSpace(item.Category))
                            {
                                <Tag Text="@item.Category" />
                            }

                            @if (!string.IsNullOrWhiteSpace(item.Category) && filteredTags.Any())
                            {
                                <span class="blog_card_separator"></span>
                            }

                            @foreach (var tag in filteredTags)
                            {
                                <Tag Text="@tag" />
                            }
                        </div>
                    }

                    @if (ShowReadMoreButton && isActive)
                    {
                        <div class="blog_card_action">
                            <Button Href="@BuildPostUrl(item.PublicId, item.Slug)" Type="ButtonType.Primary">
                                @Localizer["ReadMore"]
                            </Button>
                        </div>
                    }
                </article>
            </div>
        </div>
    }

    @if (_slides.Count > 1)
    {
        <div class="blog_header_dots" role="tablist" aria-label="@Localizer["CarouselPaginationLabel"]">
            @for (var index = 0; index < _slides.Count; index++)
            {
                var slideIndex = index;
                var isActive = slideIndex == _currentIndex;
                <button type="button"
                        class="blog_header_dot @(isActive ? "active" : string.Empty)"
                        role="tab"
                        aria-selected="@isActive"
                        aria-label="@string.Format(Localizer["GoToSlideAriaLabel"], slideIndex + 1, _slides.Count)"
                        @onclick="() => GoToSlide(slideIndex)"></button>
            }
        </div>
    }
</section>
