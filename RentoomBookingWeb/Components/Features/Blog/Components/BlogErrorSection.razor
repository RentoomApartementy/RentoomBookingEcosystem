@using Microsoft.Extensions.Localization
@using RentoomBookingWeb.Services.Localization
@using RentoomBookingWeb.Components.Shared
@inject IRouteLocalizationService RouteService
@inject IStringLocalizer<RentoomBookingWeb.Blog> Localizer
@inject IStringLocalizer<RentoomBookingWeb.NotFoundPage> NotFoundLocalizer

<div class="blog-error-page">
    <HeaderSection
        ImagePath="assets/images/header-bg-apartments.jpeg"
        Title="@(IsNotFound ? Localizer["PostNotFoundTitle"] : Localizer["ErrorTitle"])"
        IsShadow="true"
    />

    <div class="blog-error-content-wrapper">
        <div class="blog-error-container">
            <div class="blog-error-grid">
                <div class="blog-error-visual">
                    <div class="blog-error-graphic">
                        @if (IsNotFound)
                        {
                            <!-- Document/Search Glass SVG -->
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                            </svg>
                        }
                        else
                        {
                            <!-- Alert Warning SVG -->
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                            </svg>
                        }
                    </div>
                </div>

                <div class="blog-error-text-content">
                    <h2 class="blog-error-main-title">
                        @(IsNotFound ? Localizer["PostNotFoundTitle"] : Localizer["ErrorTitle"])
                    </h2>
                    
                    <p class="blog-error-description">
                        @(IsNotFound ? Localizer["PostNotFoundDescription"] : (ErrorMessage ?? Localizer["ErrorDescription"]))
                    </p>

                    <div class="blog-error-button-group">
                        <Button Href="@RouteService.GetLocalizedUrl("BlogList")" Type="ButtonType.Primary">
                            @Localizer["BackToBlog"]
                        </Button>
                    </div>
                    
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public bool IsNotFound { get; set; } = false;
}
