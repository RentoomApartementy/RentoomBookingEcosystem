@using RentoomBookingWeb.Components.Features.Blog.Components;

<PageTitle>@Localizer["BlogPageTitle"]</PageTitle>

<HeadContent>
    <meta name="robots" content="index, follow" />
    <meta name="description" content="@Localizer["BlogDescription"]" />
    <link rel="canonical" href="@($"{NavManager.BaseUri.TrimEnd('/')}{RouteService.GetLocalizedUrl("BlogList")}")" />
    <SeoHreflangs />
</HeadContent>

@if (Items.Count > 0)
{
    <BlogHeaderSection Item="Items.First()" UseH1ForTitle="true" />
}

@if (!string.IsNullOrWhiteSpace(Error))
{
    <BlogErrorSection ErrorMessage="@Error" IsNotFound="false" />
}
else if (IsLoading && Items.Count == 0)
{
    <p>Loading...</p>
}
else
{
    <div class="blog-list-container">
        <h2 class="blog-list-title">@Localizer["LatestPosts"]</h2>
        
        @if (Items.Skip(1).Any())
        {
            <div class="blog-posts-grid">
                @foreach (var item in Items.Skip(1))
                {
                    <BlogItem Item="item" />
                }
            </div>
        }
        else
        {
            <BlogEmptySection />
        }
    </div>
}

<div id="scroll-anchor" style="height: 10px; width: 100%;"></div>