@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer

@if (IsVisible)
{
    <div class="ai-response-container">
        <div class="ai-response-header">
            <div class="ai-header-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21 11.5C21 16.7467 16.7467 21 11.5 21C6.25329 21 2 16.7467 2 11.5C2 6.25329 6.25329 2 11.5 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M22 22L20 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M15 7L13 9M13 9L11 11M13 9L15 11M13 9L11 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>@Localizer["AiAssistant_Title"]</span>
            </div>
            <button class="close-btn" @onclick="OnClose">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>

        <div class="ai-response-content">
            @if (!string.IsNullOrEmpty(ResponseText))
            {
                <div class="ai-message">
                    @((MarkupString)FormattedResponse)
                </div>
            }

            @if (IsLoading)
            {
                <div class="ai-loading">
                    <span class="dot"></span>
                    <span class="dot"></span>
                    <span class="dot"></span>
                </div>
            }
            
            @if (ApartmentCards != null && ApartmentCards.Any())
            {
                <div class="ai-apartment-results">
                    @* Placeholder for future apartment cards *@
                    <p style="font-size: 0.85rem; color: #666; margin-top: 1rem;">@Localizer["AiAssistant_ResultsFound"]</p>
                </div>
            }
        </div>
    </div>
    
    <div class="ai-backdrop" @onclick="OnClose"></div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string ResponseText { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public List<object> ApartmentCards { get; set; } = new();

    private string FormattedResponse => ResponseText.Replace("\n", "<br />");
}
