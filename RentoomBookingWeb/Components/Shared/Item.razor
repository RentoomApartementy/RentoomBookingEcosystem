@namespace RentoomBookingWeb.Components.Shared

@code {
    [CascadingParameter] private Slider Parent { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized()
    {
        if (Parent == null)
            throw new InvalidOperationException("Item must be inside a Slider component.");

        if (ChildContent != null)
        {
            Parent.RegisterItem(ChildContent);
        }
    }
}