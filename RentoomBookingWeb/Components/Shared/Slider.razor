@namespace RentoomBookingWeb.Components.Shared
@inject IJSRuntime JS
@implements IAsyncDisposable

<CascadingValue Value="this">
    @ChildContent
</CascadingValue>

<div class="slider-container" @ref="_sliderContainer">
    <div class="slider-wrapper @TransitionClass" style="transform: translateX(-@(CurrentIndex * 100)%)">
        @foreach (var chunk in ChunkedItems)
        {
            <div class="slider-page">
                @foreach (var fragment in chunk)
                {
                    @fragment
                }
            </div>
        }
    </div>

    <div class="slider-dots">
        @for (int i = 0; i < ChunkedItems.Count; i++)
        {
            var index = i; 
            <button class="dot @(index == CurrentIndex ? "active" : "")"
                    @onclick="() => GoToSlide(index)">
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string TransitionClass { get; set; } = "slide-transition";
    [Parameter] public int ItemsPerPage { get; set; } = 3;

    internal List<RenderFragment> _items { get; set; } = new();
    private List<List<RenderFragment>> ChunkedItems { get; set; } = new();
    private int CurrentIndex { get; set; } = 0;
    private int _defaultItemsPerPage;
    private bool _isDisposed = false; 
    
    private ElementReference _sliderContainer;
    private DotNetObjectReference<Slider>? objRef;
    private IJSObjectReference? _jsManager;
    private IJSObjectReference? _jsModule;

    protected override void OnInitialized()
    {
        _defaultItemsPerPage = ItemsPerPage;
    }

    internal void RegisterItem(RenderFragment fragment)
    {
        _items.Add(fragment);
        SplitIntoChunks();
        StateHasChanged();
    }

    private void SplitIntoChunks()
    {
        int safeItemsPerPage = ItemsPerPage > 0 ? ItemsPerPage : 1;
        ChunkedItems = _items
            .Select((x, i) => new { x, i })
            .GroupBy(x => x.i / safeItemsPerPage)
            .Select(g => g.Select(v => v.x).ToList())
            .ToList();

        if (ChunkedItems.Count > 0)
        {
            CurrentIndex = Math.Clamp(CurrentIndex, 0, ChunkedItems.Count - 1);
        }
        else 
        {
            CurrentIndex = 0;
        }
    }

    private void GoToSlide(int index)
    {
        if (ChunkedItems.Count == 0) return;
        CurrentIndex = Math.Clamp(index, 0, ChunkedItems.Count - 1);
        StateHasChanged();
    }

    [JSInvokable]
    public void NextSlide()
    {
        if (_isDisposed) return;

        if (CurrentIndex < ChunkedItems.Count - 1)
        {
            CurrentIndex++;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void PrevSlide()
    {
        if (_isDisposed) return;

        if (CurrentIndex > 0)
        {
            CurrentIndex--;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_isDisposed)
        {
            try 
            {
                objRef = DotNetObjectReference.Create(this);
                _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/sliderGestures.js?v=" + DateTime.Now.Ticks);
                
                if (_isDisposed) return;
                
                _jsManager = await _jsModule.InvokeAsync<IJSObjectReference>("initSlider", objRef, _sliderContainer);
            }
            catch (Exception) when (_isDisposed)
            {
            }
        }
    }

    [JSInvokable]
    public void UpdateItemPerPageAsync(int width)
    {
        if (_isDisposed || objRef == null) return;
    
        int newItemsPerPage;

        if (_defaultItemsPerPage <= 1)
        {
            newItemsPerPage = 1;
        }
        else
        {
            if (width < 750) 
            {
                newItemsPerPage = 1;
            }
            else if (width < 1300) 
            {
                newItemsPerPage = 2;
            }
            else if (width < 1600) 
            {
                newItemsPerPage = 3;
            }
            else 
            {
                newItemsPerPage = _defaultItemsPerPage;
            }

            newItemsPerPage = Math.Min(newItemsPerPage, _defaultItemsPerPage);
        }

        if (ItemsPerPage != newItemsPerPage)
        {
            ItemsPerPage = newItemsPerPage;
            SplitIntoChunks();
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true; 

        try 
        {
            if (_jsManager != null)
            {
                _ = _jsManager.InvokeVoidAsync("dispose");
                await _jsManager.DisposeAsync();
            }

            if (_jsModule != null)
            {
                await _jsModule.DisposeAsync();
            }
        }
        catch (Exception)
        {
        }
        
        if (objRef != null)
        {
            var zombieRef = objRef; 
            objRef = null;

            _ = Task.Run(async () => 
            {
                try 
                {
                    await Task.Delay(5000); 
                    zombieRef.Dispose();
                }
                catch { }
            });
        }
    }
}