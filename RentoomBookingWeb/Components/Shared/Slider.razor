@namespace RentoomBookingWeb.Components.Shared
@typeparam TItem
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="slider-container" @ref="_sliderContainer">
    <div class="slider-track slide-transition"
         style="transform: translateX(-@GetTranslatePercent()%); width: @GetTrackWidth()%;">
        @foreach (var item in Items)
        {
            <div class="slider-item-wrapper" style="width: @GetItemWidth()%; flex: 0 0 @GetItemWidth()%;">
                @ItemTemplate(item)
            </div>
        }
    </div>

    @if (PageCount > 1)
    {
        <div class="slider-dots">
            @for (int i = 0; i < PageCount; i++)
            {
                var index = i;
                <button class="dot @(index == CurrentIndex ? "active" : "")" @onclick="() => GoToSlide(index)"></button>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<TItem> Items { get; set; } = Array.Empty<TItem>();
    [Parameter, EditorRequired] public RenderFragment<TItem> ItemTemplate { get; set; } = default!;
    [Parameter] public int ItemsPerPage { get; set; } = 3;

    private int CurrentIndex { get; set; } = 0;
    private int _defaultItemsPerPage;
    private bool _isDisposed = false;

    private ElementReference _sliderContainer;
    private DotNetObjectReference<Slider<TItem>>? objRef;
    private IJSObjectReference? _jsManager;
    private IJSObjectReference? _jsModule;

    private int TotalItems => Items?.Count ?? 0;

    private int PageCount => TotalItems == 0 || ItemsPerPage <= 0
        ? 1
        : (int)Math.Ceiling((double)TotalItems / ItemsPerPage);

    // tracker szerszy od kontenera o tyle razy ile jest stron
    private double GetTrackWidth() => PageCount * 100.0;

    // każdy item = 1 / TotalItems szerokości trackera
    // co odpowiada dokładnie 1/ItemsPerPage szerokości kontenera
    private double GetItemWidth() => TotalItems > 0 ? 100.0 / TotalItems : 100.0;

    // przesunięcie o 1 stronę = 100% / PageCount szerokości trackera
    private double GetTranslatePercent() => TotalItems == 0 ? 0 : CurrentIndex * (100.0 / PageCount);

    protected override void OnInitialized()
    {
        _defaultItemsPerPage = ItemsPerPage;
    }

    protected override void OnParametersSet()
    {
        ClampCurrentIndex();
    }

    private void ClampCurrentIndex()
    {
        CurrentIndex = PageCount > 0 ? Math.Clamp(CurrentIndex, 0, PageCount - 1) : 0;
    }

    private void GoToSlide(int index)
    {
        CurrentIndex = Math.Clamp(index, 0, PageCount - 1);
        StateHasChanged();
    }

    [JSInvokable]
    public void NextSlide()
    {
        if (_isDisposed) return;
        if (CurrentIndex < PageCount - 1)
        {
            CurrentIndex++;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void PrevSlide()
    {
        if (_isDisposed) return;
        if (CurrentIndex > 0)
        {
            CurrentIndex--;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void UpdateItemPerPageAsync(int width)
    {
        if (_isDisposed) return;

        int newItemsPerPage;

        if (_defaultItemsPerPage <= 1)
        {
            newItemsPerPage = 1;
        }
        else
        {
            if (width < 750)
                newItemsPerPage = 1;
            else if (width < 1300)
                newItemsPerPage = 2;
            else if (width < 1600)
                newItemsPerPage = 3;
            else
                newItemsPerPage = _defaultItemsPerPage;

            newItemsPerPage = Math.Min(newItemsPerPage, _defaultItemsPerPage);
        }

        if (ItemsPerPage != newItemsPerPage)
        {
            ItemsPerPage = newItemsPerPage;
            ClampCurrentIndex();
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_isDisposed)
        {
            try
            {
                objRef = DotNetObjectReference.Create(this);
                _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/sliderGestures.js?v=" + DateTime.Now.Ticks);
                if (_isDisposed) return;
                _jsManager = await _jsModule.InvokeAsync<IJSObjectReference>("initSlider", objRef, _sliderContainer);
            }
            catch (Exception) when (_isDisposed) { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        try
        {
            if (_jsManager != null)
            {
                _ = _jsManager.InvokeVoidAsync("dispose");
                await _jsManager.DisposeAsync();
            }
            if (_jsModule != null)
                await _jsModule.DisposeAsync();
        }
        catch (Exception) { }

        if (objRef != null)
        {
            var zombieRef = objRef;
            objRef = null;
            _ = Task.Run(async () =>
            {
                try { await Task.Delay(5000); zombieRef.Dispose(); }
                catch { }
            });
        }
    }
}