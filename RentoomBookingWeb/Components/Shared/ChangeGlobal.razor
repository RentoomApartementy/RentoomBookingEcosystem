@using System.Globalization
@using RentoomBooking.SharedFrontend.Localization
@using RentoomBookingWeb.Services.Localization
@inject NavigationManager Navigation
@inject IRouteLocalizationService RouteService

<div class="language-switcher-container">
    @* Dodano warunkową klasę 'scrolled' *@
    <div class="language-switcher-button @(IsScrolling ? "scrolled" : "")" @onclick="ToggleDropdown">
        <span class="language-icon">
            <img src="@(IsScrolling ? "assets/svgs/globe-green.svg" : "assets/svgs/globe.svg")" alt="Globe icon"/>
        </span>
        <span class="language-code">@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.ToUpper()</span>
    </div>

    @if (_isDropdownOpen)
    {
        <div class="language-dropdown">
            @foreach (var culture in _supportedCultures)
            {
                <button @onclick="(() => ApplySelectedCultureAsync(culture.Name))"
                        class="@(CultureInfo.CurrentUICulture.Name == culture.Name ? "active" : "")">
                    @SupportedLanguagesProvider.GetLanguageLabel(culture)
                </button>
            }
        </div>
    }
</div>

@code
{
    [Parameter] public bool IsScrolling { get; set; } = false;
    
    private bool _isDropdownOpen = false;
    
    private readonly IReadOnlyList<CultureInfo> _supportedCultures = SupportedLanguagesProvider.SupportedCultures;

    private void ToggleDropdown() => _isDropdownOpen = !_isDropdownOpen;

    private void ApplySelectedCultureAsync(string selectedCulture)
    {
        if (CultureInfo.CurrentUICulture.Name == selectedCulture)
        {
            _isDropdownOpen = false;
            return;
        }

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        
        // Remove existing culture prefix if any
        var parts = relativePath.Split('/');
        string? currentSlug = null;
        string? currentCultureInUrl = null;

        if (parts.Length > 0 && SupportedLanguagesProvider.SupportedCultureNames.Any(c => string.Equals(c.Split('-')[0], parts[0], StringComparison.OrdinalIgnoreCase) || string.Equals(c, parts[0], StringComparison.OrdinalIgnoreCase)))
        {
            currentCultureInUrl = parts[0];
            currentSlug = parts.Length > 1 ? parts[1].Split('?')[0] : null;
        }
        else
        {
            currentSlug = parts[0].Split('?')[0];
        }
        
        string newUri;
        if (!string.IsNullOrEmpty(currentSlug) && RouteService.TryGetPageKeyFromSlug(currentSlug, currentCultureInUrl ?? CultureInfo.CurrentUICulture.Name, out var pageKey))
        {
            newUri = RouteService.GetLocalizedUrl(pageKey!, selectedCulture);
            if (uri.Query.Length > 0) newUri += uri.Query;
        }
        else if (string.IsNullOrEmpty(currentSlug) || currentSlug == "/")
        {
            newUri = $"/{GetShortCode(selectedCulture)}";
        }
        else
        {
            // Fallback for special pages or if current slug wasn't in registry
            // Try to see if it's a canonical slug first
            var pageKeyFromCanonical = GetPageKeyFromCanonicalSlug(currentSlug);
            if (pageKeyFromCanonical != null)
            {
                newUri = RouteService.GetLocalizedUrl(pageKeyFromCanonical, selectedCulture);
            }
            else
            {
                // Last resort: keep the slug as is but change the culture prefix
                newUri = $"/{GetShortCode(selectedCulture)}/{currentSlug}";
            }
            
            if (uri.Query.Length > 0) newUri += uri.Query;
        }

        _isDropdownOpen = false; 
        Navigation.NavigateTo(newUri, forceLoad: true);
    }

    private string GetShortCode(string culture) => culture.Split('-')[0].ToLowerInvariant();

    private string? GetPageKeyFromCanonicalSlug(string slug) => slug.ToLower() switch
    {
        "apartamenty" => "Apartments",
        "kontakt" => "Contact",
        "wspolpraca" => "Cooperation",
        "regulaminy" => "Statute",
        "polozenie-torunia" => "AboutCity",
        "torun" => "AboutCity",
        _ => null
    };
}

