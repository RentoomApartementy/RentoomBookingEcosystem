@using System.Globalization
@using RentoomBookingWeb.Helpers
@inject NavigationManager Navigation

<div class="language-switcher-container">
    @* Dodano warunkową klasę 'scrolled' *@
    <div class="language-switcher-button @(IsScrolling ? "scrolled" : "")" @onclick="ToggleDropdown">
        <span class="language-icon">
            <img src="@(IsScrolling ? "/assets/svgs/globe-green.svg" : "/assets/svgs/globe.svg")" alt="Globe icon"/>
        </span>
        <span class="language-code">@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.ToUpper()</span>
    </div>

    @if (_isDropdownOpen)
    {
        <div class="language-dropdown">
            @foreach (var culture in _supportedCultures)
            {
                <button @onclick="(() => ApplySelectedCultureAsync(culture.Name))"
                        class="@(CultureInfo.CurrentUICulture.Name == culture.Name ? "active" : "")">
                    @culture.TwoLetterISOLanguageName.ToUpper()
                </button>
            }
        </div>
    }
</div>

@code
{
    [Parameter] public bool IsScrolling { get; set; } = false;
    
    private bool _isDropdownOpen = false;
    
    private readonly CultureInfo[] _supportedCultures = new[]
    {
        new CultureInfo("pl-PL"),
        new CultureInfo("en-US"),
    };

    private void ToggleDropdown() => _isDropdownOpen = !_isDropdownOpen;

    [Inject] public IJSRuntime JS { get; set; } = default!;

    private async Task ApplySelectedCultureAsync(string selectedCultureName)
    {
        if (CultureInfo.CurrentUICulture.Name == selectedCultureName)
        {
            _isDropdownOpen = false;
            return;
        }

        // Set the cookie so Blazor Server (WebSockets) knows the culture
        // Format: c=en-US|uic=en-US
        var cookieValue = $"c={selectedCultureName}|uic={selectedCultureName}";
        await JS.InvokeVoidAsync("eval", $"document.cookie = '.AspNetCore.Culture={cookieValue}; path=/; max-age=31536000'");

        var uri = new Uri(Navigation.Uri);
        var path = uri.AbsolutePath;
        
        // Remove existing culture prefix if any
        var cleanPath = NavigationHelper.RemoveCultureFromPath(path);
        
        // Get two-letter code for the URL
        var culture = new CultureInfo(selectedCultureName);
        var cultureCode = culture.TwoLetterISOLanguageName.ToLower();

        // Construct new URL with prefix and preserve query string
        var newPath = NavigationHelper.GetLocalizedUrl(cleanPath, cultureCode);
        
        var newUri = new UriBuilder(uri)
        {
            Path = newPath
        }.ToString();

        _isDropdownOpen = false; 
        Navigation.NavigateTo(newUri, forceLoad: true);
    }
}