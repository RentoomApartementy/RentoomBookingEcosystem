@using System.Globalization
@using System.Text.Json
@inject NavigationManager Navigation

@if (!string.IsNullOrWhiteSpace(JsonLd))
{
    <script type="application/ld+json">
        @((MarkupString)JsonLd)
    </script>
}

@code {
    [Parameter, EditorRequired] public string CurrentPageName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string CurrentPagePath { get; set; } = string.Empty;
    [Parameter] public string? ParentPageName { get; set; }
    [Parameter] public string? ParentPagePath { get; set; }

    private string JsonLd
    {
        get
        {
            if (string.IsNullOrWhiteSpace(CurrentPageName) || string.IsNullOrWhiteSpace(CurrentPagePath))
            {
                return string.Empty;
            }

            var items = new List<object>();
            var position = 1;

            items.Add(new
            {
                @type = "ListItem",
                position = position++,
                name = HomeLabel,
                item = ToAbsoluteUrl("/")
            });

            if (!string.IsNullOrWhiteSpace(ParentPageName) && !string.IsNullOrWhiteSpace(ParentPagePath))
            {
                items.Add(new
                {
                    @type = "ListItem",
                    position = position++,
                    name = ParentPageName,
                    item = ToAbsoluteUrl(ParentPagePath)
                });
            }

            if (!IsHome(CurrentPagePath))
            {
                items.Add(new
                {
                    @type = "ListItem",
                    position,
                    name = CurrentPageName,
                    item = ToAbsoluteUrl(CurrentPagePath)
                });
            }

            return JsonSerializer.Serialize(new
            {
                @context = "https://schema.org",
                @type = "BreadcrumbList",
                itemListElement = items
            });
        }
    }

    private string HomeLabel => CultureInfo.CurrentUICulture.Name.StartsWith("pl", StringComparison.OrdinalIgnoreCase)
        ? "Strona główna"
        : "Home";

    private static bool IsHome(string path)
    {
        var normalizedPath = path.Trim();
        return normalizedPath == "/" || string.IsNullOrWhiteSpace(normalizedPath);
    }

    private string ToAbsoluteUrl(string path)
    {
        if (Uri.TryCreate(path, UriKind.Absolute, out var absoluteUri))
        {
            return absoluteUri.ToString();
        }

        return $"{Navigation.BaseUri.TrimEnd('/')}/{path.TrimStart('/')}";
    }
}
