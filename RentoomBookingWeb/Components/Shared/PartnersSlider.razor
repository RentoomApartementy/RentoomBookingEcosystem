@namespace RentoomBookingWeb.Components.Shared

<div class="partners-slider">
    <div class="slider-track">
        @* We render the list twice to achieve seamless looping *@
        @for (int i = 0; i < 2; i++)
        {
            @foreach (var partner in Partners)
            {
                @if (!string.IsNullOrEmpty(partner.Link))
                {
                    <a href="@partner.Link" target="_blank" rel="noopener noreferrer" class="partner-item-link" title="@partner.Label">
                        <div class="partner-item-wrapper">
                            <img src="@partner.ImageUrl" alt="@partner.Label" class="partner-img" loading="lazy" />
                        </div>
                    </a>
                }
                else
                {
                    <div class="partner-item-wrapper" title="@partner.Label">
                        <img src="@partner.ImageUrl" alt="@partner.Label" class="partner-img" loading="lazy" />
                    </div>
                }
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public List<PartnerItem> Partners { get; set; } = new();

    public class PartnerItem
    {
        public string ImageUrl { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string? Link { get; set; }
    }
}
