@page "/404"
@using Microsoft.Extensions.Localization
@using RentoomBookingWeb.Components.Enums
@using RentoomBookingWeb.Components.Shared
@inject IStringLocalizer<RentoomBookingWeb.Apartment> Localizer
@inject NavigationManager Navigation

<PageTitle>@Localizer["PageNotFoundTitle"] - Rentoom</PageTitle>

<div class="not-found-page">
    <HeaderSection 
        ImagePath="assets/images/header-bg-apartments.jpeg"
        Title='@Localizer["NotFoundHeaderTitle"]'
        Height="350px"
        IsShadow="true"
    />

    <div class="content-wrapper">
        <div class="container">
            <div class="error-grid">
                <div class="error-visual">
                    <div class="giant-404">404</div>
                </div>
                
                <div class="error-content">
                    <h1 class="main-title">@Localizer["PageNotFoundTitle"]</h1>
                    <p class="description">@Localizer["PageNotFoundDescription"]</p>
                    
                    <div class="button-group">
                        <Button Type="ButtonType.Primary" @onclick='(() => Navigation.NavigateTo("/"))'>
                            @Localizer["BackToHome"]
                        </Button>
                    </div>

                    <div class="links-shortcut">
                        <span>@Localizer["NotFoundMaybeLookingFor"]</span>
                        <ul>
                            <li><a href="/apartamenty">@Localizer["NotFoundApartmentsList"]</a></li>
                            <li><a href="/wspolpraca">@Localizer["NotFoundCooperation"]</a></li>
                            <li><a href="/kontakt">@Localizer["NotFoundContact"]</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .not-found-page {
        display: flex;
        flex-direction: column;
        min-height: 85vh;
        background-color: #fff;
    }

    .content-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        padding: 60px 20px;
    }

    .container {
        max-width: 1000px;
        margin: 0 auto;
        width: 100%;
    }

    .error-grid {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 60px;
        align-items: center;
    }

    .error-visual {
        text-align: center;
    }

    .giant-404 {
        font-size: 10rem;
        font-weight: 900;
        color: #f0f0f0;
        position: relative;
        line-height: 1;
        letter-spacing: -5px;
    }

    .giant-404::after {
        content: "404";
        position: absolute;
        top: 4px;
        left: 4px;
        color: #1a1a1a;
        z-index: 1;
    }

    .main-title {
        font-size: 3rem;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 20px;
        line-height: 1.1;
    }

    .description {
        font-size: 1.25rem;
        color: #666;
        margin-bottom: 40px;
        max-width: 500px;
        line-height: 1.6;
    }

    .button-group {
        display: flex;
        gap: 15px;
        margin-bottom: 50px;
    }

    .links-shortcut {
        border-top: 1px solid #eee;
        padding-top: 30px;
    }

    .links-shortcut span {
        display: block;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #999;
        margin-bottom: 15px;
    }

    .links-shortcut ul {
        list-style: none;
        padding: 0;
        display: flex;
        gap: 30px;
    }

    .links-shortcut a {
        color: #1a1a1a;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: color 0.2s;
    }

    .links-shortcut a:hover {
        color: #666;
    }

    @@media (max-width: 900px) {
        .error-grid {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 40px;
        }
        .error-content {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .main-title {
            font-size: 2.2rem;
        }
        .giant-404 {
            font-size: 7rem;
        }
        .button-group {
            flex-direction: column;
            width: 100%;
        }
        .links-shortcut ul {
            justify-content: center;
            flex-wrap: wrap;
            gap: 15px 30px;
        }
    }
</style>
