@page "/404"
@implements IDisposable
@using Microsoft.Extensions.Localization
@using RentoomBookingWeb.Components.Enums
@using RentoomBookingWeb.Components.Shared
@using RentoomBookingWeb.Services
@using Microsoft.AspNetCore.WebUtilities
@inject IStringLocalizer<RentoomBookingWeb.Apartment> Localizer
@inject NavigationManager Navigation
@inject GoogleAnalyticsService GoogleAnalytics
@inject ReservationWorkflowTelemetry WorkflowTelemetry

<PageTitle>@Localizer["PageNotFoundTitle"] - Rentoom</PageTitle>

<div class="not-found-page">
    <HeaderSection
        ImagePath="assets/images/header-bg-apartments.jpeg"
        Title='@Localizer["NotFoundHeaderTitle"]'
        Height="350px"
        IsShadow="true"
    />

    <div class="content-wrapper">
        <div class="container">
            <div class="error-grid">
                <div class="error-visual">
                    <div class="giant-404">404</div>
                </div>

                <div class="error-content">
                    <h1 class="main-title">@Localizer["PageNotFoundTitle"]</h1>
                    <p class="description">@Localizer["PageNotFoundDescription"]</p>

                    <div class="button-group">
                        <Button Type="ButtonType.Primary" @onclick='(() => Navigation.NavigateTo("/"))'>
                            @Localizer["BackToHome"]
                        </Button>
                    </div>

                    <div class="links-shortcut">
                        <span>@Localizer["NotFoundMaybeLookingFor"]</span>
                        <ul>
                            <li><a href="/apartamenty">@Localizer["NotFoundApartmentsList"]</a></li>
                            <li><a href="/wspolpraca">@Localizer["NotFoundCooperation"]</a></li>
                            <li><a href="/kontakt">@Localizer["NotFoundContact"]</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (_showRedirectPopup)
    {
        <div class="redirect-popup-backdrop"></div>
        <div class="redirect-popup-shell">
            <div class="redirect-popup-card" role="dialog" aria-modal="true" aria-labelledby="redirect-popup-title">
                <img class="redirect-popup-logo" src="assets/images/rentoom-logo-2025.png" alt="Rentoom" />
                <div class="redirect-popup-code">404</div>

                <div class="redirect-popup-message">
                    <AppError Title="@GetPopupTitle()"
                              Message="@GetPopupMessage()"
                              Dismissible="false" />
                </div>

                <p id="redirect-popup-title" class="redirect-popup-secondary">
                    @GetPopupSecondaryText()
                </p>

                <button type="button" class="redirect-popup-button" @onclick="RedirectByClickAsync">
                    @GetRedirectButtonText()
                </button>
            </div>
        </div>
    }
</div>

@code {
    private const int AutoRedirectDelaySeconds = 5;

    private int _secondsRemaining = AutoRedirectDelaySeconds;
    private bool _showRedirectPopup = true;
    private bool _redirectTriggered;
    private string? _reason;
    private CancellationTokenSource? _redirectCts;

    protected override void OnInitialized()
    {
        ReadReasonFromQuery();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await TrackNotFoundEventAsync("NotFoundPageDisplayed");
        if (ShouldAutoRedirect())
        {
            StartAutoRedirectCountdown();
        }
    }

    private void StartAutoRedirectCountdown()
    {
        _redirectCts = new CancellationTokenSource();
        _ = RunAutoRedirectCountdownAsync(_redirectCts.Token);
    }

    private async Task RunAutoRedirectCountdownAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (_secondsRemaining > 0)
            {
                await Task.Delay(1000, cancellationToken);
                _secondsRemaining--;
                await InvokeAsync(StateHasChanged);
            }

            await RedirectAsync("NotFoundAutoRedirectTriggered");
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task RedirectByClickAsync()
    {
        await RedirectAsync("NotFoundRedirectButtonClicked");
    }

    private async Task RedirectAsync(string eventName)
    {
        if (_redirectTriggered)
        {
            return;
        }

        _redirectTriggered = true;
        _redirectCts?.Cancel();
        await TrackNotFoundEventAsync(eventName);
        Navigation.NavigateTo(GetRedirectTargetPath(), forceLoad: true);
    }

    private async Task TrackNotFoundEventAsync(string eventName)
    {
        var path = new Uri(Navigation.Uri).PathAndQuery;
        var aiProperties = new Dictionary<string, string?>
        {
            ["Path"] = path,
            ["TargetPath"] = GetRedirectTargetPath(),
            ["Language"] = System.Globalization.CultureInfo.CurrentUICulture.Name,
            ["Reason"] = _reason
        };

        WorkflowTelemetry.TrackEvent(eventName, aiProperties);

        await GoogleAnalytics.TrackEventAsync(
            eventName,
            new Dictionary<string, object?>
            {
                ["path"] = path,
                ["target_path"] = GetRedirectTargetPath(),
                ["language"] = System.Globalization.CultureInfo.CurrentUICulture.Name,
                ["reason"] = _reason
            });
    }

    private void ReadReasonFromQuery()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("reason", out var reason))
        {
            _reason = reason.ToString();
        }
    }

    private bool IsReservationCanceledReason()
    {
        return string.Equals(_reason, "reservation-canceled", StringComparison.OrdinalIgnoreCase);
    }

    private bool ShouldAutoRedirect()
    {
        return !IsReservationCanceledReason();
    }

    private string GetRedirectTargetPath()
    {
        return "/apartamenty";
    }

    private string GetPopupTitle()
    {
        if (IsReservationCanceledReason())
        {
            return Localizer["NotFoundPopupTitleReservationCanceled"];
        }

        return Localizer["NotFoundPopupTitleDefault"];
    }

    private string GetPopupMessage()
    {
        if (IsReservationCanceledReason())
        {
            return Localizer["NotFoundPopupMessageReservationCanceled"];
        }

        return Localizer["NotFoundPopupMessageDefault"];
    }

    private string GetPopupSecondaryText()
    {
        return Localizer["NotFoundPopupSecondaryText"];
    }

    private string GetRedirectButtonText()
    {
        if (IsReservationCanceledReason())
        {
            return Localizer["NotFoundPopupButton"];
        }

        return Localizer["NotFoundPopupButtonWithCountdown", _secondsRemaining];
    }

    public void Dispose()
    {
        _redirectCts?.Cancel();
        _redirectCts?.Dispose();
    }
}

<style>
    .not-found-page {
        display: flex;
        flex-direction: column;
        min-height: 85vh;
        background-color: #fff;
    }

    .content-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        padding: 60px 20px;
    }

    .container {
        max-width: 1000px;
        margin: 0 auto;
        width: 100%;
    }

    .error-grid {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 60px;
        align-items: center;
    }

    .error-visual {
        text-align: center;
    }

    .giant-404 {
        font-size: 10rem;
        font-weight: 900;
        color: #f0f0f0;
        position: relative;
        line-height: 1;
        letter-spacing: -5px;
    }

    .giant-404::after {
        content: "404";
        position: absolute;
        top: 4px;
        left: 4px;
        color: #1a1a1a;
        z-index: 1;
    }

    .main-title {
        font-size: 3rem;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 20px;
        line-height: 1.1;
    }

    .description {
        font-size: 1.25rem;
        color: #666;
        margin-bottom: 40px;
        max-width: 500px;
        line-height: 1.6;
    }

    .button-group {
        display: flex;
        gap: 15px;
        margin-bottom: 50px;
    }

    .links-shortcut {
        border-top: 1px solid #eee;
        padding-top: 30px;
    }

    .links-shortcut span {
        display: block;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #999;
        margin-bottom: 15px;
    }

    .links-shortcut ul {
        list-style: none;
        padding: 0;
        display: flex;
        gap: 30px;
    }

    .links-shortcut a {
        color: #1a1a1a;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: color 0.2s;
    }

    .links-shortcut a:hover {
        color: #666;
    }

    .redirect-popup-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(13, 20, 22, 0.5);
        backdrop-filter: blur(5px);
        z-index: 1090;
    }

    .redirect-popup-shell {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        z-index: 1100;
    }

    .redirect-popup-card {
        width: min(100%, 540px);
        padding: 28px 26px 26px;
        border-radius: 24px;
        background: #fff;
        box-shadow: 0 26px 70px rgba(0, 0, 0, 0.22);
        text-align: center;
    }

    .redirect-popup-logo {
        display: block;
        width: min(220px, 60%);
        height: auto;
        margin: 0 auto 18px;
    }

    .redirect-popup-code {
        margin-bottom: 14px;
        color: #66716d;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.04em;
    }

    .redirect-popup-message {
        display: flex;
        justify-content: center;
        margin-bottom: 14px;
    }

    .redirect-popup-secondary {
        margin: 0 0 20px;
        color: #6b6b6b;
        font-size: 0.95rem;
    }

    .redirect-popup-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 260px;
        min-height: 52px;
        padding: 0 24px;
        border: none;
        border-radius: 999px;
        background: linear-gradient(135deg, #1f5b4f, #2e7d6b);
        color: #fff;
        font-size: 1rem;
        font-weight: 700;
        box-shadow: 0 14px 28px rgba(31, 91, 79, 0.22);
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .redirect-popup-button:hover {
        transform: translateY(-1px);
        box-shadow: 0 18px 34px rgba(31, 91, 79, 0.28);
    }

    @@media (max-width: 900px) {
        .error-grid {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 40px;
        }

        .error-content {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .main-title {
            font-size: 2.2rem;
        }

        .giant-404 {
            font-size: 7rem;
        }

        .button-group {
            flex-direction: column;
            width: 100%;
        }

        .links-shortcut ul {
            justify-content: center;
            flex-wrap: wrap;
            gap: 15px 30px;
        }
    }

    @@media (max-width: 640px) {
        .redirect-popup-card {
            padding: 24px 18px 20px;
            border-radius: 20px;
        }

        .redirect-popup-button {
            min-width: 100%;
        }
    }
</style>
