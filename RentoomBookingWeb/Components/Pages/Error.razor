@page "/Error"
@using System.Diagnostics
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<RentoomBookingWeb.SharedResources> Localizer

<PageTitle>@Localizer["ErrorPageTitle"]</PageTitle>

<h1 class="text-danger">@Localizer["ErrorPageHeading"]</h1>
<h2 class="text-danger">@Localizer["ErrorPageDescription"]</h2>

@if (ShowRequestId)
{
    <p>
        <strong>@Localizer["ErrorPageRequestIdLabel"]</strong> <code>@RequestId</code>
    </p>
}

<h3>@Localizer["ErrorPageDevelopmentModeTitle"]</h3>
<p>
    @Localizer["ErrorPageDevelopmentModeIntro"]
</p>
<p>
    <strong>@Localizer["ErrorPageDevelopmentModeWarning"]</strong>
    @Localizer["ErrorPageDevelopmentModeGuidance"]
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
