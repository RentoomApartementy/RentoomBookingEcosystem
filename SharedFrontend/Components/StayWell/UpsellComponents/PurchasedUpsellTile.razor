@using Microsoft.AspNetCore.Components
@using QRCoder
@using RentoomBooking.SharedClasses.Integrations.RentoomApp.PartnersAndServices.Enums
@using RentoomBooking.SharedClasses.Models.Upsell
@using RentoomBooking.SharedFrontend.Components.Shared.UpsellComponents

<div class="upsell-tile-container @Theme @(IsSelected ? "is-selected" : "")">
    <div class="upsell-card-inner @(_isFlipped ? "is-flipped" : "")">
        
        <div class="upsell-card-front">
            <div class="upsell-header" @onclick="ToggleFlip">
                <img src="@StayWellBannerUrl" alt="@Tile.Title" class="upsell-image" />
                
                @if (Tile.Discount.HasValue && Tile.PricingDiscountType != PartnerServiceDiscountType.None)
                {
                    <div class="upsell-badge">
                        @if (Tile.PricingDiscountType == PartnerServiceDiscountType.Percent)
                        {
                            <span>-@((Tile.Discount.Value * 100).ToString("F0"))%</span>
                        }
                        else
                        {
                            <span>-@Tile.Discount.Value.ToString("F2") @Tile.Currency</span>
                        }
                    </div>
                }

                 <div class="upsell-details-overlay">
                    <span>@Texts.BadgeInfo</span>
                </div>
            </div>

            <div class="upsell-content">
                <div class="click-area" @onclick="ToggleFlip">
                   
                    <h3 class="upsell-title">@Tile.Title</h3>
                    <p class="upsell-description">@Tile.ShortDescription</p>
                    <div class="upsell-partner-info upsell-unit-info">
                        @if (Tile.PartnerInfo != null)
                        {
                            <span>@Tile.PartnerInfo.Name</span>
                            <span>@Tile.PartnerInfo.PostalCode @Tile.PartnerInfo.City, @Tile.PartnerInfo.AddressLine</span>
                            <span>@Tile.PartnerInfo.ContactPhone</span>
                        }
                    </div>
                    <div class="upsell-context">
                        <span>@Context.Nights @Texts.NightsText</span>
                        <span class="separator">•</span>
                        <span>@Context.TotalGuests @Texts.GuestsText</span>
                    </div>
                </div>
                
                
                <div class="upsell-pricing">
                    <div class="upsell-total">
                        <span class="current-price">@Total.ToString("F2") @Currency</span>
                        @if (Tile.Discount.HasValue && OldPrice > Total)
                        {
                            <span class="old-price">@OldPrice.ToString("F2") @Currency</span>
                        }
                    </div>
                    <div class="upsell-unit-info">@DisplayText</div>
                </div>
                
                <label class="upsell-button">
                    <input type="checkbox" checked="@IsSelected" @onchange="HandleToggle" />
                    <span class="button-text">Pokaż kod voucher</span>
                </label>
            </div>
        </div>

        <div class="upsell-card-back" @onclick="ToggleFlip">
            <div class="upsell-back-content voucher-back">
                <div class="voucher-header">
                    <span class="voucher-title">Twój kod</span>
                    <button type="button" class="voucher-close" @onclick="CloseFlip" @onclick:stopPropagation>
                        ×
                    </button>
                </div>

                <div class="voucher-code">
                    <span class="voucher-code-label">Kod do podania ręcznie</span>
                    <span class="voucher-code-value">@Voucher.CodeShort</span>
                </div>

                <div class="voucher-qr-wrap">
                    @if (!string.IsNullOrWhiteSpace(_qrDataUri))
                    {
                        <img src="@_qrDataUri" alt="Kod QR vouchera" class="voucher-qr" />
                    }
                    else
                    {
                        <div class="voucher-qr-placeholder">QR niedostępny</div>
                    }
                </div>

                <button type="button" class="voucher-expand" @onclick="OpenFullscreen" @onclick:stopPropagation>
                    Powiększ
                </button>
            </div>
        </div>

    </div>

    @if (_isFullscreen)
    {
        <div class="voucher-overlay" @onclick="CloseFullscreen">
            <div class="voucher-overlay-panel" @onclick:stopPropagation>
                <div class="voucher-overlay-header">
                    <span class="voucher-overlay-title">Pokaż w restauracji</span>
                    <button type="button" class="voucher-overlay-close" @onclick="CloseFullscreen">×</button>
                </div>

                <div class="voucher-code">
                    <span class="voucher-code-label">Kod</span>
                    <span class="voucher-code-value">@Voucher.CodeShort</span>
                </div>

                <div class="voucher-overlay-qr">
                    @if (!string.IsNullOrWhiteSpace(_qrDataUri))
                    {
                        <img src="@_qrDataUri" alt="Kod QR vouchera" class="voucher-qr big" />
                    }
                    else
                    {
                        <div class="voucher-qr-placeholder">QR niedostępny</div>
                    }
                </div>

                <p class="voucher-overlay-hint">Pokaż ten kod obsłudze, aby zrealizować voucher.</p>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public UpsellTileDto Tile { get; set; } = new();
    [Parameter] public UpsellVoucherDto Voucher { get; set; } = new();
    [Parameter] public ReservationPricingContext Context { get; set; } = new();
    [Parameter] public int Quantity { get; set; } = 1;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback<bool> OnToggled { get; set; }
    
    [Parameter] 
    public UpsellTextConfig Texts { get; set; } = new();
    
    [CascadingParameter] public string Theme { get; set; } = "rentoom-theme";

    private bool _isFlipped = false;
    private bool _isFullscreen;
    private string? _qrDataUri;
    private string _lastQrCacheKey = string.Empty;
    private string StayWellBannerUrl { get; set; } = string.Empty;

    protected override void OnParametersSet()
    {
        StayWellBannerUrl = ResolveStayWellBannerUrl();

        var currentQrCacheKey = $"{Voucher?.QrToken}|{Voucher?.CodeShort}|{Tile?.PartnerServicePublicId}";
        if (_lastQrCacheKey != currentQrCacheKey)
        {
            _lastQrCacheKey = currentQrCacheKey;
            _qrDataUri = GenerateVoucherQrDataUri();
        }
    }

    private string ResolveStayWellBannerUrl()
    {
        if (Tile.BannerUrls is not null && Tile.BannerUrls.TryGetValue(PartnerServiceBannerPlacementType.StayWell, out var bannerUrl))
        {
            return bannerUrl;
        }

        return string.Empty;
    }

    private string? GenerateVoucherQrDataUri()
    {
        var code = Voucher?.QrToken ?? Voucher?.CodeShort;
        var payload = !string.IsNullOrWhiteSpace(code) ? $"https://staywell.rentoom.com/partnerportal/{Tile.PartnerPublicId}/{Tile.PartnerPublicSlug}/{Tile.PartnerServicePublicId}" : null;
        if (string.IsNullOrWhiteSpace(payload))
        {
            return null;
        }

        using var generator = new QRCodeGenerator();
        using var data = generator.CreateQrCode(payload, QRCodeGenerator.ECCLevel.Q);
        var qr = new PngByteQRCode(data);
        var bytes = qr.GetGraphic(10);
        return $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
    }


    private decimal Total => UpsellPricingCalculator.CalculateTotal(
        Tile.PricingModel,
        Tile.Price,
        Context.Nights,
        Context.TotalGuests,
        Quantity);

    private decimal OldPrice => Tile.PricingDiscountType switch
    {
        PartnerServiceDiscountType.Percent => (Tile.Discount.HasValue && Tile.Discount.Value < 1) 
            ? Total / (1 - Tile.Discount.Value) 
            : Total,
        PartnerServiceDiscountType.FixedAmount => Total + (Tile.Discount ?? 0),
        _ => Total
    };

    private string Currency => string.IsNullOrWhiteSpace(Context.Currency) ? Tile.Currency : Context.Currency;

    private string DisplayText => 
        $"Cena: {Tile.Price:F2} {Currency} / {GetPricingModelText(Tile.PricingModel)}";

    private string GetPricingModelText(PartnerServicePricingModel model) => model switch
    {
        PartnerServicePricingModel.PerPersonPerDay => "os./dzień",
        PartnerServicePricingModel.PerApartmentPerDay => "apt./dzień",
        PartnerServicePricingModel.PerStay => "pobyt",
        PartnerServicePricingModel.OneTime => "jednorazowo",
        _ => model.ToString()
    };

    private void ToggleFlip() => _isFlipped = !_isFlipped;

    private void CloseFlip()
    {
        _isFlipped = false;
    }

    private void OpenFullscreen()
    {
        _isFullscreen = true;
    }

    private void CloseFullscreen()
    {
        _isFullscreen = false;
    }

    private async Task HandleToggle(ChangeEventArgs args)
    {
        ToggleFlip();

        var selected = args.Value is bool boolValue && boolValue;
        if (OnToggled.HasDelegate)
        {
            await OnToggled.InvokeAsync(selected);
        }
    }
}
