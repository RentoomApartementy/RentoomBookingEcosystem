@page "/reservation/{token}/InstructionsPage"
@using RentoomBooking.StayWell.Components
@using RentoomBooking.StayWell.States

@using Microsoft.Extensions.Localization
@using System.Globalization
@inject StayWell.Services.ClipboardService ClipboardService
@inject IStringLocalizer<InstructionsPage> Localizer
@inject StayWell.Services.ToastService ToastService

@inherits Models.PageBase

<PageTitle>@Localizer["InstructionsPage"]</PageTitle>

<Carousel ImageUrls="@urls" UseControlButtons="@true" IsInstructionCarousel=true></Carousel>

<div class="codes-wrapper">
    <div class="code wifi">
        <img src="/icons/map-pin.svg"/>
        <div class="text-wrapper">
            <div class="title">Adres</div>
            <div class="digits">@ApartmentState.CurrentApartment?.ObjectLocation?.Address</div>
            @* <div class="digits">@ReservationState.CurrentReservation?.Reservation?.Items?.FirstOrDefault()?.itemCode</div> *@
        </div>
    </div>
    <div class="code wifi">
        <img src="/icons/door-open.svg"/>
        <div class="text-wrapper">
            <div class="title">Numer</div>
            @* <div class="digits">@ApartmentState.CurrentApartment?.ObjectLocation?.Address</div> *@
            <div class="digits">@ReservationState.CurrentReservation?.Reservation?.Items?.FirstOrDefault()?.itemCode</div>
        </div>
    </div>
    <div class="code wifi">
        <img src="/icons/fence.svg"/>
        <div class="text-wrapper">
            @if (ReservationState.IsActiveReservation)
            {
                <div class="title">Kod do furtki</div>
                <div class="digits">0000</div>
            }
            else
            {
                <span>
                    Otrzymasz dostęp za:
                    <span class="fw-bold">
                        @_days dni @_hours h @_minutes min
                    </span>
                </span>
            }
        </div>
    </div>
    <div class="code wifi">
        <img src="/icons/building.svg"/>
        <div class="text-wrapper">
        @if(ReservationState.IsActiveReservation){
            <div class="title">Kod do budynku</div>
                <div class="digits">0000</div>
            }
            else
            {
                <span>
                    Otrzymasz dostęp za:
                    <span class="fw-bold">
                        @_days dni @_hours h @_minutes min
                    </span>
                </span>
            }
        </div>
    </div>
    <div class="code wifi">
        <img src="/icons/square-parking.svg"/>
        <div class="text-wrapper">
        @if(ReservationState.IsActiveReservation){
            <div class="title">Parking</div>
            <div class="digits">0000</div>
            }
            else
            {
                <span>
                    Otrzymasz dostęp za:
                    <span class="fw-bold">
                        @_days dni @_hours h @_minutes min
                    </span>
                </span>
            }
        </div>
    </div>
    <div class="code wifi">
        <img src="/icons/wifi.svg"/>
        <div class="text-wrapper">
        @if(ReservationState.IsActiveReservation){
            <div class="title">wifi_multimedia</div>
            <div class="digits">
                @wifi_pass
                <button @onclick="CopyToClipboard" class="copy-button">
                    <img src="/icons/copy.svg"/>
                </button>
                </div>
            }
            else
            {
                <span>Otrzymasz dostęp za:
                    <span class="fw-bold">
                        @_days dni @_hours h @_minutes min
                    </span>
                </span>
            }
        </div>
    </div>
</div>

@code{
    private string wifi_pass = "MV329R8VHJYT98W";

    private string[] urls = ["/images/mock_instruction/1.png",
    "/images/mock_instruction/2.png",
    "/images/mock_instruction/3COZY.png",
    "/images/mock_instruction/4.png",
    "/images/mock_instruction/5.png",
    "/images/mock_instruction/6.png",
    "/images/mock_instruction/7 COZY.png",
    "/images/mock_instruction/8.png",];

    private int _days;
    private int _hours;
    private int _minutes;
    private System.Threading.Timer? _timer;

    protected override Task OnInitializedAsync()
    {
        if (!ReservationState.IsActiveReservation)
        {
            StartTimer();
        }
        return base.OnInitializedAsync();
    }  

    private void StartTimer()
    {
        UpdateCountdown();
        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                UpdateCountdown();
                StateHasChanged();
            });
        }, null, 0, 1000 * 60);
    }

    private void UpdateCountdown()
    {
        var checkIn = ReservationState?.CurrentReservation?.Reservation.ReservationDetails.getDateFrom();
        if (checkIn == null)
        {
            _days = _hours = _minutes = 0;
            return;
        }

        var now = DateTime.Now;
        var diff = checkIn.Value - now;
        if (diff.TotalSeconds < 0)
        {
            _days = _hours = _minutes = 0;
        }
        else
        {
            _days = diff.Days;
            _hours = diff.Hours;
            _minutes = diff.Minutes;
        }
    }

    async Task CopyToClipboard()
    {
        // Writing to the clipboard may be denied, so you must handle the exception
        try
        {
            await ClipboardService.WriteTextAsync(wifi_pass);
            ToastService.ShowToast($"Skopiowano {wifi_pass}");
        }
        catch
        {
            Console.WriteLine("Cannot write text to clipboard");
        }
    }

    public void Dispose()
    {
        // LayoutState.ShowFooter = true;
        _timer?.Dispose();
    }

}