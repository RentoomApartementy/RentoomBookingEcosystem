@page "/reservation/{token}/InstructionsPage"
@using RentoomBooking.StayWell.Components
@using RentoomBooking.StayWell.States
@using RentoomBooking.SharedClasses.Integrations.RentoomApp.ArrivalInstructions
@using RentoomBooking.SharedClasses.Models.StayWell
@using System.Linq
@using Microsoft.Extensions.Localization
@using System.Globalization
@using Microsoft.JSInterop
@using System.Text.Json
@using System.Text.RegularExpressions
@inject NavigationManager Navigation
@inject StayWell.Services.ClipboardService ClipboardService
@inject IStringLocalizer<InstructionsPage> Localizer
@inject IJSRuntime JS
@inject StayWell.Services.BackendApi BackendApi

@inherits Models.PageBase
@implements IDisposable
@implements IAsyncDisposable

<PageTitle>@Localizer["InstructionsPage"]</PageTitle>

<div class="instructions-page">
    <section class="instructions-section shortcuts-section">
        <div class="shortcuts-bar">
            <button type="button"
                    class="shortcut-btn @(IsActiveTarget("wifi-shortcut-target") ? "shortcut-btn--active" : string.Empty)"
                    title="@Localizer["Wifi"]"
                    aria-label="@Localizer["Wifi"]"
                    @onclick='() => ScrollToTarget("wifi-shortcut-target")'>
                <img src="/icons/wifi.svg" alt="@Localizer["Wifi"]" />
            </button>

            <button type="button"
                    class="shortcut-btn @(IsActiveTarget("open-shortcut-target") ? "shortcut-btn--active" : string.Empty)"
                    title="@Localizer["OpenButton"]"
                    aria-label="@Localizer["OpenButton"]"
                    @onclick='() => ScrollToTarget("open-shortcut-target")'>
                <img src="/icons/lock.svg" alt="@Localizer["OpenButton"]" />
            </button>

            <button type="button"
                    class="shortcut-btn @(IsActiveTarget("map-info-target") ? "shortcut-btn--active" : string.Empty)"
                    title="@Localizer["OpenButton"]"
                    aria-label="@Localizer["OpenButton"]"
                    @onclick='() => ScrollToTarget("map-info-target")'>
                <img src="/icons/map-pin.svg" alt="@Localizer["OpenButton"]" />
            </button>

            <button type="button"
                    class="shortcut-btn @(IsActiveTarget("parking-info-target") ? "shortcut-btn--active" : string.Empty)"
                    title="@Localizer["OpenButton"]"
                    aria-label="@Localizer["OpenButton"]"
                    @onclick='() => ScrollToTarget("parking-info-target")'>
                <img src="/icons/square-parking.svg" alt="@Localizer["OpenButton"]" />
            </button>
        </div>
    </section>

    <section class="instructions-section">
        <header class="instructions-section__header">
            <h3 class="instructions-section__title">@Localizer["Instructions"]</h3>
        </header>

        <div class="carousel-wrapper">
            @if (ApartmentState.IsLoading)
            {
                <div class="skeleton skeleton--carousel"></div>
            }
            else if (InstructionAvailable)
            {
                <Carousel Description=""
                          Descriptions="@InstructionDescriptions"
                          StepTitles="@InstructionTitles"
                          ImageUrls="@InstructionImageUrls"
                          UseControlButtons="@true"
                          IsInstructionCarousel=true>
                </Carousel>
            }
            else
            {
                <div class="instruction-unavailable">
                    <img src="/icons/octagon-alert.svg" />
                    <p>@Localizer["InstructionsUnavailable"]</p>
                </div>
            }
        </div>
    </section>

    <section class="instructions-section">
        <header class="instructions-section__header">
            <h3 class="instructions-section__title">@Localizer["CodesTitle"]</h3>
        </header>

        <div class="codes-grid">
            @if (ApartmentState.IsLoading || ReservationState.IsLoading)
            {
                @for (int i = 0; i < 4; i++)
                {
                    <div class="code-card">
                        <div class="skeleton skeleton--icon"></div>
                        <div class="code-card__content" style="flex: 1;">
                            <div class="skeleton skeleton--label"></div>
                            <div class="skeleton skeleton--value"></div>
                        </div>
                    </div>
                }
            }
            else
            {
                @if (HasCode(ApartmentAddress) || HasMapLink(ApartmentMapUrl))
                {
                    @if (HasMapLink(ApartmentMapUrl))
                    {
                        <a id="map-info-target" class="code-card code-card--map code-card--link code-card--scroll-target @(IsActiveTarget("map-info-target") ? "code-card--active" : string.Empty)" href="@ApartmentMapUrl" target="_blank" rel="noopener noreferrer">
                            <div class="code-card__icon-wrapper">
                                <img src="/icons/map-pin.svg" class="code-card__icon" />
                            </div>
                            <div class="code-card__content">
                                <div class="code-card__header">
                                    <div class="code-card__label">@Localizer["Address"]</div>
                                    <span class="code-card__status code-card__status--available">@Localizer["GoogleMaps"]</span>
                                </div>
                                <div class="code-card__value">@(!string.IsNullOrWhiteSpace(ApartmentAddress) ? ApartmentAddress : Localizer["ApartmentMap"])</div>
                                <div class="code-card__cta">
                                    <span>@Localizer["OpenMap"]</span>
                                    <img src="/icons/external-link.svg" class="code-card__cta-icon" alt="" aria-hidden="true" />
                                </div>
                            </div>
                        </a>
                    }
                    else
                    {
                        <div id="map-info-target" class="code-card code-card--map code-card--muted code-card--scroll-target @(IsActiveTarget("map-info-target") ? "code-card--active" : string.Empty)">
                            <div class="code-card__icon-wrapper">
                                <img src="/icons/map-pin.svg" class="code-card__icon" />
                            </div>
                            <div class="code-card__content">
                                <div class="code-card__header">
                                    <div class="code-card__label">@Localizer["Address"]</div>
                                    <span class="code-card__status code-card__status--unavailable">@Localizer["NoMap"]</span>
                                </div>
                                <div class="code-card__value">@ApartmentAddress</div>
                                <div class="code-card__meta">@Localizer["MapUnavailable"]</div>
                            </div>
                        </div>
                    }
                }

                @if (HasCode(ParkingSpotNumber) || HasMapLink(ParkingMapUrl))
                {
                    @if (HasMapLink(ParkingMapUrl))
                    {
                        <a id="parking-info-target" class="code-card code-card--map code-card--link code-card--scroll-target @(IsActiveTarget("parking-info-target") ? "code-card--active" : string.Empty)" href="@ParkingMapUrl" target="_blank" rel="noopener noreferrer">
                            <div class="code-card__icon-wrapper">
                                <img src="/icons/square-parking.svg" class="code-card__icon" />
                            </div>
                            <div class="code-card__content">
                                <div class="code-card__header">
                                    <div class="code-card__label">@(HasCode(ParkingSpotNumber) ? Localizer["ParkingNumber"] : Localizer["ParkingMap"])</div>
                                    <span class="code-card__status code-card__status--available">@Localizer["GoogleMaps"]</span>
                                </div>
                                @if (HasCode(ParkingSpotNumber))
                                {
                                    <div class="code-card__value">@ParkingSpotNumber</div>
                                }
                                else
                                {
                                    <div class="code-card__value">@Localizer["ParkingMap"]</div>
                                }
                                <div class="code-card__cta">
                                    <span>@Localizer["OpenMap"]</span>
                                    <img src="/icons/external-link.svg" class="code-card__cta-icon" alt="" aria-hidden="true" />
                                </div>
                            </div>
                        </a>
                    }
                    else if (HasCode(ParkingSpotNumber))
                    {
                        <div id="parking-info-target" class="code-card code-card--map code-card--scroll-target @(IsActiveTarget("parking-info-target") ? "code-card--active" : string.Empty)">
                            <div class="code-card__icon-wrapper">
                                <img src="/icons/square-parking.svg" class="code-card__icon" />
                            </div>
                            <div class="code-card__content">
                                <div class="code-card__header">
                                    <div class="code-card__label">@Localizer["ParkingNumber"]</div>
                                    <span class="code-card__status code-card__status--unavailable">@Localizer["NoMap"]</span>
                                </div>
                                <div class="code-card__value">@ParkingSpotNumber</div>
                                <div class="code-card__meta">@Localizer["MapUnavailable"]</div>
                            </div>
                        </div>
                    }
                }

                @if (HasCode(LocksState.ApartmentItemCodes?.GateCode))
                {
                    <div class="code-card">
                        <div class="code-card__icon-wrapper">
                            <img src="/icons/fence.svg" class="code-card__icon" />
                        </div>
                        <div class="code-card__content">
                            <div class="code-card__label">@Localizer["GateCode"]</div>
                            <div class="code-card__value">@RenderCodeTiles(LocksState.ApartmentItemCodes?.GateCode)</div>
                        </div>
                    </div>
                }

                @if (HasCode(LocksState.ApartmentItemCodes?.GateDoorCode))
                {
                    <div class="code-card">
                        <div class="code-card__icon-wrapper">
                            <img src="/icons/building.svg" class="code-card__icon" />
                        </div>
                        <div class="code-card__content">
                            <div class="code-card__label">@Localizer["BuildingCode"]</div>
                            <div class="code-card__value">@RenderCodeTiles(LocksState.ApartmentItemCodes?.GateDoorCode)</div>
                        </div>
                    </div>
                }

                @if (HasCode(LocksState.ApartmentItemCodes?.AdditionalDoorCode))
                {
                    <div class="code-card">
                        <div class="code-card__icon-wrapper">
                            <img src="/icons/door-closed-2.svg" class="code-card__icon" />
                        </div>
                        <div class="code-card__content">
                            <div class="code-card__label">@Localizer["SharedDoorsCode"]</div>
                            <div class="code-card__value">@RenderCodeTiles(LocksState.ApartmentItemCodes?.AdditionalDoorCode)</div>
                        </div>
                    </div>
                }

                @if (HasCode(LocksState.ApartmentItemCodes?.StoreroomCode))
                {
                    <div class="code-card">
                        <div class="code-card__icon-wrapper">
                            <img src="/icons/mailbox.svg" class="code-card__icon" />
                        </div>
                        <div class="code-card__content">
                            <div class="code-card__label">@Localizer["KeySafeCode"]</div>
                            <div class="code-card__value">@RenderCodeTiles(LocksState.ApartmentItemCodes?.StoreroomCode)</div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(ReservationState.CurrentReservation?.Reservation?.Items?.FirstOrDefault()?.itemCode))
                {
                    <div class="code-card">
                        <div class="code-card__icon-wrapper">
                            <img src="/icons/door-open.svg" class="code-card__icon" />
                        </div>
                        <div class="code-card__content">
                            <div class="code-card__label">@Localizer["ApartmentNumber"]</div>
                            <div class="code-card__value">@ReservationState.CurrentReservation?.Reservation?.Items?.FirstOrDefault()?.itemCode</div>
                        </div>
                    </div>
                }

                <div id="open-shortcut-target" class="code-card code-card--scroll-target @(IsActiveTarget("open-shortcut-target") ? "code-card--active" : string.Empty)">
                    <div class="code-card__icon-wrapper">
                        <img src="/icons/lock.svg" class="code-card__icon" />
                    </div>
                    <div class="code-card__content">
                        <div class="code-card__label">@Localizer["GoOpen"]</div>
                        <div class="code-card__value">
                            <button class="openapartment-btn" @onclick='() => Navigation.NavigateTo($"/reservation/{Token}/OpenApartmentPage")'>
                                <span>@Localizer["OpenButton"] <img class="white-filter" src="/icons/chevron-right.svg" /></span>
                            </button>
                        </div>
                    </div>
                </div>

                <div id="wifi-shortcut-target" class="code-card code-card--scroll-target @(IsActiveTarget("wifi-shortcut-target") ? "code-card--active" : string.Empty)">
                    <div class="code-card__icon-wrapper">
                        <img src="/icons/wifi.svg" class="code-card__icon" />
                    </div>
                    <div class="code-card__content">
                        <div class="code-card__label">@Localizer["Wifi"]</div>
                        @if (ApartmentState.IsLoading)
                        {
                            <div class="skeleton skeleton--value"></div>
                        }
                        else if (HasWifiInfo())
                        {
                            @if (HasCode(WifiSsid))
                            {
                                <div class="code-card__meta" style="padding-top: 10px;">@Localizer["WifiSsid"]</div>
                                <div class="code-card__value">@WifiSsid</div>
                            }
                            @if (HasCode(WifiPassword))
                            {
                                <div class="code-card__meta" style="padding-top: 10px;">@Localizer["WifiPassword"]</div>
                                <div @onclick="CopyToClipboard" class="code-card__row" style="background-color: whitesmoke; padding: 10px; border-radius: 12px; justify-content: center;">
                                    <div class="code-card__value">@WifiPassword</div>
                                    <button class="copy-button" title="Skopiuj">
                                        <img src="/icons/copy.svg" />
                                    </button>
                                </div>
                            }
                            @if (HasCode(WifiAuth))
                            {
                                <div class="code-card__meta">@Localizer["Security"]: @WifiAuth</div>
                            }
                        }
                        else
                        {
                            <div class="code-card__meta">@Localizer["NoWifi"]</div>
                        }
                    </div>
                </div>
            }
        </div>
    </section>
</div>

@code {
    private const string InstructionPlaceholderUrl = "/images/placeholders/apartment_placeholder.png";

    private static readonly Dictionary<string, string> CodeIconMappings = new(StringComparer.OrdinalIgnoreCase)
    {
        { "dzwonek", "/icons/bell-ring.svg" },
        { "dzwon", "/icons/bell-ring.svg" },
        { "kluczyk", "/icons/key-round.svg" },
        { "klucz", "/icons/key-round.svg" },
        { "drzwi", "/icons/door-closed-2.svg" }
    };

    private static readonly Regex CodeIconRegex = new(
        string.Join("|", CodeIconMappings.Keys
            .OrderByDescending(k => k.Length)
            .Select(k => Regex.Escape(k))),
        RegexOptions.IgnoreCase | RegexOptions.Compiled);

    private string? WifiPassword => ApartmentState.WifiInfo?.Password;
    private string? WifiSsid => ApartmentState.WifiInfo?.Ssid;
    private string? WifiAuth => ApartmentState.WifiInfo?.Auth;
    private string? ApartmentAddress => ApartmentState.CurrentApartment?.ObjectLocation?.Address;
    private string? ApartmentMapUrl => NormalizeMapUrl(ReservationState.CurrentReservationRecord?.State.GoogleMapsLink);
    private string? ParkingMapUrl => NormalizeMapUrl(ReservationState.CurrentReservationRecord?.State.ParkingMapUrl);
    private string? ParkingSpotNumber => GetParkingSpotNumber();

    private IReadOnlyList<ApartmentArrivalInstructionStepDTO> ArrivalInstructionSteps =>
        ApartmentState.ArrivalInstructionSteps ?? Array.Empty<ApartmentArrivalInstructionStepDTO>();

    private bool InstructionAvailable => ArrivalInstructionSteps.Count > 0;

    private string[] InstructionDescriptions => ArrivalInstructionSteps
        .Select(s => s.Description)
        .ToArray();

    private string[] InstructionTitles => ArrivalInstructionSteps
        .Select(s => s.Name)
        .ToArray();

    private string[] InstructionImageUrls => ArrivalInstructionSteps
        .Select(s => NormalizeInstructionImageUrl(s.ImageUrl))
        .ToArray();

    private string NormalizeInstructionImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
        {
            return InstructionPlaceholderUrl;
        }

        var normalizedImageUrl = imageUrl.Trim().Replace("\\", "/");

        if (Uri.TryCreate(normalizedImageUrl, UriKind.Absolute, out var absoluteUri))
        {
            return absoluteUri.ToString();
        }

        return Navigation.ToAbsoluteUri(normalizedImageUrl.TrimStart('/')).ToString();
    }

    private string? GetParkingSpotNumber()
    {
        var apartmentItemCodes = LocksState.ApartmentItemCodes;
        if (apartmentItemCodes is null)
        {
            return null;
        }

        var language = GlobalizationService.CurrentCulture.TwoLetterISOLanguageName;
        if (string.Equals(language, "pl", StringComparison.OrdinalIgnoreCase))
        {
            return apartmentItemCodes.ParkingSpotNumber;
        }

        if (string.IsNullOrWhiteSpace(apartmentItemCodes.ParkingSpotNumberTranslationsJson))
        {
            return apartmentItemCodes.ParkingSpotNumber;
        }

        try
        {
            var translations = JsonSerializer.Deserialize<List<ParkingLanguage>>(
                apartmentItemCodes.ParkingSpotNumberTranslationsJson);

            if (translations is null || translations.Count == 0)
            {
                return apartmentItemCodes.ParkingSpotNumber;
            }

            var translationDict = translations.ToDictionary(
                t => t.Language, t => t.Value, StringComparer.OrdinalIgnoreCase);

            if (translationDict.TryGetValue(language, out var languageMatch) &&
                HasCode(languageMatch))
            {
                return languageMatch;
            }
        }
        catch (JsonException)
        {
        }

        return apartmentItemCodes.ParkingSpotNumber;
    }

    private MarkupString RenderCodeTiles(string? code)
    {
        if (string.IsNullOrWhiteSpace(code))
        {
            return new MarkupString(string.Empty);
        }

        var sb = new System.Text.StringBuilder();
        sb.Append("<div class=\"code-tiles\">");

        var matches = CodeIconRegex.Matches(code);

        if (matches.Count == 0)
        {
            foreach (char c in code)
            {
                if (!char.IsWhiteSpace(c))
                {
                    sb.Append("<span class=\"code-tile\">");
                    sb.Append(System.Net.WebUtility.HtmlEncode(c.ToString()));
                    sb.Append("</span>");
                }
            }
        }
        else
        {
            int lastIndex = 0;

            foreach (Match match in matches)
            {
                for (int i = lastIndex; i < match.Index; i++)
                {
                    char c = code[i];
                    if (!char.IsWhiteSpace(c))
                    {
                        sb.Append("<span class=\"code-tile\">");
                        sb.Append(System.Net.WebUtility.HtmlEncode(c.ToString()));
                        sb.Append("</span>");
                    }
                }

                var iconUrl = CodeIconMappings
                    .First(kvp => string.Equals(
                        kvp.Key,
                        match.Value,
                        StringComparison.OrdinalIgnoreCase))
                    .Value;

                sb.Append("<span class=\"code-tile code-tile--icon\">");
                sb.Append("<img src=\"");
                sb.Append(System.Net.WebUtility.HtmlEncode(iconUrl));
                sb.Append("\" alt=\"");
                sb.Append(System.Net.WebUtility.HtmlEncode(match.Value));
                sb.Append("\" class=\"code-tile__icon\" />");
                sb.Append("</span>");

                lastIndex = match.Index + match.Length;
            }

            for (int i = lastIndex; i < code.Length; i++)
            {
                char c = code[i];
                if (!char.IsWhiteSpace(c))
                {
                    sb.Append("<span class=\"code-tile\">");
                    sb.Append(System.Net.WebUtility.HtmlEncode(c.ToString()));
                    sb.Append("</span>");
                }
            }
        }

        sb.Append("</div>");
        return new MarkupString(sb.ToString());
    }

    private async Task CopyToClipboard()
    {
        var password = WifiPassword;
        if (!HasCode(password))
        {
            return;
        }

        try
        {
            await ClipboardService.WriteTextAsync(password);
            ToastService.ShowToast($"{Localizer["Copied"]} {password}");
        }
        catch
        {
            Console.WriteLine("Cannot write text to clipboard");
        }
    }

    private static bool HasCode(string? code)
    {
        return !string.IsNullOrWhiteSpace(code);
    }

    private static bool HasMapLink(string? url)
    {
        return !string.IsNullOrWhiteSpace(url);
    }

    private static string? NormalizeMapUrl(string? url)
    {
        return string.IsNullOrWhiteSpace(url) ? null : url.Trim();
    }

    private bool HasWifiInfo()
    {
        return HasCode(WifiSsid) || HasCode(WifiPassword) || HasCode(WifiAuth);
    }

    private DotNetObjectReference<InstructionsPage>? _dotNetRef;
    private string? ActiveShortcutTarget { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        GlobalizationService.OnChange += OnLanguageChanged;
        LocksState.OnChange += OnStateChanged;
        OnLanguageChanged();

        if (LocksState.ApartmentItemCodes is null && !string.IsNullOrEmpty(Token))
        {
            await LocksState.GetApartmentItemCodesAsync(Token);
        }

        StateHasChanged();
    }

    private bool IsActiveTarget(string targetId)
    {
        return string.Equals(ActiveShortcutTarget, targetId, StringComparison.Ordinal);
    }

    private void OnLanguageChanged() =>
        InvokeAsync(async () =>
        {
            var apartmentItemId = ReservationState.CurrentReservation?.Reservation?.Items?.FirstOrDefault()?.objectItemId;
            if (apartmentItemId is > 0)
            {
                await ApartmentState.GetArrivalInstructionStepsAsync(
                    apartmentItemId.Value,
                    GlobalizationService.CurrentCulture.Name);
            }

            StateHasChanged();
        });

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("setupInstructionShortcutScrollReset", _dotNetRef);
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    [JSInvokable]
    public Task ResetActiveShortcutFromScroll()
    {
        if (ActiveShortcutTarget is null)
        {
            return Task.CompletedTask;
        }

        ActiveShortcutTarget = null;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ScrollToTarget(string elementId)
    {
        ActiveShortcutTarget = null;
        await InvokeAsync(StateHasChanged);

        await JS.InvokeVoidAsync("scrollInMainBodyToElement", elementId);

        ActiveShortcutTarget = elementId;
        await InvokeAsync(StateHasChanged);
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("removeInstructionShortcutScrollReset");
        }
        catch
        {
        }

        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    public override void Dispose()
    {
        GlobalizationService.OnChange -= OnLanguageChanged;
        LocksState.OnChange -= OnStateChanged;
        base.Dispose();
    }

    private class ParkingLanguage
    {
        public string Language { get; set; } = string.Empty;
        public string? Value { get; set; }
    }

}
