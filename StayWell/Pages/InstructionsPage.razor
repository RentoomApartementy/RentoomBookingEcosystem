@page "/reservation/{token}/InstructionsPage"
@using RentoomBooking.StayWell.Components
@using RentoomBooking.StayWell.States
@using RentoomBooking.SharedClasses.Integrations.RentoomApp.ArrivalInstructions
@using System.Linq
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject StayWell.Services.ClipboardService ClipboardService
@inject IStringLocalizer<InstructionsPage> Localizer
@inject StayWell.Services.ToastService ToastService

@inherits Models.PageBase
@implements IDisposable

<PageTitle>@Localizer["InstructionsPage"]</PageTitle>

<div class="instructions-page">
    <section class="instructions-section">
        <header class="instructions-section__header">
            <h3 class="instructions-section__title">@Localizer["Instructions"]</h3>
        </header>
        <div class="carousel-wrapper">
            @if (ApartmentState.IsLoading)
            {
                <div class="skeleton skeleton--carousel"></div>
            }
            else if (InstructionAvailable)
            {
                <Carousel Description=""
                          Descriptions="@InstructionDescriptions"
                          StepTitles="@InstructionTitles"
                          ImageUrls="@InstructionImageUrls"
                          UseControlButtons="@true"
                          IsInstructionCarousel=true>
                </Carousel>
            }
            else
            {
                <div class="instruction-unavailable">
                    <img src="/icons/octagon-alert.svg" />
                    <p>@Localizer["InstructionsUnavailable"]</p>
                </div>
            }
        </div>
    </section>

    <section class="instructions-section">
        <header class="instructions-section__header">
            <h3 class="instructions-section__title">@Localizer["CodesTitle"]</h3>
        </header>

        <div class="codes-grid">
            @if (ApartmentState.IsLoading || ReservationState.IsLoading)
            {
                @for (int i = 0; i < 4; i++)
                {
                    <div class="code-card">
                        <div class="skeleton skeleton--icon"></div>
                        <div class="code-card__content" style="flex: 1;">
                            <div class="skeleton skeleton--label"></div>
                            <div class="skeleton skeleton--value"></div>
                        </div>
                    </div>
                }
            }
            else
            {
                @if (!string.IsNullOrEmpty(ApartmentState.CurrentApartment?.ObjectLocation?.Address))
                {
                    <div class="code-card">
                        <div class="code-card__icon-wrapper">
                            <img src="/icons/map-pin.svg" class="code-card__icon" />
                        </div>
                        <div class="code-card__content">
                            <div class="code-card__label">@Localizer["Address"]</div>
                            <div class="code-card__value">@ApartmentState.CurrentApartment?.ObjectLocation?.Address</div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(ReservationState.CurrentReservation?.Reservation?.Items?.FirstOrDefault()?.itemCode))
                {
                    <div class="code-card">
                        <div class="code-card__icon-wrapper">
                            <img src="/icons/door-open.svg" class="code-card__icon" />
                        </div>
                        <div class="code-card__content">
                            <div class="code-card__label">@Localizer["ApartmentNumber"]</div>
                            <div class="code-card__value">@ReservationState.CurrentReservation?.Reservation?.Items?.FirstOrDefault()?.itemCode</div>
                        </div>
                    </div>
                }

                @if (HasCode(LocksState.ApartmentItemCodes?.GateCode))
                {
                    <div class="code-card">
                        <div class="code-card__icon-wrapper">
                            <img src="/icons/fence.svg" class="code-card__icon" />
                        </div>
                        <div class="code-card__content">
                            <div class="code-card__label">@Localizer["GateCode"]</div>
                            <div class="code-card__value code-highlight">@LocksState.ApartmentItemCodes?.GateCode</div>
                        </div>
                    </div>
                }

                @if (HasCode(LocksState.ApartmentItemCodes?.GateDoorCode))
                {
                    <div class="code-card">
                        <div class="code-card__icon-wrapper">
                            <img src="/icons/building.svg" class="code-card__icon" />
                        </div>
                        <div class="code-card__content">
                            <div class="code-card__label">@Localizer["BuildingCode"]</div>
                            <div class="code-card__value code-highlight">@LocksState.ApartmentItemCodes?.GateDoorCode</div>
                        </div>
                    </div>
                }

                @if (HasCode(LocksState.ApartmentItemCodes?.AdditionalDoorCode))
                {
                    <div class="code-card">
                        <div class="code-card__icon-wrapper">
                            <img src="/icons/door-closed-2.svg" class="code-card__icon" />
                        </div>
                        <div class="code-card__content">
                            <div class="code-card__label">@Localizer["SharedDoorsCode"]</div>
                            <div class="code-card__value code-highlight">@LocksState.ApartmentItemCodes?.AdditionalDoorCode</div>
                        </div>
                    </div>
                }

                @if (HasCode(LocksState.ApartmentItemCodes?.StoreroomCode))
                {
                    <div class="code-card">
                        <div class="code-card__icon-wrapper">
                            <img src="/icons/door-open.svg" class="code-card__icon" />
                        </div>
                        <div class="code-card__content">
                            <div class="code-card__label">@Localizer["KeySafeCode"]</div>
                            <div class="code-card__value code-highlight">@LocksState.ApartmentItemCodes?.StoreroomCode</div>
                        </div>
                    </div>
                }

                <div class="code-card">
                    <div class="code-card__icon-wrapper">
                        <img src="/icons/wifi.svg" class="code-card__icon" />
                    </div>
                    <div class="code-card__content">
                        <div class="code-card__label">@Localizer["Wifi"]</div>
                        @if (ApartmentState.IsLoading)
                        {
                            <div class="skeleton skeleton--value"></div>
                        }
                        else if (HasWifiInfo())
                        {
                            @if (HasCode(WifiSsid))
                            {
                                <div class="code-card__value">@WifiSsid</div>
                            }
                            @if (HasCode(WifiPassword))
                            {
                                <div @onclick="CopyToClipboard" class="code-card__row" style="background-color: whitesmoke; padding: 10px; border-radius: 12px; justify-content: center;">
                                    <div class="code-card__value">@WifiPassword</div>
                                    <button class="copy-button" title="Skopiuj">
                                        <img src="/icons/copy.svg" />
                                    </button>
                                </div>
                            }
                            @if (HasCode(WifiAuth))
                            {
                                <div class="code-card__meta">@Localizer["Security"]: @WifiAuth</div>
                            }
                        }
                        else
                        {
                            <div class="code-card__meta">@Localizer["NoWifi"]</div>
                        }
                    </div>
                </div>
            }
        </div>
    </section>
</div>

@code {
    private const string InstructionPlaceholderUrl = "/images/placeholders/apartment_placeholder.png";
    //private const string InstructionImageBaseUrl = "https://app.rentoom.pl/";
    // private const string DefaultFallbackInstructionDescription = "Instrukcje zameldowania są w trakcie przygotowania.";

    private string? WifiPassword => ApartmentState.WifiInfo?.Password;
    private string? WifiSsid => ApartmentState.WifiInfo?.Ssid;
    private string? WifiAuth => ApartmentState.WifiInfo?.Auth;

    private IReadOnlyList<ApartmentArrivalInstructionStepDTO> ArrivalInstructionSteps =>
        ApartmentState.ArrivalInstructionSteps ?? Array.Empty<ApartmentArrivalInstructionStepDTO>();

    private bool InstructionAvailable => ArrivalInstructionSteps.Count > 0;

    // private string FallbackInstructionDescription => DefaultFallbackInstructionDescription;

    private string[] InstructionDescriptions => ArrivalInstructionSteps
        .Select(s => s.Description)
        .ToArray();

    private string[] InstructionTitles => ArrivalInstructionSteps
        .Select(s => s.Name)
        .ToArray();

    private string[] InstructionImageUrls => ArrivalInstructionSteps
        .Select(s => s.ImageUrl)
        .ToArray();

   /* private string NormalizeInstructionImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
        {
            return InstructionPlaceholderUrl;
        }

        if (Uri.TryCreate(imageUrl, UriKind.Absolute, out var absoluteUri))
        {
            return absoluteUri.ToString();
        }

        return $"{InstructionImageBaseUrl.TrimEnd('/')}/{imageUrl.TrimStart('/')}";
    }
    */
    private async Task CopyToClipboard()
    {
        var password = WifiPassword;
        if (!HasCode(password))
        {
            return;
        }

        try
        {
            await ClipboardService.WriteTextAsync(password);
            ToastService.ShowToast($"{Localizer["Copied"]} {password}");
        }
        catch
        {
            Console.WriteLine("Cannot write text to clipboard");
        }
    }

    private static bool HasCode(string? code)
    {
        return !string.IsNullOrWhiteSpace(code);
    }

    private bool HasWifiInfo()
    {
        return HasCode(WifiSsid) || HasCode(WifiPassword) || HasCode(WifiAuth);
    }
}