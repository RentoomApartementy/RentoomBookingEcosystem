@page "/reservation/{token}/TermsPage"
@using RentoomBooking.StayWell.Components
@using RentoomBooking.StayWell.States
@using RentoomBooking.StayWell.Models
@using RentoomBooking.SharedClasses.Models.StayWell
@using RentoomBooking.SharedClasses.Models.Database.EFEntitites
@using RentoomBooking.SharedClasses.Models
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizer<PrearrivalPage> Localizer
@inject IJSRuntime JSRuntime
@inject RentoomBooking.StayWell.Services.BackendApi BackendApi

@inherits Models.PageBase

<PageTitle>@Localizer["TermsAndRegistrationPageTitle"]</PageTitle>

<div class="terms-container">
    <div class="content-section">
        <div class="reservation-section main-terms-card @(IsShowingRules ? "is-rules-view" : "") @(IsShowingTerms ? "is-tos-view" : "") @(IsShowingRegistration ? "is-registration-view" : "")">

            <div class="transition-container @(_isTransitioning ? "fade-out" : "fade-in")">
                @if (CurrentView == ViewState.Rules)
                {
                    <div class="rules-view">
                        <h3 class="rules-title">@Localizer["HouseRulesTitle"]</h3>
                        <ul class="rules-list">
                            @foreach (var rule in rules)
                            {
                                <li class="rule-row">
                                    <div class="rule-icon">
                                        @if (!string.IsNullOrEmpty(rule.Image))
                                        {
                                            <img src="@rule.Image" alt="" />
                                        }
                                    </div>
                                    <p class="rule-text">@rule.Text</p>
                                </li>
                            }
                        </ul>
                    </div>
                }
                else if (CurrentView == ViewState.Terms)
                {
                    <div class="tos-view">
                        @if (_isTermsLoading)
                        {
                            <div class="terms-loading">
                                <span>@Localizer["Loading"]</span>
                            </div>
                        }
                        else if (_termsLoadError)
                        {
                            <div class="terms-error">
                                <span>@Localizer["TermsLoadError"]</span>
                                <button class="retry-btn" @onclick="RetryLoadTerms">@Localizer["Retry"]</button>
                            </div>
                        }
                        else if (_termsSources is { Count: > 0 })
                        {
                            <div class="terms-list">
                                @foreach (var term in _termsSources)
                                {
                                    var t = term;
                                    var isAccepted = _userSelections.GetValueOrDefault(t.Id);
                                    var isLocked = t.IsRequired && _preAccepted.Contains(t.Id);
                                    var hasContent = !string.IsNullOrEmpty(t.HtmlContent) || !string.IsNullOrEmpty(t.Link);

                                    <div class="consent-row @(isLocked ? "consent-row--locked" : "")">
                                        <ToggleSwitch Value="isAccepted"
                                                      ValueChanged="(val) => OnTermToggled(t, val)"
                                                      Text="@t.Description"
                                                      Disabled="isLocked"
                                                      Description="@(isLocked ? Localizer["AlreadyAccepted"] : t.IsRequired ? Localizer["FieldRequired"] : "")" />
                                        @if (hasContent)
                                        {
                                            <button class="view-terms-btn"
                                                    @onclick="() => ShowTermContent(t)"
                                                    title="@Localizer["ViewDocument"]">
                                                <img src="/icons/external-link.svg" alt="" />
                                            </button>
                                        }
                                    </div>
                                }

                                @if (_termsSources.Any(t => !t.IsRequired))
                                {
                                    <p class="optional-consents-hint">@Localizer["OptionalConsentsHint"]</p>
                                }
                            </div>
                        }
                    </div>
                }
                else if (CurrentView == ViewState.RegistrationCard)
                {
                    <div class="registration-view">
                        <div class="reg-header">
                            <img src="/icons/file-user.svg" class="reg-header-icon" alt="" />
                            <h3 class="reg-title">@Localizer["RegisterCard"]</h3>
                        </div>

                        <div class="reg-field">
                            <label class="reg-field-label" for="email">
                                @Localizer["Email"]
                                @if (IsEmailValid)
                                {
                                    <img src="/icons/circle-check.svg" class="field-check-icon" alt="" />
                                }
                            </label>
                            <input class="reg-input @(IsEmailValid ? "is-valid" : "")"
                                   id="email" type="email" placeholder="@Localizer["EmailPlaceholder"]"
                                   value="@_mail"
                                   @oninput="OnEmailChanged"
                                   @onchange="OnEmailChanged"
                                   inputmode="email" autocomplete="email" autocapitalize="off" autocorrect="off" />
                        </div>

                        <div class="reg-actions">
                            <button class="reg-action-btn @(IsTimeSelected ? "completed" : "")" @onclick="SelectTime">
                                <img src="/icons/clock.svg" class="action-icon" alt="" />
                                <span class="action-text">
                                    @if (IsTimeUnknown)
                                    {
                                        @Localizer["DontKnowYet"]
                                    }
                                    else if (_checkInTime is not null)
                                    {
                                        @($"{Localizer["TimeSelected"]}: {_checkInTime.Value.ToString(@"hh\:mm")}")
                                    }
                                    else
                                    {
                                        @Localizer["TimeSelect"]
                                    }
                                </span>
                                @if (IsTimeSelected)
                                {
                                    <img src="/icons/circle-check.svg" class="action-check-icon" alt="" />
                                }
                            </button>

                            <button class="reg-action-btn @(AreGuestsFilled() ? "completed" : "")" @onclick="FillGuestInfo">
                                <img src="/icons/users.svg" class="action-icon" alt="" />
                                <span class="action-text">@(AreGuestsFilled() ? $"{Localizer["ChangeGuest"]} ({_guests.Count})" : Localizer["FillGuest"])</span>
                                @if (AreGuestsFilled())
                                {
                                    <img src="/icons/circle-check.svg" class="action-check-icon" alt="" />
                                }
                            </button>
                        </div>
                    </div>
                }
            </div>

            <div class="dots-indicator">
                @for (int i = 0; i < TotalStatesCount; i++)
                {
                    <span class="dot @(i == _currentStep ? "active" : "")"></span>
                }
            </div>
        </div>
    </div>
</div>

    <FloatingButton Text="@(CurrentView == ViewState.Rules ? Localizer["Continue"] : CurrentView == ViewState.Terms ? Localizer["Accept"] : Localizer["Confirm"])"
        IconPath="@(CurrentView != ViewState.RegistrationCard ? "/icons/chevron-right.svg" : "/icons/handshake.svg")"
        IsDisabled="IsButtonDisabled"
        IsLoading="_isAdvancing"
        OnClick="HandleNextClick" />

@code {
    protected override bool DeferSecondaryData => true;

    private enum ViewState { Rules, Terms, RegistrationCard }

    private (string Image, string Text)[] rules => new[]
    {
        ("/images/clock.png", $"{Localizer["Step11"]} {ReservationState.CheckInTime:HH\\:mm} {Localizer["Step12"]} {ReservationState.CheckOutTime:HH\\:mm} {Localizer["Step13"]}"),
        ("/images/broken-window.png", $"{Localizer["Step2"]}"),
        ("/images/no-smoking.png", $"{Localizer["Step3"]}"),
        ("/images/party.png", $"{Localizer["Step4"]}")
    };

    private int _currentStep = 0;
    private bool _isTransitioning = false;
    private bool _isAdvancing = false;

    private string? _mail;
    private TimeSpan? _checkInTime;
    private List<RegistrationCardGuestModel> _guests = new();

    private List<CustomerTermDisplayDto>? _termsSources;
    private Dictionary<int, bool> _userSelections = new();
    private HashSet<int> _preAccepted = new();
    private bool _isTermsLoading = true;
    private bool _termsLoadError = false;

    private const int RulesStep = 0;
    private const int TermsStep = 1;

    private int TotalStatesCount => 3;

    private ViewState CurrentView =>
        _currentStep == RulesStep ? ViewState.Rules :
        _currentStep == TermsStep ? ViewState.Terms :
        ViewState.RegistrationCard;

    private bool IsShowingRules => CurrentView == ViewState.Rules;
    private bool IsShowingTerms => CurrentView == ViewState.Terms;
    private bool IsShowingRegistration => CurrentView == ViewState.RegistrationCard;
    private bool IsEmailValid => !string.IsNullOrWhiteSpace(_mail) && _mail.Contains("@") && _mail.Contains(".");
    private bool IsTimeUnknown => _checkInTime == TimeSpan.Zero;
    private bool IsTimeSelected => _checkInTime is not null;

    private bool IsButtonDisabled =>
        (IsShowingTerms && !AllRequiredTermsAccepted()) ||
        (IsShowingRegistration && (!IsEmailValid || !IsTimeSelected || !AreGuestsFilled())) ||
        _isTransitioning;

    private bool AllRequiredTermsAccepted()
    {
        if (_termsSources == null || _isTermsLoading) return false;

        return _termsSources
            .Where(t => t.IsRequired)
            .All(t => _userSelections.GetValueOrDefault(t.Id));
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (RegistrationCardState.IsFilled)
        {
            NavigationManager.NavigateTo($"/reservation/{Token}");
            LayoutState.ShowFooter = true;
            return;
        }

        await LoadTermsAsync();
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();

        LayoutState.ShowFooter = false;

        var firstItem = ReservationState?.CurrentReservation?.Reservation?.Items?.FirstOrDefault();
        int adults = firstItem?.numberOfAdults ?? 1;
        int children = int.TryParse(firstItem?.numberOfSmallChildren, out var parsedChildren) ? parsedChildren : 0;
        int totalGuests = adults + children;

        _guests = RegistrationCardState.CurrentCard?.GuestsData?.Any() == true
            ? RegistrationCardState.CurrentCard.GuestsData
            : Enumerable.Range(0, totalGuests).Select(_ => new RegistrationCardGuestModel()).ToList();

        TryInitializeMail();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            LayoutState.ShowFooter = false;
            TryInitializeMail();
        }
    }

    private async Task LoadTermsAsync()
    {
        if (_termsSources is not null) return;

        try
        {
            _isTermsLoading = true;
            _termsLoadError = false;
            var language = CultureInfo.CurrentUICulture.Name;


            var termsTask = BackendApi.GetTermsForDisplayAsync(language);
            var agreedTask = SafeGetAgreedTermsAsync(language);
            await Task.WhenAll(termsTask, agreedTask);

            _termsSources = await termsTask;
            _userSelections = _termsSources.ToDictionary(t => t.Id, _ => false);

            foreach (var agreedTerm in await agreedTask)
            {
                if (_userSelections.ContainsKey(agreedTerm.TermsSourceId) && agreedTerm.IsAccepted)
                {
                    _userSelections[agreedTerm.TermsSourceId] = true;
                    _preAccepted.Add(agreedTerm.TermsSourceId);
                }
            }
        }
        catch
        {
            _termsLoadError = true;
        }
        finally
        {
            _isTermsLoading = false;
        }
    }

    private async Task<List<CustomerAgreedTermDto>> SafeGetAgreedTermsAsync(string language)
    {
        try
        {
            return await BackendApi.GetAgreedTermsByReservationAsync(Token!, language);
        }
        catch
        {
            return new();
        }
    }

    private async Task RetryLoadTerms()
    {
        _termsSources = null;
        await LoadTermsAsync();
    }

    private void OnTermToggled(CustomerTermDisplayDto term, bool newValue)
    {
        if (term.IsRequired && _preAccepted.Contains(term.Id)) return;

        _userSelections[term.Id] = newValue;
        StateHasChanged();
    }

    private void ShowTermContent(CustomerTermDisplayDto term)
    {
        if (!string.IsNullOrEmpty(term.Link) && string.IsNullOrEmpty(term.HtmlContent))
        {
            _ = JSRuntime.InvokeVoidAsync("open", term.Link, "_blank");
            return;
        }

        var title = term.Title ?? term.Description ?? Localizer["TOS"];
        ModalService.ShowModal(title,
            @<div class="terms-modal-content">
                @((MarkupString)(term.HtmlContent ?? ""))
            </div>
        );
    }

    private void OnEmailChanged(ChangeEventArgs e)
    {
        _mail = e.Value?.ToString();
        StateHasChanged();
    }

    private void TryInitializeMail()
    {
        if (!string.IsNullOrWhiteSpace(_mail)) return;

        _mail = GetInitialEmail();
        if (!string.IsNullOrWhiteSpace(_mail))
        {
            StateHasChanged();
        }
    }

    private string? GetInitialEmail()
    {
        var savedEmail = RegistrationCardState.CurrentCard?.ContactEmail;
        if (!string.IsNullOrWhiteSpace(savedEmail)) return savedEmail;

        var reservationEmail = ReservationState?.CurrentReservation?.Reservation?.Client?.Email;
        if (string.IsNullOrWhiteSpace(reservationEmail)) return null;

        return IsBookingMail(reservationEmail) ? null : reservationEmail;
    }

    private static bool IsBookingMail(string? mail)
    {
        if (string.IsNullOrWhiteSpace(mail)) return false;
        return mail.EndsWith("@guest.booking.com", StringComparison.OrdinalIgnoreCase);
    }

    private void SelectTime() => ModalService.ShowModal(Localizer["TimeSelect"],
        @<RentoomBooking.StayWell.Components.ModalContent.TimeSelectorContent @bind-value="_checkInTime" />);

    private void FillGuestInfo() => ModalService.ShowModal(Localizer["FillGuest"],
        @<RentoomBooking.StayWell.Components.ModalContent.FillGuestDataContent InitialGuests="@_guests" OnConfirm="@HandleGuestsConfirmed" />);

    private void HandleGuestsConfirmed(List<RegistrationCardGuestModel> updatedGuests)
    {
        _guests = updatedGuests;
        StateHasChanged();
    }

    private bool AreGuestsFilled()
    {
        if (_guests == null || !_guests.Any()) return false;
        return _guests.All(g => !string.IsNullOrWhiteSpace(g.FirstName) && !string.IsNullOrWhiteSpace(g.LastName));
    }

    private async Task HandleNextClick()
    {
        if (IsButtonDisabled || _isAdvancing) return;

        _isAdvancing = true;
        StateHasChanged();

        try
        {
            if (IsShowingTerms)
            {
                await AcceptTermsAsync();
                await MoveToNext();
            }
            else if (IsShowingRegistration)
            {
                await SaveRegistrationAndFinish();
            }
            else
            {
                await MoveToNext();
            }
        }
        finally
        {
            _isAdvancing = false;
            StateHasChanged();
        }
    }

    private async Task MoveToNext()
    {
        _isTransitioning = true;
        StateHasChanged();

        await Task.Delay(300);
        _currentStep++;

        _isTransitioning = false;
        StateHasChanged();
    }

    private async Task AcceptTermsAsync()
    {
        if (string.IsNullOrEmpty(Token) || _userSelections.Count == 0) return;

        await BackendApi.SaveCustomerTermsAsync(Token, _userSelections);
    }

    private async Task SaveRegistrationAndFinish()
    {
        try
        {
            var checkInDateTime = DateTime.UtcNow.Date.Add(_checkInTime!.Value);
            var regcard = new RegistrationCardEntity { ResToken = Token, ContactEmail = _mail, CheckInTime = checkInDateTime, GuestsData = _guests };
            await RegistrationCardState.SaveCardAsync(regcard);
            NavigationManager.NavigateTo($"/reservation/{Token}/Prearrival");
        }
        catch { ToastService.ShowToast(Localizer["RegistrationSaveError"]); }
    }

    public override void Dispose()
    {
        LayoutState.ShowFooter = true;
        base.Dispose();
    }
}
