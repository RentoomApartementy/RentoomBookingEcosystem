@page "/reservation/{token}/TermsPage"
@using RentoomBooking.StayWell.Components
@using RentoomBooking.StayWell.States
@using RentoomBooking.StayWell.Models
@using RentoomBooking.SharedClasses.Models.StayWell
@using RentoomBooking.SharedClasses.Models.Database.EFEntitites
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizer<PrearrivalPage> Localizer
@inject IJSRuntime JSRuntime

@inherits Models.PageBase

<PageTitle>Regulamin i Zameldowanie</PageTitle>

<div class="terms-container">
    <div class="content-section">
        <div class="reservation-section main-terms-card @(IsShowingTerms ? "is-tos-view" : "") @(IsShowingRegistration ? "is-registration-view" : "")">

            <div class="transition-container @(_isTransitioning ? "fade-out" : "fade-in")">
                @if (CurrentView == ViewState.Steps)
                {
                    var step = steps[_currentStep];
                    <div class="step-view">
                        <div class="image-container">
                            @if (!string.IsNullOrEmpty(step.Image))
                            {
                                <img src="@step.Image" class="step-image" alt="step" />
                            }
                        </div>
                        <div class="text-container">
                            <p>@step.Text</p>
                        </div>
                    </div>
                }
                else if (CurrentView == ViewState.Terms)
                {
                    <div class="tos-view">
                        <div id="terms-scroll-area" class="tos-scroll-area">
                            @Localizer["Terms"]
                        </div>
                    </div>
                }
                else if (CurrentView == ViewState.RegistrationCard)
                {
                    <div class="registration-view">
                        <h3 class="reg-title">@Localizer["RegisterCard"]</h3>

                        <div class="mail-wrapper">
                            <label class="mail-input-title" for="email">E-mail</label>
                            <input class="editform-input @(IsEmailValid ? "is-valid" : "")"
                                   id="email" type="email" placeholder="twój@email.pl"
                                   @bind="_mail" @bind:event="oninput" />
                        </div>

                        <div class="form-buttons">
                            <Button OnClick="SelectTime" ButtonStyle="padding: 22px 12px !important; width: 100%;">
                                <RenderFragment>
                                    <span>@(_checkInTime is null ? Localizer["TimeSelect"] : $"{Localizer["TimeSelected"]}: {_checkInTime.Value.ToString(@"hh\:mm")}")</span>
                                </RenderFragment>
                            </Button>

                            <Button OnClick="FillGuestInfo" ButtonStyle="padding: 22px 12px !important; width: 100%;">
                                <RenderFragment>
                                    <span>@(AreGuestsFilled() ? $"{Localizer["ChangeGuest"]} ({_guests.Count})" : Localizer["FillGuest"])</span>
                                </RenderFragment>
                            </Button>
                        </div>
                    </div>
                }
            </div>

            <div class="dots-indicator">
                @for (int i = 0; i < TotalStatesCount; i++)
                {
                    <span class="dot @(i == _currentStep ? "active" : "")"></span>
                }
            </div>
        </div>
    </div>  
</div>

    <FloatingButton Text="@(CurrentView == ViewState.Steps ? Localizer["Continue"] : CurrentView == ViewState.Terms ? Localizer["Accept"] : Localizer["Confirm"])"
        IconPath="@(CurrentView != ViewState.RegistrationCard ? "/icons/chevron-right.svg" : "/icons/handshake.svg")"
        IsDisabled="IsButtonDisabled"
        OnClick="HandleNextClick" />

<script>
    window.termsScrollObserver = {
        init: function (elementId, dotNetRef) {
            setTimeout(function() {
                var el = document.getElementById(elementId);
                if (!el) return;

                function check() {
                    // Tolerancja 5px dla różnych przeglądarek i zoomu
                    if (el.scrollTop + el.clientHeight >= el.scrollHeight - 5) {
                        dotNetRef.invokeMethodAsync('OnScrollEnd');
                        el.removeEventListener('scroll', check);
                    }
                }

                if (el.scrollHeight <= el.clientHeight) {
                    dotNetRef.invokeMethodAsync('OnScrollEnd');
                } else {
                    el.addEventListener('scroll', check);
                }
            }, 100);
        }
    };
</script>

@code {
    private enum ViewState { Steps, Terms, RegistrationCard }

    private (string Image, string Text)[] steps => new[]
    {
        ("/images/clock.png", $"{Localizer["Step11"]} {ReservationState.CheckInTime:HH\\:mm} {Localizer["Step12"]} {ReservationState.CheckOutTime:HH\\:mm} {Localizer["Step13"]}"),
        ("/images/broken-window.png", $"{Localizer["Step2"]}"),
        ("/images/no-smoking.png", $"{Localizer["Step3"]}"),
        ("/images/party.png", $"{Localizer["Step4"]}")
    };

    private int _currentStep = 0;
    private bool _isTransitioning = false;
    private bool _termsScrolledToBottom = false;
    private bool _observerInitialized = false;

    private string? _mail;
    private TimeSpan? _checkInTime;
    private List<RegistrationCardGuestModel> _guests = new();
    private DotNetObjectReference<TermsPage>? _objRef;

    private int TotalStatesCount => steps.Length + 2; // Steps + Terms + Registration

    private ViewState CurrentView =>
        _currentStep < steps.Length ? ViewState.Steps :
        _currentStep == steps.Length ? ViewState.Terms :
        ViewState.RegistrationCard;

    private bool IsShowingTerms => CurrentView == ViewState.Terms;
    private bool IsShowingRegistration => CurrentView == ViewState.RegistrationCard;
    private bool IsEmailValid => !string.IsNullOrWhiteSpace(_mail) && _mail.Contains("@") && _mail.Contains(".");

    private bool IsButtonDisabled =>
        (IsShowingTerms && !_termsScrolledToBottom) ||
        (IsShowingRegistration && (!IsEmailValid || _checkInTime == null || !AreGuestsFilled())) ||
        _isTransitioning;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (RegistrationCardState.IsFilled)
        {
            NavigationManager.NavigateTo($"/reservation/{Token}");
            ToastService.ShowToast("Nie masz dostepu do tej strony.");
            LayoutState.ShowFooter = true;
        }
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();

        LayoutState.ShowFooter = false;
        _objRef = DotNetObjectReference.Create(this);

        int adults = ReservationState?.CurrentReservation?.Reservation?.Items?.FirstOrDefault()?.numberOfAdults ?? 1;
        _guests = RegistrationCardState.CurrentCard?.GuestsData?.Any() == true
            ? RegistrationCardState.CurrentCard.GuestsData
            : Enumerable.Range(0, adults).Select(_ => new RegistrationCardGuestModel()).ToList();

        TryInitializeMail();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            LayoutState.ShowFooter = false;
            TryInitializeMail();
        }

        if (IsShowingTerms && !_observerInitialized)
        {
            _observerInitialized = true;
            await JSRuntime.InvokeVoidAsync("window.termsScrollObserver.init", "terms-scroll-area", _objRef);
        }
    }

    private void TryInitializeMail()
    {
        if (!string.IsNullOrWhiteSpace(_mail))
        {
            return;
        }

        _mail = GetInitialEmail();
        if (!string.IsNullOrWhiteSpace(_mail))
        {
            StateHasChanged();
        }
    }

    private string? GetInitialEmail()
    {
        var savedEmail = RegistrationCardState.CurrentCard?.ContactEmail;
        if (!string.IsNullOrWhiteSpace(savedEmail))
        {
            return savedEmail;
        }

        var reservationEmail = ReservationState?.CurrentReservation?.Reservation?.Client?.Email;
        if (string.IsNullOrWhiteSpace(reservationEmail))
        {
            return null;
        }

        return IsBookingMail(reservationEmail) ? null : reservationEmail;
    }

    private static bool IsBookingMail(string? mail)
    {
        if (string.IsNullOrWhiteSpace(mail)) return false;
        return mail.EndsWith("@guest.booking.com", StringComparison.OrdinalIgnoreCase);
    }

    private void SelectTime() => ModalService.ShowModal(Localizer["TimeSelect"],
        @<RentoomBooking.StayWell.Components.ModalContent.TimeSelectorContent @bind-value="_checkInTime" />);

    private void FillGuestInfo() => ModalService.ShowModal(Localizer["FillGuest"],
        @<RentoomBooking.StayWell.Components.ModalContent.FillGuestDataContent InitialGuests="@_guests" OnConfirm="@HandleGuestsConfirmed" />);

    private void HandleGuestsConfirmed(List<RegistrationCardGuestModel> updatedGuests)
    {
        _guests = updatedGuests;
        StateHasChanged();
    }

    private bool AreGuestsFilled()
    {
        if (_guests == null || !_guests.Any()) return false;
        return _guests.All(g => !string.IsNullOrWhiteSpace(g.FirstName) && !string.IsNullOrWhiteSpace(g.LastName));
    }

    private async Task HandleNextClick()
    {
        if (IsButtonDisabled) return;

        if (IsShowingTerms)
        {
            await AcceptTermsAsync();
            await MoveToNext();
        }
        else if (IsShowingRegistration)
        {
            await SaveRegistrationAndFinish();
        }
        else
        {
            await MoveToNext();
        }
    }

    private async Task MoveToNext()
    {
        _isTransitioning = true;
        StateHasChanged();

        await Task.Delay(300);
        _currentStep++;
        _observerInitialized = false;

        _isTransitioning = false;
        StateHasChanged();
    }

    private async Task AcceptTermsAsync()
    {
        var terms = new TermsEntity
        {
            ResToken = Token,
            VersionAccepted = "1.0",
            TypeAccepted = "regulamin",
            AcceptedAt = DateTime.UtcNow
        };

        await TermsState.SaveTermsAsync(terms);
    }

    private async Task SaveRegistrationAndFinish()
    {
        try
        {
            var checkInDateTime = DateTime.UtcNow.Date.Add(_checkInTime!.Value);
            var regcard = new RegistrationCardEntity { ResToken = Token, ContactEmail = _mail, CheckInTime = checkInDateTime, GuestsData = _guests };
            await RegistrationCardState.SaveCardAsync(regcard);
            NavigationManager.NavigateTo($"/reservation/{Token}/Prearrival");
        }
        catch { ToastService.ShowToast("Błąd zapisu danych."); }
    }

    [JSInvokable]
    public void OnScrollEnd()
    {
        if (!_termsScrolledToBottom)
        {
            _termsScrolledToBottom = true;
            StateHasChanged();
        }
    }

    public override void Dispose()
    {
        LayoutState.ShowFooter = true;
        _objRef?.Dispose();
        base.Dispose();
    }
}