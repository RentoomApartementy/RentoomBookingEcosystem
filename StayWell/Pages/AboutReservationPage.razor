@page "/reservation/{token}/AboutReservationPage"
@using RentoomBooking.StayWell.Components
@using Microsoft.Extensions.Localization
@using System.Globalization
@using RentoomBooking.SharedClasses.Models.IdoBooking;
@using RentoomBooking.SharedClasses.Models
@using RentoomBooking.StayWell.States
@using RentoomBooking.StayWell.Services
@inject IStringLocalizer<AboutReservationPage> Localizer
@inject NavigationManager Navigation
@inject CustomerAgreedTermsState CustomerAgreedTermsState
@inject BackendApi BackendApi
@inject IJSRuntime JSRuntime
@inherits Models.PageBase

<PageTitle>@Localizer["PageTitle"]</PageTitle>

<div class="reservation-page">
    <div class="reservation-page__sections">
        <section class="reservation-section">
            <header class="reservation-section__header">
                <h3 class="reservation-section__title">@Localizer["BookingDetailsTitle"]</h3>
            </header>
            <div class="reservation-section__content">
                @if (ReservationState.IsLoading || RegistrationCardState.IsLoading)
                {
                    <div class="reservation-field">
                        <div class="skeleton skeleton--label"></div>
                        <div class="skeleton skeleton--value"></div>
                    </div>
                    <div class="reservation-field">
                        <div class="skeleton skeleton--label"></div>
                        <div class="skeleton skeleton--value"></div>
                    </div>
                    <div class="reservation-field">
                        <div class="skeleton skeleton--label"></div>
                        <div class="skeleton skeleton--guest-card"></div>
                        <div class="skeleton skeleton--guest-card"></div>
                    </div>
                }
                else
                {
                    <div class="reservation-field">
                        <span class="reservation-field__label">
                            <img class="reservation-field__icon" src="/icons/users.svg" />
                            @Localizer["BookingPerson"]:
                        </span>
                        <span class="reservation-field__value">
                            @Reservation?.Client.FirstName @Reservation?.Client.LastName
                        </span>
                    </div>

                    <div class="reservation-field">
                        <span class="reservation-field__label">
                            <img class="reservation-field__icon" src="/icons/mail.svg" />
                            @Localizer["ContactMail"]:
                        </span>
                        <span class="reservation-field__value">
                            @RegistrationCardState.CurrentCard?.ContactEmail
                        </span>
                    </div>

                    <div class="reservation-field">
                        <span class="reservation-field__label">
                            <img class="reservation-field__icon" src="/icons/users.svg" />
                            @Localizer["RegisteredGuests"]:
                        </span>
                        <div class="guest-list">
                            @foreach (var (guest, index) in RegistrationCardState?.CurrentCard?.GuestsData?.Select((g, i) => (g, i)) ?? [])
                            {
                                <div class="guest-card">
                                    <div class="guest-card__avatar">@(index + 1)</div>
                                    <div class="guest-card__body">
                                        <div class="guest-card__row">
                                            <span class="guest-card__label">@Localizer["Name"]</span>
                                            <span class="guest-card__value">@guest.FirstName</span>
                                        </div>
                                        <div class="guest-card__row">
                                            <span class="guest-card__label">@Localizer["Surname"]</span>
                                            <span class="guest-card__value">@guest.LastName</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="reservation-section">
            <header class="reservation-section__header">
                <h3 class="reservation-section__title">@Localizer["ApartmentAndStayTitle"]</h3>
            </header>
            <div class="reservation-section__content">
                @if (ReservationState.IsLoading || ApartmentState.IsLoading || AmenitiesState.IsLoading)
                {
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="reservation-field">
                            <div class="skeleton skeleton--label"></div>
                            <div class="skeleton skeleton--value"></div>
                        </div>
                    }
                }
                else
                {
                    <div class="reservation-field">
                        <span class="reservation-field__label">
                            <img class="reservation-field__icon" src="/icons/door-open.svg" />
                            @Localizer["Apartment"]:
                        </span>
                        <span class="reservation-field__value">
                            @Reservation?.Items?.FirstOrDefault()?.objectName
                        </span>
                        <span class="reservation-field__value">
                            @Reservation?.Items?.FirstOrDefault()?.itemCode
                        </span>
                    </div>

                    <div class="reservation-field">
                        <span class="reservation-field__label">
                            <img class="reservation-field__icon" src="/icons/map-pin.svg" />
                            @Localizer["Address"]:
                        </span>
                        <span class="reservation-field__value">
                            @ApartmentState.CurrentApartment?.ObjectLocation?.Address
                        </span>
                    </div>

                    <div class="reservation-field">
                        <span class="reservation-field__label">
                            <img class="reservation-field__icon" src="/icons/clock.svg" />
                            @Localizer["CheckinCheckOutTime"]:
                        </span>
                        <span class="reservation-field__value">
                            @Localizer["CheckInTime"]:
                            @if (ReservationState.HasEarlyCheckIn)
                            {
                                <span class="time--original">15:00</span>
                                <span class="time--updated">@ReservationState.CheckInTime.ToString("HH:mm")</span>
                            }
                            else
                            {
                                <span>15:00</span>
                            }
                        </span>
                        <span class="reservation-field__value">
                            @Localizer["CheckOutTime"]:
                            @if (ReservationState.HasLateCheckOut)
                            {
                                <span class="time--original">11:00</span>
                                <span class="time--updated">@ReservationState.CheckOutTime.ToString("HH:mm")</span>
                            }
                            else
                            {
                                <span>11:00</span>
                            }
                        </span>
                    </div>

                    <div class="reservation-field">
                        <span class="reservation-field__label">
                            <img class="reservation-field__icon" src="/icons/calendar-days.svg" />
                            @Localizer["StayDates"]:
                        </span>
                        <span class="reservation-field__value">
                            @Localizer["CheckInDate"]:
                            <span>
                                @ReservationState.CurrentReservation?.Reservation?.ReservationDetails?.getDateFrom().ToString("dd.MM.yyyy")
                            </span>
                        </span>
                        <span class="reservation-field__value">
                            @Localizer["CheckOutDate"]:
                            <span>
                                @ReservationState.CurrentReservation?.Reservation?.ReservationDetails?.getDateTo().ToString("dd.MM.yyyy")
                            </span>
                        </span>
                    </div>

                    @if (AmenitiesState.CurrentAmenities?.Count > 0)
                    {
                        <div class="reservation-field">
                            <span class="reservation-field__label">
                                <img class="reservation-field__icon" src="/icons/bed-double.svg" />
                                @Localizer["ApartmentAmenities"]:
                            </span>
                            <button class="reservation-field__action" @onclick="ShowAmenitiesModal">
                                @Localizer["ShowAmenitiesButton"]
                            </button>
                        </div>
                    }
                }
            </div>
        </section>

        <section class="reservation-section">
            <header class="reservation-section__header">
                <h3 class="reservation-section__title">@Localizer["TOSConsents"]:</h3>
            </header>
            <div class="reservation-section__content">
                @if (TermsState.IsLoading || RegistrationCardState.IsLoading || CustomerAgreedTermsState.IsLoading)
                {
                    <div class="reservation-field">
                        <div class="skeleton skeleton--label"></div>
                        <div class="skeleton skeleton--value"></div>
                    </div>
                    <div class="reservation-field">
                        <div class="skeleton skeleton--label"></div>
                        <div class="skeleton skeleton--toggle"></div>
                        <div class="skeleton skeleton--toggle"></div>
                    </div>
                }
                else
                {
                    <div class="reservation-field">
                        <span class="reservation-field__label">
                            <img class="reservation-field__icon" src="/icons/list-checks.svg" />
                            @Localizer["Consents"]:
                        </span>
                        @foreach (var term in CustomerAgreedTermsState.Terms.Where(t => t.IsRequired))
                        {
                            var capturedTerm = term;
                            var displayTerm = _termDisplayDict.GetValueOrDefault(capturedTerm.TermsSourceId);
                            var hasContent = displayTerm is not null && (!string.IsNullOrEmpty(displayTerm.HtmlContent) || !string.IsNullOrEmpty(displayTerm.Link));
                            <div class="consent-row">
                                <div class="consent-toggle consent-toggle--disabled">
                                    <ToggleSwitch Value="capturedTerm.IsAccepted"
                                                  ValueChanged="EventCallback<bool>.Empty"
                                                  Text="@capturedTerm.Description"
                                                  Description="@capturedTerm.AgreedAt.ToString("dd.MM.yyyy HH:mm")" />
                                </div>
                                @if (hasContent)
                                {
                                    <button class="view-terms-btn"
                                            @onclick="() => ShowTermContent(displayTerm!)"
                                            title="@Localizer["ViewDocument"]">
                                        <img src="/icons/external-link.svg" alt="" />
                                    </button>
                                }
                            </div>
                        }
                        @foreach (var term in CustomerAgreedTermsState.Terms.Where(t => !t.IsRequired))
                        {
                            var capturedTerm = term;
                            var displayValue = GetDisplayValue(capturedTerm);
                            var displayTerm = _termDisplayDict.GetValueOrDefault(capturedTerm.TermsSourceId);
                            var hasContent = displayTerm is not null && (!string.IsNullOrEmpty(displayTerm.HtmlContent) || !string.IsNullOrEmpty(displayTerm.Link));
                            <div class="consent-row">
                                <div class="consent-toggle">
                                    <ToggleSwitch Value="displayValue"
                                                  ValueChanged="(val) => OnTermToggled(capturedTerm, val)"
                                                  Text="@capturedTerm.Description"
                                                  Description="@capturedTerm.AgreedAt.ToString("dd.MM.yyyy HH:mm")" />
                                </div>
                                @if (hasContent)
                                {
                                    <button class="view-terms-btn"
                                            @onclick="() => ShowTermContent(displayTerm!)"
                                            title="@Localizer["ViewDocument"]">
                                        <img src="/icons/external-link.svg" alt="" />
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </section>
        <section class="reservation-section">
            <header class="reservation-section__header">
                <h3 class="reservation-section__title">@Localizer["YourStay"]</h3>
            </header>
            <div class="reservation-section__content">
                    <div class="reservation-field">

                        <span class="reservation-field__label">
                            <img class="reservation-field__icon" src="/icons/files.svg" />
                            <span style="font-weight:600">@Localizer["TaxIdLabel"]</span>
                        </span>
                        <span class="reservation-field__value">
                            <span>@Localizer["TaxIdValue"]</span>
                        </span>
                    </div>
                <div class="reservation-field">
                    <span class="reservation-field__label">
                        <img class="reservation-field__icon" src="/icons/building.svg" />
                        <span style="font-weight:600">@Localizer["OfficeAddress"]</span>
                    </span>
                    <span class="reservation-field__value">
                        <span>@Localizer["OfficeAddressValue"]</span>
                    </span>
                </div>
            </div>
        </section>
    </div>
</div>

@code {

    private Dictionary<int, bool> _overrides = [];
    private CustomerAgreedTermDto? _pendingCancelTerm;
    private Dictionary<int, CustomerTermDisplayDto> _termDisplayDict = [];

    private Reservation? Reservation => ReservationState?.CurrentReservation?.Reservation;
    private ApartmentObject? Apartment => ApartmentState?.CurrentApartment;

    private bool GetDisplayValue(CustomerAgreedTermDto term) =>
        _overrides.TryGetValue(term.TermsSourceId, out var val) ? val : term.IsAccepted;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        if (!string.IsNullOrEmpty(Token))
        {
            CustomerAgreedTermsState.OnChange += OnTermsChanged;
            ModalService.OnClose += OnModalClosed;
            await CustomerAgreedTermsState.LoadAsync(Token, CultureInfo.CurrentUICulture.Name);
            await LoadTermDisplayAsync();
        }
    }

    private void OnTermsChanged()
    {
        _overrides.Clear();
        _pendingCancelTerm = null;
        StateHasChanged();
    }

    private void OnModalClosed()
    {
        if (_pendingCancelTerm is not null)
        {
            _overrides.Remove(_pendingCancelTerm.TermsSourceId);
            _pendingCancelTerm = null;
            StateHasChanged();
        }
    }

    public override void Dispose()
    {
        base.Dispose();
        CustomerAgreedTermsState.OnChange -= OnTermsChanged;
        ModalService.OnClose -= OnModalClosed;
    }

    private async Task LoadTermDisplayAsync()
    {
        try
        {
            var language = CultureInfo.CurrentUICulture.Name;
            var terms = await BackendApi.GetTermsForDisplayAsync(language);
            _termDisplayDict = terms.ToDictionary(t => t.Id);
        }
        catch
        {
            // Display terms unavailable; buttons simply won't show
        }
    }

    private void ShowTermContent(CustomerTermDisplayDto term)
    {
        if (!string.IsNullOrEmpty(term.Link) && string.IsNullOrEmpty(term.HtmlContent))
        {
            _ = JSRuntime.InvokeVoidAsync("open", term.Link, "_blank");
            return;
        }

        var title = term.Title ?? term.Description ?? Localizer["TOS"];
        ModalService.ShowModal(title,
            @<div class="terms-modal-content">
                @((MarkupString)(term.HtmlContent ?? ""))
            </div>
        );
    }

    private void ShowAmenitiesModal()
    {
        var amenities = AmenitiesState.CurrentAmenities!;
        ModalService.ShowModal(
            Localizer["ApartmentAmenities"],
            @<div class="amenities-modal">
                @foreach (var amenity in amenities)
                {
                    <div class="amenity-pill">
                        <img src="/icons/check.svg" class="amenity-pill__icon" alt="" aria-hidden="true" />
                        <span class="amenity-pill__name">@amenity.Name</span>
                    </div>
                }
            </div>
        );
    }

    private void OnTermToggled(CustomerAgreedTermDto term, bool newValue)
    {
        if (!newValue)
        {
            _overrides[term.TermsSourceId] = false;
            _pendingCancelTerm = term;
            StateHasChanged();

            ModalService.ShowModal(
                Localizer["WithdrawConsentModalTitle"],
                @<div>
                    <p>@Localizer["WithdrawConsentModalQuestion"]</p>
                    <p style="font-size: 0.85rem; color: rgba(0,0,0,0.55); margin-top: 4px; padding: 5px; font-weight: 500;">@term.Description</p>
                    <div style="display: flex; gap: 10px; margin-top: 16px;">
                        <Button OnClick="() => ConfirmToggle(term, false)" Text="@Localizer["WithdrawConsentModalConfirm"]" ButtonStyle="background-color: red;"></Button>
                        <Button OnClick="() => CancelToggle(term)" Text="@Localizer["WithdrawConsentModalCancel"]"></Button>
                    </div>
                </div>
            );
        }
        else
        {
            _ = ApplyToggleAsync(term, true);
        }
    }

    private void CancelToggle(CustomerAgreedTermDto term)
    {
        _pendingCancelTerm = null;
        _overrides.Remove(term.TermsSourceId);
        ModalService.HideModal();
        StateHasChanged();
    }

    private void ConfirmToggle(CustomerAgreedTermDto term, bool newValue)
    {
        _pendingCancelTerm = null;
        ModalService.HideModal();
        _ = ApplyToggleAsync(term, newValue);
    }

    private async Task ApplyToggleAsync(CustomerAgreedTermDto term, bool newValue)
    {
        if (string.IsNullOrEmpty(Token)) return;

        _overrides[term.TermsSourceId] = newValue;
        StateHasChanged();

        var success = await CustomerAgreedTermsState.UpdateAcceptanceAsync(Token, term.TermsSourceId, newValue);
        if (!success)
        {
            _overrides.Remove(term.TermsSourceId);
            StateHasChanged();
        }
    }
}
