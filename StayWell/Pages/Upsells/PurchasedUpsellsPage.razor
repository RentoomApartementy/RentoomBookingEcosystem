@page "/reservation/{Token}/MyVouchersPage"
@using Microsoft.Extensions.Localization
@using RentoomBooking.SharedClasses.Models.Upsell
@using RentoomBooking.SharedFrontend.Components.Shared.UpsellComponents
@using RentoomBooking.SharedFrontend.Components.StayWell.UpsellComponents
@using RentoomBooking.StayWell.States
@inject RentoomBooking.StayWell.Services.BackendApi BackendApi
@inject UpsellTextsState UpsellTextsState
@inject IStringLocalizer<PurchasedUpsellsPage> Localizer

@inherits Models.PageBase

<PageTitle>@Localizer["PurchasedUpsellsPageTitle"]</PageTitle>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <p>@_errorMessage</p>
}
else if (_isLoading)
{
    <div class="upsell-outer-wrapper staywell-theme">
        <div class="upsell-section-container">
            <div class="upsell-list-scroll-wrapper">
                    <div class="skeleton-tile">
                        <div class="skeleton skeleton--tile-image"></div>
                        <div class="skeleton-tile__body">
                            <div class="skeleton skeleton--tile-title"></div>
                            <div class="skeleton skeleton--tile-desc"></div>
                            <div class="skeleton skeleton--tile-desc skeleton--tile-desc--short"></div>
                            <div class="skeleton skeleton--tile-price"></div>
                            <div class="skeleton skeleton--tile-btn"></div>
                        </div>
                    </div>
            </div>
        </div>
    </div>
}
else
{
    <PurchasedUpsellList PurchasedUpsells="_purchasedVouchers"
                         ReservationContext="_context"
                         Theme="staywell-theme"
                         Texts="_texts"
                         OnEnlargeImage="HandleEnlargeImage" />
}

@code {
    private List<UpsellOrderLineRecord> _purchasedVouchers = new();
    private ReservationPricingContext _context = new();
    private bool _isLoading = true;
    private string? _errorMessage;

    private UpsellTextConfig _texts = new()
    {
        Title = string.Empty,
        SubTitle = string.Empty
    };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        if (string.IsNullOrWhiteSpace(Token))
        {
            _errorMessage = Localizer["TokenMissingError"];
            _isLoading = false;
            return;
        }

        _texts = UpsellTextsState.Build(Localizer);


        var purchasedSummary = await BackendApi.GetPurchasedUpsellsByReservationTokenAsync(Token);
        _purchasedVouchers = purchasedSummary?.PurchasedUpsellsWithVouchers ?? new();

        var firstLine = _purchasedVouchers.FirstOrDefault();

        var reservationFrom = ReservationState.CurrentReservation?.Reservation?.ReservationDetails?.getDateFrom();
        var reservationTo = ReservationState.CurrentReservation?.Reservation?.ReservationDetails?.getDateTo();

        var startDate = reservationFrom.HasValue
            ? DateOnly.FromDateTime(reservationFrom.Value)
            : DateOnly.FromDateTime(DateTime.Today);

        var endDate = reservationTo.HasValue
            ? DateOnly.FromDateTime(reservationTo.Value)
            : startDate.AddDays(Math.Max(1, firstLine?.Nights ?? 1));

        var adults = firstLine?.TotalGuests ?? 0;
        var children = 0;

        _context = new ReservationPricingContext
        {
            StartDate = startDate,
            EndDate = endDate,
            Adults = adults,
            Children = children,
            Currency = "PLN"
        };

        _isLoading = false;
    }

    private void HandleEnlargeImage(string[] imageUrls)
    {
        if (imageUrls.Length == 0) return;

        ModalService.ShowModal("",
            @<RentoomBooking.StayWell.Components.ModalContent.GalleryModalContent
                ImageUrls="@imageUrls"
                StartIndex="0"
                ShowControls="@(imageUrls.Length > 1)" />,
            true);
    }
}
