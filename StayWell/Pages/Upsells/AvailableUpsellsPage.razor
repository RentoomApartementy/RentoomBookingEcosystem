@page "/reservation/{Token}/Vouchers"
@page "/reservation/{Token}/VouchersPage"
@using System.Globalization
@using Microsoft.Extensions.Localization
@using RentoomBooking.SharedClasses.Models.ReservationWorkflow
@using RentoomBooking.SharedClasses.Models.Upsell
@using RentoomBooking.SharedFrontend.Components.Shared.UpsellComponents
@using RentoomBooking.StayWell.Services
@using RentoomBooking.StayWell.States
@inject AvailableUpsellsState AvailableUpsellsState
@inject NavigationManager Navigation
@inject IStringLocalizer<PurchasedUpsellsPage> UpsellLocalizer;
@inject UpsellCartState UpsellCartState
@inherits Models.PageBase
@implements IDisposable

@if (AvailableUpsellsState.IsLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrWhiteSpace(AvailableUpsellsState.Error))
{
    <p>@AvailableUpsellsState.Error</p>
}
else if (AvailableUpsellsState.AvailableUpsells.Count == 0)
{
    <p>Brak dostępnych dodatków</p>
}
else
{
    <UpsellList @key="_upsellListKey"
                AvailableUpsellsList="AvailableUpsellsState.AvailableUpsells"
                ReservationContext="_reservationContext"
                Theme="staywell-theme"
                Texts="_texts"
                InitialSelection="_cartSelected"
                OnSelectionChanged="HandleSelectionChanged" />
}

@code {
    private List<SelectedUpsellDto> _cartSelected = new();
    private ReservationPricingContext _reservationContext = new();
    private int _upsellListKey = 0;

    private UpsellTextConfig _texts = new()
    {
        Title = "Vouchery",
        SubTitle = "Dostępne dodatki do kupienia"
    };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        UpsellCartState.OnCleared += OnCartCleared;

        if (string.IsNullOrWhiteSpace(Token))
            return;

        var locale = string.IsNullOrWhiteSpace(CultureInfo.CurrentUICulture.Name)
            ? "pl-PL"
            : CultureInfo.CurrentUICulture.Name;

        _reservationContext = BuildReservationPricingContext();
        _cartSelected = UpsellCartState.PendingUpsells.ToList();
        await AvailableUpsellsState.EnsureLoadedAsync(Token, locale);
    }

    public override void Dispose()
    {
        base.Dispose();
        UpsellCartState.OnCleared -= OnCartCleared;
    }

    private void OnCartCleared()
    {
        _cartSelected = [];
        _upsellListKey++;
        InvokeAsync(StateHasChanged);
    }

    private ReservationPricingContext BuildReservationPricingContext()
    {
        var reservation = ReservationState.CurrentReservation?.Reservation;
        var reservationDetails = reservation?.ReservationDetails;
        var firstItem = reservation?.Items?.FirstOrDefault();

        var fromDateTime = reservationDetails?.getDateFrom() ?? DateTime.Today;
        var toDateTime = reservationDetails?.getDateTo() ?? fromDateTime;

        var adults = firstItem?.numberOfAdults ?? 0;
        var childrenRaw = firstItem?.numberOfSmallChildren;
        var children = int.TryParse(childrenRaw, out var parsedChildren) ? parsedChildren : 0;

        var currency = reservationDetails?.currency;
        if (string.IsNullOrWhiteSpace(currency))
            currency = reservation?.Client?.Currency;
        if (string.IsNullOrWhiteSpace(currency))
            currency = "PLN";

        return new ReservationPricingContext
        {
            StartDate = DateOnly.FromDateTime(fromDateTime),
            EndDate = DateOnly.FromDateTime(toDateTime),
            Adults = adults,
            Children = children,
            Currency = currency
        };
    }

    private void HandleSelectionChanged(List<SelectedUpsellDto> selectedUpsells)
    {
        _cartSelected = selectedUpsells;

        var tiles = _cartSelected
            .Select(s => AvailableUpsellsState.AvailableUpsells
                .FirstOrDefault(u => u.PartnerServiceId == s.PartnerServiceId))
            .Where(t => t is not null)
            .Select(t => t!);

        UpsellCartState.SetVisuals(tiles);

        var lines = _cartSelected.Select(s =>
        {
            var tile = AvailableUpsellsState.AvailableUpsells
                .FirstOrDefault(u => u.PartnerServiceId == s.PartnerServiceId);

            var lineTotal = tile is not null
                ? UpsellPricingCalculator.CalculateTotal(
                    tile.PricingModel,
                    tile.Price,
                    _reservationContext.Nights,
                    _reservationContext.TotalGuests,
                    s.Quantity)
                : 0m;

            return new UpsellSummaryLineDto
            {
                PartnerServiceId = s.PartnerServiceId,
                Title = tile?.Title ?? $"Upsell #{s.PartnerServiceId}",
                PricingModel = tile?.PricingModel ?? default,
                Quantity = s.Quantity,
                UnitPriceGross = tile?.Price ?? 0m,
                Nights = _reservationContext.Nights,
                TotalGuests = _reservationContext.TotalGuests,
                LineTotalGross = lineTotal,
                DisplayText = tile?.ShortDescription ?? string.Empty
            };
        }).ToList();

        UpsellCartState.SetFromSummary(lines, _reservationContext.Currency);
    }
}
