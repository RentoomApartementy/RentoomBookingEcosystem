@page "/ContactUsPage"
@using RentoomBooking.StayWell.Components


<PageTitle>Contact Us</PageTitle>

<div class="page-info-wrapper">
    <PageInfo Title="Szeroka Premier No 2A" Subtitle="Skontaktuj się z nami"></PageInfo>
</div>

<div class="description-wrapper">
    <Description>
        <DescriptionContent>
            <img src="/icons/info.svg"/>
            <span>
                Nasze wsparcie dostępna jest od poniedziałku do niedzieli 08:00 - 22:00
            </span>
        </DescriptionContent>
    </Description>
</div>

<div class="buttons-wrapper">
