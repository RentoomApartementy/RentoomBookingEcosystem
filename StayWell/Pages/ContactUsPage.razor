        </Icon>
    </Button>
    <Button Text="info@rentoom.pl">
        <Icon>
            <img src="/icons/mail.svg">
        </Icon>
    </Button>
        <Button Text="+48 xxx-xxx-xxx">
        <Icon>
            <img src="/icons/phone.svg">
        </Icon>
    </Button>
</div>