@page "/reservation/{token}/HomePage"
@using Microsoft.Extensions.Localization
@using System.Globalization
@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.StayWell.Components
@using RentoomBooking.StayWell.States
@inject StayWell.Services.GlobalizationService GlobalizationService
@inject NavigationManager Navigation
@inject IStringLocalizer<HomePage> Localizer
@implements IDisposable
@inherits Models.PageBase

<PageTitle>Main</PageTitle>

<div class="image-wrapper">
    @if (_isLoading)
    {
        <div class="skeleton">

        </div>
    }
    else
    {
        <ApartmentImage Source="@ImageUrl">

        </ApartmentImage>
    }
</div>




<div class="reservation-info-wrapper">
    @if (_isLoading)
    {
        <div class="reservation-info-skeleton">
            <div class="skeleton-line skeleton-line-title"></div>
            <div class="skeleton-line skeleton-line-address"></div>
            <div class="skeleton-line skeleton-line-dates"></div>
        </div>
    }
    else
    {
        <ReservationInfo apartmentName="@ApartmentName"
            apartmentAddress="@ApartmentAddress"
            apartmentNumber="@ApartmentNumber"
            reservationCheckInDate="@ReservationDateFrom"
            reservationCheckOutDate="@ReservationDateTo">
        </ReservationInfo>
    }
</div>

<div class="buttons-wrapper">

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/ClubPage"))" Text="@Localizer["ClubBenefits"]" ButtonStyle="border-color: #F9B806; color: #F9B806; background-color: #21573e; margin-bottom: 2rem;">
        <Icon>
            <img src="/icons/hand-coins.svg" alt="ClubPage">
        </Icon>
    </Button>

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/InstructionsPage"))" Text="@Localizer["Instructions"]">
        <Icon>
            <img src="/icons/book.svg" alt="InstructionsPage">
        </Icon>
    </Button>

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/OpenApartmentPage"))" Text="@Localizer["OpenApartment"]">
        <Icon>
            <img src="/icons/door-open.svg" alt="OpenApartmentPage">
        </Icon>
    </Button>

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/AboutReservationPage"))" Text="@Localizer["AboutReservation"]">
        <Icon>
            <img src="/icons/info.svg" alt="AboutReservationPage">
        </Icon>
    </Button>

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/ManageStayPage"))" Text="@Localizer["ManageStay"]">
        <Icon>
            <img src="/icons/lamp.svg" alt="ManageStayPage">
        </Icon>
    </Button>

</div>
@code
{

    public string? ApartmentName;
    public string? ApartmentNumber;
    public string? ApartmentAddress;
    public string? ReservationDateFrom;
    public string? ReservationDateTo;
    public string? ImageUrl = string.Empty;

    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        GlobalizationService.OnChange += StateHasChanged;
        LoadData();
        _isLoading = false;
    }

    private void LoadData()
    {   

        var res = Data?.Reservation?.Reservation;
        ApartmentName = res?.Items?.FirstOrDefault()?.objectName;
        ApartmentNumber = res?.Items?.FirstOrDefault()?.itemCode;
        ApartmentAddress = Data?.Apartment?.ObjectLocation?.LocalizationItem?.Street;
        ReservationDateFrom = res?.ReservationDetails?.dateFrom;
        ReservationDateTo = res?.ReservationDetails?.dateTo;

        var image = Data?.Media?.FirstOrDefault(m => m.Extension is "jpg")?.Url;

        ImageUrl = image;
    }

    public void Dispose()
    {
        GlobalizationService.OnChange -= StateHasChanged;
    }
}