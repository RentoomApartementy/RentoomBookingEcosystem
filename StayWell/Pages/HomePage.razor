@page "/reservation/{Token}/"
@page "/reservation/{Token}/HomePage"
@using Microsoft.Extensions.Localization
@using System.Globalization
@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.StayWell.States
@inject NavigationManager Navigation
@inject IStringLocalizer<HomePage> Localizer
@inherits Models.PageBase

<PageTitle>Main</PageTitle>

<div class="image-wrapper">
    @if (_isLoading)
    {
        <div class="skeleton">

        </div>
    }
    else
    {
        <ApartmentImage Source="@ImageUrl" ApartmentName="@ApartmentName">

        </ApartmentImage>
    }
</div>




<div class="reservation-info-wrapper">
    @if (_isLoading)
    {
        <div class="reservation-info-skeleton">
            <div class="skeleton-line skeleton-line-title"></div>
            <div class="skeleton-line skeleton-line-address"></div>
            <div class="skeleton-line skeleton-line-dates"></div>
        </div>
    }
    else
    {
        <DateRangeBar CheckInDate="@checkIn" CheckOutDate="@checkOut" CurrentDate="@now" CheckInLabel="@Localizer["CheckIn"]" CheckOutLabel="@Localizer["CheckOut"]"/>
    }
</div>

<div class="buttons-wrapper">

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/ClubPage"))" Text="@Localizer["ClubBenefits"]" BenefitsClub=true>
        <Icon>
            <img src="/icons/hand-coins.svg" alt="ClubPage">
        </Icon>
    </Button>

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/MyVouchersPage"))" Text="Twoje Vouchery" BenefitsClub=true>
        <Icon>
            <img src="/icons/hand-coins.svg" alt="ClubPage">
        </Icon>
    </Button>

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/Vouchers"))" Text="Vouchery" BenefitsClub=true>
        <Icon>
            <img src="/icons/hand-coins.svg" alt="ClubPage">
        </Icon>
    </Button>


    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/InstructionsPage"))" Text="@Localizer["Instructions"]">
        <Icon>
            <img src="/icons/book.svg" alt="InstructionsPage">
        </Icon>
    </Button>

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/OpenApartmentPage"))" Text="@Localizer["OpenApartment"]">
        <Icon>
            <img src="/icons/door-open.svg" alt="OpenApartmentPage">
        </Icon>
    </Button>

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/AboutReservationPage"))" Text="@Localizer["AboutReservation"]">
        <Icon>
            <img src="/icons/info.svg" alt="AboutReservationPage">
        </Icon>
    </Button>

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/ManageStayPage"))" Text="@Localizer["ManageStay"]">
        <Icon>
            <img src="/icons/lamp.svg" alt="ManageStayPage">
        </Icon>
    </Button>

    <Button OnClick="@(() => Navigation.NavigateTo($"/reservation/{Token}/ExtendReservationPage"))" Text="@Localizer["ExtendReservation"]">
        <Icon>
            <img src="/icons/calendar-plus.svg" alt="ExtendReservationPage">
        </Icon>
    </Button>

</div>
@code
{

    public string? ApartmentName;
    public string? ApartmentNumber;
    public string? ApartmentAddress;
    public string? ReservationDateFrom;
    public string? ReservationDateTo;
    public string? ImageUrl = string.Empty;

    private DateTime checkIn;
    private DateTime checkOut;
    private DateTime now;

    private Reservation? Reservation => ReservationState?.CurrentReservation?.Reservation;

    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        LoadData();
        DateTime.TryParseExact(Reservation?.ReservationDetails?.dateFrom, "yyyy-MM-dd HH:mm", null, DateTimeStyles.None, out var ci);
        DateTime.TryParseExact(Reservation?.ReservationDetails?.dateTo, "yyyy-MM-dd HH:mm", null, DateTimeStyles.None, out var co);
        checkIn = ci;
        checkOut = co;
        now = DateTime.Now;
        _isLoading = false;
    }

    private void LoadData()
    {   

        ApartmentName = Reservation?.Items?.FirstOrDefault()?.objectName;
        ApartmentNumber = Reservation?.Items?.FirstOrDefault()?.itemCode;
        ApartmentAddress = ApartmentState.CurrentApartment?.ObjectLocation?.LocalizationItem?.Street;
        ReservationDateFrom = Reservation?.ReservationDetails?.dateFrom;
        ReservationDateTo = Reservation?.ReservationDetails?.dateTo;

        LoadImage();

    }

    private void LoadImage()
    {
        const string placeholder = "/images/placeholders/apartment_placeholder.png";

        ImageUrl = MediaState?.CurrentMedia?
            .FirstOrDefault(m => string.Equals(m.Extension, "jpg", StringComparison.OrdinalIgnoreCase))
            ?.Url
            ?? placeholder;
    }


}
