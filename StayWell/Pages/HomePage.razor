@page "/reservation/{Token}/"
@page "/reservation/{Token}/HomePage"
@using Microsoft.Extensions.Localization
@using System.Globalization
@using RentoomBooking.SharedClasses.Models.IdoBooking
@using RentoomBooking.StayWell.States
@using RentoomBooking.SharedClasses.Models.ReservationWorkflow
@using RentoomBooking.SharedClasses.Models.Upsell
@using RentoomBooking.SharedFrontend.Components.Shared.UpsellComponents
@using RentoomBooking.StayWell.Services
@inject NavigationManager Navigation
@inject IStringLocalizer<HomePage> Localizer
@inject FeatureFlagsService FeatureFlagsService
@inject BackendApi BackendApi
@inject UpsellCartState UpsellCartState
@inject AvailableUpsellsState AvailableUpsellsState
@inherits Models.PageBase

<PageTitle>@Localizer["PageTitle"]</PageTitle>

<div class="image-wrapper">
    @if (MediaState.IsLoading || ReservationState.IsLoading || string.IsNullOrEmpty(ImageUrl))
    {
        <div class="skeleton"></div>
    }
    else
    {
        <ApartmentImage Source="@ImageUrl" ApartmentName="@ApartmentName" />
    }
</div>

@if (ReservationState.IsLoading)
{
    <div style="padding-top: 20px;">
        <div class="skeleton skeleton-bar"></div>
    </div>

    <div class="tile--row">
        <div class="skeleton skeleton-tile" style="max-width:180px; flex:1;"></div>
        <div class="skeleton skeleton-tile" style="max-width:180px; flex:1;"></div>
        <div class="skeleton skeleton-tile" style="max-width:180px; flex:1;"></div>
    </div>
}
else
{
    <div style="padding-top: 20px;">
        <DateRangeBar CheckInDate="@checkIn" CheckOutDate="@checkOut" CurrentDate="@now"
                      CheckInLabel="@Localizer["CheckIn"]" CheckOutLabel="@Localizer["CheckOut"]"
                      CheckInTime="@ReservationState.CheckInTime"
                      CheckOutTime="@ReservationState.CheckOutTime" />
    </div>

    @if (checkIn != default) // && now >= checkIn.AddMinutes(-15))
    {
        <div class="checkin-button-wrapper">
            <button type="button" class="checkin-button" @onclick='() => Navigation.NavigateTo($"/reservation/{Token}/CheckIn")'>
                <span class="checkin-button-text">@Localizer["CheckInNow"]</span>
                <img class="checkin-button-pointer" src="/icons/pointer.svg" alt="" />
            </button>
        </div>
    }

    <div class="tile--row">
        <div class="tile" @onclick='() => Navigation.NavigateTo($"/reservation/{Token}/CheckIn?focus=instructions")'>
            <div class="tile-header">
                <span class="tile-text">@Localizer["Instructions"]</span>
                <img class="tile-chevron" src="/icons/chevron-right.svg" alt="" aria-hidden="true" />
            </div>
            <div class="tile-icon">
                <img class="fas" src="/icons/book.svg" />
            </div>
        </div>
        <div class="tile" @onclick='() => Navigation.NavigateTo($"/reservation/{Token}/CheckIn?focus=open")'>
            <div class="tile-header">
                <span class="tile-text">@Localizer["OpenApartment"]</span>
                <img class="tile-chevron" src="/icons/chevron-right.svg" alt="" aria-hidden="true" />
            </div>
            <div class="tile-icon">
                <img class="fas" src="/icons/lock.svg" />
            </div>
            @if (!LocksState.IsLoading && LocksState.CurrentCode is not null)
            {
                <div class="tile-access-code">
                    <span class="tile-access-code__number">@LocksState.CurrentCode.Code</span>
                    <span class="tile-access-code__sep">·</span>
                    <span class="tile-access-code__hash">#</span>
                    <span class="tile-access-code__sep">·</span>
                    <img class="tile-access-code__key" src="/icons/key-round.svg" alt="" />
                </div>
            }
        </div>
        @if (FeatureFlagsService.FeatureAllowed("ai-assistant"))
        {
            <div class="tile" @onclick="OpenAiChat">
                <div class="tile-header">
                    <span class="tile-text">@Localizer["AiAssistant"]</span>
                    <img class="tile-chevron" src="/icons/chevron-right.svg" alt="" aria-hidden="true" />
                </div>
                <div class="tile-icon">
                    <img class="fas" src="/icons/chat-ai-staywell.jpg" />
                </div>
            </div>
        }

    @if (FeatureFlagsService.FeatureAllowed("my-vouchers"))
    {


        <div class="tile vouchers" @onclick='() => Navigation.NavigateTo($"/reservation/{Token}/MyVouchersPage")'>
            <div class="tile-header">
                <span class="tile-text tile-text-vouchers">@Localizer["MyVouchers"]</span>
                <img class="tile-chevron" src="/icons/chevron-right.svg" alt="" aria-hidden="true" />
            </div>
            <div class="tile-icon-vouchers">
                <img class="fas" src="/icons/ticket-percent.svg" />
                @if (PurchasedVouchersCount > 0)
                {
                    <span class="vouchers-badge">@PurchasedVouchersCount</span>
                }
            </div>
        </div>

     }
    </div>

    @if (FeatureFlagsService.FeatureAllowed("upsells"))
    {
        //MS 17.03: Sekcja narazie jest ukryta - flow biznesowy jest jeszcze do obgadania.
        <RentoomBooking.StayWell.Components.Upsells.AvailableUpsells
        Token="@Token"
        ReservationContext="_reservationContext"
        Title="@Localizer["Enhance"]"
        MaxItems="3"
        MaxItemsDesktop="2"
        Theme="staywell-theme"
        morebuttontext="@Localizer["More"]"
        OnSelectionChanged="OnUpsellsSelected" />

        <div class="homepage-upsell-spacer"></div>
    }
}

@code
{
    public string? ApartmentName;
    public string? ApartmentNumber;
    public string? ApartmentAddress;
    public string? ReservationDateFrom;
    public string? ReservationDateTo;
    public string? ImageUrl = null;

    private DateTime checkIn;
    private DateTime checkOut;
    private DateTime now;
    private int PurchasedVouchersCount;

    private Reservation? Reservation => ReservationState?.CurrentReservation?.Reservation;

    private ReservationPricingContext _reservationContext = new();

    private void OnUpsellsSelected(List<SelectedUpsellDto> selected)
    {
        var tiles = selected
            .Select(s => AvailableUpsellsState.AvailableUpsells
                .FirstOrDefault(u => u.PartnerServiceId == s.PartnerServiceId))
            .Where(t => t is not null)
            .Select(t => t!);

        UpsellCartState.SetVisuals(tiles);

        var lines = selected.Select(s =>
        {
            var tile = AvailableUpsellsState.AvailableUpsells
                .FirstOrDefault(u => u.PartnerServiceId == s.PartnerServiceId);

            var lineTotal = tile is not null
                ? UpsellPricingCalculator.CalculateTotal(
                    tile.PricingModel,
                    tile.Price,
                    _reservationContext.Nights,
                    _reservationContext.TotalGuests,
                    s.Quantity)
                : 0m;

            return new UpsellSummaryLineDto
            {
                PartnerServiceId = s.PartnerServiceId,
                Title = tile?.Title ?? $"Upsell #{s.PartnerServiceId}",
                PricingModel = tile?.PricingModel ?? default,
                Quantity = s.Quantity,
                UnitPriceGross = tile?.Price ?? 0m,
                Nights = _reservationContext.Nights,
                TotalGuests = _reservationContext.TotalGuests,
                LineTotalGross = lineTotal,
                DisplayText = tile?.ShortDescription ?? string.Empty
            };
        }).ToList();

        UpsellCartState.SetFromSummary(lines, _reservationContext.Currency);
    }

    private ReservationPricingContext BuildReservationPricingContext()
    {
        var reservation = ReservationState.CurrentReservation?.Reservation;
        var reservationDetails = reservation?.ReservationDetails;
        var firstItem = reservation?.Items?.FirstOrDefault();

        var fromDateTime = reservationDetails?.getDateFrom() ?? DateTime.Today;
        var toDateTime = reservationDetails?.getDateTo() ?? fromDateTime;

        var adults = firstItem?.numberOfAdults ?? 0;
        var childrenRaw = firstItem?.numberOfSmallChildren;
        var children = int.TryParse(childrenRaw, out var parsedChildren) ? parsedChildren : 0;

        var currency = reservationDetails?.currency;
        if (string.IsNullOrWhiteSpace(currency))
            currency = reservation?.Client?.Currency;
        if (string.IsNullOrWhiteSpace(currency))
            currency = "PLN";

        return new ReservationPricingContext
        {
            StartDate = DateOnly.FromDateTime(fromDateTime),
            EndDate = DateOnly.FromDateTime(toDateTime),
            Adults = adults,
            Children = children,
            Currency = currency
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        LoadData();
        // Licznik voucherów ładuje się w tle — nie blokuje pierwszego renderu strony.
        _ = LoadPurchasedVouchersCountAsync();

        if (!string.IsNullOrWhiteSpace(Token))
        {
            if (!LocksState.IsStatusResolved)
            {
                _ = LocksState.CheckTTLockStatusAsync(Token);
            }

            if (FeatureFlagsService.FeatureAllowed("dev-mock-lock"))
            {
                _ = Task.Run(async () =>
                {
                    await LocksState.LoadAccessCodesAsync(Token);
                    await LocksState.RestoreDevMockCodesAsync(Token);
                    await LocksState.EnsureInitialDevMockCodeAsync(Token);
                });
            }
            else if (LocksState.CurrentCode is null)
            {
                _ = LocksState.LoadAccessCodesAsync(Token);
            }
        }

        DateTime.TryParseExact(Reservation?.ReservationDetails?.dateFrom, "yyyy-MM-dd HH:mm", null, DateTimeStyles.None, out var ci);
        DateTime.TryParseExact(Reservation?.ReservationDetails?.dateTo, "yyyy-MM-dd HH:mm", null, DateTimeStyles.None, out var co);
        checkIn = ci;
        checkOut = co;
        now = DateTime.Now;
    }

    private async Task LoadPurchasedVouchersCountAsync()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            PurchasedVouchersCount = 0;
            return;
        }

        try
        {
            var purchasedSummary = await BackendApi.GetPurchasedUpsellsByReservationTokenAsync(Token);
            var purchasedVoucherLines = purchasedSummary?.PurchasedUpsellsWithVouchers ?? [];

            PurchasedVouchersCount = purchasedVoucherLines
                .Where(line => line.Voucher is not null)
                .Sum(line => line.Quantity > 0 ? line.Quantity : 0);

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"LoadPurchasedVouchersCountAsync failed: {ex}");
        }
    }

    private void LoadData()
    {
        ApartmentName = Reservation?.Items?.FirstOrDefault()?.objectName;
        ApartmentNumber = Reservation?.Items?.FirstOrDefault()?.itemCode;
        ApartmentAddress = ApartmentState.CurrentApartment?.ObjectLocation?.LocalizationItem?.Street;
        ReservationDateFrom = Reservation?.ReservationDetails?.dateFrom;
        ReservationDateTo = Reservation?.ReservationDetails?.dateTo;
        LoadImage();
        _reservationContext = BuildReservationPricingContext();
    }

    private void LoadImage()
    {
        const string placeholder = "/images/placeholders/apartment_placeholder.png";

        var image = MediaState?.CurrentMedia?
            .FirstOrDefault(m =>
                !string.IsNullOrWhiteSpace(m.Url) &&
                (string.Equals(m.Extension, "jpg", StringComparison.OrdinalIgnoreCase) ||
                 string.Equals(m.Extension, "png", StringComparison.OrdinalIgnoreCase)))
            ?? MediaState?.CurrentMedia?
                .FirstOrDefault(m => !string.IsNullOrWhiteSpace(m.Url));

        ImageUrl = image?.Url ?? placeholder;
    }

    private void OpenAiChat()
    {
        ModalService.ShowAiChatModal(
            Localizer["AiChatTitle"],
            @<RentoomBooking.StayWell.Components.ModalContent.AiChatPanel Token="@Token" IsFullscreen="true" />
        );
    }
}
