@page "/reservation/{token}/OpenApartmentPage"
@using RentoomBooking.StayWell.Components
@using RentoomBooking.StayWell.States
@using Microsoft.Extensions.Localization
@using RentoomBooking.StayWell.Services
@using System.Globalization
@using System.Threading

@inject IStringLocalizer<OpenApartmentPage> Localizer
@inject BackendApi BackendApi
@inherits Models.PageBase

@inject IJSRuntime JS

<PageTitle>OpenApartmentPage</PageTitle>

<div class="buttons-wrapper">
    @if (LocksState.IsLoading)
    {
        <div class="tile tile--center">
            <div class="skeleton skeleton--button"></div>
            <div class="skeleton skeleton--text" style="margin-top: 15px;"></div>
        </div>
    }
    else if (LocksState.IsTTLockLoading)
    {
        <div class="tile tile--center">
            <div class="spinner"></div>
            <div class="status-text">
                <span>@Localizer["CheckingLock"]</span>
            </div>
        </div>
    }
    else if (LocksState.IsTTLockAvailable)
    {
        <div class="tile tile--center">
            <div class="tile__title" style="margin-bottom: 10px;">
                @Localizer["RemoteOpen"]
            </div>
            <button class="open-button @(IsOpened ? "unlocked" : "locked") @(IsProcessing ? "loading" : "")"
                    @onclick="ToggleDoor"
                    disabled="@(IsButtonDisabled || IsProcessing)">
                @if (IsProcessing)
                {
                    <div class="spinner"></div>
                }
                else
                {
                    <img class="lock" src="@(IsOpened ? "/icons/lock-open.svg" : "/icons/lock.svg")" />
                }
            </button>
            <div class="status-text">
                @if (IsProcessing)
                {
                    <span>@Localizer["Processing"]...</span>
                }
                else if (IsOpened)
                {
                    <span class="text-unlocked">@Localizer["DoorOpened"]</span>
                }
                else
                {
                    <span class="text-locked">@Localizer["PressToOpen"]</span>
                }
            </div>
        </div>
    }
    else
    {
        <div class="tile">
            <div class="tile__title">
                @Localizer["RemoteOpen"]
            </div>
            <div class="tile__content">
                @Localizer["RemoteUnavailable"]
                <div style="margin-top: 12px;">
                    <button class="retry-button"
                            disabled="@IsRetryDisabled"
                            @onclick="RetryPing">
                        @RetryButtonText
                    </button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-message">
            @ErrorMessage
        </div>
    }

    <div class="tile">
        <div class="tile__title">
            <img src="/icons/binary.svg" class="icon-inline" />
            @Localizer["YourIndividualCode"]:
        </div>
        <div class="tile__content">
            @if (ReservationState.IsLoading || LocksState.IsLoading)
            {
                <div class="skeleton skeleton--code"></div>
                <div class="skeleton skeleton--text-short" style="margin-top: 8px;"></div>
            }
            else if (!ReservationState.IsActiveReservation)
            {
                <span>@Localizer["CodeNotAvailable"]</span>
            }
            else if (!string.IsNullOrEmpty(LocksState.CurrentLocks?.FirstOrDefault()?.Code?.ToString()))
            {
                <span class="bold">@LocksState.CurrentLocks?.FirstOrDefault()?.Code?.ToString()</span>
                <span>@Localizer["Confirm"]</span>
                <span class="bold">#</span>
                <span>@Localizer["Or"]</span>
                <img src="/icons/key-round.svg" class="icon-key" />
            }
            else
            {
                <div>
                    <img style="height: 50px; width: 50px;" src="/icons/octagon-alert.svg" />
                    <p style="padding-top: 10px;">
                        @Localizer["NoCode"]
                    </p>
                </div>
            }
        </div>
    </div>

    <div class="carousel-card">
        <div class="carousel-track" id="lock-carousel">
            <div class="carousel-slide">
                <div class="tile__title" style="justify-content: center; margin-bottom: 15px;">
                    @Localizer["HowTo"] *1
                </div>
                <RentoomBooking.StayWell.Components.AnimationsComponents.LockAnimation />
            </div>
            <div class="carousel-slide">
                <div class="tile__title" style="justify-content: center; margin-bottom: 15px;">
                    @Localizer["HowTo"] *2
                </div>
                <RentoomBooking.StayWell.Components.AnimationsComponents.LockPanelAnimation />
            </div>
        </div>
        <div class="dots-indicator" id="carousel-dots">
            <div class="dot active" @onclick="() => ScrollToSlide(0)"></div>
            <div class="dot" @onclick="() => ScrollToSlide(1)"></div>
        </div>
    </div>
</div>

@code {
    private bool IsOpened = false;
    private bool IsProcessing = false;
    private string? ErrorMessage;

    private bool IsButtonDisabled => ReservationState?.CurrentReservation?.Reservation?.ReservationDetails == null ||
                                     DateTime.Now < ReservationState.CurrentReservation.Reservation.ReservationDetails.getDateFrom();

    private async Task ScrollToSlide(int index)
    {
        await JS.InvokeVoidAsync("eval", $"document.getElementById('lock-carousel').scrollTo({{ left: document.getElementById('lock-carousel').clientWidth * {index}, behavior: 'smooth' }})");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", @"
                const track = document.getElementById('lock-carousel');
                const dots = document.getElementById('carousel-dots').children;
                if (track && dots.length > 0) {
                    track.addEventListener('scroll', () => {
                        const index = Math.round(track.scrollLeft / track.clientWidth);
                        Array.from(dots).forEach((dot, i) => {
                            if (i === index) {
                                dot.classList.add('active');
                            } else {
                                dot.classList.remove('active');
                            }
                        });
                    }, { passive: true });
                }
            ");
        }

        var isRemoteUnavailable = IsRemoteUnavailable;
        if (isRemoteUnavailable && !_wasRemoteUnavailable)
        {
            StartRetryCountdown();
        }
        else if (!isRemoteUnavailable && _wasRemoteUnavailable)
        {
            CancelRetryCountdown();
        }

        _wasRemoteUnavailable = isRemoteUnavailable;
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        if (!string.IsNullOrWhiteSpace(Token))
        {
            _ = LocksState.CheckTTLockStatusAsync(Token);
        }
    }

    private async Task ToggleDoor()
    {
        if (IsButtonDisabled || IsProcessing) return;

        IsProcessing = true;
        ErrorMessage = null;

        try
        {
            if (!IsOpened)
            {
                var result = await BackendApi.OpenLockAsync(Token);
                if (result is not null && result.IsSuccess)
                {
                    IsOpened = true;
                }
                else
                {
                    ErrorMessage = result?.Status ?? Localizer["ErrorOpening"];
                }
            }
            else
            {
                var result = await BackendApi.CloseLockAsync(Token);
                if (result is not null && result.IsSuccess)
                {
                    IsOpened = false;
                }
                else
                {
                    ErrorMessage = result?.Status ?? Localizer["ErrorClosing"];
                }
            }
        }
        catch
        {
            ErrorMessage = Localizer["ErrorServerConnection"];
        }
        finally
        {
            IsProcessing = false;
        }
    }

    private int _retrySecondsRemaining;
    private bool _isRetryCountdownActive;
    private bool _wasRemoteUnavailable;
    private CancellationTokenSource? _retryCts;

    private bool IsRemoteUnavailable =>
        !LocksState.IsLoading && !LocksState.IsTTLockLoading && !LocksState.IsTTLockAvailable;

    private bool IsRetryDisabled =>
        _retrySecondsRemaining > 0 || LocksState.IsTTLockLoading || string.IsNullOrWhiteSpace(Token);

    private string RetryButtonText =>
        _isRetryCountdownActive
            ? string.Format(CultureInfo.CurrentCulture, Localizer["TryAgainIn"], _retrySecondsRemaining)
            : Localizer["TryAgain"];

    private void StartRetryCountdown()
    {
        CancelRetryCountdown();
        _retrySecondsRemaining = 30;
        _isRetryCountdownActive = true;
        _retryCts = new CancellationTokenSource();
        _ = RunRetryCountdownAsync(_retryCts.Token);
        StateHasChanged();
    }

    private void CancelRetryCountdown()
    {
        if (_retryCts is not null)
        {
            _retryCts.Cancel();
            _retryCts.Dispose();
            _retryCts = null;
        }

        _retrySecondsRemaining = 0;
        _isRetryCountdownActive = false;
    }

    private async Task RunRetryCountdownAsync(CancellationToken token)
    {
        try
        {
            while (_retrySecondsRemaining > 0 && !token.IsCancellationRequested)
            {
                await Task.Delay(1000, token);
                if (token.IsCancellationRequested)
                {
                    return;
                }

                _retrySecondsRemaining--;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException)
        {
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _isRetryCountdownActive = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task RetryPing()
    {
        if (string.IsNullOrWhiteSpace(Token) || LocksState.IsTTLockLoading)
        {
            return;
        }

        await LocksState.CheckTTLockStatusAsync(Token);
    }

    public override void Dispose()
    {
        CancelRetryCountdown();
        base.Dispose();
    }
}
