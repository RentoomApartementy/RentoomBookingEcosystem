@page "/reservation/{token}/OpenApartmentPage"
@using RentoomBooking.StayWell.Components
@using RentoomBooking.StayWell.States
@using Microsoft.Extensions.Localization
@using RentoomBooking.StayWell.Services
@using System.Globalization

@inject IStringLocalizer<OpenApartmentPage> Localizer
@inject BackendApi BackendApi
@inject FeatureFlagsService FeatureFlagsService
@inherits Models.PageBase

@inject IJSRuntime JS

<PageTitle>@Localizer["PageTitle"]</PageTitle>

<div class="buttons-wrapper">
    @if (LocksState.IsLoading && !IsDevMockLock)
    {
        <div class="tile tile--center">
            <div class="skeleton skeleton--button"></div>
            <div class="skeleton skeleton--text" style="margin-top: 15px;"></div>
        </div>
    }
    else if (LocksState.IsTTLockLoading && !IsDevMockLock)
    {
        <div class="tile tile--center">
            <div class="tile__title" style="margin-bottom: 10px;">
                @Localizer["RemoteOpen"]
            </div>
            <div class="spinner"></div>
            <div class="status-text">
                <span>@Localizer["CheckingLock"]</span>
            </div>
        </div>
    }
    else if (!ReservationState.IsActiveReservation && !_debugMode && !IsDevMockLock)
    {
        <div class="tile tile--center">
            <div class="tile__title" style="margin-bottom: 10px;">
                @Localizer["RemoteOpen"]
            </div>
            <div class="inactive-reservation-badge">
                <img src="/icons/octagon-alert.svg" class="inactive-reservation-icon" />
                @if (ReservationState.IsAfterCheckOut)
                {
                    <span>@Localizer["ReservationEnded"]</span>
                }
                else
                {
                    <span>@string.Format(CultureInfo.CurrentCulture, Localizer["ReservationNotActive"], ReservationState.CheckInTime.ToString("HH:mm"))</span>
                }
            </div>
        </div>
    }
    else if (LocksState.IsTTLockAvailable || IsDevMockLock)
    {
        <div class="tile tile--center">
            <div class="tile__title" style="margin-bottom: 10px;">
                @Localizer["RemoteOpen"]
            </div>
            <button class="open-button @(IsOpened ? "unlocked" : "locked") @(IsProcessing ? "loading" : "")"
                    @onclick="ToggleDoor"
                    disabled="@(IsButtonDisabled || IsProcessing)">
                @if (IsProcessing)
                {
                    <div class="spinner"></div>
                }
                else
                {
                    <img class="lock" src="@(IsOpened ? "/icons/lock-open.svg" : "/icons/lock.svg")" />
                }
            </button>
            <div class="status-text">
                @if (IsProcessing)
                {
                    <span>@Localizer["Processing"]...</span>
                }
                else if (IsOpened)
                {
                    <span class="text-unlocked">@Localizer["DoorOpened"]</span>
                }
                else
                {
                    <span class="text-locked">@Localizer["PressToOpen"]</span>
                }
            </div>
        </div>
    }
    else
    {
        <div class="tile">
            <div class="tile__title">
                @Localizer["RemoteOpen"]
            </div>
            <div class="tile__content">
                @Localizer["RemoteUnavailable"]
                <div style="margin-top: 12px;">
                    <button class="retry-button"
                            disabled="@(LocksState.IsRetryDisabled || string.IsNullOrWhiteSpace(Token))"
                            @onclick="RetryPing">
                        @if (LocksState.IsTTLockLoading)
                        {
                            <div class="spinner spinner--small"></div>
                        }
                        else
                        {
                            @RetryButtonText
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-message">
            @ErrorMessage
        </div>
    }

    <div class="tile">
        <div class="tile__title">
            <img src="/icons/binary.svg" class="icon-inline" />
            @Localizer["YourIndividualCode"]:
        </div>
        <div class="tile__content">
            @if (ReservationState.IsLoading || LocksState.IsLoading)
            {
                <div class="skeleton skeleton--code"></div>
                <div class="skeleton skeleton--text-short" style="margin-top: 8px;"></div>
            }
            else if (!ReservationState.IsCodeAvailable && !_debugMode && !IsDevMockLock)
            {
                @if (ReservationState.IsAfterCheckOut)
                {
                    <span>@Localizer["CodeNoLongerAvailable"]</span>
                }
                else
                {
                    <span>@string.Format(CultureInfo.CurrentCulture, Localizer["CodeNotAvailable"], ReservationState.CodeAvailableFromTime.ToString("HH:mm"))</span>
                }
            }
            else
            {
                @if (LocksState.CurrentCode is not null && LocksState.CurrentCode.IsTTLock)
                {
                    <div class="passcode-main">
                        <span class="bold">@LocksState.CurrentCode.Code</span>
                        <span>@Localizer["Confirm"]</span>
                        <span class="bold">#</span>
                        <span>@Localizer["Or"]</span>
                        <img src="/icons/key-round.svg" class="icon-key" />
                    </div>
                    <div class="passcode-validity passcode-validity--center ">
                        <img src="/icons/clock.svg" class="passcode-validity__icon" />
                        <span>@FormatPasscodeValidity(LocksState.CurrentCode.ValidFrom, LocksState.CurrentCode.ValidTo)</span>
                    </div>
                }
                else if (LocksState.CurrentCode is not null && LocksState.CurrentCode.IsIdo)
                {
                    <span class="bold">@LocksState.CurrentCode.Code</span>
                    <span>@Localizer["Confirm"]</span>
                    <span class="bold">#</span>
                    <span>@Localizer["Or"]</span>
                    <img src="/icons/key-round.svg" class="icon-key" />
                }
                else
                {
                    <div>
                        <img style="height: 50px; width: 50px;" src="/icons/octagon-alert.svg" />
                        <p style="padding-top: 10px;">
                            @Localizer["NoCode"]
                        </p>
                    </div>
                }

                @if ((ReservationState.IsActiveReservation || _debugMode || IsDevMockLock))
                {
                    <div style="margin-top: 14px;">
                        <button class="retry-button"
                                disabled="@(!IsGenerateButtonEnabled && !_debugMode)"
                                @onclick="HandleGeneratePasscode">
                            @if (LocksState.IsPasscodeLoading)
                            {
                                <div class="spinner spinner--small"></div>
                                <span>@string.Format(
                                    CultureInfo.CurrentCulture,
                                    Localizer["GeneratingCode"],
                                    LocksState.PasscodeLoadingElapsedSeconds)</span>
                            }
                            else if (LocksState.LiveCooldownSecondsRemaining > 0 && !_debugMode)
                            {
                                <img src="/icons/alarm-clock-check.svg" class="retry-button__icon" />
                                @string.Format(
                                    CultureInfo.CurrentCulture,
                                    Localizer["NewCodeIn"],
                                    FormatCooldown(LocksState.LiveCooldownSecondsRemaining))
                            }
                            else
                            {
                                @Localizer["GenerateNewCode"]
                            }
                        </button>
                    </div>
                }
            }
        </div>
    </div>

    @{
        var hasHistory = LocksState.AllCodes.Count > 1;
    }
    @if (hasHistory && (ReservationState.IsActiveReservation || _debugMode || IsDevMockLock) && !ReservationState.IsLoading && !LocksState.IsLoading)
    {
        <div class="tile passcode-history-tile">
            <button class="passcode-history__toggle" @onclick="TogglePasscodeHistory">
                <div class="passcode-history__toggle-left">
                    <img src="/icons/clock.svg" class="icon-inline" />
                    <span>@Localizer["PreviousCodes"]</span>
                </div>
                <img src="/icons/chevron-down.svg"
                     class="passcode-history__chevron @(IsPasscodeHistoryOpen ? "passcode-history__chevron--open" : "")" />
            </button>

            @if (IsPasscodeHistoryOpen)
            {
                <div class="passcode-history__list">
                    @foreach (var code_ in LocksState.AllCodes.Skip(1))
                    {
                        @if (code_.IsIdo)
                        {
                            <div class="passcode-history__item passcode-history__item--ido">
                                <div class="passcode-history__left">
                                    <span class="passcode-history__code bold">@code_.Code</span>
                                    <span class="passcode-history__confirm-hint">
                                        @Localizer["Confirm"] <span class="bold">#</span>
                                        @Localizer["Or"]
                                        <img src="/icons/key-round.svg" class="passcode-history__key-icon" />
                                    </span>
                                </div>
                                <span class="passcode-history__meta">@Localizer["CodeFromIdo"]</span>
                            </div>
                        }
                        else
                        {
                            <div class="passcode-history__item">
                                <div class="passcode-history__left">
                                    <span class="passcode-history__code bold">@code_.Code</span>
                                    <span class="passcode-history__confirm-hint">
                                        @Localizer["Confirm"] <span class="bold">#</span>
                                        @Localizer["Or"]
                                        <img src="/icons/key-round.svg" class="passcode-history__key-icon" />
                                    </span>
                                    @if (code_.ValidFrom is not null || code_.ValidTo is not null)
                                    {
                                        <span class="passcode-history__validity">
                                            @FormatPasscodeValidity(code_.ValidFrom, code_.ValidTo)
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    }

    <LockGuideCard />
</div>

@code {
    private bool IsPasscodeHistoryOpen = false;

#if DEBUG
    private bool _debugMode = false;
#else
    private bool _debugMode = false;
#endif

    private bool IsDevMockLock => FeatureFlagsService.FeatureAllowed("dev-mock-lock");

    private bool IsGenerateButtonEnabled =>
        LocksState.IsPasscodeGenerationAllowed || IsDevMockLock;

    private bool IsOpened = false;
    private bool IsProcessing = false;
    private string? ErrorMessage;

    private bool IsButtonDisabled =>
        !_debugMode
        && !IsDevMockLock
        && (
            ReservationState?.CurrentReservation?.Reservation?.ReservationDetails
                == null
            || DateTime.Now
                < ReservationState
                    .CurrentReservation
                    .Reservation
                    .ReservationDetails
                    .getDateFrom()
        );

    private string RetryButtonText =>
        LocksState.IsRetryCountdownActive
            ? string.Format(
                CultureInfo.CurrentCulture,
                Localizer["TryAgainIn"],
                LocksState.RetrySecondsRemaining
            )
            : Localizer["TryAgain"];

    private static string FormatCooldown(int seconds)
    {
        var h = seconds / 3600;
        var m = (seconds % 3600) / 60;
        var s = seconds % 60;
        return h > 0
            ? $"{h}:{m:D2}:{s:D2}"
            : m > 0
                ? $"{m}:{s:D2}"
                : $"{s}s";
    }

    private string FormatPasscodeValidity(DateTimeOffset? startDate, DateTimeOffset? endDate)
    {
        var start = startDate?.ToLocalTime();
        var end = endDate?.ToLocalTime();

        if (start is not null && end is not null)
        {
            return string.Format(
                CultureInfo.CurrentCulture,
                Localizer["CodeValidFromTo"],
                start.Value.ToString("HH:mm dd.MM", CultureInfo.CurrentCulture),
                end.Value.ToString("HH:mm dd.MM", CultureInfo.CurrentCulture));
        }

        if (start is not null)
        {
            return string.Format(
                CultureInfo.CurrentCulture,
                Localizer["CodeValidFrom"],
                start.Value.ToString("HH:mm dd.MM", CultureInfo.CurrentCulture));
        }

        if (end is not null)
        {
            return string.Format(
                CultureInfo.CurrentCulture,
                Localizer["CodeValidTo"],
                end.Value.ToString("HH:mm dd.MM", CultureInfo.CurrentCulture));
        }

        return string.Empty;
    }

    private void TogglePasscodeHistory() =>
        IsPasscodeHistoryOpen = !IsPasscodeHistoryOpen;

    private async Task HandleGeneratePasscode()
    {
        if (IsDevMockLock)
        {
            await LocksState.GenerateDevMockPasscodeAsync(Token);
            ToastService.ShowToast(Localizer["PasscodeGeneratedSuccess"]);
            return;
        }

        if (string.IsNullOrWhiteSpace(Token)) return;

        var previousPwdId = LocksState.CurrentCode?.KeyboardPwdId;

        await LocksState.GeneratePasscodeAsync(Token);

        if (LocksState.CurrentCode is not null && !LocksState.IsPasscodeLoading
            && LocksState.CurrentCode.KeyboardPwdId != previousPwdId)
        {
            ToastService.ShowToast(Localizer["PasscodeGeneratedSuccess"]);
        }
    }

    private void DebugResetCooldown()
    {
        StateHasChanged();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            LocksState.RestoreRetryCountdownIfNeeded();
        }

        return Task.CompletedTask;
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        GlobalizationService.OnChange += OnLanguageChanged;

        if (!string.IsNullOrWhiteSpace(Token))
        {
            if (!LocksState.IsStatusResolved)
            {
                _ = LocksState.CheckTTLockStatusAsync(Token);
            }

            if (IsDevMockLock)
            {
                _ = Task.Run(async () =>
                {
                    await LocksState.LoadAccessCodesAsync(Token);
                    await LocksState.RestoreDevMockCodesAsync(Token);
                    await LocksState.EnsureInitialDevMockCodeAsync(Token);
                });
            }
            else
            {
                _ = LocksState.LoadAccessCodesAsync(Token);
            }
        }

        LoadLockInstructions();
    }

    public void Dispose()
    {
        GlobalizationService.OnChange -= OnLanguageChanged;
    }

    private void LoadLockInstructions() =>
        InvokeAsync(async () =>
        {
            var apartmentItemId = ReservationState.CurrentReservation?.Reservation?.Items?.FirstOrDefault()?.objectItemId;
            if (apartmentItemId is > 0)
            {
                await ApartmentState.GetArrivalInstructionStepsAsync(apartmentItemId.Value, GlobalizationService.CurrentCulture.Name);
            }
            StateHasChanged();
        });

    private void OnLanguageChanged() => LoadLockInstructions();

    private async Task ToggleDoor()
    {
        if (IsButtonDisabled || IsProcessing) return;

        if (IsDevMockLock)
        {
            IsProcessing = true;
            ErrorMessage = null;
            try
            {
                await Task.Delay(1000);
                IsOpened = !IsOpened;
            }
            finally
            {
                IsProcessing = false;
            }
            return;
        }

        IsProcessing = true;
        ErrorMessage = null;

        try
        {
            if (!IsOpened)
            {
                var result = await BackendApi.OpenLockAsync(Token);
                if (result is not null && result.IsSuccess)
                {
                    IsOpened = true;
                }
                else
                {
                    ErrorMessage =
                        result?.Status ?? Localizer["ErrorOpening"];
                }
            }
            else
            {
                var result = await BackendApi.CloseLockAsync(Token);
                if (result is not null && result.IsSuccess)
                {
                    IsOpened = false;
                }
                else
                {
                    ErrorMessage =
                        result?.Status ?? Localizer["ErrorClosing"];
                }
            }
        }
        catch
        {
            ErrorMessage = Localizer["ErrorServerConnection"];
        }
        finally
        {
            IsProcessing = false;
        }
    }

    private async Task RetryPing()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            return;
        }

        await LocksState.RetryCheckTTLockStatusAsync(Token);
    }
}
