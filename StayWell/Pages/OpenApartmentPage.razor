@page "/reservation/{token}/OpenApartmentPage"
@using RentoomBooking.StayWell.Components
@using RentoomBooking.StayWell.States
@using Microsoft.Extensions.Localization
@using RentoomBooking.StayWell.Services
@using System.Globalization

@inject IStringLocalizer<OpenApartmentPage> Localizer
@inject BackendApi BackendApi
@inherits Models.PageBase

<PageTitle>OpenApartmentPage</PageTitle>

<div class="buttons-wrapper">
    @if (!LocksState.IsTTLockAvailable)
    {        
        <div class="tile tile--center">
            <button class="open-button @(IsOpened ? "unlocked" : "locked") @(IsProcessing ? "loading" : "")"
                    @onclick="ToggleDoor"
                    disabled="@(IsButtonDisabled || IsProcessing)">
                @if (IsProcessing)
                {
                    <div class="spinner"></div>
                }
                else
                {
                    <img class="lock" src="@(IsOpened ? "/icons/lock-open.svg" : "/icons/lock.svg")" />
                }
            </button>

            <div class="status-text">
                @if (IsProcessing)
                {
                    <span>@Localizer["Processing"]...</span>
                }
                else if (IsOpened)
                {
                    <span class="text-unlocked">@Localizer["DoorOpened"]</span>
                }
                else
                {
                    <span class="text-locked">@Localizer["PressToOpen"]</span>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-message">
            @ErrorMessage
        </div>
    }

    <div class="tile">
        <div class="tile__title">
            <img src="/icons/binary.svg" class="icon-inline" />
            @Localizer["YourIndividualCode"]:
        </div>

        <div class="tile__content">
            @if (!ReservationState.IsActiveReservation)
            {
                <span>@Localizer["CodeNotAvaliable"]</span>
            }
            else
            {
                <span class="bold">@LocksState.CurrentLocks?.FirstOrDefault()?.Code?.ToString()</span>
                <span>@Localizer["Confirm"]</span>
                <span class="bold">#</span>
                <span>@Localizer["Or"]</span>
                <img src="/icons/key-round.svg" class="icon-key" />
            }
        </div>
    </div>
</div>

@code {
    private bool IsOpened = false;
    private bool IsProcessing = false;
    private string? ErrorMessage;

    private bool IsButtonDisabled => ReservationState?.CurrentReservation?.Reservation?.ReservationDetails == null ||
                                     DateTime.Now < ReservationState.CurrentReservation.Reservation.ReservationDetails.getDateFrom();

    private async Task ToggleDoor()
    {
        if (IsButtonDisabled || IsProcessing) return;

        IsProcessing = true;
        ErrorMessage = null;

        try
        {
            if (!IsOpened)
            {
                var result = await BackendApi.OpenLockAsync(Token);
                if (result != null && result.Success)
                {
                    IsOpened = true;
                }
                else
                {
                    ErrorMessage = result?.Status ?? "Błąd podczas otwierania";
                }
            }
            else
            {
                var result = await BackendApi.CloseLockAsync(Token);
                if (result != null && result.Success)
                {
                    IsOpened = false;
                }
                else
                {
                    ErrorMessage = result?.Status ?? "Błąd podczas zamykania";
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Błąd połączenia z serwerem";
        }
        finally
        {
            IsProcessing = false;
        }
    }
}