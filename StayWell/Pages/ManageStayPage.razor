@page "/reservation/{token}/ManageStayPage"
@using Microsoft.Extensions.Localization
@using System.Globalization
@using RentoomBooking.StayWell.Components
@using RentoomBooking.StayWell.States
@using RentoomBooking.SharedClasses.Models.RentoomBooking
@inject CustomerAgreedTermsState CustomerAgreedTermsState
@inject IStringLocalizer<ManageStayPage> Localizer
@inject NavigationManager Navigation
@inject UpsellCartState UpsellCartState
@inherits Models.PageBase
@implements IDisposable

<PageTitle>@Localizer["ManageStay"]</PageTitle>

<section class="reservation-section">
    <div class="reservation-section__content">
        <div class="manage-grid" style="@(!UpsellCartState.IsEmpty ? "padding-bottom: 160px;" : "")">
            <div class="manage-tile--report">
                <ManageTile Category="@Localizer["Help"]"
                            Title="@Localizer["Report"]"
                            Icon="/icons/frown.svg"
                            ActionIcon="/icons/chevron-right.svg"
                            Description="@Localizer["ReportDescription"]"
                            ShowPrice="false"
                            OnClick="@(() => Navigation.NavigateTo($"reservation/{Token}/ReportPage"))" />
            </div>
            @if (ApartmentState.IsLoading || ReservationState.IsLoading)
            {
                <div class="skeleton skeleton--tile"></div>
                <div class="skeleton skeleton--tile"></div>
                <div class="skeleton skeleton--tile"></div>
                <div class="skeleton skeleton--tile"></div>
            }
            else
            {
                @if (ApartmentState.CurrentApartment?.Addons is not null)
                {
                    var allAddons = ApartmentState.CurrentApartment.Addons
                        .Where(a => a.Id != AddonServiceFeeId && a.Id != AddonCleaningFeeId)
                        .ToList();

                    var activeAddons = allAddons.Where(a => IsAddonAvailable(a.Id) && !IsPurchasedAddon(a.Id)).ToList();
                    var purchasedAddons = allAddons.Where(a => IsPurchasedAddon(a.Id)).ToList();

                   //13.03.2026 -komentarz Maciej - Wyłaczyłem mozliwosc zakupu dodatkow poniewaz narazie implementacje jest niepelna . uzgodnione z Bartkiem.
                    @*foreach (var addon in activeAddons)
                    {
                        var definedAddon = addon.Id.HasValue
                            ? ApartmentState.DefinedAddons.FirstOrDefault(a => a.IdoBookingId == addon.Id.Value)
                            : null;
                        var details = definedAddon?.AddonDefinition?.Details
                            .FirstOrDefault(d => string.Equals(d.Lang, CurrentAddonsLanguage, StringComparison.OrdinalIgnoreCase));
                        var title = details?.Name ?? addon.Name ?? "Dodatek";
                        var description = details?.Description ?? string.Empty;
                        var priceText = definedAddon is not null ? $"{definedAddon.PriceGross:#.00} PLN" : string.Empty;
                        var priceInfo = details?.PaymentTypeShortDescription ?? string.Empty;
                        var addonId = addon.Id;
                        var isSelected = addonId.HasValue && UpsellCartState.IsAddonSelected(addonId.Value);
                        var allowQuantity = definedAddon is not null && AllowsQuantitySelection(definedAddon.PaymentType);
                        var maxQty = addonId.HasValue && AddonMaxQuantityMap.TryGetValue(addonId.Value, out var max) ? max : (int?)null;
                        var currentQty = addonId.HasValue ? UpsellCartState.GetAddonQuantity(addonId.Value) : 1;

                        <ManageTile Category="@Localizer["Addon"]"
                                    Title="@title"
                                    Icon=""
                                    ActionIcon=""
                                    Description="@description"
                                    ShowPrice="@(definedAddon is not null)"
                                    PriceText="@priceText"
                                    PriceInfo="@priceInfo"
                                    IsSelected="@isSelected"
                                    ShowQuantitySelector="@allowQuantity"
                                    Quantity="@currentQty"
                                    MaxQuantity="@maxQty"
                                    OnQuantityChanged="@((qty) => UpsellCartState.SetAddonQuantity(addonId!.Value, qty))"
                                    OnClick="@(() => ToggleAddon(addonId, title, description, priceText, priceInfo, definedAddon?.PriceGross, allowQuantity, maxQty))" />
                    }*@
                    @if (purchasedAddons.Count > 0)
                    {
                        <span class="manage-purchased-label">@Localizer["Purchased"]</span>

                        foreach (var addon in purchasedAddons)
                        {
                            var definedAddon = addon.Id.HasValue
                                ? ApartmentState.DefinedAddons.FirstOrDefault(a => a.IdoBookingId == addon.Id.Value)
                                : null;
                            var details = definedAddon?.AddonDefinition?.Details
                                .FirstOrDefault(d => string.Equals(d.Lang, CurrentAddonsLanguage, StringComparison.OrdinalIgnoreCase));
                            var title = details?.Name ?? addon.Name ?? Localizer["Addon"];
                            var description = details?.Description ?? string.Empty;
                            var priceText = definedAddon is not null ? $"{definedAddon.PriceGross:#.00} PLN" : string.Empty;
                            var priceInfo = details?.PaymentTypeShortDescription ?? string.Empty;

                            <ManageTile Category="@Localizer["Addon"]"
                                        Title="@title"
                                        Icon=""
                                        ActionIcon=""
                                        Description="@description"
                                        ShowPrice="@(definedAddon is not null)"
                                        PriceText="@priceText"
                                        PriceInfo="@priceInfo"
                                        Disabled="true"
                                        IsPurchased="true" />
                        }
                    }
                }
            }
        </div>
    </div>
</section>

@code {
    private const int AddonServiceFeeId = 2;
    private const int AddonCleaningFeeId = 8;
    private const int EarlyCheckInAddonId = 40;
    private const int LateCheckOutAddonId = 41;
    private static readonly TimeSpan LateCheckOutCutoffTime = new(20, 0, 0);


    // addonId -> maxQuantity
    private static readonly Dictionary<int, int> AddonMaxQuantityMap = new()
    {
        [42] = 2,
        [43] = 1
    };

    private string CurrentAddonsLanguage =>
        CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.ToUpperInvariant();

    private static bool AllowsQuantitySelection(AddonPaymentType paymentType) =>
        paymentType is AddonPaymentType.PayPerAmount or AddonPaymentType.PayPerAmountPerNight;

    private bool IsPurchasedAddon(int? addonId)
    {
        if (!addonId.HasValue)
            return false;

        return addonId.Value switch
        {
            EarlyCheckInAddonId => ReservationState.HasEarlyCheckIn,
            LateCheckOutAddonId => ReservationState.HasLateCheckOut,
            _ => false
        };
    }

    protected override void OnInitialized()
    {
        UpsellCartState.OnChange += StateHasChanged;
        CustomerAgreedTermsState.InitializeLanguageSync();
    }

    public override void Dispose()
    {
        base.Dispose();
        UpsellCartState.OnChange -= StateHasChanged;
    }

    private void ToggleAddon(int? addonId, string title, string description, string priceText, string priceInfo, decimal? priceGross, bool allowQuantity, int? maxQuantity)
    {
        if (!addonId.HasValue)
            return;

        UpsellCartState.ToggleAddon(new UpsellCartState.CartAddonItem(
            IdoBookingAddonId: addonId.Value,
            Title: title,
            Description: description,
            Icon: string.Empty,
            PriceText: priceText,
            PriceInfo: priceInfo,
            PriceGross: priceGross,
            Quantity: 1,
            AllowQuantitySelection: allowQuantity,
            MaxQuantity: maxQuantity
        ));
    }

    private bool IsAddonAvailable(int? addonId)
    {
        if (!addonId.HasValue)
            return true;

        return addonId.Value switch
        {
            EarlyCheckInAddonId => !ReservationState.HasEarlyCheckIn,
            LateCheckOutAddonId => !ReservationState.HasLateCheckOut && IsLateCheckOutAvailable(),
            _ => true
        };
    }

    private bool IsLateCheckOutAvailable()
    {
        var checkoutDate = ReservationState.CurrentReservation?.Reservation?.ReservationDetails?.getDateTo();
        if (checkoutDate is null)
            return true;

        var cutoff = checkoutDate.Value.Date.AddDays(-1).Add(LateCheckOutCutoffTime);
        return DateTime.Now <= cutoff;
    }
}
