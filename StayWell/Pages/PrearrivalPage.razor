@page "/reservation/{token}/Prearrival"
@using Microsoft.Extensions.Localization
@using System.Globalization
@using RentoomBooking.StayWell.Components
@inject NavigationManager Navigation
@inject IStringLocalizer<PrearrivalPage> Localizer
@inherits Models.PageBase

<div class="wrap">
    <div class="hero">
        @if (!ReservationState.IsActiveReservation)
        {
            <div class="t">@Localizer["TimeLeft"]</div>
            <div class="grid">
                <div>
                    <div class="n">@_days</div>
                    <div class="l">@Localizer["Days"]</div>
                </div>
                <div>
                    <div class="n">@_hours</div>
                    <div class="l">@Localizer["Hours"]</div>
                </div>
                <div>
                    <div class="n">@_minutes</div>
                    <div class="l">@Localizer["Minutes"]</div>
                </div>
            </div>
            <div class="sg">@Localizer["CantWait"]</div>
        }
        else
        {
            <div class="t">
                @Localizer["Ready"]
            </div>
        }
    </div>

    <div class="card">
        <div class="pb-3">
            <Carousel ImageUrls="@urls" TransitionIntervalMs="3500" UseTimer="@true" UseSmartGlow="@false" />
        </div>
        <div class="an">@ReservationState?.CurrentReservation?.Reservation.Items.FirstOrDefault()?.objectName</div>
        
        <div class="row">
            <div class="ct">@Localizer["Checkin"]</div>
            <div class="cd">@ReservationState?.CurrentReservation?.Reservation.ReservationDetails.getDateFrom().ToString("dd.MM.yyyy") @ReservationState.CheckInTime</div>
        </div>
        <div class="row">
            <div class="ct">@Localizer["Checkout"]</div>
            <div class="cd">@ReservationState?.CurrentReservation?.Reservation.ReservationDetails.getDateTo().ToString("dd.MM.yyyy") @ReservationState.CheckOutTime
            </div>
        </div>
        
        <hr class="b-l" />
        
        <div class="status-box">
            @if (RegistrationCardState.CurrentCard == null)
            {
                <div class="cdc text-secondary" style="font-size: 14px; text-align: center">
                    @Localizer["Fill"]
                </div>
            }
            else
            {
                <div class="cd">
                    <div>
                        @Localizer["Filled"] <img class="rentoom-green-filter pb-1" src="/icons/circle-check.svg" />
                    </div>
                </div>
            }
        </div>

        <hr class="b-l" />

        <div class="row">
            <div class="ct">@Localizer["Name"] </div>
            <div class="cd">@ReservationState?.CurrentReservation?.Reservation.Client.FirstName</div>
        </div>
        <div class="row">
            <div class="ct">@Localizer["Surname"] </div>
            <div class="cd">@ReservationState?.CurrentReservation?.Reservation.Client.LastName</div>
        </div>
        @if(!IsBookingMail())
        {
            <div class="row">
                <div class="ct">@Localizer["Email"]</div>
                <div class="cd">@ReservationState?.CurrentReservation?.Reservation.Client.Email</div>
            </div>
        }
        <div class="row">
            <div class="ct">@Localizer["PhoneNumber"] </div>
            <div class="cd">@ReservationState?.CurrentReservation?.Reservation.Client.Phone</div>
        </div>
        <div class="row">
            <div class="ct">@Localizer["AdultsNumber"] </div>
            <div class="cd">@ReservationState?.CurrentReservation?.Reservation.Items.FirstOrDefault()?.numberOfAdults</div>
        </div>
        @if (int.TryParse(ReservationState?.CurrentReservation?.Reservation.Items.FirstOrDefault()?.numberOfSmallChildren, out var _childrenCount) && _childrenCount > 0)
        {
            <div class="row">
                <div class="ct">@Localizer["ChildrenNumber"] </div>
                <div class="cd">@ReservationState?.CurrentReservation?.Reservation.Items.FirstOrDefault()?.numberOfSmallChildren</div>
            </div>
        }
    </div>
</div>

@if (RegistrationCardState.CurrentCard == null)
{
    <FloatingButton 
        Text="@Localizer["Continue"]"
        IconPath="/icons/chevron-right.svg"
        OnClick="NavigateToTerms" />
}

@code {
    private string[] urls = Array.Empty<string>();
    private int _days;
    private int _hours;
    private int _minutes;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        if (RegistrationCardState.IsFilled)
        {
            NavigationManager.NavigateTo($"/reservation/{Token}");
            //ToastService.ShowToast(Localizer["NoAccessToPage"]);
            LayoutState.ShowFooter = true;
        }
        else
        {
            LayoutState.ShowFooter = false;
            LoadImages();
            if (!ReservationState.IsActiveReservation)
            {
                StartTimer();
            }
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            LayoutState.ShowFooter = false;
        }

        if (!RegistrationCardState.IsFilled)
        {
            LayoutState.ShowFooter = false;
        }

        return Task.CompletedTask;
    }

    private void NavigateToTerms()
    {
        NavigationManager.NavigateTo($"/reservation/{Token}/TermsPage");
    }

    private bool IsBookingMail()
    {
        string? mail = ReservationState?.CurrentReservation?.Reservation.Client.Email;
        if (string.IsNullOrEmpty(mail)) return false;
        return mail.EndsWith("@guest.booking.com", StringComparison.OrdinalIgnoreCase);
    }

    private void StartTimer()
    {
        UpdateCountdown();
        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                UpdateCountdown();
                StateHasChanged();
            });
        }, null, 0, 1000 * 60);
    }

    private void UpdateCountdown()
    {
        var checkInDate = ReservationState?.CurrentReservation?.Reservation.ReservationDetails.getDateFrom();
        if (checkInDate == null)
        {
            _days = _hours = _minutes = 0;
            return;
        }

        var checkIn = checkInDate.Value.Date + ReservationState.CheckInTime.ToTimeSpan();

        var now = DateTime.Now;
        var diff = checkIn - now;
        if (diff.TotalSeconds < 0)
        {
            _days = _hours = _minutes = 0;
        }
        else
        {
            _days = diff.Days;
            _hours = diff.Hours;
            _minutes = diff.Minutes;
        }
    }

    private void LoadImages()
    {
        const string placeholder = "/images/placeholders/apartment_placeholder.png";
        urls = MediaState?.CurrentMedia?
            .Where(m => !string.IsNullOrEmpty(m.Url) && (m.Extension?.ToLower() == "jpg" || m.Extension?.ToLower() == "png"))
            .OrderBy(m => m.Position)
            .Select(m => m.Url!)
            .ToArray()
            ?? new[] { placeholder };
    }

    public override void Dispose()
    {
        LayoutState.ShowFooter = true;
        _timer?.Dispose();
        base.Dispose();
    }
}
