@inherits LayoutComponentBase
@using RentoomBooking.StayWell.ReservationState
@using RentoomBooking.SharedClasses.Models;
@inject ReservationState ReservationState
@implements IDisposable

@if (isLoading)
{
    <div>
        <p>Ładowanie rezerwacji...</p>
    </div>
}
else if (ReservationState.CurrentReservation is null)
{
    <div>
        <p> Nie masz dostępu do tej strony. </p>
    </div>
}
else
{
    <div class="layout-page">
        <div class="layout-header">
            <RentoomBooking.StayWell.Components.Header reservationId="@ReservationState.CurrentReservation.Reservation.id.ToString()">
            </RentoomBooking.StayWell.Components.Header>
        </div>

        <div class="layout-body">
            @Body
        </div>

        <div class="layout-footer-nav">
            <RentoomBooking.StayWell.Components.FooterNavigation>
            </RentoomBooking.StayWell.Components.FooterNavigation>
        </div>
    </div>
}

@code {
    private bool isLoading = true;

    protected override void OnInitialized()
    {
        ReservationState.OnChange += StateHasChanged;

        Task.Delay(100).ContinueWith(_ =>
        {
            isLoading = false;
            InvokeAsync(StateHasChanged);
        });
    }

    public void Dispose()
    {
        ReservationState.OnChange -= StateHasChanged;
    }
}