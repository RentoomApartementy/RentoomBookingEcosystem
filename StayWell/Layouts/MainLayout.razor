@inherits LayoutComponentBase
@using RentoomBooking.SharedClasses.Models;
@using RentoomBooking.StayWell.Components;
@using RentoomBooking.StayWell.Components.Upsells;
@using RentoomBooking.StayWell.States
@using RentoomBooking.StayWell.Services
@inject ModalService ModalService
@inject ToastService ToastService
@inject ReservationState ReservationState
@inject MediaState MediaState
@inject ApartmentState ApartmentState
@inject AmenitiesState AmenitiesState
@inject LocksState LocksState
@inject LayoutState LayoutState
@inject IJSRuntime JSRuntime
@inject BitrixService BitrixService
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Microsoft.AspNetCore.Components.WebAssembly.Hosting.IWebAssemblyHostEnvironment HostEnvironment

<div class="layout-page @(HasEnvironmentBanner ? "layout-page--has-environment-banner" : string.Empty)">
    <EnvironmentBanner EnvironmentName="@BannerEnvironmentName" />
    <CookieConsentGate />
    @if (LayoutState.ShowHeader)
    {
        <div class="layout-header" id="main-header">
            <Header Token="@ReservationState.CurrentToken" reservationId="@ReservationState.CurrentReservation?.Reservation.id.ToString()">
            </Header>
        </div>
    }
    <div class="layout-body" id="main-body">
        @Body
    </div>
    @if (LayoutState.ShowFooter)
    {
        <div class="layout-footer-nav">
            <FooterNavigation />
        </div>
    }
</div>

<UpsellFloatingCart Token="@ReservationState.CurrentToken" />

<Toast @ref="_toastComponent" />

<Modal Title="@_modalTitle"
       OnClose="CloseModal"
       IsVisible="@_modalVisibility"
       Variant="@_modalVariant"
       Content="@_modalContent">
</Modal>

@code {
    private bool _modalVisibility = false;
    private ModalVariant _modalVariant = ModalVariant.Default;
    private string _modalTitle = string.Empty;
    private RenderFragment? _modalContent;
    private Toast? _toastComponent;
    private string BannerEnvironmentName =>
        string.IsNullOrWhiteSpace(Configuration["ASPNETCORE_ENVIRONMENT_STAYWELL"])
            ? HostEnvironment.Environment
            : Configuration["ASPNETCORE_ENVIRONMENT_STAYWELL"]!;
    private bool HasEnvironmentBanner => EnvironmentBannerState.ShouldDisplay(BannerEnvironmentName);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initHeaderScroll", "main-body", "main-header");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await BitrixService.InitializeAsync();
    }

    protected override void OnInitialized()
    {
        ReservationState.OnChange += StateHasChanged;
        MediaState.OnChange += StateHasChanged;
        ApartmentState.OnChange += StateHasChanged;
        AmenitiesState.OnChange += StateHasChanged;
        LocksState.OnChange += StateHasChanged;
        LayoutState.OnChange += StateHasChanged;

        ModalService.OnShow += ShowModal;
        ModalService.OnClose += CloseModal;

        ToastService.OnShow += ShowToast;
        ToastService.OnHide += HideToast;

        InvokeAsync(StateHasChanged);
    }

    private void ShowModal(string title, RenderFragment? content, ModalVariant variant)
    {
        _modalTitle = title;
        _modalContent = content;
        _modalVariant = variant;
        _modalVisibility = true;
        StateHasChanged();
    }

    private void CloseModal()
    {
        _modalVisibility = false;
        _modalVariant = ModalVariant.Default;
        _modalContent = null;

        StateHasChanged();
    }

    private void ShowToast(string message, RenderFragment? content, int durationMs)
    {
        _toastComponent?.AddToast(message, content, durationMs);
    }

    private void HideToast()
    {
    }

    public void Dispose()
    {
        ReservationState.OnChange -= StateHasChanged;
        MediaState.OnChange -= StateHasChanged;
        ApartmentState.OnChange -= StateHasChanged;
        AmenitiesState.OnChange -= StateHasChanged;
        LocksState.OnChange -= StateHasChanged;
        LayoutState.OnChange -= StateHasChanged;
        ModalService.OnShow -= ShowModal;
        ModalService.OnClose -= CloseModal;
        ToastService.OnShow -= ShowToast;
        ToastService.OnHide -= HideToast;
    }
}
