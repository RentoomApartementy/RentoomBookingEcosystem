@using Microsoft.Extensions.Localization
@using RentoomBooking.StayWell.States

@inject LocksState LocksState
@inject IStringLocalizer<AccessCodesList> Localizer

@implements IDisposable

<div class="access-codes-list">
    @if (LocksState.ApartmentItemCodes is null)
    {
        @for (int i = 0; i < 3; i++)
        {
            <div class="access-code-card access-code-card--skeleton">
                <div class="access-code-card__icon-skeleton"></div>
                <div class="access-code-card__content">
                    <div class="access-code-card__label-skeleton"></div>
                    <div class="access-code-card__value-skeleton"></div>
                </div>
            </div>
        }
    }
    else
    {
        @if (HasCode(ParkingSpotNumber) || HasMapLink(ParkingMapUrl))
        {
            @if (HasMapLink(ParkingMapUrl))
            {
                <a class="access-code-card access-code-card--link" href="@ParkingMapUrl" target="_blank" rel="noopener noreferrer">
                    <div class="access-code-card__icon-wrapper">
                        <img src="/icons/square-parking.svg" class="access-code-card__icon" alt="" aria-hidden="true" />
                    </div>
                    <div class="access-code-card__content">
                        <div class="access-code-card__label">@(HasCode(ParkingSpotNumber) ? Localizer["ParkingNumber"] : Localizer["ParkingMap"])</div>
                        <div class="access-code-card__value">@(HasCode(ParkingSpotNumber) ? ParkingSpotNumber : Localizer["ParkingMap"])</div>
                        <div class="access-code-card__cta">
                            <span>@Localizer["OpenMap"]</span>
                            <img src="/icons/external-link.svg" class="access-code-card__cta-icon" alt="" aria-hidden="true" />
                        </div>
                    </div>
                </a>
            }
            else
            {
                <div class="access-code-card">
                    <div class="access-code-card__icon-wrapper">
                        <img src="/icons/square-parking.svg" class="access-code-card__icon" alt="" aria-hidden="true" />
                    </div>
                    <div class="access-code-card__content">
                        <div class="access-code-card__label">@Localizer["ParkingNumber"]</div>
                        <div class="access-code-card__value">@ParkingSpotNumber</div>
                    </div>
                </div>
            }
        }

        @if (HasCode(LocksState.ApartmentItemCodes.GateCode))
        {
            <div class="access-code-card">
                <div class="access-code-card__icon-wrapper">
                    <img src="/icons/fence.svg" class="access-code-card__icon" alt="" aria-hidden="true" />
                </div>
                <div class="access-code-card__content">
                    <div class="access-code-card__label">@Localizer["GateCode"]</div>
                    <div class="access-code-card__value">@RenderCodeTiles(LocksState.ApartmentItemCodes.GateCode)</div>
                </div>
            </div>
        }

        @if (HasCode(LocksState.ApartmentItemCodes.GateDoorCode))
        {
            <div class="access-code-card">
                <div class="access-code-card__icon-wrapper">
                    <img src="/icons/building.svg" class="access-code-card__icon" alt="" aria-hidden="true" />
                </div>
                <div class="access-code-card__content">
                    <div class="access-code-card__label">@Localizer["BuildingCode"]</div>
                    <div class="access-code-card__value">@RenderCodeTiles(LocksState.ApartmentItemCodes.GateDoorCode)</div>
                </div>
            </div>
        }

        @if (HasCode(LocksState.ApartmentItemCodes.AdditionalDoorCode))
        {
            <div class="access-code-card">
                <div class="access-code-card__icon-wrapper">
                    <img src="/icons/door-closed-2.svg" class="access-code-card__icon" alt="" aria-hidden="true" />
                </div>
                <div class="access-code-card__content">
                    <div class="access-code-card__label">@Localizer["SharedDoorsCode"]</div>
                    <div class="access-code-card__value">@RenderCodeTiles(LocksState.ApartmentItemCodes.AdditionalDoorCode)</div>
                </div>
            </div>
        }

        @if (HasCode(LocksState.ApartmentItemCodes.StoreroomCode))
        {
            <div class="access-code-card">
                <div class="access-code-card__icon-wrapper">
                    <img src="/icons/mailbox.svg" class="access-code-card__icon" alt="" aria-hidden="true" />
                </div>
                <div class="access-code-card__content">
                    <div class="access-code-card__label">@Localizer["KeySafeCode"]</div>
                    <div class="access-code-card__value">@RenderCodeTiles(LocksState.ApartmentItemCodes.StoreroomCode)</div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public string? ParkingSpotNumber { get; set; }

    [Parameter]
    public string? ParkingMapUrl { get; set; }

    protected override void OnInitialized() =>
        LocksState.OnChange += OnLocksStateChanged;

    private void OnLocksStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => LocksState.OnChange -= OnLocksStateChanged;

    private static readonly Dictionary<string, string> CodeIconMappings = new(StringComparer.OrdinalIgnoreCase)
    {
        { "dzwonek", "/icons/bell-ring.svg" },
        { "dzwon", "/icons/bell-ring.svg" },
        { "kluczyk", "/icons/key-round.svg" },
        { "klucz", "/icons/key-round.svg" },
        { "drzwi", "/icons/door-closed-2.svg" }
    };

    private static readonly System.Text.RegularExpressions.Regex CodeIconRegex = new(
        string.Join("|", CodeIconMappings.Keys
            .OrderByDescending(k => k.Length)
            .Select(k => System.Text.RegularExpressions.Regex.Escape(k))),
        System.Text.RegularExpressions.RegexOptions.IgnoreCase | System.Text.RegularExpressions.RegexOptions.Compiled);

    private static bool HasCode(string? code) => !string.IsNullOrWhiteSpace(code);

    private static bool HasMapLink(string? url) => !string.IsNullOrWhiteSpace(url);

    private MarkupString RenderCodeTiles(string? code)
    {
        if (string.IsNullOrWhiteSpace(code))
        {
            return new MarkupString(string.Empty);
        }

        var sb = new System.Text.StringBuilder();
        sb.Append("<div class=\"code-tiles\">");

        var matches = CodeIconRegex.Matches(code);

        if (matches.Count == 0)
        {
            AppendCharTiles(sb, code, 0, code.Length);
        }
        else
        {
            int lastIndex = 0;
            foreach (System.Text.RegularExpressions.Match match in matches)
            {
                AppendCharTiles(sb, code, lastIndex, match.Index);

                var iconUrl = CodeIconMappings
                    .First(kvp => string.Equals(kvp.Key, match.Value, StringComparison.OrdinalIgnoreCase))
                    .Value;

                sb.Append("<span class=\"code-tile code-tile--icon\">");
                sb.Append("<img src=\"");
                sb.Append(System.Net.WebUtility.HtmlEncode(iconUrl));
                sb.Append("\" alt=\"");
                sb.Append(System.Net.WebUtility.HtmlEncode(match.Value));
                sb.Append("\" class=\"code-tile__icon\" />");
                sb.Append("</span>");

                lastIndex = match.Index + match.Length;
            }
            AppendCharTiles(sb, code, lastIndex, code.Length);
        }

        sb.Append("</div>");
        return new MarkupString(sb.ToString());
    }

    private static void AppendCharTiles(System.Text.StringBuilder sb, string code, int start, int end)
    {
        for (int i = start; i < end; i++)
        {
            char c = code[i];
            if (!char.IsWhiteSpace(c))
            {
                sb.Append("<span class=\"code-tile\">");
                sb.Append(System.Net.WebUtility.HtmlEncode(c.ToString()));
                sb.Append("</span>");
            }
        }
    }
}
