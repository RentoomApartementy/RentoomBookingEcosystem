@using RentoomBooking.StayWell.Pages
@using StayWell.Services
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject ModalService ModalService
@inject GlobalizationService GlobalizationService
@implements IDisposable
@inject Services.ToastService ToastService
@inject States.ReservationState ReservationState
@inject States.LiveChatNotificationState LiveChatNotificationState

@inject IStringLocalizer<HomePage> Localizer

<div class="header">
    <div class="left">
        <img class="logo" src="/images/resized-logo.png"/>
        <div class="texts">
            <span class="name"><span class="stay">Stay</span><span class="stay">Well</span></span>
            <span class="reservation-id">
                @reservationId
            </span>
        </div>
    </div>
    <div class="right-wrapper">

        <div class="Languages">
            <button @onclick="@ChangeLangButton" style="background: none; border: none">
                <img src="/icons/languages.svg" />
            </button>
        </div>

        @if (ReservationState.IsValidReservation)
        {   
        <div class="Contact">
            <button class="chat-btn" @onclick="@OpenLiveChat">
                <img src="/icons/message-circle.svg" />
                @if (LiveChatNotificationState.UnreadCount > 0)
                {
                    <span class="chat-badge">@(LiveChatNotificationState.UnreadCount > 99 ? "99+" : LiveChatNotificationState.UnreadCount.ToString())</span>
                }
            </button>
        </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string? Token { get; set; }
    [Parameter] 
    public string reservationId { get; set; } = "brak";

    protected override async Task OnInitializedAsync()
    {
        GlobalizationService.OnChange += StateHasChanged;
        LiveChatNotificationState.OnChange += StateHasChanged;
        var savedPreference = await GlobalizationService.LoadPreferenceAsync();
        if (!string.IsNullOrWhiteSpace(savedPreference))
        {
            GlobalizationService.SetCulture(savedPreference);
        }
    }

    protected override Task OnParametersSetAsync()
    {
        if (ReservationState.IsValidReservation && !string.IsNullOrWhiteSpace(Token))
        {
            LiveChatNotificationState.StartListening(Token);
        }
        return Task.CompletedTask;
    }

    private void ChangeLangButton()
    {
        ModalService.ShowModal(
            Localizer["ChangeLanguage"],
            @<RentoomBooking.StayWell.Components.ModalContent.LanguageModalContent />
        );
    }

    private void OpenLiveChat()
    {
        ModalService.ShowLiveChatModal(
            "Czat z obsługą",
            @<RentoomBooking.StayWell.Components.ModalContent.LiveChatPanel Token="@Token" />
        );
    }

    public void Dispose()
    {
        GlobalizationService.OnChange -= StateHasChanged;
        LiveChatNotificationState.OnChange -= StateHasChanged;
    }

}