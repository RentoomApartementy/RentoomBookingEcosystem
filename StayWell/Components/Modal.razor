@using RentoomBooking.StayWell.Services
@using RentoomBooking.StayWell.Components
@inject GlobalizationService GlobalizationService
@inject ModalService ModalService
@inject LiveChatSettingsService LiveChatSettingsService

@if (IsVisible)
{
    <div class="modal-backdrop @(IsFullscreenVariant ? "modal-backdrop-aichat-fullscreen-mode" : string.Empty)"
         @onclick="Close"
         tabindex="-1"
         @ref="backdropRef">

        <div class="modal @(IsImageVariant ? "modal-image-mode" : "") @(IsFullscreenVariant ? "modal-aichat-fullscreen-mode" : "")"
             @onclick:stopPropagation="@(!IsImageVariant)"
             role="dialog"
             aria-labelledby="modal-title"
             aria-modal="true">

            @if (!IsImageVariant && !String.IsNullOrEmpty(Title))
            {
                <div class="modal-header">
                    <button class="modal-close" @onclick="Close" aria-label="Zamknij modal">
                        ×
                    </button>
                    <p class="modal-title">@Title</p>
                    @if (IsLiveChatFullscreenVariant)
                    {
                        <button class="modal-header-action" type="button" @onclick="() => LiveChatSettingsService.RequestOpenSettings()" aria-label="Ustawienia tłumaczenia">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="3"></circle>
                                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                            </svg>
                        </button>
                    }
                    else
                    {
                        <span class="modal-header-spacer"></span>
                    }
                </div>
            }

            @if (IsImageVariant)
            {
                <div class="modal-content image-content" @onclick="Close">
                    <div class="image-wrapper" @onclick="Close">
                        <div class="image-inner" @onclick:stopPropagation>
                            <button type="button" class="image-close-btn" @onclick="Close" @onclick:stopPropagation aria-label="Zamknij">
                                ×
                            </button>
                            @Content
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="modal-content @(IsFullscreenVariant ? "modal-content-aichat-fullscreen-mode" : string.Empty)">
                    @Content
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public RenderFragment? Content { get; set; }
    [Parameter] public ModalVariant Variant { get; set; } = ModalVariant.Default;

    private ElementReference backdropRef;
    private int _rotation = 0;

    private bool IsRotatedPerpendicular => _rotation == 90 || _rotation == 270;
    private bool IsImageVariant => Variant == ModalVariant.Image;
    private bool IsAiChatFullscreenVariant => Variant == ModalVariant.AiChatFullscreen;
    private bool IsLiveChatFullscreenVariant => Variant == ModalVariant.LiveChatFullscreen;
    private bool IsFullscreenVariant => IsAiChatFullscreenVariant || IsLiveChatFullscreenVariant;

    protected override Task OnInitializedAsync()
    {
        GlobalizationService.OnChange += StateHasChanged;
        return base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && IsVisible)
        {
            await backdropRef.FocusAsync();
        }
    }

    private async Task Close()
    {
        _rotation = 0;
        ModalService.HideModal();

        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync();
        }
        else
        {
            IsVisible = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        GlobalizationService.OnChange -= StateHasChanged;
    }
}
