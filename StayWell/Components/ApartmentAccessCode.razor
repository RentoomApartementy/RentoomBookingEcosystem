@using Microsoft.Extensions.Localization
@using RentoomBooking.StayWell.States
@using RentoomBooking.StayWell.Services
@using System.Globalization

@inject IStringLocalizer<ApartmentAccessCode> Localizer
@inject LocksState LocksState
@inject ReservationState ReservationState
@inject FeatureFlagsService FeatureFlagsService
@inject ToastService ToastService
@inject ModalService ModalService

@implements IDisposable

<div class="tile">
    <div class="tile__title">
        <img src="/icons/binary.svg" class="icon-inline" alt="" aria-hidden="true" />
        @Localizer["YourIndividualCode"]:
    </div>
    <div class="tile__content">
        @if (ReservationState.IsLoading || LocksState.IsLoading || IsWaitingForCodes)
        {
            <div class="skeleton skeleton--code"></div>
            <div class="skeleton skeleton--text-short" style="margin-top: 8px;"></div>
        }
        else if (!ReservationState.IsCodeAvailable && !IsDevMockLock)
        {
            @if (ReservationState.IsAfterCheckOut)
            {
                <div class="code-unavailable">
                    <img src="/icons/door-closed.svg" alt="" aria-hidden="true" />
                    <p>@Localizer["CodeNoLongerAvailable"]</p>
                </div>
            }
            else
            {
                <div class="code-unavailable">
                    <img src="/icons/clock.svg" alt="" aria-hidden="true" />
                    <p>@string.Format(CultureInfo.CurrentCulture, Localizer["CodeNotAvailable"], ReservationState.CodeAvailableFromTime.ToString("HH:mm"))</p>
                </div>
            }
        }
        else
        {
            @if (LocksState.CurrentCode is not null && LocksState.CurrentCode.IsTTLock)
            {
                var validityText = FormatPasscodeValidity(LocksState.CurrentCode.ValidFrom, LocksState.CurrentCode.ValidTo);

                <div class="passcode-display">
                    <div class="passcode-digits">@LocksState.CurrentCode.Code</div>
                    <div class="passcode-confirm-row">
                        <span class="passcode-hash">#</span>
                        <span class="passcode-separator">·</span>
                        <img src="/icons/key-round.svg" class="icon-key" alt="" aria-hidden="true" />
                    </div>
                    @*@if (!string.IsNullOrEmpty(validityText))
                    {
                        <div class="passcode-deadline">
                            <img src="/icons/clock.svg" class="passcode-deadline__icon" alt="" aria-hidden="true" />
                            <span>@validityText</span>
                        </div>
                    }*@
                </div>
            }
            else if (LocksState.CurrentCode is not null && LocksState.CurrentCode.IsIdo)
            {
                <div class="passcode-display">
                    <div class="passcode-digits">@LocksState.CurrentCode.Code</div>
                    <div class="passcode-confirm-row">
                        <span class="passcode-hash">#</span>
                        <span class="passcode-separator">·</span>
                        <img src="/icons/key-round.svg" class="icon-key" alt="" aria-hidden="true" />
                    </div>
                </div>
            }
            else
            {
                <div class="passcode-no-code">
                    <img src="/icons/octagon-alert.svg" alt="" aria-hidden="true" />
                    <p>@Localizer["NoCode"]</p>
                </div>
            }

            @if (ReservationState.IsActiveReservation || IsDevMockLock)
            {
                <div class="passcode-footer">
                    <button class="retry-button"
                            disabled="@(!IsGenerateButtonEnabled)"
                            @onclick="HandleGeneratePasscode"
                            title="@Localizer["GenerateNewCode"]">
                        @if (LocksState.IsPasscodeLoading)
                        {
                            <div class="spinner spinner--small"></div>
                            <span class="retry-button__label">@string.Format(CultureInfo.CurrentCulture, Localizer["GeneratingCode"], LocksState.PasscodeLoadingElapsedSeconds)</span>
                        }
                        else if (LocksState.LiveCooldownSecondsRemaining > 0)
                        {
                            <img src="/icons/alarm-clock-check.svg" class="retry-button__icon" alt="" aria-hidden="true" />
                            <span class="retry-button__label">@FormatCooldown(LocksState.LiveCooldownSecondsRemaining)</span>
                        }
                        else
                        {
                            <img src="/icons/refresh-ccw.svg" class="retry-button__icon" alt="" aria-hidden="true" />
                            <span class="retry-button__label">@Localizer["GenerateNewCode"]</span>
                        }
                    </button>

                    @if (LocksState.AllCodes.Count > 1)
                    {
                        <button type="button" class="passcode-history__link" @onclick="OpenPasscodeHistoryModal">
                            <img src="/icons/clock.svg" class="passcode-history__link-icon" alt="" aria-hidden="true" />
                            <span>@Localizer["PreviousCodes"]</span>
                        </button>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public string? Token { get; set; }

    private bool IsDevMockLock => FeatureFlagsService.FeatureAllowed("dev-mock-lock");

    // Rezerwacja mówi, że kod jest dostępny, ale kody zamka jeszcze nie dojechały —
    // trzymamy skeleton, żeby nie mrugnąć gałęzią „NoCode".
    private bool IsWaitingForCodes =>
        !IsDevMockLock && ReservationState.IsCodeAvailable && !LocksState.AreCodesLoaded;

    private bool IsGenerateButtonEnabled =>
        LocksState.IsPasscodeGenerationAllowed || IsDevMockLock;

    protected override void OnInitialized()
    {
        LocksState.OnChange += OnStateChanged;
        ReservationState.OnChange += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void OpenPasscodeHistoryModal()
    {
        var codes = LocksState.AllCodes.Skip(1).ToList();
        ModalService.ShowModal(Localizer["PreviousCodes"],
            @<RentoomBooking.StayWell.Components.ModalContent.PasscodeHistoryContent Codes="@codes" />);
    }

    private async Task HandleGeneratePasscode()
    {
        if (IsDevMockLock)
        {
            await LocksState.GenerateDevMockPasscodeAsync(Token);
            ToastService.ShowToast(Localizer["PasscodeGeneratedSuccess"]);
            return;
        }

        if (string.IsNullOrWhiteSpace(Token)) return;

        var previousPwdId = LocksState.CurrentCode?.KeyboardPwdId;

        await LocksState.GeneratePasscodeAsync(Token);

        if (LocksState.CurrentCode is not null && !LocksState.IsPasscodeLoading
            && LocksState.CurrentCode.KeyboardPwdId != previousPwdId)
        {
            ToastService.ShowToast(Localizer["PasscodeGeneratedSuccess"]);
        }
    }

    private static string FormatCooldown(int seconds)
    {
        var h = seconds / 3600;
        var m = (seconds % 3600) / 60;
        var s = seconds % 60;
        return h > 0
            ? $"{h}:{m:D2}:{s:D2}"
            : m > 0
                ? $"{m}:{s:D2}"
                : $"{s}s";
    }

    private string FormatPasscodeValidity(DateTimeOffset? startDate, DateTimeOffset? endDate)
    {
        var start = startDate?.ToLocalTime();
        var end = endDate?.ToLocalTime();

        if (start is not null && end is not null)
        {
            return string.Format(CultureInfo.CurrentCulture, Localizer["CodeValidFromTo"],
                start.Value.ToString("HH:mm dd.MM", CultureInfo.CurrentCulture),
                end.Value.ToString("HH:mm dd.MM", CultureInfo.CurrentCulture));
        }

        if (start is not null)
        {
            return string.Format(CultureInfo.CurrentCulture, Localizer["CodeValidFrom"],
                start.Value.ToString("HH:mm dd.MM", CultureInfo.CurrentCulture));
        }

        if (end is not null)
        {
            return string.Format(CultureInfo.CurrentCulture, Localizer["CodeValidTo"],
                end.Value.ToString("HH:mm dd.MM", CultureInfo.CurrentCulture));
        }

        return string.Empty;
    }

    public void Dispose()
    {
        LocksState.OnChange -= OnStateChanged;
        ReservationState.OnChange -= OnStateChanged;
    }
}
