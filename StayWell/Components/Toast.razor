@using System.Timers

<div class="toast-viewport">
    @foreach (var toast in _toasts)
    {
        var index = _toasts.IndexOf(toast);

        var style = $"data-index={index}";

        var isLatest = index == 0 ? "latest" : "stacked";
        var isClosing = toast.IsClosing ? "closing" : "";

        <div class="toast-card @isLatest @isClosing"
             data-index="@index"
             @key="toast.Id">

            <div class="toast-content-wrapper">
                @if (toast.Content != null)
                {
                    @toast.Content
                }
                else
                {
                    @toast.Message
                }
            </div>
            <button class="toast-close" @onclick="() => CloseToast(toast.Id)">×</button>
        </div>
    }
</div>

@code {
    [Parameter] public string? Message { get; set; }
    [Parameter] public RenderFragment? Content { get; set; }
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnHide { get; set; }
    [Parameter] public int DurationMs { get; set; } = 3000;

    private int _maxToast = 3;

    private List<ToastModel> _toasts = new();

    public void AddToast(string message, RenderFragment? content, int duration)
    {
        var toast = new ToastModel
        {
            Message = message,
            Content = content,
            Duration = duration
        };

        _toasts.Insert(0, toast);

        _ = AutoClose(toast);

        if (_toasts.Count > _maxToast)
        {
            var old = _toasts.Last();
            _toasts.Remove(old);
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task AutoClose(ToastModel toast)
    {
        await Task.Delay(toast.Duration);
        await CloseToast(toast.Id);
    }

    private async Task CloseToast(Guid id)
    {
        var toast = _toasts.FirstOrDefault(t => t.Id == id);
        if (toast == null || toast.IsClosing) return;

        toast.IsClosing = true;
        await InvokeAsync(StateHasChanged);

        await Task.Delay(300);
        _toasts.Remove(toast);
        await InvokeAsync(StateHasChanged);
    }

    public class ToastModel
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public string? Message { get; set; }
        public RenderFragment? Content { get; set; }
        public int Duration { get; set; }
        public bool IsClosing { get; set; }
    }
}