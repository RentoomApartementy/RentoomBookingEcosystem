@using System.Globalization
@using Microsoft.Extensions.Localization
@using RentoomBooking.SharedFrontend.Localization
@using RentoomBooking.StayWell.Pages

@inject GlobalizationService GlobalizationService
@inject ModalService ModalService
@inject ToastService ToastService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<HomePage> Localizer

<div class="language-modal">
    <p class="language-modal__current">
        @Localizer["CurrentLanguage"]: <strong>@SupportedLanguagesProvider.GetLanguageLabel(CultureInfo.CurrentCulture)</strong>
    </p>

    <p class="language-modal__disclaimer">@Localizer["TranslationDisclaimer"]</p>

    <div class="language-modal__options">
        @foreach (var culture in _supportedCultures)
        {
            <button class="language-option @ActiveClass(culture.Name)" @onclick='() => ChangeLang(culture.Name)'>
                <span class="language-option__label">@SupportedLanguagesProvider.GetLanguageLabel(culture)</span>
            </button>
        }
    </div>
</div>

@code {
    private readonly IReadOnlyList<CultureInfo> _supportedCultures = SupportedLanguagesProvider.SupportedCultures;

    private async Task ChangeLang(string cultureName)
    {
        if (CultureInfo.CurrentCulture.Name == cultureName)
            return;

        await GlobalizationService.SavePreferenceAsync(cultureName);
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }

    private string ActiveClass(string culture) =>
        CultureInfo.CurrentCulture.Name == culture
            ? "language-option--active"
            : "";
}
