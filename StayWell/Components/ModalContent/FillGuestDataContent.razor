@using RentoomBooking.StayWell.Models
@using RentoomBooking.SharedClasses.Models.StayWell
@using RentoomBooking.SharedClasses.Models.Database.EFEntitites
@using Microsoft.Extensions.Localization
@using System.Globalization
@using Pages
@inject IStringLocalizer<PrearrivalPage> Localizer
@inject Services.ModalService ModalService
@inject Services.ToastService ToastService

<div class="guest-modal">
    <p class="guest-modal-subtitle">
        @Localizer["gcText"]
    </p>

    @if (Guests != null)
    {
        <div class="guest-list">
            @for (int i = 0; i < Guests.Count; i++)
            {
                int index = i;
                var guest = Guests[index];
                var isFilled = !string.IsNullOrWhiteSpace(guest.FirstName) && !string.IsNullOrWhiteSpace(guest.LastName);

                <div class="guest-card @(isFilled ? "guest-card--filled" : "")">
                    <div class="guest-card-header">
                        <img src="/icons/users.svg" class="guest-card-icon" alt="" />
                        <span class="guest-card-label">@Localizer["Guest"] @(index + 1)</span>
                        @if (isFilled)
                        {
                            <img src="/icons/circle-check.svg" class="guest-card-check" alt="" />
                        }
                    </div>

                    <div class="guest-card-inputs">
                        <div class="guest-input-wrapper">
                            <label class="guest-input-label">@Localizer["Name"]</label>
                            <input class="guest-input"
                                   placeholder="@Localizer["Name"]"
                                   value="@guest.FirstName"
                                   @onchange="@(e => UpdateGuest(index, e.Value?.ToString(), true))" />
                        </div>

                        <div class="guest-input-wrapper">
                            <label class="guest-input-label">@Localizer["Surname"]</label>
                            <input class="guest-input"
                                   placeholder="@Localizer["Surname"]"
                                   value="@guest.LastName"
                                   @onchange="@(e => UpdateGuest(index, e.Value?.ToString(), false))" />
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="guest-modal-footer">
        <button class="guest-confirm-btn" disabled="@(!IsValid)" @onclick="@Confirm">
            @Localizer["Accept2"]
        </button>
    </div>
</div>

@code {
    [Parameter] public List<RegistrationCardGuestModel> InitialGuests { get; set; } = new();

    [Parameter] public EventCallback<List<RegistrationCardGuestModel>> OnConfirm { get; set; }

    private List<RegistrationCardGuestModel> Guests { get; set; } = new();

    protected override void OnInitialized()
    {
        if (InitialGuests != null)
        {
            Guests = InitialGuests.Select(g => new RegistrationCardGuestModel
            {
                FirstName = g.FirstName,
                LastName = g.LastName
            }).ToList();
        }
    }

    private bool IsValid => Guests != null && Guests.All(g =>
        !string.IsNullOrWhiteSpace(g.FirstName) &&
        !string.IsNullOrWhiteSpace(g.LastName));

    private void UpdateGuest(int index, string? value, bool isFirstName)
    {
        if (index < 0 || index >= Guests.Count) return;
        if (isFirstName) Guests[index].FirstName = value ?? string.Empty;
        else Guests[index].LastName = value ?? string.Empty;
    }

    private async Task Confirm()
    {
        if (IsValid)
        {
            await OnConfirm.InvokeAsync(Guests);
            ModalService.HideModal();
            ToastService.ShowToast(Localizer["SavedSuccesfully"]);
        }
    }
}