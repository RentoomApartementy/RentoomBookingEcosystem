@using Microsoft.AspNetCore.Components.Web
@using RentoomBooking.ChatAI.Contracts
@using RentoomBooking.StayWell.Models.Chat
@using RentoomBooking.StayWell.States
@implements IDisposable
@inject AiChatClientService AiChatClientService
@inject SafeMarkdownService MarkdownService
@inject LocalStorageService LocalStorageService
@inject ReservationState ReservationState
@inject ModalService ModalService
@inject GlobalizationService GlobalizationService
@inject IJSRuntime JS

<div class="ai-chat-panel">
    <div class="ai-chat-messages" id="ai-chat-messages">
        @foreach (var message in _messages)
        {
            <div class="ai-chat-message @(message.Role == ChatRoles.User ? "ai-chat-message--user" : "ai-chat-message--assistant")">
                <div class="ai-chat-message-role">@(message.Role == ChatRoles.User ? "Ty" : "Asystent")</div>
                @if (message.Role == ChatRoles.User)
                {
                    <div class="ai-chat-message-content">@message.Markdown</div>
                }
                else
                {
                    <div class="ai-chat-message-content">@((MarkupString)MarkdownService.ToSafeHtml(message.Markdown))</div>
                }
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="ai-chat-error">@_error</div>
    }
    else if (_isStreaming)
    {
        <div class="ai-chat-loader">Asystent pisze...</div>
    }

    <div class="ai-chat-actions">
        <textarea
            class="ai-chat-input"
            placeholder="Napisz wiadomość..."
            @bind="_input"
            @bind:event="oninput"
            @onkeydown="HandleInputKeyDown"
            disabled="@_isStreaming"></textarea>

        <div class="ai-chat-buttons">
            <button class="ai-chat-btn ai-chat-btn--ghost" @onclick="Close" disabled="@_isStreaming">Zamknij</button>
            <button class="ai-chat-btn ai-chat-btn--danger" @onclick="StopAsync" disabled="@(!_isStreaming)">Stop</button>
            <button
                class="ai-chat-btn ai-chat-btn--mic @(_isDictating ? "ai-chat-btn--mic-active" : string.Empty)"
                @onclick="ToggleDictationAsync"
                disabled="@(_isStreaming || !_isSpeechSupported)">
                <img src="/icons/radio.svg" alt="Mikrofon" />
                @(_isDictating ? "Nasłuch..." : "Mikrofon")
            </button>
            <button class="ai-chat-btn ai-chat-btn--primary" @onclick="SendAsync" disabled="@(!_canSend)">Wyślij</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? Token { get; set; }

    private readonly List<ChatUiMessage> _messages = new();
    private ElementReference _messagesContainerRef;
    private string? _conversationId;
    private string? _conversationStorageKey;
    private string _input = string.Empty;
    private string? _error;
    private bool _isStreaming;
    private bool _isSpeechSupported = true;
    private bool _isDictating;
    private string _speechInputPrefix = string.Empty;
    private bool _pendingScrollToBottom;
    private CancellationTokenSource? _streamCts;
    private DotNetObjectReference<AiChatPanel>? _dotNetRef;

    private bool _canSend => !_isStreaming && !string.IsNullOrWhiteSpace(_input);

    protected override void OnInitialized()
    {
        if (_messages.Count == 0)
        {
            _messages.Add(new ChatUiMessage
            {
                Role = ChatRoles.Assistant,
                Markdown = "Cześć! Jestem asystentem StayWell. Jak mogę pomóc podczas Twojego pobytu?"
            });
        }

        QueueScrollToBottom();
    }

    protected override async Task OnParametersSetAsync()
    {
        var token = ResolveToken();
        if (string.IsNullOrWhiteSpace(token))
        {
            return;
        }

        var key = BuildConversationStorageKey(token);
        if (string.Equals(_conversationStorageKey, key, StringComparison.Ordinal))
        {
            return;
        }

        _conversationStorageKey = key;
        _conversationId = await LocalStorageService.GetItemAsync(key);
    }

    private async Task SendAsync()
    {
        if (!_canSend)
        {
            return;
        }

        if (_isDictating)
        {
            await StopDictationAsync();
        }

        var token = ResolveToken();
        if (string.IsNullOrWhiteSpace(token))
        {
            _error = "Brak tokenu rezerwacji. Odśwież stronę i spróbuj ponownie.";
            StateHasChanged();
            return;
        }

        var reservationId = ReservationState.CurrentReservation?.Id;
        if (reservationId is null || reservationId <= 0)
        {
            _error = "Brak danych rezerwacji. Odśwież stronę i spróbuj ponownie.";
            StateHasChanged();
            return;
        }

        var userMessage = _input.Trim();
        _input = string.Empty;
        _error = null;

        _messages.Add(new ChatUiMessage
        {
            Role = ChatRoles.User,
            Markdown = userMessage
        });

        var assistantMessage = new ChatUiMessage
        {
            Role = ChatRoles.Assistant,
            Markdown = string.Empty
        };

        _messages.Add(assistantMessage);
        _isStreaming = true;
        QueueScrollToBottom();
        StateHasChanged();

        _streamCts?.Cancel();
        _streamCts?.Dispose();
        _streamCts = new CancellationTokenSource();

        try
        {
            await AiChatClientService.StreamAsync(
                new ChatRequestDto(userMessage, token,ReservationState.CurrentReservation.Id,  _conversationId),
                async chunk =>
                {
                    assistantMessage.Markdown += chunk.Text;
                    QueueScrollToBottom();
                    await InvokeAsync(StateHasChanged);
                },
                async conversationId =>
                {
                    if (!string.IsNullOrWhiteSpace(conversationId))
                    {
                        _conversationId = conversationId;
                        if (!string.IsNullOrWhiteSpace(_conversationStorageKey))
                        {
                            await LocalStorageService.SetItemAsync(_conversationStorageKey, conversationId);
                        }
                    }

                    QueueScrollToBottom();
                    await InvokeAsync(StateHasChanged);
                },
                async message =>
                {
                    _error = message;
                    QueueScrollToBottom();
                    await InvokeAsync(StateHasChanged);
                },
                _streamCts.Token);

            if (string.IsNullOrWhiteSpace(assistantMessage.Markdown))
            {
                assistantMessage.Markdown = "Brak odpowiedzi z modelu.";
                QueueScrollToBottom();
            }
        }
        catch (OperationCanceledException)
        {
            if (string.IsNullOrWhiteSpace(assistantMessage.Markdown))
            {
                _messages.Remove(assistantMessage);
                QueueScrollToBottom();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            if (ex is HttpRequestException httpEx &&
                (httpEx.StatusCode == System.Net.HttpStatusCode.NotFound || httpEx.StatusCode == System.Net.HttpStatusCode.Forbidden))
            {
                _conversationId = null;
                if (!string.IsNullOrWhiteSpace(_conversationStorageKey))
                {
                    await LocalStorageService.RemoveItemAsync(_conversationStorageKey);
                }
            }

            if (string.IsNullOrWhiteSpace(assistantMessage.Markdown))
            {
                _messages.Remove(assistantMessage);
            }

            QueueScrollToBottom();
        }
        finally
        {
            _isStreaming = false;
            QueueScrollToBottom();
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _isSpeechSupported = await JS.InvokeAsync<bool>("staywellAiChat.isSpeechSupported");
            await InvokeAsync(StateHasChanged);
        }

        if (!_pendingScrollToBottom)
        {
            return;
        }

        _pendingScrollToBottom = false;
        await JS.InvokeVoidAsync("staywellAiChat.scrollToBottom", _messagesContainerRef);
    }

    private Task HandleInputKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !args.ShiftKey)
        {
            return SendAsync();
        }

        return Task.CompletedTask;
    }

    private async Task ToggleDictationAsync()
    {
        if (!_isSpeechSupported || _isStreaming || _dotNetRef is null)
        {
            return;
        }

        _error = null;
        if (_isDictating)
        {
            await StopDictationAsync();
            return;
        }

        _speechInputPrefix = _input;
        await JS.InvokeVoidAsync("staywellAiChat.startDictation", _dotNetRef, GetSpeechLanguage());
    }

    [JSInvokable]
    public Task OnSpeechStateChanged(bool isListening)
    {
        _isDictating = isListening;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnSpeechTranscriptChanged(string transcript)
    {
        _input = MergeSpeechWithInput(_speechInputPrefix, transcript);
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnSpeechError(string message)
    {
        _error = string.IsNullOrWhiteSpace(message) ? "Nie udało się uruchomić rozpoznawania mowy." : message;
        _isDictating = false;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnSpeechSupportChanged(bool isSupported)
    {
        _isSpeechSupported = isSupported;
        if (!isSupported)
        {
            _isDictating = false;
        }

        return InvokeAsync(StateHasChanged);
    }

    private async Task StopDictationAsync()
    {
        if (_isDictating)
        {
            await JS.InvokeVoidAsync("staywellAiChat.stopDictation");
        }

        _isDictating = false;
    }

    private Task StopAsync()
    {
        _streamCts?.Cancel();
        return Task.CompletedTask;
    }

    private string? ResolveToken()
    {
        if (!string.IsNullOrWhiteSpace(Token))
        {
            return Token;
        }

        return ReservationState.CurrentToken;
    }

    private static string BuildConversationStorageKey(string token) => $"staywell:ai-chat:conversation:{token}";

    private Task Close()
    {
            await StopDictationAsync();
        }

        ModalService.HideModal();
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _streamCts?.Cancel();
        _streamCts?.Dispose();
        _dotNetRef?.Dispose();

        try
        {
            _ = JS.InvokeVoidAsync("staywellAiChat.stopDictation");
        }
        catch
        {
            // Ignore JS interop errors during component disposal.
        }
    }
}
