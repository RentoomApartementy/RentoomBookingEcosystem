@using Microsoft.AspNetCore.Components.Web
@using RentoomBooking.ChatAI.Contracts
@using RentoomBooking.StayWell.Models.Chat
@using RentoomBooking.StayWell.States
@implements IDisposable
@inject AiChatClientService AiChatClientService
@inject SafeMarkdownService MarkdownService
@inject LocalStorageService LocalStorageService
@inject ReservationState ReservationState
@inject GlobalizationService GlobalizationService
@inject IJSRuntime JS

<div class="ai-chat-panel @(IsFullscreen ? "ai-chat-panel--fullscreen" : string.Empty)">
    <div class="ai-chat-messages" id="ai-chat-messages" @ref="_messagesContainerRef">
        @foreach (var message in _messages)
        {
            <div class="ai-chat-message @(message.Role == ChatRoles.User ? "ai-chat-message--user" : "ai-chat-message--assistant")">
                <div class="ai-chat-message-role">@(message.Role == ChatRoles.User ? "Ty" : "Asystent")</div>
                @if (message.Role == ChatRoles.User)
                {
                    <div class="ai-chat-message-content">@message.Markdown</div>
                }
                else
                {
                    <div class="ai-chat-message-content">@((MarkupString)MarkdownService.ToSafeHtml(message.Markdown))</div>
                }
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="ai-chat-error">@_error</div>
    }
    else if (_isStreaming)
    {
        <div class="ai-chat-loader">Asystent pisze...</div>
    }

    <div class="ai-chat-actions">
        <div class="ai-chat-mode-toggle" role="group" aria-label="Tryb rozmowy AI">
            <button type="button"
                    class="ai-chat-mode-option @GetTransportModeClass(AiChatTransportMode.Classic)"
                    @onclick="async () => await SetTransportModeAsync(AiChatTransportMode.Classic)"
                    disabled="@_isStreaming"
                    aria-pressed="@(_transportMode == AiChatTransportMode.Classic)"
                    title="Klasyczna ścieżka chatu">
                Klasyczny
            </button>
            <button type="button"
                    class="ai-chat-mode-option @GetTransportModeClass(AiChatTransportMode.Agent)"
                    @onclick="async () => await SetTransportModeAsync(AiChatTransportMode.Agent)"
                    disabled="@_isStreaming"
                    aria-pressed="@(_transportMode == AiChatTransportMode.Agent)"
                    title="Ścieżka przez agenta Foundry">
                Agent
            </button>
        </div>

        <div class="ai-chat-composer">
            <textarea class="ai-chat-input"
                      placeholder="Napisz wiadomość..."
                      @bind="_input"
                      @bind:event="oninput"
                      @onkeydown="HandleInputKeyDown"
                      disabled="@_isStreaming"></textarea>

            <div class="ai-chat-composer-actions">
                <button class="ai-chat-icon-btn ai-chat-icon-btn--mic @(_isDictating ? "ai-chat-icon-btn--mic-active" : string.Empty)"
                        @onclick="ToggleDictationAsync"
                        disabled="@(_isStreaming || !_isSpeechSupported)"
                        aria-label="@(_isDictating ? "Zatrzymaj nasłuch mikrofonu" : "Uruchom mikrofon")"
                        title="@(_isDictating ? "Nasłuch..." : "Mikrofon")">
                    <img src="/icons/microphone-svgrepo-com.svg" alt="" />
                </button>

                @if (_isStreaming)
                {
                    <button class="ai-chat-icon-btn ai-chat-icon-btn--stop"
                            @onclick="StopAsync"
                            aria-label="Zatrzymaj generowanie"
                            title="Stop">
                        <img src="/icons/x.svg" alt="" />
                    </button>
                }
                else
                {
                    <button class="ai-chat-icon-btn ai-chat-icon-btn--send"
                            @onclick="SendAsync"
                            disabled="@(!_canSend)"
                            aria-label="Wyślij wiadomość"
                            title="Wyślij">
                        <img src="/icons/circle-arrow-right.svg" alt="" />
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? Token { get; set; }
    [Parameter] public bool IsFullscreen { get; set; }

    private const string WelcomeMessage = "Cześć! Jestem asystentem StayWell. Jak mogę pomóc podczas Twojego pobytu?";
    private readonly List<ChatUiMessage> _messages = new();
    private ElementReference _messagesContainerRef;
    private string? _conversationId;
    private string? _conversationStorageKey;
    private string? _loadedConversationContextKey;
    private string _input = string.Empty;
    private string? _error;
    private bool _isStreaming;
    private bool _isSpeechSupported = true;
    private bool _isDictating;
    private bool _acceptSpeechInput;
    private string _speechInputPrefix = string.Empty;
    private bool _pendingScrollToBottom;
    private CancellationTokenSource? _streamCts;
    private DotNetObjectReference<AiChatPanel>? _dotNetRef;
    private AiChatTransportMode _transportMode = AiChatTransportMode.Classic;

    private bool _canSend => !_isStreaming && !string.IsNullOrWhiteSpace(_input);

    protected override async Task OnInitializedAsync()
    {
        await SetTransportModeAsync(AiChatTransportMode.Agent);
        EnsureWelcomeMessage();
        QueueScrollToBottom();
    }

    protected override async Task OnParametersSetAsync()
    {
        var token = ResolveToken();
        if (string.IsNullOrWhiteSpace(token))
        {
            return;
        }
        await SetTransportModeAsync(AiChatTransportMode.Agent);
        await LoadConversationContextAsync(token);
    }

    private async Task SendAsync()
    {
        if (!_canSend)
        {
            return;
        }

        if (_isDictating)
        {
            _acceptSpeechInput = false;
            await StopDictationAsync();
        }

        var token = ResolveToken();
        if (string.IsNullOrWhiteSpace(token))
        {
            _error = "Brak tokenu rezerwacji. Odśwież stronę i spróbuj ponownie.";
            StateHasChanged();
            return;
        }

        var reservationId = ReservationState.CurrentReservation?.Id;
        if (reservationId is null || reservationId <= 0)
        {
            _error = "Brak danych rezerwacji. Odśwież stronę i spróbuj ponownie.";
            StateHasChanged();
            return;
        }

        var userMessage = _input.Trim();
        _input = string.Empty;
        _error = null;

        _messages.Add(new ChatUiMessage
        {
            Role = ChatRoles.User,
            Markdown = userMessage
        });

        var assistantMessage = new ChatUiMessage
        {
            Role = ChatRoles.Assistant,
            Markdown = string.Empty
        };

        _messages.Add(assistantMessage);
        _isStreaming = true;
        QueueScrollToBottom();
        StateHasChanged();

        _streamCts?.Cancel();
        _streamCts?.Dispose();
        _streamCts = new CancellationTokenSource();

        try
        {
            await AiChatClientService.StreamAsync(
                new ChatRequestDto(userMessage, token, reservationId.Value, _conversationId),
                _transportMode,
                async chunk =>
                {
                    assistantMessage.Markdown += chunk.Text;
                    QueueScrollToBottom();
                    await InvokeAsync(StateHasChanged);
                },
                async conversationId =>
                {
                    if (!string.IsNullOrWhiteSpace(conversationId))
                    {
                        _conversationId = conversationId;
                        if (!string.IsNullOrWhiteSpace(_conversationStorageKey))
                        {
                            await LocalStorageService.SetItemAsync(_conversationStorageKey, conversationId);
                        }
                    }

                    QueueScrollToBottom();
                    await InvokeAsync(StateHasChanged);
                },
                async message =>
                {
                    _error = message;
                    QueueScrollToBottom();
                    await InvokeAsync(StateHasChanged);
                },
                _streamCts.Token);

            if (string.IsNullOrWhiteSpace(assistantMessage.Markdown))
            {
                assistantMessage.Markdown = "Brak odpowiedzi z modelu.";
                QueueScrollToBottom();
            }
        }
        catch (OperationCanceledException)
        {
            if (string.IsNullOrWhiteSpace(assistantMessage.Markdown))
            {
                _messages.Remove(assistantMessage);
                QueueScrollToBottom();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            if (ex is HttpRequestException httpEx &&
                (httpEx.StatusCode == System.Net.HttpStatusCode.NotFound || httpEx.StatusCode == System.Net.HttpStatusCode.Forbidden))
            {
                _conversationId = null;
                if (!string.IsNullOrWhiteSpace(_conversationStorageKey))
                {
                    await LocalStorageService.RemoveItemAsync(_conversationStorageKey);
                }
            }

            if (string.IsNullOrWhiteSpace(assistantMessage.Markdown))
            {
                _messages.Remove(assistantMessage);
            }

            QueueScrollToBottom();
        }
        finally
        {
            _isStreaming = false;
            QueueScrollToBottom();
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _isSpeechSupported = await JS.InvokeAsync<bool>("staywellAiChat.isSpeechSupported");
            await InvokeAsync(StateHasChanged);
        }

        if (!_pendingScrollToBottom)
        {
            return;
        }

        _pendingScrollToBottom = false;
        await JS.InvokeVoidAsync("staywellAiChat.scrollToBottom", _messagesContainerRef);
    }

    private Task HandleInputKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !args.ShiftKey)
        {
            return SendAsync();
        }

        return Task.CompletedTask;
    }

    private async Task ToggleDictationAsync()
    {
        if (!_isSpeechSupported || _isStreaming || _dotNetRef is null)
        {
            return;
        }

        _error = null;
        if (_isDictating)
        {
            await StopDictationAsync();
            return;
        }

        _speechInputPrefix = _input;
        _acceptSpeechInput = true;
        await JS.InvokeVoidAsync("staywellAiChat.startDictation", _dotNetRef, GetSpeechLanguage());
    }

    [JSInvokable]
    public Task OnSpeechStateChanged(bool isListening)
    {
        _isDictating = isListening;
        _acceptSpeechInput = isListening;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnSpeechTranscriptChanged(string transcript)
    {
        if (!_acceptSpeechInput)
        {
            return Task.CompletedTask;
        }

        _input = MergeSpeechWithInput(_speechInputPrefix, transcript);
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnSpeechError(string message)
    {
        _error = string.IsNullOrWhiteSpace(message) ? "Nie udało się uruchomić rozpoznawania mowy." : message;
        _isDictating = false;
        _acceptSpeechInput = false;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnSpeechSupportChanged(bool isSupported)
    {
        _isSpeechSupported = isSupported;
        if (!isSupported)
        {
            _isDictating = false;
            _acceptSpeechInput = false;
        }

        return InvokeAsync(StateHasChanged);
    }

    private async Task StopDictationAsync()
    {
        _acceptSpeechInput = false;
        if (_isDictating)
        {
            await JS.InvokeVoidAsync("staywellAiChat.stopDictation");
        }

        _isDictating = false;
    }

    private Task StopAsync()
    {
        _streamCts?.Cancel();
        return Task.CompletedTask;
    }

    private async Task SetTransportModeAsync(AiChatTransportMode transportMode)
    {
        if (_isStreaming || _transportMode == transportMode)
        {
            return;
        }

        _transportMode = transportMode;
        _conversationStorageKey = null;
        _loadedConversationContextKey = null;

        var token = ResolveToken();
        if (!string.IsNullOrWhiteSpace(token))
        {
            await LoadConversationContextAsync(token);
        }

        StateHasChanged();
    }

    private string GetTransportModeClass(AiChatTransportMode transportMode)
    {
        return _transportMode == transportMode ? "ai-chat-mode-option--active" : string.Empty;
    }

    private string? ResolveToken()
    {
        if (!string.IsNullOrWhiteSpace(Token))
        {
            return Token;
        }

        return ReservationState.CurrentToken;
    }

    private async Task LoadConversationContextAsync(string token)
    {
        var key = BuildConversationStorageKey(token, _transportMode);
        if (string.Equals(_loadedConversationContextKey, key, StringComparison.Ordinal))
        {
            return;
        }

        _conversationStorageKey = key;
        _conversationId = await LocalStorageService.GetItemAsync(key);

        await LoadMessagesFromHistoryAsync(token, _conversationId);
        _loadedConversationContextKey = key;
    }

    private static string BuildConversationStorageKey(string token, AiChatTransportMode transportMode)
    {
        return transportMode == AiChatTransportMode.Agent
            ? $"staywell:ai-chat:agent-conversation:{token}"
            : $"staywell:ai-chat:conversation:{token}";
    }

    private async Task LoadMessagesFromHistoryAsync(string token, string? conversationId)
    {
        _messages.Clear();

        if (!string.IsNullOrWhiteSpace(conversationId))
        {
            try
            {
                var history = await AiChatClientService.GetHistoryAsync(token, conversationId, _transportMode);
                if (history?.Messages is not null)
                {
                    foreach (var message in history.Messages)
                    {
                        if (!string.IsNullOrWhiteSpace(message.Role))
                        {
                            _messages.Add(new ChatUiMessage
                            {
                                Role = message.Role,
                                Markdown = message.Content ?? string.Empty
                            });
                        }
                    }
                }
            }
            catch
            {
                // Ignore history-load failures and fall back to welcome message.
            }
        }

        EnsureWelcomeMessage();
        QueueScrollToBottom();
    }

    private void EnsureWelcomeMessage()
    {
        if (_messages.Count > 0)
        {
            return;
        }

        _messages.Add(new ChatUiMessage
        {
            Role = ChatRoles.Assistant,
            Markdown = WelcomeMessage
        });
    }

    private static string MergeSpeechWithInput(string prefix, string transcript)
    {
        var cleanedPrefix = prefix?.TrimEnd() ?? string.Empty;
        var cleanedTranscript = transcript?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(cleanedPrefix))
        {
            return cleanedTranscript;
        }

        if (string.IsNullOrWhiteSpace(cleanedTranscript))
        {
            return cleanedPrefix;
        }

        return $"{cleanedPrefix} {cleanedTranscript}";
    }

    private string GetSpeechLanguage()
    {
        var lang = GlobalizationService.CurrentCulture?.Name;
        if (string.IsNullOrWhiteSpace(lang))
        {
            return "pl-PL";
        }

        return lang;
    }

    private void QueueScrollToBottom()
    {
        _pendingScrollToBottom = true;
    }

    public void Dispose()
    {
        _streamCts?.Cancel();
        _streamCts?.Dispose();
        _dotNetRef?.Dispose();

        try
        {
            _ = JS.InvokeVoidAsync("staywellAiChat.stopDictation");
        }
        catch
        {
            // Ignore JS interop errors during component disposal.
        }
    }
}
