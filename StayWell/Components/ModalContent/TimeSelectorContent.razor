@using System
@using Microsoft.Extensions.Localization
@using System.Globalization
@using Pages
@inject Services.ModalService ModalService
@inject Services.ToastService ToastService
@inject StayWell.States.ReservationState ReservationState
@inject IStringLocalizer<PrearrivalPage> Localizer

<div class="content-modal">
    <ul class="List">
        @foreach (int h in _hours)
        {
            var time = new TimeSpan(h,0,0);
            <li class="Element"
                @onclick="()=>Select(time)">
                @time.ToString(@"hh\:mm")
            </li>
        }
        @* <li class="Element">Ciężko oszacować</li> *@
        @* <li class="Element">Nie wiem</li> *@
    </ul>
</div>

@code{
    [Parameter]
    public TimeSpan? Value { get; set; }

    [Parameter]
    public EventCallback<TimeSpan?> ValueChanged { get; set; }

    private List<int> _hours = new();

    protected override void OnInitialized()
    {
        _hours = Enumerable.Range(15, 8).ToList();

        if (ReservationState?.HasEarlyCheckIn == true)
        {
            if (!_hours.Contains(14))
            {
                _hours.Insert(0, 14);
            }
        }
    }

    private async Task Select(TimeSpan? time)
    {
        await ValueChanged.InvokeAsync(time);
        ModalService.HideModal();
        ToastService.ShowToast(
            $"{Localizer["YouChoseTime"]} {time}"
        );
    }

}