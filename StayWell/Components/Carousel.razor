@using System.Timers
@using Microsoft.AspNetCore.Components.Web
@implements IDisposable
@inject StayWell.Services.ModalService ModalService

<div class="carousel-component-root @(UseSmartGlow ? "with-glow" : "")">

    @if (UseSmartGlow)
    {
        <div class="glow-layer">
            <div class="slider" style="transform: translateX(calc(-@(_index * 100)%))">
                @for (int i = 0; i < ImageUrls.Length; i++)
                {
                    <div class="slide">
                        <img class="slide-img" src="@ImageUrls[i]" aria-hidden="true" alt="" />
                    </div>
                }
            </div>
        </div>
    }

    <div class="carousel-card">
        <div class="carousel-mask"
             @ontouchstart="HandleTouchStart"
             @ontouchmove="HandleTouchMove"
             @ontouchend="HandleTouchEnd"
             @ontouchcancel="HandleTouchCancel"
             style="height: @(IsInstructionCarousel ? "500px;" : "250px;"); touch-action: pan-y;">
            <div class="slider" style="transform: translateX(calc(-@(_index * 100)%))">
                @for (int i = 0; i < ImageUrls.Length; i++)
                {
                    <div class="slide" @onclick="EnlargeImage" style="cursor: pointer;" title="Kliknij, aby powiększyć">
                        <div class="slide-bg" style="background-image: url('@ImageUrls[i]')"></div>
                        <img class="slide-img" src="@ImageUrls[i]" loading="lazy" alt="slide-@i"
                             style="object-fit: @(IsInstructionCarousel ? "contain;" : "cover;")" />
                    </div>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(CurrentDescription))
        {
            <div class="description-wrap">
                <div class="description-title">
                    @CurrentTitle
                </div>
                <div class="description-text">
                    @CurrentDescription
                </div>
            </div>
        }

        @if (UseControlButtons)
        {
            <div class="control-buttons-wrapper">
                <button class="nav-btn" @onclick="PreviousSlide" aria-label="Poprzedni">
                    <img src="/icons/chevron-left.svg" alt="<" />
                </button>

                <span class="slide-counter">
                    <span class="current">@(_index + 1)</span>
                    <span class="divider">/</span>
                    <span class="total">@ImageUrls.Length</span>
                </span>

                <button class="nav-btn" @onclick="NextSlide" aria-label="Następny">
                    <img src="/icons/chevron-right.svg" alt=">" />
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string[] ImageUrls { get; set; } = Array.Empty<string>();
    [Parameter] public bool UseTimer { get; set; }
    [Parameter] public bool UseControlButtons { get; set; }
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string[] Descriptions { get; set; } = Array.Empty<string>();
    [Parameter] public string[] StepTitles { get; set; } = Array.Empty<string>();
    [Parameter] public int TransitionIntervalMs { get; set; } = 2000;
    [Parameter] public bool UseSmartGlow { get; set; } = false;
    [Parameter] public string AdditionalStyle { get; set; } = string.Empty;
    [Parameter] public bool IsInstructionCarousel { get; set; } = false;

    private int _index = 0;
    private System.Timers.Timer? _timer;

    private double _touchStartX;
    private double _touchStartY;
    private double _touchLastX;
    private double _touchLastY;
    private bool _touchStarted;
    private bool _suppressNextTap;

    private const double SwipeThresholdPx = 50;

    private string CurrentDescription =>
        Descriptions.Length > _index ? Descriptions[_index] : Description;

    private string CurrentTitle =>
        StepTitles.Length > _index && !string.IsNullOrWhiteSpace(StepTitles[_index])
            ? StepTitles[_index]
            : $"Krok {_index + 1}";

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && UseTimer) StartTimer();
    }

    private void EnlargeImage()
    {
        if (_suppressNextTap)
        {
            _suppressNextTap = false;
            return;
        }

        if (ImageUrls == null || ImageUrls.Length == 0) return;

        if (UseControlButtons)
        {
            ModalService.ShowModal("",
            @<RentoomBooking.StayWell.Components.ModalContent.GalleryModalContent
            ImageUrls="@ImageUrls"
            StartIndex="@_index"
            ShowControls="@UseControlButtons" />,
            true
            );
        }
    }

    private void HandleTouchStart(TouchEventArgs args)
    {
        if (args.Touches is null || args.Touches.Count() == 0) return;

        _touchStartX = args.Touches[0].ClientX;
        _touchStartY = args.Touches[0].ClientY;
        _touchLastX = _touchStartX;
        _touchLastY = _touchStartY;
        _touchStarted = true;
    }

    private void HandleTouchMove(TouchEventArgs args)
    {
        if (!_touchStarted || args.Touches is null || args.Touches.Count() == 0) return;

        _touchLastX = args.Touches[0].ClientX;
        _touchLastY = args.Touches[0].ClientY;
    }

    private void HandleTouchEnd(TouchEventArgs args)
    {
        if (!_touchStarted) return;

        var endX = _touchLastX;
        var endY = _touchLastY;

        if (args.ChangedTouches is not null && args.ChangedTouches.Count() > 0)
        {
            endX = args.ChangedTouches[0].ClientX;
            endY = args.ChangedTouches[0].ClientY;
        }

        var deltaX = endX - _touchStartX;
        var deltaY = endY - _touchStartY;

        if (Math.Abs(deltaX) >= SwipeThresholdPx && Math.Abs(deltaX) > Math.Abs(deltaY))
        {
            if (deltaX < 0)
            {
                NextSlide();
            }
            else
            {
                PreviousSlide();
            }

            _suppressNextTap = true;
        }

        ResetTouchState();
    }

    private void HandleTouchCancel()
    {
        ResetTouchState();
    }

    private void ResetTouchState()
    {
        _touchStarted = false;
        _touchStartX = 0;
        _touchStartY = 0;
        _touchLastX = 0;
        _touchLastY = 0;
    }

    private void NextSlide()
    {
        if (ImageUrls.Length == 0) return;

        if (_index < ImageUrls.Length - 1)
        {
            _index++;
        }
        else
        {
            _index = 0;
        }
    }

    private void PreviousSlide()
    {
        if (ImageUrls.Length == 0) return;

        if (_index > 0)
        {
            _index--;
        }
        else
        {
            _index = ImageUrls.Length - 1;
        }
    }

    private void StartTimer()
    {
        if (TransitionIntervalMs == 0) return;
        _timer = new Timer();
        _timer.Interval = TransitionIntervalMs;
        _timer.Elapsed += async (sender, args) =>
        {
            NextSlide();
            await InvokeAsync(StateHasChanged);
        };
        _timer.AutoReset = true;
        _timer.Start();
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }
}