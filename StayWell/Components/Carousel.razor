@using System.Timers
@implements IDisposable
@inject StayWell.Services.ModalService ModalService

<div class="carousel @(UseControlButtons ? "noradius" : "")">
    <div class="slider" style="transform: translateX(calc(-@(_index*100)%))">
        @for (int i = 0; i < ImageUrls.Length; i++)
        {
            <div class="slide" @onclick="EnlargeImage">
                <img class="slide-img" src="@ImageUrls[i]" loading="lazy" alt="slide-@i"/>
            </div>
        }
    </div>
</div>
@if (UseControlButtons == true)
{
    <div class="control-buttons-wrapper">
        <button @onclick="PreviousSlide"> &lt; </button>
        <span>@(_index+1) / @ImageUrls.Length </span>
        <button @onclick="NextSlide"> &gt; </button>
    </div>
}

@code {

    [Parameter] public string[] ImageUrls { get; set; } = Array.Empty<string>(); // tablica URLobrazków
    [Parameter] public bool UseTimer { get; set; } // automatyczna zmiana slajdów
    [Parameter] public bool UseControlButtons { get; set; } // wyswietla przyciski do zmiany slajdów
    [Parameter] public int TransitionIntervalMs { get; set; } = 2000; // interwa³ zmiany slajdów w ms

    private int _index = 0;
    private System.Timers.Timer? _timer;

    protected override void OnAfterRender(bool firstRender)
    {
        if(firstRender && UseTimer) StartTimer();
    }

    private void EnlargeImage()
    {
        ModalService.ShowModal("",
        @<div>
            <img class="big-img" src="@(ImageUrls[_index])"/>
        </div>
        );
    }

    private void NextSlide()
    {
        
        if (_index < ImageUrls.Length - 1)
        {
            _index++;
        }
        else
        {
            _index = 0;
        }
    }

    private void PreviousSlide()
    {

        if (_index > 0)
        {
            _index--;
        }
        else
        {
            _index = ImageUrls.Length - 1;
        }
    }

    private void StartTimer()
    {
        if (TransitionIntervalMs == 0) return;
        _timer = new Timer();
        _timer.Interval = TransitionIntervalMs;
        _timer.Elapsed += async (sender, args) =>
        {
            NextSlide();
            await InvokeAsync(StateHasChanged);
        };
        _timer.AutoReset = true;
        _timer.Start();

    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }

}