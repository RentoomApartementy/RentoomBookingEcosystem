@inject NavigationManager Navigation
@using Microsoft.Extensions.Localization
@using System.Globalization
@using Pages
@inject IStringLocalizer<HomePage> Localizer
@inject Services.GlobalizationService GlobalizationService
@implements IDisposable

<div class="footer-navigation-row">
    <NavigationButton href="@($"/reservation/{TokenFromUrl}/InstructionsPage")"
                      active="@IsActive($"/reservation/{TokenFromUrl}/InstructionsPage")"
                      Text="@Localizer["InstructionsFooter"]">
        <Icon>
            <img src="/icons/book.svg" alt="Instrukcja" />
        </Icon>
    </NavigationButton>

    <NavigationButton href="@($"/reservation/{TokenFromUrl}/OpenApartmentPage")"
                      active="@IsActive($"/reservation/{TokenFromUrl}/OpenApartmentPage")"
                      Text="@Localizer["Open"]">
        <Icon>
            <img src="/icons/lock.svg" alt="Otwórz" />
        </Icon>
    </NavigationButton>

    <NavigationButton href="@($"/reservation/{TokenFromUrl}/HomePage")"
                      active="@IsActive([$"/reservation/{TokenFromUrl}/HomePage", $"/reservation/{TokenFromUrl}/",$"/reservation/{TokenFromUrl}"])"
                      Text="@Localizer["Home"]">
        <Icon>
            <img src="/icons/house.svg" alt="Główna" />
        </Icon>
    </NavigationButton>

    <NavigationButton href="@($"/reservation/{TokenFromUrl}/ManageStayPage")"
                      active="@IsActive($"/reservation/{TokenFromUrl}/ManageStayPage")"
                      Text="@Localizer["Manage"]">
        <Icon>
            <img src="/icons/lamp.svg" alt="Zarządzaj" />
        </Icon>
    </NavigationButton>

    <NavigationButton href="@($"/reservation/{TokenFromUrl}/AboutReservationPage")"
                      active="@IsActive($"/reservation/{TokenFromUrl}/AboutReservationPage")"
                      Text="Info">
        <Icon>
            <img src="/icons/info.svg" alt="Info" />
        </Icon>
    </NavigationButton>
</div>

@code {
    protected override void OnInitialized()
    {
        base.OnInitialized();
        Navigation.LocationChanged += OnLocationChanged;
        GlobalizationService.OnChange += StateHasChanged;
    }

    private string? TokenFromUrl
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0];
            var segments = path.Trim('/').Split('/');
            if (segments.Length >= 2 && segments[0] == "reservation")
                return segments[1];
            return null;
        }
    }

    private void OnLocationChanged(
        object? sender,
        Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e
    )
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        GlobalizationService.OnChange -= StateHasChanged;
    }

    private bool IsActive(string href)
    {
        var currentUri = Navigation.Uri;
        var baseUri = Navigation.BaseUri;
        var relativeUri = currentUri.StartsWith(baseUri)
            ? currentUri.Substring(baseUri.Length - 1)
            : currentUri;

        return relativeUri.Equals(href, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsActive(List<string> hrefs)
    {
        var currentUri = Navigation.Uri;
        var baseUri = Navigation.BaseUri;
        var relativeUri = currentUri.StartsWith(baseUri)
            ? currentUri.Substring(baseUri.Length - 1)
            : currentUri;

        return hrefs.Any(href =>
            relativeUri.Equals(href, StringComparison.OrdinalIgnoreCase)
        );
    }
}