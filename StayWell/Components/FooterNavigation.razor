@inject NavigationManager Navigation
@using Microsoft.Extensions.Localization
@using System.Globalization
@using Pages
@inject IStringLocalizer<HomePage> Localizer
@inject Services.GlobalizationService GlobalizationService
@inject FeatureFlagsService FeatureFlagsService
@inject IJSRuntime JS
@implements IDisposable

<div class="footer-nav-wrapper">

    <div class="footer-menu-backdrop @(_menuOpen ? "open" : "")" @onclick="CloseMenu"></div>

    <div class="footer-menu-panel @(_menuOpen ? "open" : "")">
        <button class="footer-menu-item @(IsActive($"/reservation/{TokenFromUrl}/AboutReservationPage") ? "active" : "")" @onclick="@(() => NavigateTo($"/reservation/{TokenFromUrl}/AboutReservationPage"))">
            <img src="/icons/info.svg" alt="@Localizer["AboutReservationFooter"]" />
            <span>@Localizer["AboutReservationFooter"]</span>
        </button>
        <button class="footer-menu-item @(IsActive($"/reservation/{TokenFromUrl}/ParkingPage") ? "active" : "")" @onclick="@(() => NavigateTo($"/reservation/{TokenFromUrl}/ParkingPage"))">
            <img src="/icons/square-parking.svg" alt="@Localizer["ParkingFooter"]" />
            <span>@Localizer["ParkingFooter"]</span>
        </button>


        @if(FeatureFlagsService.FeatureAllowed("loyalty-programme"))
        {
            <button class="footer-menu-item @(IsActive($"/reservation/{TokenFromUrl}/loyalty-programme") ? "active" : "")" @onclick="@(() => NavigateTo($"/reservation/{TokenFromUrl}/loyalty-programme"))">
                <img src="/icons/coins.svg" alt="@Localizer["LoyaltyFooter"]" />
            <span>@Localizer["LoyaltyFooter"]</span>
        </button>
        }
    </div>

    <div class="footer-navigation-row">
        <div class="footer-nav-indicator @(_activeIndex >= 0 ? "show" : "") @_indicatorDir @(_indicatorDir != "" ? (_pulseToggle ? "neck-a" : "neck-b") : "")" style="--i:@_activeIndex"></div>

        <NavigationButton href="@($"/reservation/{TokenFromUrl}/InstructionsPage")"
                          active="@IsActive($"/reservation/{TokenFromUrl}/InstructionsPage")"
                          Text="@Localizer["InstructionsFooter"]">
            <Icon>
                <img src="/icons/book.svg" alt="Instrukcja" />
            </Icon>
        </NavigationButton>

        <NavigationButton href="@($"/reservation/{TokenFromUrl}/OpenApartmentPage")"
                          active="@IsActive($"/reservation/{TokenFromUrl}/OpenApartmentPage")"
                          Text="@Localizer["Open"]">
            <Icon>
                <img src="/icons/lock.svg" alt="Otwórz" />
            </Icon>
        </NavigationButton>

        <NavigationButton href="@($"/reservation/{TokenFromUrl}/HomePage")"
                          active="@IsActive([$"/reservation/{TokenFromUrl}/HomePage", $"/reservation/{TokenFromUrl}/",$"/reservation/{TokenFromUrl}"])"
                          Text="@Localizer["Home"]">
            <Icon>
                <img src="/icons/house.svg" alt="Główna" />
            </Icon>
        </NavigationButton>

        <NavigationButton href="@($"/reservation/{TokenFromUrl}/ManageStayPage")"
                          active="@IsActive($"/reservation/{TokenFromUrl}/ManageStayPage")"
                          Text="@Localizer["Manage"]">
            <Icon>
                <img src="/icons/lamp.svg" alt="Zarządzaj" />
            </Icon>
        </NavigationButton>

        <div class="footer-nav-btn-wrapper">
            <button class="footer-nav-btn @(_menuOpen ? "active" : "")" @onclick="ToggleMenu">
                <div class="footer-nav-icon">
                    <span class="burger-icon">
                        <span></span>
                        <span></span>
                        <span></span>
                    </span>
                </div>
                <span class="footer-nav-text">Menu</span>
            </button>
        </div>
    </div>
</div>

@code {
    private bool _menuOpen = false;

    // Column the sliding pill currently rests in: 0-3 nav buttons, 4 = Menu, -1 = hidden.
    private int _activeIndex = -1;
    // Travel direction class so the trailing edge can lag and stretch the pill.
    private string _indicatorDir = "";
    // Alternates each move so the raindrop "neck" animation restarts every time.
    private bool _pulseToggle;

    // Column the pill should travel to, derived from route + menu state.
    private int CalculateActiveIndex()
    {
        if (_menuOpen) return 4;
        var t = TokenFromUrl;
        if (IsActive($"/reservation/{t}/InstructionsPage")) return 0;
        if (IsActive($"/reservation/{t}/OpenApartmentPage")) return 1;
        if (IsActive(new List<string> { $"/reservation/{t}/HomePage", $"/reservation/{t}/", $"/reservation/{t}" })) return 2;
        if (IsActive($"/reservation/{t}/ManageStayPage")) return 3;
        return -1;
    }

    private void RefreshIndicator()
    {
        var idx = CalculateActiveIndex();
        if (idx == _activeIndex) return;

        // Only stretch when sliding between two real buttons; a fade-in shouldn't.
        if (idx >= 0 && _activeIndex >= 0)
        {
            _indicatorDir = idx > _activeIndex ? "to-right" : "to-left";
            _pulseToggle = !_pulseToggle; // restart the neck animation on every move
        }
        else
        {
            _indicatorDir = "";
        }
        _activeIndex = idx;
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Navigation.LocationChanged += OnLocationChanged;
        GlobalizationService.OnChange += StateHasChanged;
        RefreshIndicator();
    }

    private string? TokenFromUrl
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0];
            var segments = path.Trim('/').Split('/');
            if (segments.Length >= 2 && segments[0] == "reservation")
                return segments[1];
            return null;
        }
    }

    private async Task ToggleMenu()
    {
        _menuOpen = !_menuOpen;
        RefreshIndicator();
        await SetBodyScroll(!_menuOpen);
    }

    private async Task CloseMenu()
    {
        _menuOpen = false;
        RefreshIndicator();
        await SetBodyScroll(true);
    }

    private async Task NavigateTo(string href)
    {
        _menuOpen = false;
        await SetBodyScroll(true);
        Navigation.NavigateTo(href);
    }

    private async void OnLocationChanged(
        object? sender,
        Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e
    )
    {
        _menuOpen = false;
        RefreshIndicator();
        await SetBodyScroll(true);
        StateHasChanged();
    }

    private ValueTask SetBodyScroll(bool enabled) =>
        JS.InvokeVoidAsync("eval", $"var b=document.getElementById('main-body');if(b)b.style.overflowY='{(enabled ? "auto" : "hidden")}'");

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        GlobalizationService.OnChange -= StateHasChanged;
        if (_menuOpen)
            JS.InvokeVoidAsync("eval", "var b=document.getElementById('main-body');if(b)b.style.overflowY=''");
    }

    private bool IsActive(string href)
    {
        var currentUri = Navigation.Uri;
        var baseUri = Navigation.BaseUri;
        var relativeUri = currentUri.StartsWith(baseUri)
            ? currentUri.Substring(baseUri.Length - 1)
            : currentUri;

        return relativeUri.Equals(href, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsActive(List<string> hrefs)
    {
        var currentUri = Navigation.Uri;
        var baseUri = Navigation.BaseUri;
        var relativeUri = currentUri.StartsWith(baseUri)
            ? currentUri.Substring(baseUri.Length - 1)
            : currentUri;

        return hrefs.Any(href =>
            relativeUri.Equals(href, StringComparison.OrdinalIgnoreCase)
        );
    }
}
