@using RentoomBooking.SharedClasses.Models.Upsell
@using RentoomBooking.SharedFrontend.Components.Shared.UpsellComponents
@using RentoomBooking.StayWell.States
@using RentoomBooking.SharedClasses.Models.ReservationWorkflow
@using System.Globalization
@using RentoomBooking.StayWell.Components.Upsells
@using RentoomBooking.StayWell.Services
@inject AvailableUpsellsState AvailableUpsellsState
@inject UpsellCartState UpsellCartState
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject GlobalizationService GlobalizationService
@implements IAsyncDisposable

<div class="upsell-strip-wrapper">
    <div class="upsell-strip-header">
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <img class="upsell-strip-header__icon" src="/icons/tickets.svg" alt="" />
            <h2 class="upsell-strip-title">@Title</h2>
        }
        <a class="upsell-strip-more-link" href="/reservation/@Token/Vouchers">@morebuttontext <img src="/icons/chevron-right.svg"/></a>
    </div>

    @if (AvailableUpsellsState.IsLoading)
    {
        <div class="upsell-strip-loading">
            @for (int i = 0; i < SkeletonCount; i++)
            {
                <div class="upsell-strip-skeleton"></div>
            }
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(AvailableUpsellsState.Error))
    {
        <p class="upsell-strip-error">@AvailableUpsellsState.Error</p>
    }
    else if (!AvailableUpsellsState.AvailableUpsells.Any())
    {
        @**@
    }
    else
    {
        var upsellList = DisplayedUpsells.ToList();
        var activeIndex = upsellList.FindIndex(t => t.PartnerServiceId == _activeId);

        <div class="upsell-strip-dots-card">
            <div class="upsell-strip-dots">
                @for (int i = 0; i < upsellList.Count; i++)
                {
                    <span class="upsell-strip-dot @(i == activeIndex ? "active" : "")"></span>
                }
            </div>
        </div>

        <div class="upsell-strip-scroll-wrapper">
            <button class="upsell-strip-nav upsell-strip-nav--prev"
                    @onclick="ScrollPrev"
                    aria-label="Poprzedni">
                <img src="/icons/chevron-right.svg" />
            </button>

            <div class="upsell-strip-scroll" @ref="_scrollRef">
                @foreach (var tile in upsellList)
                {
                    <div class="upsell-strip-item @(_activeId == tile.PartnerServiceId ? "is-active" : "")"
                         id="strip-item-@tile.PartnerServiceId">
                        <CascadingValue Value="@Theme">
                            <UpsellTile Tile="tile"
                                        Context="_reservationContext"
                                        Quantity="GetQuantity(tile.PartnerServiceId)"
                                        IsSelected="IsSelected(tile.PartnerServiceId)"
                                        OnToggled="toggled => HandleToggle(tile.PartnerServiceId, toggled)"
                                        Texts="_texts" />
                        </CascadingValue>
                    </div>
                }
            </div>

            <button class="upsell-strip-nav upsell-strip-nav--next"
                    @onclick="ScrollNext"
                    aria-label="Następny">
                <img src="/icons/chevron-right.svg" />
            </button>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Token { get; set; } = string.Empty;
    [Parameter] public ReservationPricingContext ReservationContext { get; set; } = new();
    [Parameter] public string Title { get; set; } = "Dostępne dodatki";
    [Parameter] public string Theme { get; set; } = "staywell-theme";
    [Parameter] public string morebuttontext { get; set; } = "more";
    [Parameter] public int MaxItems { get; set; } = 3;
    [Parameter] public int MaxItemsDesktop { get; set; } = 2;
    [Parameter] public EventCallback<List<SelectedUpsellDto>> OnSelectionChanged { get; set; }

    private const int DesktopBreakpoint = 640;

    private ReservationPricingContext _reservationContext = new();
    private ElementReference _scrollRef;
    private int _activeId = -1;
    private bool _jsInitialized;
    private int _windowWidth = 0;

    private bool IsDesktop => _windowWidth >= DesktopBreakpoint;
    private int EffectiveMaxItems => IsDesktop ? MaxItemsDesktop : MaxItems;
    private int SkeletonCount => EffectiveMaxItems > 0 ? EffectiveMaxItems : 4;

    private IEnumerable<UpsellTileDto> DisplayedUpsells =>
        EffectiveMaxItems > 0
            ? AvailableUpsellsState.AvailableUpsells.Take(EffectiveMaxItems)
            : AvailableUpsellsState.AvailableUpsells;

    private bool IsSelected(int partnerServiceId) =>
        UpsellCartState.PendingUpsells.Any(x => x.PartnerServiceId == partnerServiceId);

    private int GetQuantity(int partnerServiceId) =>
        UpsellCartState.PendingUpsells.FirstOrDefault(x => x.PartnerServiceId == partnerServiceId)?.Quantity ?? 1;

    private readonly UpsellTextConfig _texts = new()
    {
        Title = "Vouchery",
        SubTitle = "Dostępne dodatki",
        BadgeInfo = "Szczegóły",
        NightsText = "nocy",
        GuestsText = "gości",
        DeleteText = "Usuń",
        AddText = "Dodaj",
        DescriptionText = "Opis",
        TermsTitleText = "Warunki",
        PricingPerApartmentPerDayText = "za apartament / noc",
        PricingOneTimeText = "jednorazowo",
        PricingPerPersonPerDayText = "za osobę / noc",
        PricingPerStayText = "za pobyt",
        PriceLabel = "Cena",
    };

    protected override void OnInitialized()
    {
        AvailableUpsellsState.OnChange += OnAvailableUpsellsStateChanged;
        UpsellCartState.OnChange += OnCartStateChanged;
        GlobalizationService.OnChange += OnLanguageChanged;
    }

    private string _lastLoadedToken = string.Empty;
    private string _lastLoadedLocale = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        _reservationContext = ReservationContext;

        var locale = GlobalizationService.CurrentCulture.Name;

        if (!string.IsNullOrWhiteSpace(Token)
            && (Token != _lastLoadedToken || locale != _lastLoadedLocale))
        {
            _lastLoadedToken = Token;
            _lastLoadedLocale = locale;
            await LoadUpsellsAsync(locale);
        }
    }

    private void OnLanguageChanged() =>
        InvokeAsync(ReloadAsync);

    private async Task ReloadAsync()
    {
        _jsInitialized = false;
        AvailableUpsellsState.BeginReload();
        StateHasChanged();

        var locale = GlobalizationService.CurrentCulture.Name;
        _lastLoadedLocale = locale;
        _lastLoadedToken = Token;

        await LoadUpsellsAsync(locale, force: true);
    }

    private async Task LoadUpsellsAsync(string locale, bool force = false)
    {
        var effectiveLocale = string.IsNullOrWhiteSpace(locale) ? "pl-PL" : locale;
        await AvailableUpsellsState.EnsureLoadedAsync(Token, effectiveLocale, force: force);
    }

    private bool _isDisposed;
    private DotNetObjectReference<AvailableUpsells>? _selfRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isDisposed)
        {
            return;
        }

        if (firstRender)
        {
            _windowWidth = await JS.InvokeAsync<int>("upsellStrip.getWindowWidth");

            if (_isDisposed)
            {
                return;
            }

            _selfRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("upsellStrip.onWindowResize", _selfRef);

            if (_isDisposed)
            {
                return;
            }

            StateHasChanged();
            return;
        }

        if (_jsInitialized)
        {
            return;
        }

        var upsells = AvailableUpsellsState.AvailableUpsells;
        if (!upsells.Any())
        {
            return;
        }

        if (string.IsNullOrEmpty(_scrollRef.Id))
        {
            return;
        }

        _jsInitialized = true;
        _activeId = upsells.First().PartnerServiceId;
        _selfRef ??= DotNetObjectReference.Create(this);

        try
        {
            await JS.InvokeVoidAsync("upsellStrip.init", _scrollRef, _selfRef);
        }
        catch
        {
        }

        if (_isDisposed)
        {
            return;
        }

        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        _isDisposed = true;

        AvailableUpsellsState.OnChange -= OnAvailableUpsellsStateChanged;
        UpsellCartState.OnChange -= OnCartStateChanged;
        GlobalizationService.OnChange -= OnLanguageChanged;

        if (_selfRef is not null)
        {
            try
            {
                await JS.InvokeVoidAsync("upsellStrip.offWindowResize", _selfRef);
            }
            catch
            {
            }
        }

        try
        {
            await JS.InvokeVoidAsync("upsellStrip.destroy", _scrollRef);
        }
        catch
        {
        }

        _selfRef?.Dispose();
        _selfRef = null;
    }

    [JSInvokable]
    public void OnWindowResize(int width)
    {
        if (_windowWidth == width) return;
        var wasDesktop = IsDesktop;
        _windowWidth = width;
        if (IsDesktop != wasDesktop)
        {
            _jsInitialized = false;
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnAvailableUpsellsStateChanged()
    {
        _jsInitialized = false;
        InvokeAsync(StateHasChanged);
    }

    private void OnCartStateChanged() =>
        InvokeAsync(StateHasChanged);

    [JSInvokable]
    public void SetActiveItem(int id)
    {
        if (_activeId == id) return;
        _activeId = id;
        InvokeAsync(StateHasChanged);
    }

    private async Task ScrollPrev() =>
        await JS.InvokeVoidAsync("upsellStrip.scrollToPrev", _scrollRef);

    private async Task ScrollNext() =>
        await JS.InvokeVoidAsync("upsellStrip.scrollToNext", _scrollRef);

    private async Task HandleToggle(int partnerServiceId, bool isSelected)
    {
        var current = UpsellCartState.PendingUpsells.ToList();

        if (isSelected)
        {
            if (!current.Any(x => x.PartnerServiceId == partnerServiceId))
                current.Add(new SelectedUpsellDto { PartnerServiceId = partnerServiceId, Quantity = 1 });
        }
        else
        {
            current.RemoveAll(x => x.PartnerServiceId == partnerServiceId);
        }

        UpsellCartState.SetPendingUpsells(current);

        if (OnSelectionChanged.HasDelegate)
            await OnSelectionChanged.InvokeAsync(current);
    }
}