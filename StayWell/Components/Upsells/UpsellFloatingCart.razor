@using RentoomBooking.SharedClasses.Models.Upsell
@using RentoomBooking.StayWell.States
@inject UpsellCartState UpsellCartState
@inject NavigationManager Navigation
@implements IDisposable

@if (!UpsellCartState.IsEmpty && IsOnAllowedPage)
{
    <div class="upsell-cart-bar-container">
        <div class="upsell-cart-bar">
            <div class="upsell-cart-bar-info">
                <span class="upsell-cart-bar-count">dodatki: @UpsellCartState.TotalQuantity</span>
                @if (UpsellCartState.TotalCombinedPrice > 0)
                {
                    <span class="upsell-cart-bar-total">
                        @UpsellCartState.TotalCombinedPrice.ToString("F2") @UpsellCartState.Currency
                    </span>
                }
            </div>
            <button class="upsell-cart-bar-btn" @onclick="GoToCart">
                <img src="/icons/shopping-cart.svg" alt="Koszyk" class="upsell-cart-btn-icon" />
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public string Token { get; set; } = string.Empty;

    private static readonly string[] AllowedPageSegments =
    [
        "/HomePage",
        "/ManageStayPage",
        "/Vouchers",
        "/VouchersPage"
    ];

    private bool IsOnAllowedPage =>
        AllowedPageSegments.Any(segment =>
            Navigation.Uri.Contains(segment, StringComparison.OrdinalIgnoreCase))
        || Navigation.Uri.TrimEnd('/').EndsWith($"/reservation/{Token}", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        UpsellCartState.OnChange += StateHasChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    public void Dispose()
    {
        UpsellCartState.OnChange -= StateHasChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void GoToCart() =>
        Navigation.NavigateTo($"/reservation/{Token}/UpsellsCartPage");


}