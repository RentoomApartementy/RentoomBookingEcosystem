@using RentoomBooking.StayWell.Components
@using RentoomBooking.StayWell.Services
@inject NavigationManager Navigation
@inject ReservationTokenService ReservationTokenService
@inject PwaInstallService PwaInstallService
<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private bool _checkedStartupToken;
    private string? _lastPath;
    private string? _lastSavedPwaToken;
    private bool? _isStandalone;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var pathOnly = relativePath.Split('?', '#')[0];

        if (firstRender && !_checkedStartupToken)
        {
            _checkedStartupToken = true;

            if (string.IsNullOrWhiteSpace(pathOnly))
            {
                var isStandalone = await IsStandaloneAsync();
                var token = isStandalone
                    ? await ReservationTokenService.GetPwaTokenAsync()
                    : await ReservationTokenService.GetTokenAsync();

                if (!string.IsNullOrWhiteSpace(token))
                {
                    Navigation.NavigateTo($"/reservation/{token}/");
                    return;
                }
            }
        }

        if (!string.Equals(_lastPath, pathOnly, StringComparison.Ordinal))
        {
            _lastPath = pathOnly;
            await PersistPwaTokenIfStandaloneAsync(pathOnly);
        }
    }

    private async Task<bool> IsStandaloneAsync()
    {
        if (_isStandalone.HasValue)
        {
            return _isStandalone.Value;
        }

        _isStandalone = await PwaInstallService.IsStandaloneAsync();
        return _isStandalone.Value;
    }

    private async Task PersistPwaTokenIfStandaloneAsync(string pathOnly)
    {
        var token = ExtractToken(pathOnly);
        if (string.IsNullOrWhiteSpace(token))
        {
            return;
        }

        if (!await IsStandaloneAsync())
        {
            return;
        }

        if (string.Equals(_lastSavedPwaToken, token, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await ReservationTokenService.SavePwaTokenAsync(token);
        _lastSavedPwaToken = token;
    }

    private static string? ExtractToken(string pathOnly)
    {
        if (string.IsNullOrWhiteSpace(pathOnly))
        {
            return null;
        }

        var parts = pathOnly.Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2 && string.Equals(parts[0], "reservation", StringComparison.OrdinalIgnoreCase))
        {
            return parts[1];
        }

        return null;
    }
}
